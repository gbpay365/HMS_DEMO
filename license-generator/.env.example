# Copy to .env and fill with output from: npm run generate-keys
PORT=5055

# REQUIRED — RSA private key decrypts client request codes
# LICENSE_RSA_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# REQUIRED — Ed25519 private key signs serial numbers
# LICENSE_ED25519_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional — require X-Admin-Token header on API calls
# LICENSE_GENERATOR_ADMIN_TOKEN=

# Instant push to clients (must match each hospital HMS LICENSE_SERVER_WEBHOOK_SECRET)
# LICENSE_SERVER_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Offline email alerts (comma-separated)
# LICENSE_SERVER_ALERT_EMAIL=licensing@yourcompany.com

# Minutes without heartbeat before a client is considered offline (default 45)
# LICENSE_SERVER_OFFLINE_MINUTES=45

# How often to check for offline clients in ms (default 300000 = 5 min)
# LICENSE_SERVER_OFFLINE_CHECK_MS=300000

# SMTP for alert emails (falls back to HMS_SMTP_* if unset)
# LICENSE_SMTP_HOST=smtp.example.com
# LICENSE_SMTP_PORT=587
# LICENSE_SMTP_SECURE=false
# LICENSE_SMTP_USER=
# LICENSE_SMTP_PASS=
# LICENSE_SMTP_FROM="ZAIZENS License Server <licensing@yourcompany.com>"

# SQLite database path (optional)
# LICENSE_SERVER_DB_PATH=./data/license-server.db

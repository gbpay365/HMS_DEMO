# Copy to railway-postgres.env — DO NOT COMMIT (gitignored)
# Used by: node scripts/migrate-mysql-to-postgres.js

# Local XAMPP MySQL (defaults: HMS .env DB_*)
LOCAL_DB_USE_HMS_ENV=1
# LOCAL_DB_HOST=localhost
# LOCAL_DB_PORT=3306
# LOCAL_DB_USER=root
# LOCAL_DB_PASSWORD=
# LOCAL_DB_NAME=hms

# Railway PostgreSQL — use PUBLIC proxy from your PC (not postgres.railway.internal)
DATABASE_PUBLIC_URL=postgresql://postgres:CHANGE_ME@turntable.proxy.rlwy.net:41969/railway

# Migration tuning
MIGRATE_BATCH_SIZE=300
MIGRATE_SKIP_TABLES=
MIGRATE_ONLY_TABLES=

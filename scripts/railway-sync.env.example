# Copy to railway-sync.env and fill secrets (do not commit railway-sync.env)
#
# Used by:
#   bidirectional-sync-local-railway.js  — local ↔ Railway every 10 min (recommended)
#   replicate-local-to-railway.js        — full local → Railway only
#   sync-local-railway.js                — selective one-way table groups
#
# --- Local MySQL (deployed Windows server) ---
# Recommended: use the same DB credentials as the HMS app (.env in install folder).
LOCAL_DB_USE_HMS_ENV=1
#
# Override only if needed (set LOCAL_DB_USE_HMS_ENV=0):
# LOCAL_DB_HOST=localhost
# LOCAL_DB_PORT=3306
# LOCAL_DB_USER=root
# LOCAL_DB_PASSWORD=your-password
# LOCAL_DB_NAME=hms_demo
#
# --- Railway MySQL (use PUBLIC proxy from your PC / hospital server) ---
# Do NOT use mysql.railway.internal — that only works inside Railway containers.
RAILWAY_MYSQL_HOST=crossover.proxy.rlwy.net
RAILWAY_MYSQL_PORT=36338
RAILWAY_MYSQL_USER=root
RAILWAY_MYSQL_PASSWORD=
RAILWAY_MYSQL_DATABASE=railway
#
# Bidirectional sync (bidirectional-sync-local-railway.js)
# Tables WITH updated_at/modified_at/created_at: newer row wins on each side.
# Tables WITHOUT timestamps: one-way copy using owner below (default local wins).
BIDIRECTIONAL_NO_TS_OWNER=local
# BIDIRECTIONAL_EXCLUDE_TABLES=tbl_some_large_table
#
# Optional: full one-way replication — comma-separated tables to skip on Railway
# REPLICATE_EXCLUDE_TABLES=tbl_patient,tbl_employee
#
# Optional: selective sync defaults (overridden by CLI)
# SYNC_PRESETS=all-config
# SYNC_TABLES=
# SYNC_DIRECTION=local-to-railway
#
SYNC_BATCH_SIZE=200
RAILWAY_CONNECT_TIMEOUT_MS=60000

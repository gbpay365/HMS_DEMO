# =============================================================================
# ZAIZENS HMS — Database sync config (local server <-> Railway)
# =============================================================================
# 1) Copy this file to:  scripts\db-sync.env
# 2) Fill in BOTH sections below
# 3) Run:  sync-database.bat
# =============================================================================

# --- LOCAL MySQL (your deploy server) ---
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=your-local-mysql-password
LOCAL_DB_NAME=hms_demo

# Set to 1 to use HMS .env instead of LOCAL_DB_* above
LOCAL_DB_USE_HMS_ENV=0

# --- RAILWAY MySQL (public proxy — not mysql.railway.internal) ---
RAILWAY_MYSQL_HOST=crossover.proxy.rlwy.net
RAILWAY_MYSQL_PORT=36338
RAILWAY_MYSQL_USER=root
RAILWAY_MYSQL_PASSWORD=your-railway-password
RAILWAY_MYSQL_DATABASE=railway

# --- Sync behaviour ---
BIDIRECTIONAL_NO_TS_OWNER=local
SYNC_BATCH_SIZE=200
RAILWAY_CONNECT_TIMEOUT_MS=60000

# Do NOT set PORT on Phusion Passenger / cPanel Node.js — the host sets it.
# Only set PORT for local development (e.g. PORT=3000).
# PORT=3000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=Hellt0cell
DB_NAME=hms_demo
SESSION_SECRET=your_session_secret

# Branding (optional — defaults to ZAIZENS)
# HMS_BRAND_NAME=ZAIZENS
# HMS_PRODUCT_NAME=ZAIZENS Integrated HMS
# HMS_LOGIN_SUBTITLE=An integrated HMS
# HMS_BRAND_TAGLINE=Digital Intelligence. Redefined.
# HMS_FACILITY_LEGAL_NAME=ZAIZENS
# HMS_FACILITY_NAME=ZAIZENS
# HMS_ORG_NAME=ZAIZENS
# HMS_BRAND_WEBSITE=https://www.zaizens.com/
# HMS_LOGO_PATH=/img/zaizens-brand.svg
# HMS_FAVICON_PATH=/img/zaizens-favicon.svg
# HMS_LETTERHEAD_PATH=/img/hms-letterhead.png?v=20260515
# HMS_SLIP_HEADER=ZAIZENS
DATABASE_URL="mysql://root:Hellt0cell@localhost:3306/hms_demo"

# Solution licensing (generate keys: cd license-generator && npm run generate-keys)
# Public keys only on hospital installations — never deploy private keys to clients.
# LICENSE_RSA_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# LICENSE_ED25519_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# LICENSE_VENDOR_EMAIL=licensing@yourcompany.com

# Outbound email for subscription request codes (optional)
# HMS_SMTP_HOST=smtp.example.com
# HMS_SMTP_PORT=587
# HMS_SMTP_SECURE=false
# HMS_SMTP_USER=your-smtp-user
# HMS_SMTP_PASS=your-smtp-password
# HMS_SMTP_FROM="ZAIZENS HMS <noreply@yourhospital.org>"

# Subscription-driven deployment (auto when license public keys are set). Set 0 for manual Super Admin deployment.
# HMS_LICENSE_DEPLOYMENT=1

# Central license server (optional — enables remote revoke/sync from vendor dashboard)
# Deploy license-generator on a public host, then point each hospital installation here:
# LICENSE_SERVER_URL=https://licenses.yourcompany.com
# LICENSE_SERVER_SYNC_INTERVAL_MS=900000
# Shared secret for instant push webhooks (must match license server LICENSE_SERVER_WEBHOOK_SECRET)
# LICENSE_SERVER_WEBHOOK_SECRET=change-me-to-a-long-random-string
# Public URL of this HMS site (used to build push webhook unless LICENSE_SERVER_PUSH_URL is set)
# HMS_PUBLIC_URL=https://hospital.example.com
# LICENSE_SERVER_PUSH_URL=https://hospital.example.com/api/hms/license-server/push

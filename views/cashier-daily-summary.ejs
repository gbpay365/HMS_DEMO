<% locals.hmsSurfaceBodyClass = ' hms-body--cashier'; %>
<%- include('partials/header') %>
<%
if (typeof _t !== 'function') {
  var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
}
var _tc = function (key, fallback, opts) {
  var o = { ns: 'clinical', defaultValue: fallback };
  if (opts && typeof opts === 'object') { for (var pk in opts) { if (Object.prototype.hasOwnProperty.call(opts, pk)) o[pk] = opts[pk]; } }
  return _t('cashier.daily_summary.' + key, o);
};
var _catLabel = function (key) {
  return _tc('cat_' + key, key.replace(/_/g, ' '));
};
var _period = report.bounds.period || 'day';
var _dateVal = report.bounds.start || '';
var _f = report.filters || {};
var _printQs = typeof filterQueryString !== 'undefined' ? filterQueryString : ('period=' + encodeURIComponent(_period) + '&date=' + encodeURIComponent(_dateVal));
var _resetQs = 'period=' + encodeURIComponent(_period) + '&date=' + encodeURIComponent(_dateVal);
%>
<link rel="stylesheet" href="/css/hms-app-surface.css?v=2">
<div class="page-wrapper hms-surface-module"><div class="content px-3 pb-5">

<div class="hms-surface-hero mb-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
    <div>
      <p class="mb-2"><a href="/cashier" class="small text-white-50"><i class="fa fa-arrow-left"></i> <%= _tc('back_cashier', 'Back to cashier') %></a></p>
      <h1 class="hms-surface-hero-title mb-1"><i class="fa fa-bar-chart mr-2"></i><%= _tc('title', 'Daily transactions summary') %></h1>
      <p class="mb-0"><%= _tc('subtitle', 'Cumulative collections by service category') %> · <strong><%= report.bounds.label %></strong></p>
    </div>
    <div class="no-print">
      <a href="/cashier/daily-summary/print?<%= _printQs %>" target="_blank" rel="noopener" class="btn btn-light btn-sm font-weight-bold rounded-pill">
        <i class="fa fa-print mr-1"></i><%= _tc('print', 'Print report') %>
      </a>
      <a href="/cashier/eod-reconciliation?date=<%= encodeURIComponent(_dateVal) %>" class="btn btn-light btn-sm font-weight-bold rounded-pill">
        <i class="fa fa-balance-scale mr-1"></i><%= _t('cashier.eod_reconciliation_link', { ns: 'clinical', defaultValue: 'End of day reconciliation' }) %>
      </a>
    </div>
  </div>
</div>

<form method="GET" action="/cashier/daily-summary" class="card border-0 shadow-sm mb-4 no-print" style="border-radius:14px;">
  <div class="card-body p-3">
    <div class="small font-weight-bold text-muted text-uppercase mb-2"><%= _tc('filter_period', 'Period') %></div>
    <div class="form-row align-items-end">
      <div class="form-group col-6 col-md-3 mb-2 mb-md-0">
        <label class="small font-weight-bold"><%= _tc('period', 'Period') %></label>
        <select name="period" class="form-control form-control-sm">
          <option value="day" <%= _period === 'day' ? 'selected' : '' %>><%= _tc('period_day', 'Day') %></option>
          <option value="week" <%= _period === 'week' ? 'selected' : '' %>><%= _tc('period_week', 'Week') %></option>
          <option value="month" <%= _period === 'month' ? 'selected' : '' %>><%= _tc('period_month', 'Month') %></option>
        </select>
      </div>
      <div class="form-group col-6 col-md-3 mb-2 mb-md-0">
        <label class="small font-weight-bold"><%= _tc('anchor_date', 'Date') %></label>
        <input type="hidden" name="date" value="<%= _dateVal %>" data-hms-dmy-hidden>
        <input type="text" class="form-control form-control-sm" value="<%= _dateVal && fmtDate(_dateVal) !== '—' ? fmtDate(_dateVal) : '' %>" placeholder="DD/MM/YYYY" inputmode="numeric" autocomplete="off" data-hms-dmy-display>
      </div>
    </div>
    <hr class="my-3">
    <div class="small font-weight-bold text-muted text-uppercase mb-2"><%= _tc('filter_title', 'Filters') %></div>
    <div class="form-row align-items-end">
      <div class="form-group col-6 col-md-3 mb-2 mb-md-0">
        <label class="small font-weight-bold"><%= _tc('filter_category', 'Category') %></label>
        <select name="category" class="form-control form-control-sm">
          <option value="all" <%= !_f.category || _f.category === 'all' ? 'selected' : '' %>><%= _tc('filter_all', 'All') %></option>
          <% (report.filterOptions.categories || []).forEach(function(c){ %>
          <option value="<%= c.key %>" <%= _f.category === c.key ? 'selected' : '' %>><%= _catLabel(c.key) %></option>
          <% }); %>
        </select>
      </div>
      <div class="form-group col-6 col-md-3 mb-2 mb-md-0">
        <label class="small font-weight-bold"><%= _tc('filter_method', 'Payment method') %></label>
        <select name="method" class="form-control form-control-sm">
          <option value="all" <%= !_f.method || _f.method === 'all' ? 'selected' : '' %>><%= _tc('filter_all', 'All') %></option>
          <% (report.filterOptions.methods || []).forEach(function(m){ %>
          <option value="<%= m.key %>" <%= _f.method === m.key ? 'selected' : '' %>><%= m.label %></option>
          <% }); %>
        </select>
      </div>
      <div class="form-group col-12 col-md-3 mb-2 mb-md-0">
        <label class="small font-weight-bold"><%= _tc('filter_patient', 'Patient') %></label>
        <input type="search" name="patient" class="form-control form-control-sm" value="<%= _f.patient || '' %>" placeholder="<%= _tc('filter_patient_ph', 'Name, ticket code, or patient ID') %>">
      </div>
      <div class="form-group col-6 col-md-2 mb-2 mb-md-0">
        <label class="small font-weight-bold"><%= _tc('filter_min_amount', 'Min amount') %></label>
        <input type="number" name="min_amount" class="form-control form-control-sm" min="0" step="1" value="<%= _f.min_amount != null ? _f.min_amount : '' %>" placeholder="0">
      </div>
      <div class="form-group col-6 col-md-2 mb-2 mb-md-0">
        <label class="small font-weight-bold"><%= _tc('filter_max_amount', 'Max amount') %></label>
        <input type="number" name="max_amount" class="form-control form-control-sm" min="0" step="1" value="<%= _f.max_amount != null ? _f.max_amount : '' %>" placeholder="∞">
      </div>
      <div class="form-group col-12 col-md-4 mb-0 d-flex flex-wrap align-items-end gap-2">
        <button type="submit" class="btn btn-primary btn-sm font-weight-bold rounded-pill px-4"><i class="fa fa-filter mr-1"></i><%= _tc('apply', 'Apply') %></button>
        <a href="/cashier/daily-summary?<%= _resetQs %>" class="btn btn-outline-secondary btn-sm font-weight-bold rounded-pill px-3"><%= _tc('filter_reset', 'Reset filters') %></a>
      </div>
    </div>
  </div>
</form>

<% if (report.filtersActive) { %>
<div class="alert alert-info border-0 shadow-sm small mb-4 no-print" style="border-radius:12px;">
  <i class="fa fa-filter mr-1"></i>
  <%= _tc('filter_active_hint', 'Showing {{shown}} of {{total}} line items (filtered).', { shown: report.totals.filteredRows, total: report.totals.allRows }) %>
</div>
<% } %>

<div class="row mb-4">
  <div class="col-md-4 mb-3">
    <div class="card border-0 shadow-sm h-100" style="border-radius:14px;">
      <div class="card-body">
        <div class="small text-muted font-weight-bold text-uppercase"><%= _tc('kpi_collected', 'Total collected') %></div>
        <div class="h3 font-weight-bold text-dark mb-0"><%= report.summary.grandTotal_fmt %></div>
      </div>
    </div>
  </div>
  <div class="col-md-4 mb-3">
    <div class="card border-0 shadow-sm h-100" style="border-radius:14px;">
      <div class="card-body">
        <div class="small text-muted font-weight-bold text-uppercase"><%= _tc('kpi_tickets', 'Paid tickets') %></div>
        <div class="h3 font-weight-bold text-dark mb-0"><%= report.summary.ticketCount %></div>
      </div>
    </div>
  </div>
  <div class="col-md-4 mb-3">
    <div class="card border-0 shadow-sm h-100" style="border-radius:14px;">
      <div class="card-body">
        <div class="small text-muted font-weight-bold text-uppercase"><%= _tc('kpi_lines', 'Line items') %></div>
        <div class="h3 font-weight-bold text-dark mb-0"><%= report.summary.lineCount %></div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-7 mb-4">
    <div class="card border-0 shadow-sm" style="border-radius:14px;">
      <div class="card-header bg-white border-0 pt-3 pb-0">
        <h5 class="font-weight-bold mb-0"><i class="fa fa-pie-chart text-muted mr-1"></i> <%= _tc('by_category', 'By service category') %></h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="thead-light">
              <tr>
                <th><%= _tc('col_category', 'Category') %></th>
                <th class="text-right"><%= _tc('col_lines', 'Lines') %></th>
                <th class="text-right"><%= _tc('col_share', 'Share') %></th>
                <th class="text-right"><%= _tc('col_amount', 'Amount') %></th>
              </tr>
            </thead>
            <tbody>
              <% if (!report.categoryRows.length) { %>
              <tr><td colspan="4" class="text-center text-muted py-4"><%= _tc('empty', 'No paid transactions for this period.') %></td></tr>
              <% } %>
              <% report.categoryRows.forEach(function(row){ %>
              <tr>
                <td>
                  <i class="fa <%= row.icon %> mr-2" style="color:<%= row.color %>;"></i>
                  <strong><%= _catLabel(row.key) %></strong>
                </td>
                <td class="text-right"><%= row.line_count %></td>
                <td class="text-right text-muted"><%= row.share_pct %>%</td>
                <td class="text-right font-weight-bold"><%= row.amount_fmt %></td>
              </tr>
              <% }); %>
              <% if (report.categoryRows.length) { %>
              <tr class="table-active font-weight-bold">
                <td><%= _tc('total', 'Total') %></td>
                <td class="text-right"><%= report.summary.lineCount %></td>
                <td class="text-right">100%</td>
                <td class="text-right"><%= report.summary.grandTotal_fmt %></td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-5 mb-4">
    <div class="card border-0 shadow-sm h-100" style="border-radius:14px;">
      <div class="card-header bg-white border-0 pt-3 pb-0">
        <h5 class="font-weight-bold mb-0"><i class="fa fa-credit-card text-muted mr-1"></i> <%= _tc('by_payment', 'By payment method') %></h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="thead-light">
              <tr>
                <th><%= _tc('col_method', 'Method') %></th>
                <th class="text-right"><%= _tc('col_share', 'Share') %></th>
                <th class="text-right"><%= _tc('col_amount', 'Amount') %></th>
              </tr>
            </thead>
            <tbody>
              <% if (!report.paymentRows.length) { %>
              <tr><td colspan="3" class="text-center text-muted py-4">—</td></tr>
              <% } %>
              <% report.paymentRows.forEach(function(row){ %>
              <tr>
                <td><%= row.label %></td>
                <td class="text-right text-muted"><%= row.share_pct %>%</td>
                <td class="text-right font-weight-bold"><%= row.amount_fmt %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
  <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
    <h5 class="font-weight-bold mb-0"><i class="fa fa-list text-muted mr-1"></i> <%= _tc('txn_detail', 'Transaction detail') %></h5>
    <span class="badge badge-light"><%= report.transactions.length %></span>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-sm table-hover mb-0">
        <thead class="thead-light">
          <tr>
            <th><%= _tc('col_time', 'Time') %></th>
            <th><%= _tc('col_ticket', 'Ticket') %></th>
            <th><%= _tc('col_patient', 'Patient') %></th>
            <th><%= _tc('col_category', 'Category') %></th>
            <th><%= _tc('col_method', 'Method') %></th>
            <th class="text-right"><%= _tc('col_amount', 'Amount') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (!report.transactions.length) { %>
          <tr><td colspan="6" class="text-center text-muted py-4"><%= _tc('empty_filtered', 'No transactions match the current filters.') %></td></tr>
          <% } %>
          <% report.transactions.forEach(function(row){ %>
          <tr>
            <td class="text-nowrap"><%= row.paid_time %></td>
            <td class="font-monospace small"><%= row.ticket_code %></td>
            <td><%= row.patient %></td>
            <td><%= _catLabel(row.category) %></td>
            <td><%= row.payment_method %></td>
            <td class="text-right font-weight-bold"><%= row.amount_fmt %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

</div></div>
<script src="/js/hms-date-dmy-field.js"></script>
<%- include('partials/footer') %>

<%- include('partials/header') %>
<%
var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
var _up = locals.userPerms || [];
function hasP(){ if (_up.includes('*')) return true; for (var i=0;i<arguments.length;i++) if (_up.includes(arguments[i])) return true; return false; }
var _radName = userDisplayName || locals.user?.name || _t('portal_radiology.default_role', { ns: 'legacy', defaultValue: 'Radiology Technician' });
var _radKpis = [
  [_t('portal_radiology.kpi_total_exams', { ns: 'legacy', defaultValue: 'Total Exams' }), stats.total, 'fa-film', '#0891b2', '#cffafe'],
  [_t('portal_radiology.kpi_pending_work', { ns: 'legacy', defaultValue: 'Pending work' }), stats.pending, 'fa-clock-o', '#f59e0b', '#fef3c7'],
  [_t('portal_radiology.kpi_completed', { ns: 'legacy', defaultValue: 'Completed' }), stats.done, 'fa-check-circle', '#10b981', '#d1fae5'],
  [_t('portal_radiology.kpi_orders_today', { ns: 'legacy', defaultValue: 'Orders Today' }), stats.today, 'fa-plus-circle', '#1a6bd8', '#dbeafe']
];
var stMap={
  pending:['warning', _t('portal_shared.rad_status_pending', { ns: 'legacy', defaultValue: 'Pending' })],
  in_progress:['info', _t('portal_shared.rad_status_in_progress', { ns: 'legacy', defaultValue: 'In Progress' })],
  received:['success', _t('portal_shared.rad_status_received', { ns: 'legacy', defaultValue: 'Completed' })]
};
%>
<div class="page-wrapper"><div class="content">
<%- include('partials/clinical-dept-alerts-strip', { clinicalDeptStripDept: 'radiology' }) %>
<%- include('partials/portal-flash') %>
<div class="card border-0 shadow-sm mb-4 hms-page-hero">
  <div class="card-body py-4 px-4 d-flex align-items-center justify-content-between flex-wrap">
 <div>
 <h1 class="h4 mb-1 font-weight-bold" style="color:#fff;"><i class="fa fa-film mr-2"></i><%= _t('portal_radiology.title', { ns: 'legacy', defaultValue: 'Radiology & Imaging Portal' }) %></h1>
 <p class="mb-0 small" style="color:rgba(255,255,255,.85);"><%= _t('portal_shared.welcome_role', { ns: 'legacy', name: _radName, defaultValue: 'Welcome, ' + _radName }) %></p>
 </div>
 <div class="mt-2 mt-md-0">
 <% if(hasP('radiology.read','radiology.write')){ %><a href="/radiology" class="btn btn-light btn-sm font-weight-bold" style="color:#0891b2;"><i class="fa fa-film mr-1"></i><%= _t('portal_radiology.all_results', { ns: 'legacy', defaultValue: 'All Results' }) %></a><% } %>
 <% if(hasP('radiology.write')){ %><a href="/radiology/order-alerts" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-bell mr-1"></i><%= _t('portal_radiology.order_alerts', { ns: 'legacy', defaultValue: 'Order alerts' }) %></a><% } %>
 </div>
  </div>
</div>
<div class="row mb-4">
  <% _radKpis.forEach(function(s){ %>
  <div class="col-6 col-md-3 mb-3">
 <div class="card border-0 shadow-sm h-100" style="border-left:4px solid <%=s[3]%>;">
 <div class="card-body d-flex align-items-center">
 <span class="rounded-circle mr-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:<%=s[4]%>;flex-shrink:0;">
 <i class="fa <%=s[2]%>" style="color:<%=s[3]%>;font-size:1.1rem;"></i></span>
 <div><div style="font-size:1.8rem;font-weight:800;color:#1e293b;"><%=s[1]%></div><div class="text-muted small"><%=s[0]%></div></div>
 </div>
 </div>
  </div>
  <% }); %>
</div>
<%- include('partials/portal-tiles', { portal: 'radiology', title: _t('portal_radiology.radiology_tools', { ns: 'legacy', defaultValue: 'Radiology Tools' }) }) %>
<div class="card border-0 shadow-sm" style="border-radius:12px;">
  <div class="card-header bg-white d-flex justify-content-between align-items-center" style="border-bottom:2px solid #e2e8f0;">
 <span class="font-weight-bold"><i class="fa fa-film mr-1" style="color:#0891b2;"></i><%= _t('portal_radiology.recent_orders', { ns: 'legacy', defaultValue: 'Recent Radiology Orders' }) %></span>
 <a href="/radiology" class="btn btn-sm btn-primary" style="background:#0891b2;border-color:#0891b2;"><%= _t('portal_shared.view_all', { ns: 'legacy', defaultValue: 'View All' }) %></a>
  </div>
  <div class="card-body p-0" data-hms-table-paginate data-hms-page-size="5"><div class="table-responsive">
 <table class="table table-hover mb-0">
 <thead class="thead-light"><tr><th><%= _t('portal_shared.patient', { ns: 'legacy', defaultValue: 'Patient' }) %></th><th><%= _t('portal_shared.exam', { ns: 'legacy', defaultValue: 'Exam' }) %></th><th><%= _t('portal_shared.modality', { ns: 'legacy', defaultValue: 'Modality' }) %></th><th><%= _t('portal_shared.status', { ns: 'legacy', defaultValue: 'Status' }) %></th><th><%= _t('portal_shared.date', { ns: 'legacy', defaultValue: 'Date' }) %></th></tr></thead>
 <tbody>
 <% if(!recentExams||recentExams.length===0){ %><tr><td colspan="5" class="text-center text-muted py-4"><%= _t('portal_radiology.no_orders', { ns: 'legacy', defaultValue: 'No radiology orders found.' }) %></td></tr>
 <% } else { recentExams.forEach(function(r){ var st=stMap[r.status]||['secondary',r.status]; var d=r.created_at?fmtDate(r.created_at):'—'; %>
 <tr><td class="font-weight-bold"><%=r.first_name||''%> <%=r.last_name||''%></td>
 <td><%=r.exam_name||'—'%></td>
 <td class="small text-muted"><%=r.modality||'—'%></td>
 <td><span class="badge badge-<%=st[0]%>"><%=st[1]%></span></td>
 <td class="small text-muted"><%=d%></td></tr>
 <% }); } %>
 </tbody>
 </table>
  </div></div>
</div>
</div></div><%- include('partials/footer') %>

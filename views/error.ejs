<%- include('partials/header') %>
<% var _errT = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>

<div class="main-wrapper error-wrapper">
 <div class="error-box">
 <h1 class="text-primary"><%= status %></h1>
 <h3><i class="fa fa-warning"></i> <%= _errT('page.oops', { ns: 'errors', defaultValue: 'Oops!' }) %> <%= message %></h3>
 <p><%= status === 404 ? _errT('page.not_found_body', { ns: 'errors', defaultValue: 'The page you requested was not found or an error occurred.' }) : _errT('page.error_body', { ns: 'errors', defaultValue: 'An unexpected error occurred. Please try again or contact support.' }) %></p>
 <a href="/" class="btn btn-primary go-home"><%= _errT('page.go_home', { ns: 'errors', defaultValue: 'Go to Home' }) %></a>
 </div>
</div>

<%- include('partials/footer') %>

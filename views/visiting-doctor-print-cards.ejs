<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || 'Visiting Doctor Cards' %></title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; margin: 0; padding: 24px; color: #0f172a; background: #f8fafc; }
    h1 { margin: 0 0 8px; font-size: 1.35rem; }
    .meta { color: #64748b; font-size: 0.9rem; margin-bottom: 20px; }
    .toolbar { margin-bottom: 20px; }
    .toolbar button { background: #0ea5e9; color: #fff; border: 0; border-radius: 8px; padding: 10px 16px; font-weight: 600; cursor: pointer; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; }
    .card { border: 2px dashed #cbd5e1; border-radius: 12px; background: #fff; padding: 14px; min-height: 130px; }
    .card.available { border-color: #86efac; }
    .card.in-use { border-color: #fecaca; background: #fff7f7; }
    .slot { font-size: 1.4rem; font-weight: 800; letter-spacing: 0.02em; }
    .pwd { margin-top: 10px; font-size: 0.95rem; }
    .pwd strong { font-family: ui-monospace, monospace; font-size: 1.1rem; }
    .status { margin-top: 8px; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
    .status.available { color: #166534; }
    .status.in-use { color: #991b1b; }
    .hint { margin-top: 24px; font-size: 0.82rem; color: #64748b; }
    @media print {
      body { background: #fff; padding: 12px; }
      .toolbar { display: none; }
      .grid { grid-template-columns: repeat(4, 1fr); gap: 8px; }
      .card { break-inside: avoid; page-break-inside: avoid; min-height: 110px; }
    }
  </style>
</head>
<body>
  <div class="toolbar">
    <button type="button" onclick="window.print()">Print cards</button>
    <a href="/admin/visiting-doctors" style="margin-left:12px;color:#0ea5e9;text-decoration:none;font-weight:600;">← Back to dashboard</a>
  </div>
  <h1>Visiting doctor account cards</h1>
  <p class="meta">Reception reference — default password for available accounts. Doctors must change it on first login.</p>
  <div class="grid">
    <% (usernames || []).forEach(function(code) {
      const acc = (accounts || []).find(function(a) { return String(a.username).toUpperCase() === String(code).toUpperCase(); }) || { username: code, available: true };
    %>
      <div class="card <%= acc.inUse ? 'in-use' : 'available' %>">
        <div class="slot"><%= acc.username %></div>
        <div class="pwd">Password: <strong><%= defaultPassword %></strong></div>
        <div class="status <%= acc.inUse ? 'in-use' : 'available' %>">
          <%= acc.inUse ? (acc.setupInProgress ? 'Setup in progress' : 'In use') : 'Available' %>
        </div>
        <% if (acc.inUse && acc.doctorName) { %>
          <div style="margin-top:6px;font-size:0.78rem;color:#475569;"><%= acc.doctorName %></div>
        <% } %>
      </div>
    <% }); %>
  </div>
  <p class="hint">Each card is a shared slot (VD1–VD20). Only one doctor may use a slot until the visit end date or admin release.</p>
</body>
</html>

<%- include('partials/header') %>
<%
var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
var _patCount = (patients && patients.length) || 0;
%>
<div class="page-wrapper"><div class="content">
<%- include('partials/portal-flash') %>
<div class="card border-0 shadow-sm mb-4 hms-page-hero">
  <div class="card-body py-4 px-4 d-flex align-items-center justify-content-between flex-wrap">
 <div>
 <h1 class="h4 mb-1 font-weight-bold" style="color:#fff;"><i class="fa fa-users mr-2"></i><%= _t('portal_patient.title', { ns: 'legacy', defaultValue: 'Patient Registry' }) %></h1>
 <p class="mb-0 small" style="color:rgba(255,255,255,.85);"><%= _t('portal_shared.active_count', { ns: 'legacy', count: _patCount, defaultValue: 'Active patient directory ? ' + _patCount + ' patients shown.' }) %></p>
 </div>
 <div class="mt-2 mt-md-0">
 <a href="/patients" class="btn btn-light btn-sm font-weight-bold" style="color:#1a6bd8;"><i class="fa fa-users mr-1"></i><%= _t('portal_shared.full_directory', { ns: 'legacy', defaultValue: 'Full Directory' }) %></a>
 <a href="/patients" class="btn btn-outline-light btn-sm font-weight-bold ml-2"><i class="fa fa-user-plus mr-1"></i><%= _t('portal_patient.register', { ns: 'legacy', defaultValue: 'Register' }) %></a>
 </div>
  </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius:12px;">
  <div class="card-header bg-white d-flex justify-content-between align-items-center" style="border-bottom:2px solid #e2e8f0;">
 <span class="font-weight-bold"><i class="fa fa-user mr-1 text-primary"></i><%= _t('portal_shared.patient_directory', { ns: 'legacy', defaultValue: 'Patient Directory' }) %></span>
 <a href="/patients" class="btn btn-sm btn-primary"><%= _t('portal_shared.view_all', { ns: 'legacy', defaultValue: 'View All' }) %></a>
  </div>
  <div class="card-body p-0" data-hms-table-paginate data-hms-page-size="5"><div class="table-responsive">
 <table class="table table-hover mb-0">
 <thead class="thead-light"><tr><th>#</th><th><%= _t('portal_shared.name', { ns: 'legacy', defaultValue: 'Name' }) %></th><th><%= _t('portal_shared.gender', { ns: 'legacy', defaultValue: 'Gender' }) %></th><th><%= _t('portal_shared.phone', { ns: 'legacy', defaultValue: 'Phone' }) %></th><th><%= _t('portal_shared.type', { ns: 'legacy', defaultValue: 'Type' }) %></th><th><%= _t('portal_shared.action', { ns: 'legacy', defaultValue: 'Action' }) %></th></tr></thead>
 <tbody>
 <% if(!patients||patients.length===0){ %><tr><td colspan="6" class="text-center text-muted py-4"><%= _t('portal_shared.no_patients', { ns: 'legacy', defaultValue: 'No patients found.' }) %></td></tr>
 <% } else { patients.forEach(function(p){ %>
 <tr>
 <td class="text-muted small"><%=p.id%></td>
 <td class="font-weight-bold"><%=p.first_name%> <%=p.last_name%></td>
 <td class="small"><%=p.gender||'?'%></td>
 <td class="small text-muted"><%=p.phone||'?'%></td>
 <td><span class="badge badge-light border"><%=p.patient_type||_t('portal_shared.general', { ns: 'legacy', defaultValue: 'General' })%></span></td>
 <td><a href="/patient-chart/<%=p.id%>" class="btn btn-sm btn-outline-primary"><%= _t('portal_shared.chart', { ns: 'legacy', defaultValue: 'Chart' }) %></a></td>
 </tr>
 <% }); } %>
 </tbody>
 </table>
  </div></div>
</div>
</div></div><%- include('partials/footer') %>

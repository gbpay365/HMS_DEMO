<%- include('partials/header') %>

<div class="page-wrapper">
 <div class="content">
 <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 no-print">
 <div>
 <h4 class="page-title font-weight-bold text-dark mb-0"><%= docTitle %></h4>
 <p class="text-muted small mb-0"><%- _tl('docs_print.printable_guide', 'Printable guide — use <strong>Print</strong> or download PDF when Dompdf is available.') %></p>
 </div>
 <div class="d-flex flex-wrap gap-2">
 <a href="<%= backUrl %>" class="btn btn-outline-secondary btn-sm"><i class="fa fa-arrow-left mr-1"></i><%= _tl('docs_print.back', 'Back') %></a>
 <% if (pdfAvailable) { %>
 <a href="<%= pdfUrl %>" class="btn btn-primary btn-sm font-weight-bold" target="_blank" rel="noopener"><i class="fa fa-file-pdf-o mr-1"></i><%= _tl('docs_print.download_pdf', 'Download PDF') %></a>
 <% } %>
 <button type="button" class="btn btn-outline-primary btn-sm" onclick="window.print()"><i class="fa fa-print mr-1"></i><%= _tl('docs_print.print', 'Print') %></button>
 </div>
 </div>
 <% if (!pdfAvailable) { %>
 <div class="alert alert-info border-0 shadow-sm small no-print mb-3" style="border-radius:12px;">
  <%- _tl('docs_print.pdf_unavailable', 'PDF download needs PHP + Dompdf in <code>htdocs_php/htdocs</code> (<code>composer install</code>). You can still <strong>Print → Save as PDF</strong> from this page.') %>
 </div>
 <% } %>
 <div class="card border-0 shadow-sm docs-print-frame" style="border-radius:12px;">
 <iframe id="docFrame" title="<%= docTitle %>" class="w-100 border-0" style="min-height:70vh;" srcdoc=""></iframe>
 </div>
 </div>
</div>

<script>
(function () {
 var html = <%- JSON.stringify(bodyHtml) %>;
 var frame = document.getElementById('docFrame');
 if (frame) frame.srcdoc = html;
})();
</script>

<%- include('partials/footer') %>

<%
if (typeof _t !== 'function') {
  var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
}
if (typeof _tl !== 'function') {
  var _tl = function (key, fallback, opts) {
    var o = { ns: 'legacy', defaultValue: fallback };
    if (opts && typeof opts === 'object') { for (var pk in opts) { if (Object.prototype.hasOwnProperty.call(opts, pk)) o[pk] = opts[pk]; } }
    return _t(key, o);
  };
}
%>
<!DOCTYPE html>
<html lang="<%= locals.lang || 'en' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/font-awesome.min.css">
  <link rel="stylesheet" href="/css/hms-fonts-local.css">
  <style>
    html { font-size: 118%; }
    html, body { height: 100%; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; }
    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: radial-gradient(1200px 600px at 10% 10%, rgba(5,150,105,.22), transparent),
                  radial-gradient(900px 500px at 90% 80%, rgba(37,99,235,.25), transparent),
                  linear-gradient(160deg, #0f172a 0%, #1e293b 45%, #064e3b 100%);
      color: #e2e8f0;
      font-size: 1.12rem;
    }
    .card-sign {
      width: 100%;
      max-width: 520px;
      border-radius: 22px;
      background: rgba(15,23,42,.9);
      border: 1px solid rgba(52,211,153,.28);
      box-shadow: 0 24px 60px rgba(0,0,0,.45);
      backdrop-filter: blur(10px);
      padding: 2rem 2.25rem !important;
    }
    .brand-mark {
      font-weight: 800;
      letter-spacing: .14em;
      font-size: 1.15rem;
      color: #34d399;
      text-transform: uppercase;
    }
    .queue-sign-title {
      font-size: clamp(1.85rem, 4.5vw, 2.35rem);
      font-weight: 800;
      color: #fff;
      margin: 0 0 0.35rem;
    }
    .queue-sign-lead {
      font-size: 1.1rem;
      line-height: 1.5;
      color: #94a3b8;
      margin: 0 0 1.5rem;
    }
    .btn-enter {
      font-size: 1.45rem !important;
      padding: 1.1rem 1.4rem !important;
      font-weight: 800;
      border-radius: 14px;
      background: linear-gradient(135deg, #059669, #2563eb);
      border: none;
      color: #fff;
      width: 100%;
    }
    .btn-enter:hover { filter: brightness(1.08); color: #fff; }
  </style>
</head>
<body>
  <div class="card-sign text-center">
    <div class="brand-mark mb-3"><i class="fa fa-hospital-o mr-2"></i><%= _tl('portal_queue.brand', 'ZAIZENS') %></div>
    <h1 class="queue-sign-title"><%= _tl('portal_queue.title', 'OPD waiting display') %></h1>
    <p class="queue-sign-lead"><%= _tl('portal_queue.lead', "Lobby or TV — tap Enter, then use full screen (F11). Shows today's outpatient queue only.") %></p>
    <% if (locals.flash) { %>
      <div class="alert alert-success border-0 mb-3 text-left"><%= locals.flash %></div>
    <% } %>
    <% if (locals.error) { %>
      <div class="alert alert-danger border-0 mb-3 text-left"><%= locals.error %></div>
    <% } %>
    <a href="/portal/call-queue/enter" class="btn btn-enter d-inline-block">
      <i class="fa fa-sign-in mr-2"></i><%= _tl('portal_queue.enter', 'Enter') %>
    </a>
    <p class="text-muted mt-4 mb-0 small">
      <a href="/portal/front-desk" class="text-info"><%= _tl('portal_queue.front_desk_link', '← Front desk portal') %></a>
    </p>
  </div>
</body>
</html>

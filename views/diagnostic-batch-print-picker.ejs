<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'Select results to print' %></title>
  <link rel="stylesheet" href="/css/diagnostic-report-print.css?v=2">
  <style>
    body { font-family: system-ui, sans-serif; margin: 0; background: #f8fafc; color: #0f172a; }
    .dbp-picker-wrap { max-width: 720px; margin: 32px auto; padding: 0 16px 48px; }
    .dbp-picker-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; box-shadow: 0 8px 24px rgba(15,23,42,.06); overflow: hidden; }
    .dbp-picker-head { padding: 20px 24px; border-bottom: 1px solid #f1f5f9; }
    .dbp-picker-head h1 { margin: 0 0 6px; font-size: 1.15rem; font-weight: 800; }
    .dbp-picker-head p { margin: 0; font-size: .85rem; color: #64748b; }
    .dbp-picker-tools { display: flex; flex-wrap: wrap; gap: 8px; padding: 12px 24px; background: #f8fafc; border-bottom: 1px solid #f1f5f9; align-items: center; }
    .dbp-picker-tools button, .dbp-picker-tools a { font-size: .75rem; font-weight: 700; border-radius: 999px; padding: 8px 14px; cursor: pointer; text-decoration: none; border: 1px solid #e2e8f0; background: #fff; color: #334155; }
    .dbp-picker-tools button.primary { background: #0d9488; border-color: #0d9488; color: #fff; }
    .dbp-picker-tools button:disabled { opacity: .45; cursor: not-allowed; }
    .dbp-picker-list { list-style: none; margin: 0; padding: 8px 0; }
    .dbp-picker-item { display: flex; align-items: flex-start; gap: 12px; padding: 12px 24px; border-bottom: 1px solid #f8fafc; cursor: pointer; }
    .dbp-picker-item:hover { background: #f8fafc; }
    .dbp-picker-item input { margin-top: 3px; width: 16px; height: 16px; accent-color: #0d9488; }
    .dbp-picker-item strong { display: block; font-size: .9rem; }
    .dbp-picker-item span { display: block; font-size: .75rem; color: #64748b; margin-top: 2px; }
    .dbp-picker-foot { padding: 16px 24px; display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end; border-top: 1px solid #f1f5f9; }
    .dbp-picker-foot button { font-size: .8rem; font-weight: 800; border-radius: 999px; padding: 10px 18px; cursor: pointer; border: 0; }
    .dbp-btn-print { background: #0d9488; color: #fff; }
    .dbp-btn-print-all { background: #7c3aed; color: #fff; }
    .dbp-btn-cancel { background: #e2e8f0; color: #334155; }
    .dbp-rad .dbp-btn-print-all { background: #0891b2; }
    .dbp-rad .dbp-picker-tools button.primary { background: #0891b2; border-color: #0891b2; }
  </style>
</head>
<body class="<%= (typeof module !== 'undefined' && module === 'radiology') ? 'dbp-rad' : '' %>">
<div class="dbp-picker-wrap" id="dbp-picker">
  <div class="dbp-picker-card">
    <div class="dbp-picker-head">
      <h1><%= typeof pickerLabels !== 'undefined' && pickerLabels.title ? pickerLabels.title : 'Select results to print' %></h1>
      <p>
        <%= typeof pickerLabels !== 'undefined' && pickerLabels.subtitle ? pickerLabels.subtitle : 'Choose one or more completed reports, then print a combined patient handover package.' %>
        <% if (batchData && batchData.patientName) { %>
        <br><strong><%= batchData.patientName %></strong><% if (batchData.patientId) { %> · <%= batchData.patientId %><% } %>
        <% } %>
      </p>
    </div>
    <div class="dbp-picker-tools">
      <button type="button" id="dbp-select-all"><%= typeof pickerLabels !== 'undefined' && pickerLabels.selectAll ? pickerLabels.selectAll : 'Select all' %></button>
      <button type="button" id="dbp-clear-all"><%= typeof pickerLabels !== 'undefined' && pickerLabels.clearAll ? pickerLabels.clearAll : 'Clear all' %></button>
      <span id="dbp-count" style="margin-left:auto;font-size:.75rem;font-weight:700;color:#64748b;"></span>
    </div>
    <ul class="dbp-picker-list" id="dbp-list">
      <% (batchData.reports || []).forEach(function (report) {
        var pre = (typeof preselectIds !== 'undefined' && preselectIds.length) ? preselectIds : null;
        var checked = !pre || pre.indexOf(Number(report.resultId)) >= 0;
      %>
      <li class="dbp-picker-item">
        <input type="checkbox" class="dbp-pick-cb" value="<%= report.resultId %>" <%= checked ? 'checked' : '' %> id="dbp-pick-<%= report.resultId %>">
        <label for="dbp-pick-<%= report.resultId %>" style="flex:1;cursor:pointer;">
          <strong><%= report.examName || 'Report' %></strong>
          <span><%= report.registryRef || '' %><% if (report.reportDate) { %> · <%= report.reportDate %><% } %></span>
        </label>
      </li>
      <% }); %>
    </ul>
    <div class="dbp-picker-foot">
      <a href="<%= typeof backUrl !== 'undefined' ? backUrl : '/' %>" class="dbp-btn-cancel" style="display:inline-flex;align-items:center;padding:10px 18px;border-radius:999px;font-weight:800;text-decoration:none;"><%= typeof pickerLabels !== 'undefined' && pickerLabels.cancel ? pickerLabels.cancel : 'Cancel' %></a>
      <button type="button" class="dbp-btn-print-all" id="dbp-print-all"><%= typeof pickerLabels !== 'undefined' && pickerLabels.printAll ? pickerLabels.printAll : 'Print all' %></button>
      <button type="button" class="dbp-btn-print" id="dbp-print-selected"><%= typeof pickerLabels !== 'undefined' && pickerLabels.printSelected ? pickerLabels.printSelected : 'Print selected' %></button>
    </div>
  </div>
</div>
<script>window.__DIAG_PRINT_BATCH = <%- JSON.stringify(batchData) %>;</script>
<script>window.__DIAG_PRINT_PRESELECT = <%- JSON.stringify(typeof preselectIds !== 'undefined' ? preselectIds : []) %>;</script>
<script src="/js/hms-diagnostic-report-print.js?v=3"></script>
<script>
(function () {
  var batch = window.__DIAG_PRINT_BATCH;
  var backUrl = <%- JSON.stringify(typeof backUrl !== 'undefined' ? backUrl : '/laboratory') %>;
  var picker = document.getElementById('dbp-picker');
  var countEl = document.getElementById('dbp-count');
  var printSelectedBtn = document.getElementById('dbp-print-selected');

  function getCheckedIds() {
    return Array.prototype.map.call(document.querySelectorAll('.dbp-pick-cb:checked'), function (cb) {
      return parseInt(cb.value, 10) || 0;
    }).filter(function (id) { return id > 0; });
  }

  function filterBatch(ids) {
    var idSet = {};
    ids.forEach(function (id) { idSet[id] = true; });
    var reports = (batch.reports || []).filter(function (r) { return idSet[r.resultId]; });
    var out = {};
    for (var k in batch) { if (Object.prototype.hasOwnProperty.call(batch, k)) out[k] = batch[k]; }
    out.reports = reports;
    out.count = reports.length;
    out.canPrintAll = reports.length > 0;
    return out;
  }

  function updateCount() {
    var n = getCheckedIds().length;
    var total = (batch.reports || []).length;
    countEl.textContent = n + ' of ' + total + ' selected';
    printSelectedBtn.disabled = n < 1;
  }

  function runPrint(data) {
    if (!window.HmsDiagnosticReportPrint || !window.HmsDiagnosticReportPrint.renderBatchInline) {
      alert('Print module failed to load. Refresh and try again.');
      return;
    }
    if (!data || !data.canPrintAll) {
      alert('Select at least one printable result.');
      return;
    }
    if (picker) picker.style.display = 'none';
    window.HmsDiagnosticReportPrint.renderBatchInline(data, { backUrl: backUrl, autoPrint: true });
  }

  document.getElementById('dbp-select-all').addEventListener('click', function () {
    document.querySelectorAll('.dbp-pick-cb').forEach(function (cb) { cb.checked = true; });
    updateCount();
  });
  document.getElementById('dbp-clear-all').addEventListener('click', function () {
    document.querySelectorAll('.dbp-pick-cb').forEach(function (cb) { cb.checked = false; });
    updateCount();
  });
  document.querySelectorAll('.dbp-picker-item').forEach(function (li) {
    li.addEventListener('click', function (ev) {
      if (ev.target && ev.target.classList && ev.target.classList.contains('dbp-pick-cb')) return;
      var cb = li.querySelector('.dbp-pick-cb');
      if (cb) { cb.checked = !cb.checked; updateCount(); }
    });
  });
  document.querySelectorAll('.dbp-pick-cb').forEach(function (cb) {
    cb.addEventListener('change', updateCount);
  });
  document.getElementById('dbp-print-selected').addEventListener('click', function () {
    runPrint(filterBatch(getCheckedIds()));
  });
  document.getElementById('dbp-print-all').addEventListener('click', function () {
    document.querySelectorAll('.dbp-pick-cb').forEach(function (cb) { cb.checked = true; });
    updateCount();
    runPrint(batch);
  });

  updateCount();
})();
</script>
</body>
</html>

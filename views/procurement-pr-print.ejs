<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title><%= title %></title>
<style>
 body { font-family: Arial, sans-serif; font-size: 12px; color: #222; margin: 24px; }
 h1 { font-size: 18px; margin: 0 0 4px; }
 .meta { color: #555; margin-bottom: 16px; }
 table { width: 100%; border-collapse: collapse; margin-top: 12px; }
 th, td { border: 1px solid #ccc; padding: 6px 8px; text-align: left; }
 th { background: #f5f5f5; }
 .text-right { text-align: right; }
 @media print { .no-print { display: none; } }
</style>
</head>
<body>
<% if (typeof autoPrint !== 'undefined' && autoPrint) { %><script>window.onload=function(){window.print();};</script><% } %>
<p class="no-print"><button onclick="window.print()">Print / Save PDF</button></p>
<h1>Purchase Request <%= pr.pr_number %></h1>
<div class="meta">
 <div><strong><%= pr.title %></strong></div>
 <div>Status: <%= pr.status %> · Date: <%= pr.created_at ? new Date(pr.created_at).toLocaleDateString() : '' %></div>
 <% if (pr.vendor_name) { %><div>Vendor: <%= pr.vendor_name %></div><% } %>
 <% if (pr.needed_by) { %><div>Required by: <%= pr.needed_by %></div><% } %>
 <% if (pr.estimated_total) { %><div>Estimated total: <%= Number(pr.estimated_total).toLocaleString() %> XAF</div><% } %>
</div>
<% if (pr.summary_description) { %><p><%= pr.summary_description %></p><% } %>
<table>
 <thead><tr><th>#</th><th>Description</th><th class="text-right">Qty</th></tr></thead>
 <tbody>
  <% (lines||[]).forEach(function(ln){ %>
  <tr><td><%= ln.line_no %></td><td><%= ln.description %></td><td class="text-right"><%= typeof fmtPoQty === 'function' ? fmtPoQty(ln.quantity, ln.uom) : ln.quantity %></td></tr>
  <% }) %>
  <% if (!(lines||[]).length) { %><tr><td colspan="4">See summary above.</td></tr><% } %>
 </tbody>
</table>
<p class="meta" style="margin-top:24px;">Please provide quotation for the items above. — Hospital procurement</p>
</body>
</html>

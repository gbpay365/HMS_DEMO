<%
var _cashierShell = !!locals.cashierShell;
var _rosterBase = locals.rosterBasePath || '/nurse-roster';
var _savePath = locals.rosterSavePath || '/nurse-roster/save';
var _copyPath = locals.rosterCopyPath || '/nurse-roster/copy';
var _rosterQ = _rosterBase.indexOf('?') >= 0 ? '&' : '?';
if (_cashierShell) {
  locals.hmsSurfaceBodyClass = ' hms-body--cashier-odoo hms-body--cashier-roster';
  locals.cashierOdooApp = true;
  locals.showPageNav = false;
}
%>
<% if (_cashierShell) { %>
<%- include('partials/header') %>
<%- include('partials/cashier-odoo-start', {
  cashierPage: 'nurse-roster',
  pendingCount: locals.pendingCount || 0,
  billingPendingCount: locals.billingPendingCount || 0,
  userDisplayName: locals.userDisplayName,
  cashierUserInitials: locals.cashierUserInitials,
  cashierUserRole: locals.cashierUserRole,
  flash: locals.flash,
  error: locals.error
}) %>
<%- include('partials/cashier-roster-chrome', {
  cashierPage: 'nurse-roster',
  rosterPageTitle: locals.rosterPageTitle || 'Nurse Shift Roster',
  userDisplayName: locals.userDisplayName,
  cashierUserInitials: locals.cashierUserInitials,
  cashierIdentity: locals.cashierIdentity,
  balanceLabel: locals.balanceLabel,
  dateTimeLabel: locals.dateTimeLabel,
  pendingCount: locals.pendingCount || 0,
  billingPendingCount: locals.billingPendingCount || 0,
  insurancePendingCount: locals.insurancePendingCount || 0
}) %>
<main class="cs-content">
<div class="cs-page active">
<% } else { %>
<%- include('partials/header') %>
<% } %>
<% if (!_cashierShell) { %><link rel="stylesheet" href="/css/hms-roster-nurse.css?v=3"><% } %>
<% if (_cashierShell) { %><link rel="stylesheet" href="/css/cashier-roster.css?v=8"><% } %>

<% if (_cashierShell) { %>
<div class="cs-roster-page">
<div class="row cs-roster-kpi-row ins-kpi-row">
 <div class="col-6 col-md-3">
  <div class="cs-kpi cs-roster-kpi cs-roster-kpi--day">
   <div class="cs-kpi-label"><i class="fa fa-sun"></i> <%= _tl('nurse_roster.shift_day', 'Day') %></div>
   <div class="cs-kpi-value"><%= period.day %></div>
   <div class="cs-kpi-sub"><%= _tl('nurse_roster.shift_day_hours', '08:00 – 14:00') %></div>
  </div>
 </div>
 <div class="col-6 col-md-3">
  <div class="cs-kpi cs-roster-kpi cs-roster-kpi--relay">
   <div class="cs-kpi-label"><i class="fa fa-exchange-alt"></i> <%= _tl('nurse_roster.shift_relay', 'Relay') %></div>
   <div class="cs-kpi-value"><%= period.relay || 0 %></div>
   <div class="cs-kpi-sub"><%= _tl('nurse_roster.shift_relay_hours', '14:00 – 20:00') %></div>
  </div>
 </div>
 <div class="col-6 col-md-3">
  <div class="cs-kpi cs-roster-kpi cs-roster-kpi--night">
   <div class="cs-kpi-label"><i class="fa fa-moon"></i> <%= _tl('nurse_roster.shift_night', 'Night') %></div>
   <div class="cs-kpi-value"><%= period.night %></div>
   <div class="cs-kpi-sub"><%= _tl('nurse_roster.shift_night_hours', '20:00 – 08:00') %></div>
  </div>
 </div>
 <div class="col-6 col-md-3">
  <div class="cs-kpi cs-roster-kpi cs-roster-kpi--off">
   <div class="cs-kpi-label"><i class="fa fa-bed"></i> <%= _tl('nurse_roster.shift_off', 'Off') %></div>
   <div class="cs-kpi-value"><%= (nurses.length - period.day - (period.relay || 0) - period.night) %></div>
   <div class="cs-kpi-sub"><%= _tl('nurse_roster.shift_off_hours', 'No duty') %></div>
  </div>
 </div>
</div>
<div class="cs-card cs-roster-card ins-card">
 <div class="cs-card-head ins-card-head">
  <div class="cs-card-title"><i class="fa fa-calendar-o"></i> <%= _tl('nurse_roster.title', 'Ward Shift Board') %></div>
  <% if (isAdminOrSuper) { %>
  <button class="cs-btn cs-btn-sm cs-btn-primary" type="button" data-toggle="modal" data-target="#copyRosterModal">
   <i class="fa fa-copy"></i> <%= _tl('nurse_roster.copy_day', 'Copy day') %>
  </button>
  <% } %>
 </div>
<%- include('partials/cashier-roster-toolbar', {
  rosterBase: _rosterBase,
  rosterQuerySep: _rosterQ,
  rosterView: view,
  rosterDate: date,
  rosterWeekStart: weekStart || date,
  rosterMonthMeta: monthMeta,
  rosterPrevDate: prevNavDate,
  rosterNextDate: nextNavDate,
  rosterCountLabel: nurses.length + ' ' + _tl('nurse_roster.col_nurse', 'Nurse').toLowerCase() + (nurses.length === 1 ? '' : 's'),
  rosterLabelDay: _tl('nurse_roster.view_day', 'Day'),
  rosterLabelWeek: _tl('nurse_roster.view_week', 'Week'),
  rosterLabelMonth: _tl('nurse_roster.view_month', 'Month'),
  rosterLabelPrev: _tl('nurse_roster.prev', 'Previous'),
  rosterLabelNext: _tl('nurse_roster.next', 'Next'),
  rosterLabelGo: _tl('nurse_roster.go', 'Go'),
  rosterLabelToday: _tl('nurse_roster.today', 'Today'),
  rosterWeekLabel: _tl('nurse_roster.week_of', 'Week of {{date}}', { date: (typeof fmtDateShort === 'function' ? fmtDateShort(weekStart) : weekStart) })
}) %>
<div class="cs-card-body-0 cs-roster-body">
<% } else { %>
<div class="page-wrapper nr-roster-page">
 <div class="content">
<% } %>
 <% if (flash) { %>
 <div class="hms-flash hms-flash--success alert-dismissible fade show" role="alert">
 <%= flash %>
 <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
 </div>
 <% } %>
 <% if (error) { %>
 <div class="hms-flash hms-flash--error alert-dismissible fade show" role="alert">
 <%= error %>
 <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
 </div>
 <% } %>

<% if (!_cashierShell) { %>

 <div class="nr-hero d-flex flex-wrap justify-content-between align-items-start">
 <div class="nr-hero-main">
 <h4 class="mb-1 font-weight-bold">
  <span class="nr-hero-icon"><i class="fa fa-user-nurse"></i></span>
  <%= _tl('nurse_roster.title', 'Ward Shift Board') %>
 </h4>
 <p class="mb-2 small opacity-90"><%= _tl('nurse_roster.subtitle', 'Nursing coverage — day, relay, night, and monthly staffing at a glance.') %></p>
 <div class="nr-coverage-row">
  <span class="nr-coverage-stat nr-stat-day"><i class="fa fa-sun"></i> <%= _tl('nurse_roster.day_shifts_count', '{{count}} day', { count: period.day }) %></span>
  <span class="nr-coverage-stat nr-stat-relay"><i class="fa fa-exchange-alt"></i> <%= _tl('nurse_roster.relay_shifts_count', '{{count}} relay', { count: period.relay || 0 }) %></span>
  <span class="nr-coverage-stat nr-stat-night"><i class="fa fa-moon"></i> <%= _tl('nurse_roster.night_shifts_count', '{{count}} night', { count: period.night }) %></span>
 </div>
 </div>
 <% if (isAdminOrSuper) { %>
 <button class="btn btn-light btn-sm font-weight-bold rounded-pill px-3 nr-copy-btn" data-toggle="modal" data-target="#copyRosterModal">
 <i class="fa fa-copy mr-1"></i> <%= _tl('nurse_roster.copy_day', 'Copy day') %>
 </button>
 <% } %>
 </div>

 <div class="nr-shift-legend mb-3">
  <div class="nr-legend-item nr-legend-day">
   <i class="fa fa-sun"></i>
   <div>
    <strong><%= _tl('nurse_roster.shift_day', 'Day') %></strong>
    <span><%= _tl('nurse_roster.shift_day_hours', '08:00 – 14:00') %></span>
   </div>
  </div>
  <div class="nr-legend-item nr-legend-relay">
   <i class="fa fa-exchange-alt"></i>
   <div>
    <strong><%= _tl('nurse_roster.shift_relay', 'Relay') %></strong>
    <span><%= _tl('nurse_roster.shift_relay_hours', '14:00 – 20:00') %></span>
   </div>
  </div>
  <div class="nr-legend-item nr-legend-night">
   <i class="fa fa-moon"></i>
   <div>
    <strong><%= _tl('nurse_roster.shift_night', 'Night') %></strong>
    <span><%= _tl('nurse_roster.shift_night_hours', '20:00 – 08:00') %></span>
   </div>
  </div>
  <div class="nr-legend-item nr-legend-off">
   <i class="fa fa-bed"></i>
   <div>
    <strong><%= _tl('nurse_roster.shift_off', 'Off') %></strong>
    <span><%= _tl('nurse_roster.shift_off_hours', 'No duty') %></span>
   </div>
  </div>
 </div>

<% } %>

<% if (!_cashierShell) { %>
 <div class="nr-toolbar d-flex flex-wrap align-items-center justify-content-between">
 <div class="btn-group nr-view-pills">
 <a href="<%= _rosterBase %><%= _rosterQ %>view=day&date=<%= date %>" class="btn btn-sm btn-white <%= view === 'day' ? 'active' : '' %>"><i class="fa fa-calendar-day mr-1"></i><%= _tl('nurse_roster.view_day', 'Day') %></a>
 <a href="<%= _rosterBase %><%= _rosterQ %>view=week&date=<%= weekStart || date %>" class="btn btn-sm btn-white <%= view === 'week' ? 'active' : '' %>"><i class="fa fa-calendar-week mr-1"></i><%= _tl('nurse_roster.view_week', 'Week') %></a>
 <a href="<%= _rosterBase %><%= _rosterQ %>view=month&date=<%= monthMeta.start %>" class="btn btn-sm btn-white <%= view === 'month' ? 'active' : '' %>"><i class="fa fa-calendar-alt mr-1"></i><%= _tl('nurse_roster.view_month', 'Month') %></a>
 </div>

 <div class="d-flex align-items-center flex-wrap mt-2 mt-md-0" style="gap:8px;">
 <a href="<%= _rosterBase %><%= _rosterQ %>view=<%= view %>&date=<%= prevNavDate %>" class="hms-btn hms-btn-secondary btn-sm rounded-circle nr-nav-btn" title="<%= _tl('nurse_roster.prev', 'Previous') %>"><i class="fa fa-chevron-left"></i></a>
 <% if (view === 'month') { %>
 <span class="font-weight-bold text-dark px-2"><%= monthMeta.label %></span>
 <% } else if (view === 'week') { %>
 <span class="font-weight-bold text-dark px-2 small"><%= _tl('nurse_roster.week_of', 'Week of {{date}}', { date: (typeof fmtDateShort === 'function' ? fmtDateShort(weekStart) : weekStart) }) %></span>
 <% } else { %>
 <form action="<%= _rosterBase %>" method="GET" class="d-flex align-items-center mb-0" style="gap:6px;">
 <input type="hidden" name="view" value="day">
 <input type="date" name="date" class="hms-input w-full text-sm" value="<%= date %>">
 <button type="submit" class="btn btn-sm text-white font-weight-bold nr-go-btn"><%= _tl('nurse_roster.go', 'Go') %></button>
 </form>
 <% } %>
 <a href="<%= _rosterBase %><%= _rosterQ %>view=<%= view %>&date=<%= nextNavDate %>" class="hms-btn hms-btn-secondary btn-sm rounded-circle nr-nav-btn" title="<%= _tl('nurse_roster.next', 'Next') %>"><i class="fa fa-chevron-right"></i></a>
 <% if (view !== 'day') { %>
 <a href="<%= _rosterBase %><%= _rosterQ %>view=day" class="btn btn-sm btn-link"><%= _tl('nurse_roster.today', 'Today') %></a>
 <% } %>
 </div>
 </div>
<% } %>

 <% if (view === 'day') { %>
 <% if (isAdminOrSuper) { %>
 <form action="<%= _savePath %>" method="POST" id="nrSaveForm">
<% if (_cashierShell) { %><input type="hidden" name="cashier_shell" value="1"><% } %>
 <input type="hidden" name="date" value="<%= date %>">
 <input type="hidden" name="view" value="day">
 <div class="row <%= _cashierShell ? 'cs-roster-staff-grid' : '' %>">
 <% nurses.forEach(n => { %>
 <% const detail = (staffDayDetails && staffDayDetails[String(n.id)]) || { type: 'off', start_time: null, end_time: null };
    const currentShift = detail.type || 'off';
    const defs = shiftDefaults || {};
    const startVal = detail.start_time || (defs[currentShift] && defs[currentShift].start) || '';
    const endVal = detail.end_time || (defs[currentShift] && defs[currentShift].end) || ''; %>
 <div class="<%= _cashierShell ? 'col-6 col-md-4 col-lg-3 col-xl-2' : 'col-md-6 col-lg-4 col-xl-3 mb-3' %>">
 <div class="<%= _cashierShell ? 'cs-roster-staff-card' : 'nr-nurse-tile p-3' %> shift-<%= currentShift %>" data-nurse-tile="<%= n.id %>">
 <div class="<%= _cashierShell ? 'cs-roster-avatar' : 'nr-initials shift-' + currentShift + '-avatar' %>"><%= (n.first_name||'')[0] %><%= (n.last_name||'')[0] %></div>
 <% if (_cashierShell) { %>
 <h6 class="cs-roster-staff-name"><%= n.first_name %> <%= n.last_name %></h6>
 <p class="cs-roster-staff-dept"><%= n.primary_department || _tl('nurse_roster.dept_nursing', 'Nursing') %></p>
 <div class="cs-roster-shift-lanes nr-shift-lanes" data-emp="<%= n.id %>">
 <% } else { %>
 <h6 class="font-weight-bold mb-0 text-center"><%= n.first_name %> <%= n.last_name %></h6>
 <p class="text-muted text-center small mb-2"><%= n.primary_department || _tl('nurse_roster.dept_nursing', 'Nursing') %></p>
 <div class="nr-shift-lanes" data-emp="<%= n.id %>">
 <% } %>
  <label class="nr-lane-day" title="<%= _tl('nurse_roster.shift_day_long', 'Day shift') %>">
   <input type="radio" name="shifts[<%= n.id %>]" value="day" <%= currentShift === 'day' ? 'checked' : '' %>>
   <span><i class="fa fa-sun"></i> <%= _tl('nurse_roster.shift_day', 'Day') %></span>
  </label>
  <label class="nr-lane-relay" title="<%= _tl('nurse_roster.shift_relay_long', 'Relay shift') %>">
   <input type="radio" name="shifts[<%= n.id %>]" value="relay" <%= currentShift === 'relay' ? 'checked' : '' %>>
   <span><i class="fa fa-exchange-alt"></i> <%= _tl('nurse_roster.shift_relay', 'Relay') %></span>
  </label>
  <label class="nr-lane-night" title="<%= _tl('nurse_roster.shift_night_long', 'Night shift') %>">
   <input type="radio" name="shifts[<%= n.id %>]" value="night" <%= currentShift === 'night' ? 'checked' : '' %>>
   <span><i class="fa fa-moon"></i> <%= _tl('nurse_roster.shift_night', 'Night') %></span>
  </label>
  <label class="nr-lane-off" title="<%= _tl('nurse_roster.shift_off_long', 'Off') %>">
   <input type="radio" name="shifts[<%= n.id %>]" value="off" <%= currentShift === 'off' ? 'checked' : '' %>>
   <span><i class="fa fa-bed"></i> <%= _tl('nurse_roster.shift_off', 'Off') %></span>
  </label>
 </div>
 <div class="<%= _cashierShell ? 'cs-roster-time-row' : 'nr-time-row mt-2' %> <%= currentShift === 'off' ? 'is-hidden' : '' %>" data-time-row="<%= n.id %>">
  <div class="<%= _cashierShell ? '' : 'nr-time-field' %>">
   <label class="small font-weight-bold mb-0"><i class="fa fa-clock mr-1"></i><%= _tl('nurse_roster.start_time', 'Start') %></label>
   <input type="time" name="shift_start[<%= n.id %>]" class="<%= _cashierShell ? 'cs-input' : 'hms-input w-full text-sm nr-time-input' %>" value="<%= startVal %>" data-role="start">
  </div>
  <div class="<%= _cashierShell ? '' : 'nr-time-field' %>">
   <label class="small font-weight-bold mb-0"><i class="fa fa-clock mr-1"></i><%= _tl('nurse_roster.end_time', 'End') %></label>
   <input type="time" name="shift_end[<%= n.id %>]" class="<%= _cashierShell ? 'cs-input' : 'hms-input w-full text-sm nr-time-input' %>" value="<%= endVal %>" data-role="end">
  </div>
 </div>
 </div>
 </div>
 <% }); %>
 </div>
 <div class="<%= _cashierShell ? 'cs-roster-save-bar' : 'text-center mt-2' %>">
 <button type="submit" class="<%= _cashierShell ? 'cs-btn cs-btn-primary' : 'btn btn-lg font-weight-bold text-white px-5 rounded-pill shadow nr-save-btn' %>">
 <i class="fa fa-save mr-2"></i><%= _tl('nurse_roster.save_shifts', 'Save {{date}}', { date: (typeof fmtDate === 'function' ? fmtDate(date) : date) }) %>
 </button>
 </div>
 </form>
 <% } else { %>
 <div class="row <%= _cashierShell ? 'cs-roster-staff-grid' : '' %>">
 <% nurses.forEach(n => { %>
 <% const detail = (staffDayDetails && staffDayDetails[String(n.id)]) || { type: 'off' };
    const currentShift = detail.type || 'off';
    const shiftLabels = {
      day: _tl('nurse_roster.shift_day_long', 'Day shift'),
      relay: _tl('nurse_roster.shift_relay_long', 'Relay shift'),
      night: _tl('nurse_roster.shift_night_long', 'Night shift'),
      off: _tl('nurse_roster.shift_off_long', 'Off')
    };
    const shiftIcons = { day: 'fa-sun', relay: 'fa-exchange-alt', night: 'fa-moon', off: 'fa-bed' };
    const label = shiftLabels[currentShift] || shiftLabels.off;
    const icon = shiftIcons[currentShift] || shiftIcons.off;
    const timeLabel = currentShift !== 'off' && detail.start_time && detail.end_time
      ? detail.start_time + ' – ' + detail.end_time
      : ''; %>
 <div class="<%= _cashierShell ? 'col-6 col-md-4 col-lg-3 col-xl-2' : 'col-md-6 col-lg-4 col-xl-3 mb-3' %>">
 <div class="<%= _cashierShell ? 'cs-roster-staff-card text-center' : 'nr-nurse-tile p-3 text-center' %> shift-<%= currentShift %>">
 <div class="<%= _cashierShell ? 'cs-roster-avatar' : 'nr-initials shift-' + currentShift + '-avatar' %>"><%= (n.first_name||'')[0] %><%= (n.last_name||'')[0] %></div>
 <% if (_cashierShell) { %>
 <h6 class="cs-roster-staff-name"><%= n.first_name %> <%= n.last_name %></h6>
 <span class="cs-roster-status-badge is-<%= currentShift %>"><i class="fa <%= icon %>"></i> <%= label %></span>
 <% if (timeLabel) { %><div class="cs-roster-staff-dept mt-1"><i class="fa fa-clock"></i> <%= timeLabel %></div><% } %>
 <% } else { %>
 <h6 class="font-weight-bold mb-1"><%= n.first_name %> <%= n.last_name %></h6>
 <span class="nr-view-badge shift-<%= currentShift %>-badge">
  <i class="fa <%= icon %> mr-1"></i><%= label %>
 </span>
 <% if (timeLabel) { %>
 <div class="nr-view-time small text-muted mt-1"><i class="fa fa-clock mr-1"></i><%= timeLabel %></div>
 <% } %>
 <% } %>
 </div>
 </div>
 <% }); %>
 </div>
 <p class="<%= _cashierShell ? 'cs-roster-footnote' : 'text-muted small text-center mt-2' %>"><i class="fa fa-lock mr-1"></i><%= _tl('nurse_roster.view_only', 'View only — contact admin to edit shifts.') %></p>
 <% } %>

 <% } else if (view === 'week') { %>
 <% if (_cashierShell) { %>
 <div class="cs-table-wrap cs-roster-week-wrap">
 <table class="cs-table">
 <% } else { %>
 <div class="nr-week-board table-responsive bg-white">
 <table class="table table-bordered mb-0 text-center">
 <% } %>
 <thead>
 <tr>
 <th class="<%= _cashierShell ? 'cs-roster-week-name' : 'text-left pl-3' %>"><%= _tl('nurse_roster.col_nurse', 'Nurse') %></th>
 <% weekDays.forEach(wd => { %>
 <th class="<%= wd.isWeekend ? 'text-muted' : '' %> <%= wd.isToday ? (_cashierShell ? 'is-today' : 'bg-warning') : '' %>">
 <%= wd.weekday %><br><span class="text-muted font-weight-normal"><%= wd.dayNum %></span>
 </th>
 <% }); %>
 </tr>
 </thead>
 <tbody>
 <% staffWithWeek.forEach(sw => { %>
 <tr>
 <td class="<%= _cashierShell ? 'cs-roster-week-name' : 'text-left pl-3 font-weight-bold small' %>"><%= sw.first_name %> <%= sw.last_name %></td>
 <% sw.weekDays.forEach(wd => { %>
 <td>
 <% if (wd.shift === 'day') { %>
 <span class="<%= _cashierShell ? 'cs-roster-week-cell day' : 'nr-week-cell day' %>" title="<%= _tl('nurse_roster.shift_day', 'Day') %>"><i class="fa fa-sun"></i></span>
 <% } else if (wd.shift === 'relay') { %>
 <span class="<%= _cashierShell ? 'cs-roster-week-cell relay' : 'nr-week-cell relay' %>" title="<%= _tl('nurse_roster.shift_relay', 'Relay') %>"><i class="fa fa-exchange-alt"></i></span>
 <% } else if (wd.shift === 'night') { %>
 <span class="<%= _cashierShell ? 'cs-roster-week-cell night' : 'nr-week-cell night' %>" title="<%= _tl('nurse_roster.shift_night', 'Night') %>"><i class="fa fa-moon"></i></span>
 <% } else { %>
 <span class="<%= _cashierShell ? 'cs-roster-week-cell off' : 'nr-week-cell off' %>">—</span>
 <% } %>
 </td>
 <% }); %>
 </tr>
 <% }); %>
 </tbody>
 </table>
 </div>
 <p class="<%= _cashierShell ? 'cs-roster-legend' : 'text-muted small mt-2' %>"><%= _tl('nurse_roster.week_legend', 'Sun = day · arrows = relay · moon = night · Switch to Day to edit.') %></p>

 <% } else { %>
 <% if (_cashierShell) { %>
 <div class="cs-roster-month-dow-row mb-1">
 <% var nrDows = [_tl('nurse_roster.dow_mon','Mon'),_tl('nurse_roster.dow_tue','Tue'),_tl('nurse_roster.dow_wed','Wed'),_tl('nurse_roster.dow_thu','Thu'),_tl('nurse_roster.dow_fri','Fri'),_tl('nurse_roster.dow_sat','Sat'),_tl('nurse_roster.dow_sun','Sun')]; nrDows.forEach(d => { %>
 <div class="cs-roster-month-dow"><%= d %></div>
 <% }); %>
 </div>
 <% monthWeeks.forEach(week => { %>
 <div class="cs-roster-month-grid mb-1">
 <% week.forEach(cell => { %>
 <div class="cs-roster-month-cell <%= !cell.inMonth ? 'outside' : '' %> <%= cell.isToday ? 'today' : '' %> <%= cell.isWeekend ? 'weekend' : '' %>">
 <a class="day-link d-block" href="<%= _rosterBase %><%= _rosterQ %>view=day&date=<%= cell.ymd %>" title="<%= _tl('nurse_roster.open_day', 'Open day editor') %>">
 <div class="day-num"><%= cell.dayNum %></div>
 </a>
 <% if (cell.shifts && cell.shifts.day && cell.shifts.day.length) { %>
 <div class="cs-roster-month-chip day"><i class="fa fa-sun mr-1"></i><%= cell.shifts.day.join(', ') %></div>
 <% } %>
 <% if (cell.shifts && cell.shifts.relay && cell.shifts.relay.length) { %>
 <div class="cs-roster-month-chip relay"><i class="fa fa-exchange-alt mr-1"></i><%= cell.shifts.relay.join(', ') %></div>
 <% } %>
 <% if (cell.shifts && cell.shifts.night && cell.shifts.night.length) { %>
 <div class="cs-roster-month-chip night"><i class="fa fa-moon mr-1"></i><%= cell.shifts.night.join(', ') %></div>
 <% } %>
 <% if (cell.inMonth && (!cell.shifts || (!cell.shifts.day.length && !(cell.shifts.relay && cell.shifts.relay.length) && !cell.shifts.night.length))) { %>
 <span class="text-muted">—</span>
 <% } %>
 </div>
 <% }); %>
 </div>
 <% }); %>
 <% } else { %>
 <div class="nr-month-grid mb-1">
 <% var nrDows = [_tl('nurse_roster.dow_mon','Mon'),_tl('nurse_roster.dow_tue','Tue'),_tl('nurse_roster.dow_wed','Wed'),_tl('nurse_roster.dow_thu','Thu'),_tl('nurse_roster.dow_fri','Fri'),_tl('nurse_roster.dow_sat','Sat'),_tl('nurse_roster.dow_sun','Sun')]; nrDows.forEach(d => { %>
 <div class="nr-month-dow"><%= d %></div>
 <% }); %>
 </div>
 <% monthWeeks.forEach(week => { %>
 <div class="nr-month-grid mb-1">
 <% week.forEach(cell => { %>
 <div class="nr-month-cell <%= !cell.inMonth ? 'outside' : '' %> <%= cell.isToday ? 'today' : '' %> <%= cell.isWeekend ? 'weekend' : '' %>">
 <a class="day-link d-block" href="<%= _rosterBase %><%= _rosterQ %>view=day&date=<%= cell.ymd %>" title="<%= _tl('nurse_roster.open_day', 'Open day editor') %>">
 <div class="day-num"><%= cell.dayNum %></div>
 </a>
 <% if (cell.shifts && cell.shifts.day && cell.shifts.day.length) { %>
 <div class="nr-month-shift-block day-shift"><i class="fa fa-sun mr-1"></i><%= cell.shifts.day.join(', ') %></div>
 <% } %>
 <% if (cell.shifts && cell.shifts.relay && cell.shifts.relay.length) { %>
 <div class="nr-month-shift-block relay-shift"><i class="fa fa-exchange-alt mr-1"></i><%= cell.shifts.relay.join(', ') %></div>
 <% } %>
 <% if (cell.shifts && cell.shifts.night && cell.shifts.night.length) { %>
 <div class="nr-month-shift-block night-shift"><i class="fa fa-moon mr-1"></i><%= cell.shifts.night.join(', ') %></div>
 <% } %>
 <% if (cell.inMonth && (!cell.shifts || (!cell.shifts.day.length && !(cell.shifts.relay && cell.shifts.relay.length) && !cell.shifts.night.length))) { %>
 <span class="text-muted">—</span>
 <% } %>
 </div>
 <% }); %>
 </div>
 <% }); %>
 <% } %>
 <p class="<%= _cashierShell ? 'cs-roster-legend' : 'text-muted small mt-2' %>"><%= _tl('nurse_roster.month_legend', 'Click a date to edit. Amber = day · orange = relay · indigo = night.') %></p>
 <% } %>

<% if (_cashierShell) { %>
 </div>
</div>
</div>
<% } else { %>
 </div>
</div>
<% } %>

<% if (isAdminOrSuper) { %>
<div class="modal fade" id="copyRosterModal" tabindex="-1" role="dialog" aria-labelledby="copyRosterModalTitle">
 <div class="modal-dialog modal-dialog-centered">
 <div class="modal-content border-0 nr-modal">
 <form action="<%= _copyPath %>" method="POST">
<% if (_cashierShell) { %><input type="hidden" name="cashier_shell" value="1"><% } %>
 <div class="modal-header border-0">
 <h5 class="modal-title font-weight-bold" id="copyRosterModalTitle"><i class="fa fa-copy mr-2 text-teal" aria-hidden="true"></i><%= _tl('nurse_roster.copy_title', 'Copy nursing shifts') %></h5>
 <button type="button" class="close" data-dismiss="modal" aria-label="<%= _tl('nurse_roster.close', 'Close') %>"><span aria-hidden="true">&times;</span></button>
 </div>
 <div class="modal-body">
 <input type="hidden" name="view" value="<%= view %>">
 <div class="form-group">
 <label class="small font-weight-bold"><%= _tl('nurse_roster.from_date', 'From date') %></label>
 <input type="date" name="from_date" class="hms-input w-full" required>
 </div>
 <div class="form-group mb-0">
 <label class="small font-weight-bold"><%= _tl('nurse_roster.to_date', 'To date') %></label>
 <input type="date" name="to_date" class="hms-input w-full" value="<%= date %>" required>
 </div>
 </div>
 <div class="modal-footer border-0">
 <button type="button" class="hms-btn hms-btn-secondary" data-dismiss="modal"><%= _tl('nurse_roster.cancel', 'Cancel') %></button>
 <button type="submit" class="hms-btn hms-btn-primary nr-copy-submit-btn"><%= _tl('nurse_roster.copy_shifts', 'Copy shifts') %></button>
 </div>
 </form>
 </div>
 </div>
</div>
<script>
(function () {
 var el = document.getElementById('copyRosterModal');
 if (el && el.parentNode !== document.body) document.body.appendChild(el);

 var defaults = <%- JSON.stringify(shiftDefaults || {}) %>;

 function applyShiftUi(tile, shift) {
  if (!tile) return;
  tile.classList.remove('shift-day', 'shift-relay', 'shift-night', 'shift-off');
  tile.classList.add('shift-' + shift);
  var avatar = tile.querySelector('.nr-initials');
  if (avatar) {
   avatar.classList.remove('shift-day-avatar', 'shift-relay-avatar', 'shift-night-avatar', 'shift-off-avatar');
   avatar.classList.add('shift-' + shift + '-avatar');
  }
  var timeRow = tile.querySelector('.nr-time-row');
  if (timeRow) {
   if (shift === 'off') {
    timeRow.classList.add('is-hidden');
    timeRow.classList.add('d-none');
   } else {
    timeRow.classList.remove('is-hidden');
    timeRow.classList.remove('d-none');
    var def = defaults[shift] || {};
    var startIn = timeRow.querySelector('[data-role="start"]');
    var endIn = timeRow.querySelector('[data-role="end"]');
    if (startIn && def.start) startIn.value = def.start;
    if (endIn && def.end) endIn.value = def.end;
   }
  }
 }

 document.querySelectorAll('.nr-shift-lanes').forEach(function (lanes) {
  lanes.querySelectorAll('input[type="radio"]').forEach(function (radio) {
   radio.addEventListener('change', function () {
    if (!radio.checked) return;
    var tile = lanes.closest('.nr-nurse-tile');
    applyShiftUi(tile, radio.value);
   });
  });
 });
})();
</script>
<% } %>

<% if (_cashierShell) { %>
</div>
<%- include('partials/cashier-odoo-end') %>
<% } %>

<%- include('partials/footer') %>

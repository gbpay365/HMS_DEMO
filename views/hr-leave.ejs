<%- include('partials/header') %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>

<div class="page-wrapper">
 <div class="content">
 <!-- Header -->
 <div class="row align-items-center mb-4">
 <div class="col-sm-8">
 <h4 class="page-title font-weight-bold text-dark"><%= _t('hr_leave.title', { ns: 'legacy', defaultValue: 'Leave Management' }) %></h4>
 <p class="text-muted small"><%= _t('hr_leave.subtitle', { ns: 'legacy', defaultValue: 'Review and approve staff time-off requests.' }) %></p>
 </div>
 <div class="col-sm-4 text-right">
 <button class="btn btn-primary hms-btn-premium" data-toggle="modal" data-target="#requestLeaveModal">
 <i class="fa fa-plus mr-2"></i> <%= _t('hr_leave.log_request', { ns: 'legacy', defaultValue: 'Log Leave Request' }) %>
 </button>
 </div>
 </div>

 <div class="card border-0 shadow-sm rounded-xl overflow-hidden bg-white">
 <div class="table-responsive">
 <table class="table table-hover mb-0 hms-table-v3">
 <thead class="bg-light">
 <tr>
 <th><%= _t('hr_leave.col_staff', { ns: 'legacy', defaultValue: 'Staff Member' }) %></th>
 <th><%= _t('hr_leave.col_type', { ns: 'legacy', defaultValue: 'Leave Type' }) %></th>
 <th><%= _t('hr_leave.col_duration', { ns: 'legacy', defaultValue: 'Duration' }) %></th>
 <th><%= _t('hr_leave.col_days', { ns: 'legacy', defaultValue: 'Days' }) %></th>
 <th><%= _t('hr_leave.col_status', { ns: 'legacy', defaultValue: 'Status' }) %></th>
 <th class="text-right"><%= _t('hr_leave.col_action', { ns: 'legacy', defaultValue: 'Action' }) %></th>
 </tr>
 </thead>
 <tbody>
 <% requests.forEach(req => { %>
 <tr>
 <td>
 <div class="font-weight-bold text-dark"><%= req.first_name %> <%= req.last_name %></div>
 <div class="extra-small text-muted text-uppercase"><%= _t('hr_leave.requested_on', { ns: 'legacy', defaultValue: 'Requested on {{date}}', date: fmtDate(req.created_at) }) %></div>
 </td>
 <td><span class="text-capitalize"><%= req.leave_type %></span></td>
 <td>
 <div class="small"><%= fmtDate(req.start_date) %> — <%= fmtDate(req.end_date) %></div>
 </td>
 <td><span class="badge badge-light px-2"><%= _t('hr_leave.days_count', { ns: 'legacy', defaultValue: '{{count}} Days', count: req.days_count }) %></span></td>
 <td>
 <span class="badge badge-<%= req.status === 'approved' ? 'success' : (req.status === 'pending' ? 'warning' : 'danger') %>-light px-2 py-1 text-uppercase extra-small">
 <%= req.status %>
 </span>
 </td>
 <td class="text-right">
 <% if(req.status === 'pending') { %>
 <div class="btn-group">
 <button class="btn btn-sm btn-outline-success rounded-pill mr-1 px-3"><%= _t('hr_leave.approve', { ns: 'legacy', defaultValue: 'Approve' }) %></button>
 <button class="btn btn-sm btn-outline-danger rounded-pill px-3"><%= _t('hr_leave.reject', { ns: 'legacy', defaultValue: 'Reject' }) %></button>
 </div>
 <% } else { %>
 <button class="btn btn-sm btn-light rounded-circle"><i class="fa fa-eye"></i></button>
 <% } %>
 </td>
 </tr>
 <% }) %>
 <% if(requests.length === 0) { %>
 <tr>
 <td colspan="6" class="text-center py-5 text-muted"><%= _t('hr_leave.no_requests', { ns: 'legacy', defaultValue: 'No leave requests found.' }) %></td>
 </tr>
 <% } %>
 </tbody>
 </table>
 </div>
 </div>
 </div>
</div>

<style>
 .badge-success-light { background: #dcfce7; color: #166534; }
 .badge-warning-light { background: #fef3c7; color: #92400e; }
 .badge-danger-light { background: #fee2e2; color: #991b1b; }
 .extra-small { font-size: 0.65rem; }
</style>

<%- include('partials/footer') %>

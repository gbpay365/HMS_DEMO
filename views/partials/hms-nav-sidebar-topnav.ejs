<%
var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
var _nav = locals.navTopnav || { primaryLinks: [], menus: [] };
var _path = String(locals.hmsPath || '').split('?')[0];
var _homeUrl = locals.navHomeUrl || '/hms';
var _navLbl = locals.navLabel || function (_code, label) { return label; };
var _tNav = locals.t || function (k, o) { return (o && o.defaultValue) || k; };

function _itemActive(url) {
  var u = String(url || '').trim();
  if (!u || u === '__home__') return false;
  if (_path === u) return true;
  return _path.indexOf(u + '/') === 0;
}
function _groupActive(children) {
  return (children || []).some(function (ch) { return _itemActive(ch.url); });
}
function _menuByCode(code) {
  return (_nav.menus || []).find(function (m) { return m.parent && m.parent.code === code; });
}
var _clinical = _menuByCode('topnav.clinical');
var _operations = _menuByCode('topnav.operations');
var _hr = _menuByCode('topnav.hr');
var _settings = _menuByCode('topnav.configuration');
var _sidebarCompactAdmin = !!(typeof isAdminOrSuper !== 'undefined' && isAdminOrSuper && !locals.previewRole);
%>

<% if (typeof canHospitalDashboard === 'function' && canHospitalDashboard()) { %>
<div class="sb-section"><%= _tNav('sidebar.section.overview', { ns: 'nav', defaultValue: 'Overview' }) %></div>
<a href="/dashboard" class="sb-item<%= _path === '/dashboard' || _path.indexOf('/dashboard/') === 0 ? ' active' : '' %>" data-label="<%= _tNav('hospital_dashboard', { ns: 'nav', defaultValue: 'Dashboard' }) %>">
  <i class="fa fa-dashboard sb-item-icon"></i>
  <span class="sb-item-label"><%= _tNav('hospital_dashboard', { ns: 'nav', defaultValue: 'Dashboard' }) %></span>
</a>
<% } %>

<% if (_clinical && (_clinical.children || []).length) { %>
<div class="sb-section"><%= _tNav('sidebar.section.clinical', { ns: 'nav', defaultValue: 'Clinical care' }) %></div>
<% var _subId = 'sb-topnav-clinical'; var _open = _groupActive(_clinical.children); %>
<div class="sb-item<%= _open ? ' open active' : '' %>" data-sub="<%= _subId %>" data-label="<%= _navLbl(_clinical.parent.code, _clinical.parent.label) %>" role="button" tabindex="0">
  <i class="fa fa-stethoscope sb-item-icon" style="color:#0891b2;"></i>
  <span class="sb-item-label"><%= _navLbl(_clinical.parent.code, _clinical.parent.label) %></span>
  <i class="fa fa-chevron-right sb-chevron"></i>
</div>
<div class="sb-sub-wrap<%= _open ? ' open' : '' %>" id="<%= _subId %>">
<% _clinical.children.forEach(function (ch) {
  var active = _itemActive(ch.url);
  var chIcon = ch.icon || 'fa-angle-right';
  var chColor = ch.color ? ('color:' + ch.color + ';') : '';
%>
  <a href="<%= ch.url %>" class="sb-sub-item<%= active ? ' active' : '' %>" data-label="<%= _navLbl(ch.code, ch.label) %>">
    <i class="fa <%= chIcon %>" style="width:16px;text-align:center;<%= chColor %>"></i>
    <%= _navLbl(ch.code, ch.label) %>
  </a>
<% }); %>
</div>
<% } %>

<% if (_operations && (_operations.children || []).length) { %>
<div class="sb-section"><%= _tNav('sidebar.section.operations', { ns: 'nav', defaultValue: 'Hospital operations' }) %></div>
<% var _opsId = 'sb-topnav-operations'; var _opsOpen = _groupActive(_operations.children); %>
<div class="sb-item<%= _opsOpen ? ' open active' : '' %>" data-sub="<%= _opsId %>" data-label="<%= _navLbl(_operations.parent.code, _operations.parent.label) %>" role="button" tabindex="0">
  <i class="fa fa-cogs sb-item-icon" style="color:#0c8b8b;"></i>
  <span class="sb-item-label"><%= _navLbl(_operations.parent.code, _operations.parent.label) %></span>
  <i class="fa fa-chevron-right sb-chevron"></i>
</div>
<div class="sb-sub-wrap<%= _opsOpen ? ' open' : '' %>" id="<%= _opsId %>">
<% _operations.children.forEach(function (ch) {
  var active = _itemActive(ch.url);
  var chIcon = ch.icon || 'fa-angle-right';
  var chColor = ch.color ? ('color:' + ch.color + ';') : '';
%>
  <a href="<%= ch.url %>" class="sb-sub-item<%= active ? ' active' : '' %>" data-label="<%= _navLbl(ch.code, ch.label) %>">
    <i class="fa <%= chIcon %>" style="width:16px;text-align:center;<%= chColor %>"></i>
    <%= _navLbl(ch.code, ch.label) %>
  </a>
<% }); %>
</div>
<% } %>

<% if (_hr && (_hr.children || []).length && !_sidebarCompactAdmin) { %>
<div class="sb-section"><%= _tNav('sidebar.section.people', { ns: 'nav', defaultValue: 'People & HR' }) %></div>
<% var _hrId = 'sb-topnav-hr'; var _hrOpen = _groupActive(_hr.children); %>
<div class="sb-item<%= _hrOpen ? ' open active' : '' %>" data-sub="<%= _hrId %>" data-label="<%= _navLbl(_hr.parent.code, _hr.parent.label) %>" role="button" tabindex="0">
  <i class="fa fa-id-badge sb-item-icon" style="color:#7c3aed;"></i>
  <span class="sb-item-label"><%= _navLbl(_hr.parent.code, _hr.parent.label) %></span>
  <i class="fa fa-chevron-right sb-chevron"></i>
</div>
<div class="sb-sub-wrap<%= _hrOpen ? ' open' : '' %>" id="<%= _hrId %>">
<% _hr.children.forEach(function (ch) {
  var active = _itemActive(ch.url);
  var chIcon = ch.icon || 'fa-angle-right';
  var chColor = ch.color ? ('color:' + ch.color + ';') : '';
%>
  <a href="<%= ch.url %>" class="sb-sub-item<%= active ? ' active' : '' %>" data-label="<%= _navLbl(ch.code, ch.label) %>">
    <i class="fa <%= chIcon %>" style="width:16px;text-align:center;<%= chColor %>"></i>
    <%= _navLbl(ch.code, ch.label) %>
  </a>
<% }); %>
</div>
<% } %>

<% if (_settings && (_settings.children || []).length && !_sidebarCompactAdmin) { %>
<div class="sb-section"><%= _tNav('sidebar.section.admin', { ns: 'nav', defaultValue: 'Administration' }) %></div>
<% var _setId = 'sb-topnav-configuration'; var _setOpen = _groupActive(_settings.children); %>
<div class="sb-item<%= _setOpen ? ' open active' : '' %>" data-sub="<%= _setId %>" data-label="<%= _navLbl(_settings.parent.code, _settings.parent.label) %>" role="button" tabindex="0">
  <i class="fa fa-sliders sb-item-icon" style="color:#1a6bd8;"></i>
  <span class="sb-item-label"><%= _navLbl(_settings.parent.code, _settings.parent.label) %></span>
  <i class="fa fa-chevron-right sb-chevron"></i>
</div>
<div class="sb-sub-wrap<%= _setOpen ? ' open' : '' %>" id="<%= _setId %>">
<% _settings.children.forEach(function (ch) {
  var active = _itemActive(ch.url);
  var chIcon = ch.icon || 'fa-angle-right';
  var chColor = ch.color ? ('color:' + ch.color + ';') : '';
%>
  <a href="<%= ch.url %>" class="sb-sub-item<%= active ? ' active' : '' %>" data-label="<%= _navLbl(ch.code, ch.label) %>">
    <i class="fa <%= chIcon %>" style="width:16px;text-align:center;<%= chColor %>"></i>
    <%= _navLbl(ch.code, ch.label) %>
  </a>
<% }); %>
</div>
<% } %>

<% if (isAdminOrSuper && !locals.previewRole) { %>
<%- include('hms-nav-sidebar-extras') %>
<% } %>

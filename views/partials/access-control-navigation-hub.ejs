<% if (!selRole || ['1','99'].includes(String(selRole))) { %>
<div class="card border-0 shadow-sm p-4" style="border-radius:12px;">
  <p class="text-muted small mb-2"><%= _ac('legacy_page.nav_pick_role', 'Choose a staff role to configure menus and navigation visibility.') %></p>
  <div class="d-flex flex-wrap" style="gap:8px;">
    <% (roles || []).forEach(function(r){ if (['1','99'].includes(String(r.role))) return; %>
    <a href="/access-control?role=<%= r.role %>#section-navigation"
       class="btn btn-sm btn-outline-primary font-weight-bold" style="border-radius:20px;"
       onclick="switchSection('navigation',document.getElementById('mtab-navigation'))"><%= r.title %></a>
    <% }); %>
  </div>
</div>
<% } else { %>

<div class="card border-0 shadow-sm p-3 mb-3" style="border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0 !important;">
  <div class="d-flex justify-content-between align-items-center flex-wrap" style="gap:10px;">
    <div>
      <span class="font-weight-bold" style="color:#1e293b;"><i class="fa fa-compass mr-2 text-primary"></i><%= _ac('legacy_page.nav_for_role', 'Navigation for {{role}}', { role: selRoleTitle }) %></span>
      <p class="text-muted small mb-0"><%= _ac('legacy_page.nav_hub_desc', 'Show or hide header tabs, sidebar links, portal tiles, accounting menus, and row actions. This does not grant access by itself — users also need matching capabilities under Modules & permissions.') %></p>
    </div>
    <div class="d-flex flex-wrap" style="gap:6px;">
      <% roles.forEach(function(r){ if (['1','99'].includes(String(r.role))) return; %>
      <a href="/access-control?role=<%= r.role %>#section-navigation"
         class="btn btn-sm <%= String(r.role)===String(selRole) ? 'btn-primary' : 'btn-outline-secondary' %> font-weight-bold"
         style="border-radius:20px;"><%= r.title %></a>
      <% }); %>
    </div>
  </div>
</div>

<%- include('access-control-ui-visibility') %>
<%- include('navigation-studio') %>
<%- include('access-control-action-menus') %>

<% } %>

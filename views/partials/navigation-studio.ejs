<style>
.nav-studio-tabs .nav-link { border-radius: 20px; font-weight: 600; font-size: .85rem; }
.nav-studio-card--off { opacity: .55; }
.nav-studio-card--off .card-header { background: #f1f5f9; }
</style>

<script>
(function(){
  var NS_ROLE = '<%= selRole %>';
  var NS_AJAX_HEADERS = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'Accept': 'application/json'
  };
  window.navStudioToggle = function(cb) {
    var code = cb.getAttribute('data-code');
    var show = cb.checked;
    cb.disabled = true;
    fetch('/access-control/api', {
      method: 'POST',
      headers: NS_AJAX_HEADERS,
      body: new URLSearchParams({
        action: show ? 'ui_show' : 'ui_hide',
        role_val: NS_ROLE,
        element_code: code
      })
    }).then(function(r){
      if (!r.ok && r.status === 401) throw new Error('<%= _ac('nav_studio.js_session_expired', 'Session expired — please sign in again.') %>');
      if (!r.ok && r.status === 403) throw new Error('<%= _ac('nav_studio.js_access_denied', 'Access denied.') %>');
      return r.json();
    }).then(function(j){
      if (!j.ok) { cb.checked = !show; alert(j.error || '<%= _ac('nav_studio.js_save_failed', 'Save failed') %>'); }
    }).catch(function(e){ cb.checked = !show; cb.disabled = false; alert(e && e.message ? e.message : '<%= _ac('nav_studio.js_network_error', 'Network error — please reload and try again.') %>'); })
    .finally(function(){ cb.disabled = false; });
  };
  window.navStudioBulk = function(shell, show) {
    fetch('/access-control/api', {
      method: 'POST',
      headers: NS_AJAX_HEADERS,
      body: new URLSearchParams({
        action: 'ui_bulk_shell',
        role_val: NS_ROLE,
        shell: shell,
        show: show ? '1' : '0'
      })
    }).then(function(r){
      if (!r.ok && r.status === 401) throw new Error('<%= _ac('nav_studio.js_session_expired', 'Session expired — please sign in again.') %>');
      if (!r.ok && r.status === 403) throw new Error('<%= _ac('nav_studio.js_access_denied', 'Access denied.') %>');
      return r.json();
    }).then(function(j){
      if (j.ok) location.reload();
      else alert(j.error || '<%= _ac('nav_studio.bulk_failed', 'Bulk update failed') %>');
    }).catch(function(e){ alert(e && e.message ? e.message : '<%= _ac('nav_studio.js_network_error', 'Network error — please reload and try again.') %>'); });
  };
})();
</script>
<% } %>


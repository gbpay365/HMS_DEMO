<% if (typeof _sa !== 'function') {
  var _sa = function (k, d, opts) {
    if (typeof t !== 'function') return d || k;
    var o = { ns: 'superAdmin', defaultValue: d || k };
    if (opts) Object.assign(o, opts);
    return t(k, o);
  };
  if (typeof locals !== 'undefined') locals._sa = _sa;
} %>
  <ul class="nav nav-pills mb-3" role="tablist">
    <li class="nav-item"><a class="nav-link active" data-toggle="pill" href="#depmod-topnav" role="tab"><i class="fa fa-navicon mr-1"></i><%= _sa('deployModules.form.tab_topbar', 'Top bar') %></a></li>
    <li class="nav-item"><a class="nav-link" data-toggle="pill" href="#depmod-sidebar" role="tab"><i class="fa fa-bars mr-1"></i><%= _sa('deployModules.form.tab_sidebar', 'Sidebar') %></a></li>
  </ul>

  <div class="tab-content">
    <div class="tab-pane fade show active" id="depmod-topnav" role="tabpanel">
      <% if ((editor.topbarPrimary || []).length) { %>
      <p class="small text-muted text-uppercase font-weight-bold mb-2"><%= _sa('deployModules.form.primary_links', 'Primary links') %></p>
      <div class="table-responsive mb-4">
        <table class="table table-sm table-hover mb-0" style="font-size:.85rem;">
          <thead style="background:#f8fafc;"><tr><th><%= _sa('deployModules.form.col_label', 'Label') %></th><th><%= _sa('deployModules.form.col_code', 'Code') %></th><th class="text-center"><%= _sa('deployModules.form.col_slice', 'Slice') %></th><th style="min-width:140px;"><%= _sa('deployModules.form.col_override', 'Override') %></th><th class="text-center"><%= _sa('deployModules.form.col_effective', 'Effective') %></th></tr></thead>
          <tbody>
            <% editor.topbarPrimary.forEach(function(row){ %>
            <%- include('deployment-module-row', { row: row, _sa: _sa }) %>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
      <div class="row">
        <% (editor.topnavMenus || []).forEach(function(menu){ %>
        <div class="col-lg-6 mb-4">
          <div class="card border h-100" style="border-radius:12px;">
            <div class="card-header py-2 font-weight-bold small" style="background:#f8fafc;">
              <%= menu.parent.label %> <code class="ml-1"><%= menu.parent.code %></code>
            </div>
            <div class="table-responsive">
              <table class="table table-sm table-hover mb-0" style="font-size:.82rem;">
                <thead><tr><th><%= _sa('deployModules.form.col_item', 'Item') %></th><th><%= _sa('deployModules.form.col_code', 'Code') %></th><th class="text-center"><%= _sa('deployModules.form.col_slice', 'Slice') %></th><th><%= _sa('deployModules.form.col_override', 'Override') %></th><th class="text-center"><%= _sa('deployModules.form.col_eff_short', 'Eff.') %></th></tr></thead>
                <tbody>
                  <%- include('deployment-module-row', { row: menu.parent, _sa: _sa }) %>
                  <% (menu.children || []).forEach(function(row){ %>
                  <%- include('deployment-module-row', { row: row, _sa: _sa }) %>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <div class="tab-pane fade" id="depmod-sidebar" role="tabpanel">
      <% (editor.sidebarSections || []).forEach(function(sec){ if (!sec.items.length) return; %>
      <h6 class="font-weight-bold text-muted text-uppercase small mb-2 mt-3"><%= sec.label %></h6>
      <div class="table-responsive mb-3">
        <table class="table table-sm table-hover mb-0" style="font-size:.85rem;">
          <thead style="background:#f8fafc;"><tr><th><%= _sa('deployModules.form.col_label', 'Label') %></th><th><%= _sa('deployModules.form.col_code', 'Code') %></th><th class="text-center"><%= _sa('deployModules.form.col_slice', 'Slice') %></th><th style="min-width:140px;"><%= _sa('deployModules.form.col_override', 'Override') %></th><th class="text-center"><%= _sa('deployModules.form.col_effective', 'Effective') %></th></tr></thead>
          <tbody>
            <% sec.items.forEach(function(row){ %>
            <%- include('deployment-module-row', { row: row, _sa: _sa }) %>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% }); %>
    </div>
  </div>

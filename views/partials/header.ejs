      <i class="fa fa-eye mr-1"></i> Previewing navigation as role <strong>#<%= locals.previewRole %></strong>.
      <a href="<%= (locals.hmsPath || '').split('?')[0] %>" class="font-weight-bold ml-1"><%= typeof t === 'function' ? t('exit_preview', { ns: 'nav', defaultValue: 'Exit preview' }) : 'Exit preview' %></a>
    </div>
    <% } %>
    <% var _hmsDep = locals.hmsDeployment; %>
    <% if (_hmsDep && role !== '99' && _hmsDep.slices && _hmsDep.slices.indexOf('full') === -1) { %>
    <div class="alert alert-info border-0 shadow-sm mx-3 mb-2 py-2 small" style="border-radius:8px;">
      <i class="fa fa-hospital-o mr-1"></i>
      Deployment: <strong><%= _hmsDep.profileName || _hmsDep.productMode || 'custom' %></strong>
      ? only enabled modules are shown.
    </div>
    <% } %>
    <%- include('hms-nav-sidebar') %>
<% } /* end hospital nav (non?finance staff) */ %>

  </nav>

<%
var _hmsShortName = locals.userDisplayName || (typeof hmsFormatDisplayName === 'function' ? hmsFormatDisplayName(locals.user && locals.user.name) : (locals.user && locals.user.name)) || 'Staff';
var _hmsNavName = locals.userNavDisplayName || (typeof hmsFormatNavDisplayName === 'function' ? hmsFormatNavDisplayName(locals.user && locals.user.name) : _hmsShortName);
var _hmsTopTitle = typeof hmsFormatTopbarTitle === 'function' ? hmsFormatTopbarTitle(title) : title;
%>

  <!-- User card -->
  <div class="sb-user-card">
    <div class="sb-user-top">
      <div class="sb-avatar">
        <%- include('hms-user-avatar', { avatarClass: 'hms-user-avatar hms-user-avatar--lg', userProfileEmoji: locals.userProfileEmoji }) %>
        <span class="sb-avatar-dot"></span>
      </div>
      <div class="sb-user-meta">
        <div class="sb-user-name"><%= _hmsShortName %></div>
        <div class="sb-user-role"><%= locals.user.role_name || (typeof t === 'function' ? t('user', { ns: 'nav', defaultValue: 'User' }) : 'User') %></div>
      </div>
      <a href="/logout" class="sb-logout-btn" title="Logout"><i class="fa fa-sign-out"></i></a>
    </div>
    <div class="sb-user-email"><%= locals.user.email || '' %></div>
  </div>

</aside>

<% if (useOdooShell) { %>
<div class="hms-odoo-app" id="hmsOdooApp">
<%- include('hms-odoo-nav') %>
<% } %>
<!-- Main -->
<div class="main-wrapper" id="mainWrapper">
<% if (useOdooShell) { %><main class="o_action_manager"><% } %>
  <div class="hms-topbar">
    <div class="topbar-title" id="topbarPageTitle"><%= _hmsTopTitle %></div>
    <div class="topbar-right">
      <a href="<%= locals.navHomeUrl || '/dashboard' %>" class="topbar-home-btn" id="topbarHomeBtn">
        <i class="fa fa-home"></i> <%= locals.navHomeLabel || (typeof t === 'function' ? t('home', { ns: 'nav', defaultValue: 'Home' }) : 'Home') %>
      </a>
      <%- include('hms-lang-switcher') %>
      <div class="dropdown">
        <a href="#" class="dropdown-toggle" data-toggle="dropdown" id="topbarUserDrop" style="display:flex;align-items:center;gap:8px;text-decoration:none;">
          <%- include('hms-user-avatar', { avatarClass: 'hms-user-avatar hms-user-avatar--md', userProfileEmoji: locals.userProfileEmoji }) %>
          <span id="topbarUser" class="topbar-user-name"><%= _hmsNavName %></span>
        </a>
        <div class="dropdown-menu dropdown-menu-right shadow-sm border-0 mt-1" style="border-radius:10px;min-width:180px;">
          <div class="px-3 py-2 border-bottom">
            <div class="d-flex align-items-center" style="gap:8px;">
              <%- include('hms-user-avatar', { avatarClass: 'hms-user-avatar hms-user-avatar--md', userProfileEmoji: locals.userProfileEmoji }) %>
              <div>
                <div class="font-weight-bold small" style="color:#1e293b;"><%= _hmsShortName %></div>
                <div class="small text-muted"><%=locals.user.username||''%></div>
              </div>
            </div>
          </div>
          <a class="dropdown-item py-2" href="/profile"><i class="fa fa-user-circle mr-2 text-primary"></i><%= typeof t === 'function' ? t('my_profile', { ns: 'nav', defaultValue: 'My Profile' }) : 'My Profile' %></a>
          <a class="dropdown-item py-2" href="/my-profile"><i class="fa fa-cog mr-2 text-muted"></i><%= typeof t === 'function' ? t('account_settings', { ns: 'nav', defaultValue: 'Account Settings' }) : 'Account Settings' %></a>
          <% if (!isAdminOrSuper && (!sbHidden('sb.guides') || !sbHidden('sb.manual'))) { %>
          <div class="dropdown-divider"></div>
          <div class="px-3 py-1 small text-muted text-uppercase" style="font-size:.65rem;font-weight:700;letter-spacing:.06em;"><%= typeof t === 'function' ? t('help', { ns: 'nav', defaultValue: 'Help' }) : 'Help' %></div>
          <% if (!sbHidden('sb.guides')) { %>
          <a class="dropdown-item py-2" href="/workflow-guides"><i class="fa fa-sitemap mr-2" style="color:#f59e0b;"></i><%= typeof t === 'function' ? t('workflow_guides', { ns: 'nav', defaultValue: 'Workflow Guides' }) : 'Workflow Guides' %></a>
          <% } %>
          <% if (!sbHidden('sb.manual')) { %>
          <a class="dropdown-item py-2" href="/user-manual"><i class="fa fa-book mr-2 text-primary"></i><%= typeof t === 'function' ? t('user_manual', { ns: 'nav', defaultValue: 'User Manual' }) : 'User Manual' %></a>
          <% } %>
          <% } %>
          <div class="dropdown-divider"></div>
          <a class="dropdown-item py-2 text-danger" href="/logout"><i class="fa fa-sign-out mr-2"></i><%= typeof t === 'function' ? t('logout', { ns: 'nav', defaultValue: 'Logout' }) : 'Logout' %></a>

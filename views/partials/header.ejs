<% if (locals.user && locals.showPageNav !== false && !useOdooShell) { %>
  <%- include('page-nav-data', { pageNav: locals.pageNav || {} }) %>
  <div class="hms-page-nav-bar">
    <%- include('page-nav-react', { pageNav: locals.pageNav || {} }) %>
  </div>
<% } %>

<script>
(function(){
  // Define HMS first so page scripts (e.g. Patient Directory) always have alerts even if later UI init throws.
  window.HMS = {
    toast: Swal.mixin({
      toast: true,
      position: 'top-end',
      showConfirmButton: false,
      timer: 3000,
      timerProgressBar: true
    }),
    confirm: function(title, text, icon, btnText, color) {
      var isDark = document.documentElement.classList.contains('dark');
      return Swal.fire({
        title: title || 'Are you sure?',
        text: text || '',
        icon: icon || 'warning',
        showCancelButton: true,
        confirmButtonColor: color || '#15803d',
        cancelButtonColor: '#6c757d',
        confirmButtonText: btnText || 'Yes, proceed',
        background: isDark ? '#0f172a' : '#fff',
        color: isDark ? '#f8fafc' : '#1e293b'
      });
    },
    alert: function(title, text, icon) {
      var isDark = document.documentElement.classList.contains('dark');
      return Swal.fire({
        title: title || 'Information',
        text: text || '',
        icon: icon || 'info',
        confirmButtonColor: '#1a6bd8',
        background: isDark ? '#0f172a' : '#fff',
        color: isDark ? '#f8fafc' : '#1e293b'
      });
    },
    /**
     * Animated replacement for window.prompt().
     * Usage:
     *   HMS.prompt({ title, text, placeholder, defaultValue, inputType, required, icon, confirmText })
     *     .then(function(r){ if(r.isConfirmed) ... r.value ... });
     */
    prompt: function(opts) {
      opts = opts || {};
      var isDark = document.documentElement.classList.contains('dark');
      return Swal.fire({
        title: opts.title || 'Enter value',
        text: opts.text || '',
        input: opts.inputType || 'text',
        inputPlaceholder: opts.placeholder || '',
        inputValue: opts.defaultValue || '',
        icon: opts.icon || 'question',
        showCancelButton: true,
        confirmButtonText: opts.confirmText || 'OK',
        cancelButtonText: opts.cancelText || 'Cancel',
        confirmButtonColor: opts.color || '#15803d',
        cancelButtonColor: '#6c757d',
        background: isDark ? '#0f172a' : '#fff',
        color: isDark ? '#f8fafc' : '#1e293b',
        inputValidator: opts.required
          ? function(v){ return (!v || !String(v).trim()) ? (opts.requiredMsg || 'Required') : null; }
          : undefined
      });
    },
    /**
     * Drop-in animated replacement for `onsubmit="return confirm(...)"` on forms.
     * Usage:
     *   <form onsubmit="return HMS.confirmForm(this, 'Title', 'Body', 'Yes', '#dc2626', 'warning')">
     */
    confirmForm: function(form, title, text, btnText, color, icon) {
      if (!form || form.__hmsConfirmed) return true;
      this.confirm(title, text, icon || 'warning', btnText || 'Yes', color || '#dc2626')
        .then(function(r){ if (r.isConfirmed) { form.__hmsConfirmed = true; form.submit(); } });
      return false;
    },
    /**
     * Drop-in animated replacement for `onclick="return confirm(...)"` on links
     * or anchor-style submit buttons. Falls back to navigating href if confirmed.
     * Usage:
     *   <a onclick="return HMS.confirmHref(this, 'Title', 'Body')">?</a>
     */
    confirmHref: function(el, title, text, btnText, color, icon) {
      if (!el || el.__hmsConfirmed) return true;
      var href = el.getAttribute('href');
      this.confirm(title, text, icon || 'warning', btnText || 'Yes', color || '#dc2626')
        .then(function(r){ if (r.isConfirmed && href) { el.__hmsConfirmed = true; window.location.href = href; } });
      return false;
    }
  };

  var html  = document.getElementById('hmsHtml');
  var tog   = document.getElementById('themeToggle');
  if (html && tog) {
    var saved = localStorage.getItem('hmsTheme') || 'light';
    if(saved === 'dark'){ html.classList.add('dark'); tog.checked = true; }
    tog.addEventListener('change', function(){
      if(this.checked){ html.classList.add('dark'); localStorage.setItem('hmsTheme','dark'); }
      else            { html.classList.remove('dark'); localStorage.setItem('hmsTheme','light'); }
    });
  }

  // Submenu toggle
  document.querySelectorAll('.sb-item[data-sub]').forEach(function(el){
    el.addEventListener('click', function(){
      var id  = this.getAttribute('data-sub');
      var sub = document.getElementById(id);
      if (!sub) return;
      var was = sub.classList.contains('open');
      document.querySelectorAll('.sb-sub-wrap').forEach(function(s){s.classList.remove('open');});
      document.querySelectorAll('.sb-item[data-sub]').forEach(function(e){e.classList.remove('open');});
      if(!was){ sub.classList.add('open'); this.classList.add('open'); }
    });
  });

  // Active state
  var path = window.location.pathname;
  document.querySelectorAll('.sb-item[href], .sb-sub-item').forEach(function(a){
    var href = a.getAttribute('href');
    if(href && href!=='/' && (path===href || path.startsWith(href+'/'))){
      a.classList.add('active');
      var wrap = a.closest('.sb-sub-wrap');
      if(wrap){
        wrap.classList.add('open');
        var par = document.querySelector('[data-sub="'+wrap.id+'"]');
        if(par) par.classList.add('open');
      }
    }
  });

  // Search filter
  var sbSearchEl = document.getElementById('sbSearch');
  if (sbSearchEl) {
    function hmsFilterSidebarNav(q) {
      q = String(q || '').toLowerCase().trim();
      document.querySelectorAll('.sb-item[href]').forEach(function(a) {
        var txt = (a.getAttribute('data-label') || a.textContent || '').toLowerCase();
        a.style.display = (!q || txt.indexOf(q) !== -1) ? '' : 'none';
      });
      document.querySelectorAll('.sb-section').forEach(function(sec) {
        var el = sec.nextElementSibling;
        var anyVisible = false;
        while (el && !el.classList.contains('sb-section')) {
          if (el.classList && el.classList.contains('sb-item') && el.style.display !== 'none') {
            anyVisible = true;
            break;
          }
          el = el.nextElementSibling;
        }
        sec.style.display = (!q || anyVisible) ? '' : 'none';
      });
      if (!q) {
        document.querySelectorAll('.sb-section,.sb-item[href]').forEach(function(e) { e.style.display = ''; });
      }
    }
    sbSearchEl.addEventListener('input', function() { hmsFilterSidebarNav(this.value); });
    sbSearchEl.addEventListener('keydown', function(ev) {
      if (ev.key === 'Escape') { this.value = ''; hmsFilterSidebarNav(''); this.blur(); }
    });
  }

  <% if(locals.flash){ %> HMS.toast.fire({ icon: 'success', title: <%- JSON.stringify(String(locals.flash)) %> }); <% } %>
  <% if(locals.error){ %> HMS.toast.fire({ icon: 'error', title: <%- JSON.stringify(String(locals.error)) %> }); <% } %>
})();
</script>

<% } %>

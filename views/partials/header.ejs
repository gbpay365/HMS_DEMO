<style>
*{box-sizing:border-box;margin:0;padding:0;}
body,html{font-family:system-ui,-apple-system,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;height:100%;}

/* ?? THEME VARIABLES ?? */
:root{
  --sb-bg:#ffffff;--sb-border:#e5e7eb;--sb-text:#374151;--sb-muted:#6b7280;
  --sb-label:#374151;--sb-hover-bg:#f3f4f6;
  --sb-section-line:#d1d5db;
  --sb-search-bg:#f3f4f6;--sb-search-border:#e5e7eb;
  --main-bg:#f9fafb;--topbar-bg:rgba(249,250,251,.92);--topbar-border:#e5e7eb;
  --hms-content-max:min(1720px, calc(100vw - var(--sb-width) - 24px));
}
html.dark{
  --main-bg:var(--hms-bg);
}

/* ?? SIDEBAR ?? */
#hms-sidebar{
  position:fixed;top:0;left:0;width:var(--sb-width);height:100vh;
  background:var(--sb-bg);border-right:1px solid var(--sb-border);
  display:flex;flex-direction:column;z-index:1050;
  transition:background .3s,border-color .3s;
}

/* Logo */
.sb-logo{display:flex;align-items:center;gap:10px;padding:14px 14px 12px;}
.sb-logo-mark{
  width:46px;height:46px;border-radius:50%;flex-shrink:0;
  background:#fff;display:flex;align-items:center;justify-content:center;
  overflow:hidden;border:1px solid var(--sb-border);
  box-shadow:0 1px 4px rgba(0,0,0,.08);
}
.sb-logo-mark img{width:100%;height:100%;object-fit:cover;display:block;}
html.dark .sb-logo-mark{background:#fff;border-color:#1e293b;}
.sb-logo-info{min-width:0;}
.sb-logo-name{font-weight:800;font-size:1.02rem;color:var(--sb-text);line-height:1.15;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-logo-sub{font-size:.7rem;color:var(--sb-muted);font-weight:600;letter-spacing:.04em;text-transform:uppercase;margin-top:1px;}
.sb-logo-status{display:flex;align-items:center;gap:5px;font-size:.74rem;color:var(--sb-muted);margin-top:2px;}
.sb-logo-dot{width:7px;height:7px;border-radius:50%;background:#22c55e;display:inline-block;}

/* Search */
.sb-search{padding:6px 12px 10px;}
.sb-search input{
  width:100%;padding:8px 10px 8px 32px;border-radius:8px;
  border:1px solid var(--sb-search-border);background:var(--sb-search-bg);
  color:var(--sb-text);font-size:.9rem;font-family:'Inter',sans-serif;
  outline:none;transition:border-color .2s;
}
.sb-search input::placeholder{color:var(--sb-muted);}
.sb-search{position:relative;}
.sb-search-icon{position:absolute;left:22px;top:50%;transform:translateY(-55%);color:var(--sb-muted);font-size:.82rem;}

/* Theme toggle row */
.sb-theme-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:6px 14px 10px;border-bottom:1px solid var(--sb-border);
}
.sb-theme-label{display:flex;align-items:center;gap:7px;font-size:.9rem;font-weight:500;color:var(--sb-muted);}
.toggle-sw{position:relative;display:inline-block;width:38px;height:21px;}
.toggle-sw input{opacity:0;width:0;height:0;}
.toggle-knob{
  position:absolute;inset:0;border-radius:21px;background:#d1d5db;cursor:pointer;
  transition:background .3s;
}
.toggle-knob::before{
  content:'';position:absolute;width:15px;height:15px;border-radius:50%;
  background:#fff;top:3px;left:3px;transition:transform .3s;
  box-shadow:0 1px 3px rgba(0,0,0,.2);
}
.toggle-sw input:checked + .toggle-knob{background:#16a34a;}
.toggle-sw input:checked + .toggle-knob::before{transform:translateX(17px);}

/* Nav scroll area */
.sb-nav{flex:1;overflow-y:auto;overflow-x:hidden;padding:6px 0 10px;}
.sb-nav::-webkit-scrollbar{width:3px;}
.sb-nav::-webkit-scrollbar-thumb{background:var(--sb-border);border-radius:2px;}

/* Section label */
.sb-section{
  display:flex;align-items:center;gap:8px;
  padding:14px 14px 5px;font-size:.73rem;font-weight:700;
  color:var(--sb-label);text-transform:uppercase;letter-spacing:.08em;
}
.sb-section::after{content:'';flex:1;height:1px;background:var(--sb-section-line);}

/* Nav item */
.sb-item{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px 10px 14px;margin:1px 8px;border-radius:9px;
  color:var(--sb-text);font-size:.93rem;font-weight:500;
  text-decoration:none;cursor:pointer;
  transition:background .18s,color .18s;
  position:relative;
}
.sb-item:hover{background:var(--sb-hover-bg);text-decoration:none;color:var(--sb-text);}
.sb-item.active{
  background:var(--sb-active-bg);color:var(--sb-active-text);font-weight:700;
}
.sb-item.active::before{
  content:'';position:absolute;left:-8px;top:15%;bottom:15%;
  width:3px;border-radius:0 3px 3px 0;background:var(--sb-active-border);
}
.sb-item-icon{font-size:.95rem;width:22px;text-align:center;flex-shrink:0;}
.sb-item.active .sb-item-icon{color:var(--sb-active-text);}
.sb-item-label{flex:1;}
.sb-badge{
  display:inline-flex;align-items:center;justify-content:center;
  min-width:22px;height:22px;border-radius:11px;padding:0 7px;
  font-size:.74rem;font-weight:700;background:var(--badge-bg);color:var(--badge-text);
}
.sb-badge.gray{background:#e5e7eb;color:#374151;}
html.dark .sb-badge.gray{background:#334155;color:#cbd5e1;}

/* Emergency badge */
.sb-item.emg{color:#dc2626 !important;}
.sb-item.emg .sb-item-icon{color:#dc2626;}
.sb-emg-dot{
  width:7px;height:7px;border-radius:50%;background:#ef4444;
  flex-shrink:0;animation:emgBlink 1.5s infinite;
}
@keyframes emgBlink{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.5);}70%{box-shadow:0 0 0 5px rgba(239,68,68,0);}}

/* Submenu */
.sb-sub-wrap{overflow:hidden;max-height:0;transition:max-height .3s ease;}
.sb-sub-wrap.open{max-height:500px;}
.sb-sub-item{
  display:flex;align-items:center;gap:9px;
  padding:8px 12px 8px 44px;margin:1px 8px;border-radius:8px;
  color:var(--sb-muted);font-size:.89rem;font-weight:500;
  text-decoration:none;transition:background .15s,color .15s;
}
.sb-sub-item:hover{background:var(--sb-hover-bg);color:var(--sb-text);text-decoration:none;}
.sb-sub-item.active{color:var(--sb-active-text);font-weight:600;}
.sb-chevron{
  margin-left:auto;font-size:.68rem;color:var(--sb-muted);
  transition:transform .3s;flex-shrink:0;
}
.sb-item.open .sb-chevron{transform:rotate(90deg);}

/* User card at bottom */
.sb-user-card{
  margin:8px 8px 8px;padding:10px 10px;border-radius:12px;
  background:var(--sb-user-bg);border:1px solid var(--sb-border);
  display:flex;flex-direction:column;gap:2px;
  transition:background .3s;
}
.sb-user-top{display:flex;align-items:center;gap:9px;}
.sb-avatar{
  width:72px;height:72px;border-radius:14px;flex-shrink:0;
  background:transparent;display:flex;align-items:center;
  justify-content:center;position:relative;padding:0;
}
.hms-user-avatar{
  display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;
  overflow:hidden;
  border-radius:10px;background:linear-gradient(145deg,#f0fdf4,#ecfdf5);
  border:2px solid #e2e8f0;font-size:1.15rem;line-height:1;
  box-shadow:0 1px 4px rgba(15,23,42,.08);
}
.hms-user-avatar--sm{width:44px;height:44px;font-size:1.25rem;border-radius:10px;}
.hms-user-avatar--md{width:52px;height:52px;font-size:1.5rem;}
.hms-user-avatar--lg{width:72px;height:72px;font-size:2rem;border-radius:16px;}
.sb-avatar-dot{
  position:absolute;bottom:-2px;right:-2px;width:9px;height:9px;
  border-radius:50%;background:#22c55e;border:2px solid var(--sb-bg);
}
.sb-user-meta{flex:1;overflow:hidden;}
.sb-user-name{font-weight:700;font-size:.9rem;color:var(--sb-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-user-role{font-size:.76rem;color:var(--sb-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-logout-btn{
  width:30px;height:30px;border-radius:7px;border:none;
  background:rgba(0,0,0,.05);color:var(--sb-muted);
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  font-size:.88rem;transition:background .2s,color .2s;flex-shrink:0;
  text-decoration:none;
}
html.dark .sb-logout-btn{background:rgba(255,255,255,.06);}
.sb-logout-btn:hover{background:#fee2e2;color:#dc2626;}
.sb-user-email{font-size:.74rem;color:var(--sb-muted);padding-left:2px;word-break:break-all;}

/* Main area */
.main-wrapper{margin-left:var(--sb-width);min-height:100vh;background:var(--main-bg);transition:background .3s,margin .3s;}
.hms-topbar{
  position:sticky;top:0;z-index:900;background:var(--topbar-bg);
  border-bottom:1px solid var(--topbar-border);
  padding:10px 24px;display:flex;align-items:center;justify-content:space-between;
  backdrop-filter:blur(10px);
}
.topbar-title{font-weight:700;font-size:.9rem;color:var(--sb-text);}
.topbar-right{display:flex;align-items:center;gap:8px;margin-right:4px;}
.topbar-home-btn{display:inline-flex;align-items:center;gap:6px;text-decoration:none;padding:5px 13px;border-radius:20px;background:linear-gradient(135deg,#0f172a,#1e293b);color:#fff;font-size:.73rem;font-weight:700;border:1px solid rgba(15,23,42,.2);transition:opacity .2s,transform .15s;white-space:nowrap;}
.topbar-home-btn:hover{color:#fff;opacity:.92;text-decoration:none;transform:translateY(-1px);}
.topbar-user-name{font-size:.78rem;font-weight:600;color:var(--sb-text);white-space:nowrap;max-width:min(220px,28vw);}
.hms-page-nav-bar{width:100%;padding:12px 16px 0;display:flex;justify-content:flex-start;}
/* Default page shell padding (symmetric); main column centering scoped below */
.page-wrapper{padding:22px 8px;box-sizing:border-box;}
/*
 * App shell: cancel legacy style.css .page-wrapper { margin-left:230px } (sidebar offset is on .main-wrapper).
 * Center content like Patient Directory: max-width column + auto margins + tight horizontal padding.
 */
.main-wrapper .page-wrapper{
  max-width:var(--hms-content-max);
  width:100%;
  margin-left:auto !important;
  margin-right:auto !important;
}
body.hms-body--odoo .main-wrapper .page-wrapper{
  max-width:none !important;
  width:100% !important;
  margin-left:0 !important;
  margin-right:0 !important;
}
.main-wrapper .page-wrapper > .content{
  width:100%;
  max-width:100%;
  padding-top:30px !important;
  padding-bottom:30px !important;
  padding-left:12px !important;
  padding-right:12px !important;
}
/* Uniform full-width cards on each page (siblings share the same column width) */
.main-wrapper .page-wrapper > .content > .card,
.main-wrapper .page-wrapper > .content > form > .card{
  width:100%;
  max-width:100%;
}
.main-wrapper .page-wrapper > .content > .row{
  width:100%;
  margin-left:0;
  margin-right:0;
}
.main-wrapper .page-wrapper > .content > .row > [class*="col-"] > .card{
  width:100%;
  max-width:100%;
}
/* Wide data tables: natural column width + horizontal scroll when needed */
.main-wrapper .card .table-responsive{
  overflow-x:auto;
  -webkit-overflow-scrolling:touch;
  width:100%;
}
.main-wrapper .card .table-responsive > .table{
  width:100%;
}
.main-wrapper .card.hms-data-table-card .table-responsive > .table{
  width:max-content;
  min-width:100%;
}
body{background:var(--main-bg);}

/* ?? Scrollbars (wider vertical bar for readability) ?? */
html{
  scrollbar-gutter:stable;
}
/* Firefox ? avoid ?thin? overlay feel */
*{scrollbar-width:auto;scrollbar-color:#a8b0bf #eef0f5;}
html.dark *,html.dark{
  scrollbar-color:#475569 #1e293b;
}
/* Chromium / Edge / Safari */
::-webkit-scrollbar{width:14px;height:14px;}
::-webkit-scrollbar-track{background:#eef0f5;border-radius:8px;}
::-webkit-scrollbar-thumb{
  background:#a8b0bf;border-radius:8px;border:3px solid #eef0f5;
}
::-webkit-scrollbar-thumb:hover{background:#8b929e;}
html.dark ::-webkit-scrollbar-track{background:#1e293b;}
html.dark ::-webkit-scrollbar-thumb{
  background:#475569;border-color:#1e293b;
}
html.dark ::-webkit-scrollbar-thumb:hover{background:#64748b;}
</style>

<%
if (typeof _t !== 'function') {
  var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
}
var _top = function (key, fallback, opts) {
  return _t(key, Object.assign({ ns: 'ops', defaultValue: fallback }, opts || {}));
};
var _page = locals.cashierPage || 'nurse-roster';
var _pending = parseInt(locals.pendingCount, 10) || 0;
var _billing = parseInt(locals.billingPendingCount, 10) || 0;
var _insurance = parseInt(locals.insurancePendingCount, 10) || 0;
function _tabActive(id) { return _page === id ? ' active' : ''; }
%>
<div class="cs-tabs" role="tablist">
  <a href="/cashier?page=dashboard" class="cs-tab<%= _tabActive('dashboard') %>" role="tab">
    <i class="fa fa-th-large"></i> <%= _top('cashier_odoo.tab_overview', 'Overview') %>
  </a>
  <a href="/cashier?page=pos" class="cs-tab<%= _tabActive('pos') %>" role="tab">
    <i class="fa fa-credit-card"></i> <%= _top('cashier_odoo.point_of_sale', 'Point of Sale') %>
  </a>
  <a href="/cashier?page=bills" class="cs-tab<%= _tabActive('bills') %>" role="tab">
    <i class="fa fa-file-text-o"></i> <%= _top('cashier_odoo.patient_bills', 'Patient bills') %>
    <% if (_pending > 0) { %>
    <span class="cs-tab-chip" style="background:var(--cs-pending-bg);color:var(--cs-pending-text);"><%= _pending %> <%= _top('cashier_odoo.pending_short', 'pending') %></span>
    <% } %>
  </a>
  <a href="/cashier?page=invoices" class="cs-tab<%= _tabActive('invoices') %>" role="tab">
    <i class="fa fa-file-text"></i> <%= _top('cashier_odoo.invoices', 'Invoices') %>
    <% if (_billing > 0) { %>
    <span class="cs-tab-chip" style="background:#EDE9FE;color:#5B21B6;"><%= _billing %> <%= _top('cashier_odoo.invoices_short', 'open') %></span>
    <% } %>
  </a>
  <a href="/cashier?page=insurance" class="cs-tab<%= _tabActive('insurance') %>" role="tab">
    <i class="fa fa-shield"></i> <%= _top('cashier_odoo.insurance', 'Insurance claims') %>
    <% if (_insurance > 0) { %>
    <span class="cs-tab-chip" style="background:var(--cs-partial-bg);color:var(--cs-partial-text);"><%= _insurance %> <%= _top('cashier_odoo.insurance_short', 'claims') %></span>
    <% } %>
  </a>
  <a href="/cashier?page=shift" class="cs-tab<%= _tabActive('shift') %>" role="tab">
    <i class="fa fa-clock-o"></i> <%= _top('cashier_odoo.shift_summary', 'Shift summary') %>
  </a>
  <a href="/cashier?page=refunds" class="cs-tab<%= _tabActive('refunds') %>" role="tab">
    <i class="fa fa-undo"></i> <%= _top('cashier_odoo.refunds', 'Refunds') %>
  </a>
  <a href="/cashier?page=reports" class="cs-tab<%= _tabActive('reports') %>" role="tab">
    <i class="fa fa-line-chart"></i> <%= _top('cashier_odoo.tab_reports', 'Reports') %>
  </a>
</div>

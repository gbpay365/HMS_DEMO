<% 
if (typeof _t !== 'function') {
  var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
}
var _tc = function (key, fallback, opts) {
  return _t(key, Object.assign({ ns: 'clinical', defaultValue: fallback }, opts || {}));
};
  var _cdaDept = (typeof clinicalDeptStripDept !== 'undefined' && clinicalDeptStripDept) ? clinicalDeptStripDept : 'laboratory';
  var _cdaHue = _cdaDept === 'radiology' ? '#0369a1' : (_cdaDept === 'pharmacy' ? '#059669' : '#6d28d9');
  var _cdaI18n = {
    kindImaging: _tc('cda_strip.kind_imaging', 'imaging'),
    kindMedication: _tc('cda_strip.kind_medication', 'medication'),
    kindLab: _tc('cda_strip.kind_lab', 'lab'),
    kindOrder: _tc('cda_strip.kind_order', 'order'),
    ctxEmergency: _tc('labWorkflow.ctx_emergency', 'Emergency'),
    ctxInpatient: _tc('labWorkflow.ctx_inpatient', 'Inpatient'),
    ctxOutpatient: _tc('labWorkflow.ctx_outpatient', 'Outpatient'),
    ctxClinical: _tc('labWorkflow.ctx_clinical', 'Clinical'),
    aeAlert: _tc('cda_strip.ae_alert', 'A&E ALERT'),
    stat: _tc('cda_strip.stat', 'STAT'),
    emergencyNewOrder: _tc('cda_strip.emergency_new_order', 'EMERGENCY · NEW {{kind}} ORDER'),
    prescribedBy: _tc('cda_strip.prescribed_by', 'Prescribed by:'),
    patient: _tc('labWorkflow.patient', 'Patient'),
    ward: _tc('cda_strip.ward', 'Ward:'),
    bed: _tc('cda_strip.bed', 'Bed:'),
    openInbox: _tc('cda_strip.open_inbox', 'Open inbox'),
    dismiss: _tc('cda_strip.dismiss', 'Dismiss for me'),
    newOrder: _tc('cda_strip.new_order', 'New {{kind}} order · {{ctx}}'),
    testDefault: _tc('labWorkflow.test_default', 'Test')
  };
%>
<div id="cdaStripRoot" data-cda-dept="<%= _cdaDept %>" style="display:none;"></div>
<div id="cdaStripMount" class="cda-strip-mount"></div>
<style>
@keyframes cdaPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.45); transform: scale(1); }
  50% { box-shadow: 0 0 0 10px rgba(255, 255, 255, 0); transform: scale(1.002); }
}
@keyframes cdaShine {
  0% { background-position: 0% 50%; }
  100% { background-position: 200% 50%; }
}
.cda-strip-mount { margin-bottom: 0; position: relative; z-index: 1; }
.cda-banner {
  border-radius: 12px;
  margin-bottom: 14px;
  overflow: hidden;
  color: #fff;
  background: linear-gradient(110deg, <%= _cdaHue %>, #0f172a 45%, <%= _cdaHue %> 90%);
  background-size: 200% 100%;
  animation: cdaShine 4s linear infinite;
  border: 2px solid rgba(255,255,255,.35);
  box-shadow: 0 8px 28px rgba(15, 23, 42, 0.35);
}
.cda-banner-inner {
  padding: 12px 16px;
  animation: cdaPulse 2.2s ease-in-out infinite;
}
.cda-banner h6 {
  margin: 0 0 6px 0;
  font-weight: 800;
  letter-spacing: .04em;
  text-transform: uppercase;
  font-size: .72rem;
  opacity: .95;
}
.cda-line { font-size: .95rem; font-weight: 700; line-height: 1.45; }
.cda-line small { font-weight: 600; opacity: .88; display: block; margin-top: 4px; font-size: .82rem; }
.cda-actions { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.cda-actions a, .cda-actions button {
  font-size: .75rem;
  font-weight: 700;
  border-radius: 999px;
  padding: 4px 12px;
  border: 1px solid rgba(255,255,255,.5);
  background: rgba(255,255,255,.12);
  color: #fff;
  cursor: pointer;
}
.cda-actions a:hover, .cda-actions button:hover { background: rgba(255,255,255,.22); color: #fff; text-decoration: none; }

/* ── A&E / Emergency only: must dominate the page ─────────────────────── */
@keyframes cdaErGlow {
  0%, 100% {
    box-shadow:
      0 0 0 3px rgba(220, 160, 160, 0.9),
      0 0 26px 8px rgba(100, 0, 0, 0.55),
      0 14px 40px rgba(20, 0, 0, 0.65);
    filter: brightness(1);
  }
  50% {
    box-shadow:
      0 0 0 5px rgba(255, 200, 200, 0.85),
      0 0 38px 14px rgba(139, 0, 0, 0.5),
      0 18px 52px rgba(45, 0, 0, 0.75);
    filter: brightness(1.06);
  }
}
@keyframes cdaErShake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-3px); }
  40% { transform: translateX(3px); }
  60% { transform: translateX(-2px); }
  80% { transform: translateX(2px); }
}
@keyframes cdaErIconBlink {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.65; transform: scale(1.15); }
}
.cda-banner--emergency {
  border-radius: 14px;
  margin-bottom: 16px;
  overflow: visible;
  color: #fff;
  /* Blood red: crimson → dark maroon → near-black wine */
  background: linear-gradient(
    165deg,
    #9f0712 0%,
    #7f0000 28%,
    #5a0404 58%,
    #2a0202 100%
  ) !important;
  background-size: 100% 100% !important;
  animation: cdaErGlow 1.1s ease-in-out infinite !important;
  border: 4px solid rgba(255, 200, 200, 0.92) !important;
  outline: 3px solid rgba(75, 0, 0, 0.95);
  outline-offset: 2px;
}
.cda-banner--emergency .cda-banner-inner--emergency {
  padding: 14px 18px 16px;
  animation: cdaErShake 2.5s ease-in-out infinite;
}
.cda-er-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  margin-bottom: 10px;
}
.cda-er-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 999px;
  background: rgba(15, 0, 0, 0.45);
  border: 2px solid rgba(255, 190, 190, 0.88);
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.65);
  animation: cdaErIconBlink 1.4s ease-in-out infinite;
}
.cda-er-badge .fa { animation: cdaErIconBlink 0.9s ease-in-out infinite; }
.cda-er-badge:nth-child(2) { animation-delay: 0.35s; }
.cda-er-headline {
  margin: 0 0 8px 0;
  font-weight: 900;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  font-size: 0.82rem;
  color: #ffe4e4;
  text-shadow: 0 2px 6px rgba(0, 0, 0, 0.65), 0 0 12px rgba(180, 40, 40, 0.45);
}
.cda-er-headline .fa { margin-right: 8px; font-size: 1.05em; vertical-align: middle; }
.cda-er-testname {
  font-size: 1.35rem;
  font-weight: 900;
  line-height: 1.25;
  letter-spacing: 0.02em;
  color: #fff5f5;
  text-shadow: 0 3px 10px rgba(0, 0, 0, 0.65), 0 0 2px rgba(0, 0, 0, 0.8);
  margin-bottom: 8px;
}
.cda-er-meta {
  display: block;
  font-weight: 700;
  font-size: 0.84rem !important;
  line-height: 1.5;
  opacity: 1 !important;
  color: rgba(255, 255, 255, 0.98) !important;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
}
.cda-banner--emergency .cda-actions a,
.cda-banner--emergency .cda-actions button {
  font-weight: 900;
  border-width: 2px;
  background: rgba(20, 0, 0, 0.4);
  border-color: rgba(255, 210, 210, 0.95);
  color: #fff5f5;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
}
.cda-banner--emergency .cda-actions a:hover,
.cda-banner--emergency .cda-actions button:hover {
  background: #ffdede !important;
  color: #3b0000 !important;
  border-color: #ffdede !important;
}
@media (prefers-reduced-motion: reduce) {
  .cda-banner--emergency,
  .cda-banner--emergency .cda-banner-inner--emergency,
  .cda-er-badge,
  .cda-er-badge .fa {
    animation: none !important;
  }
}
</style>
<script type="application/json" id="cdaStripI18n"><%- JSON.stringify(_cdaI18n).replace(/</g, '\\u003c') %></script>
<script>
(function () {
  var root = document.getElementById('cdaStripRoot');
  var mount = document.getElementById('cdaStripMount');
  if (!root || !mount) return;
  var i18n = {};
  try {
    var i18nEl = document.getElementById('cdaStripI18n');
    if (i18nEl) i18n = JSON.parse(i18nEl.textContent || '{}');
  } catch (e) { i18n = {}; }
  function tr(key, fallback) { return (i18n && i18n[key] != null) ? i18n[key] : fallback; }
  function trFmt(key, fallback, vars) {
    var s = tr(key, fallback);
    if (vars) Object.keys(vars).forEach(function (k) { s = s.split('{{' + k + '}}').join(vars[k]); });
    return s;
  }
  var dept = root.getAttribute('data-cda-dept') || 'laboratory';
  var inboxPath = dept === 'radiology' ? '/radiology/order-alerts' : (dept === 'pharmacy' ? '/pharmacy/order-alerts' : '/laboratory/order-alerts');
  var kindLabel = dept === 'radiology' ? tr('kindImaging', 'imaging') : (dept === 'pharmacy' ? tr('kindMedication', 'medication') : tr('kindLab', 'lab'));
  function esc(s) {
    return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;');
  }
  function render(items) {
    mount.innerHTML = '';
    if (!items || !items.length) { mount.style.display = 'none'; return; }
    mount.style.display = 'block';
    items.forEach(function (a) {
      var el = document.createElement('div');
      var ctx = (a.context || '').toUpperCase();
      var isEr = ctx === 'ER';
      el.className = 'cda-banner mb-2' + (isEr ? ' cda-banner--emergency' : '');
      var locLabel = ctx === 'ER' ? tr('ctxEmergency', 'Emergency') : ctx === 'IPD' ? tr('ctxInpatient', 'Inpatient') : ctx === 'OPD' ? tr('ctxOutpatient', 'Outpatient') : (ctx || tr('ctxClinical', 'Clinical'));
      var kindUpper = String(kindLabel || tr('kindOrder', 'order')).toUpperCase();
      if (isEr) {
        el.innerHTML =
          '<div class="cda-banner-inner cda-banner-inner--emergency">' +
          '<div class="cda-er-bar">' +
          '<span class="cda-er-badge"><i class="fa fa-exclamation-triangle"></i> ' + esc(tr('aeAlert', 'A&E ALERT')) + '</span>' +
          '<span class="cda-er-badge"><i class="fa fa-ambulance"></i> ' + esc(tr('stat', 'STAT')) + '</span>' +
          '<span class="cda-er-badge"><i class="fa fa-bell"></i> ' + esc(locLabel) + '</span>' +
          '</div>' +
          '<h6 class="cda-er-headline"><i class="fa fa-bolt"></i> ' + esc(trFmt('emergencyNewOrder', 'EMERGENCY · NEW {{kind}} ORDER', { kind: kindUpper })) + '</h6>' +
          '<div class="cda-er-testname">' + esc(a.test_display || '—') + '</div>' +
          '<small class="cda-er-meta">' + esc(tr('prescribedBy', 'Prescribed by:')) + ' ' + esc(a.doctor_display || '—') + ' · ' + esc(tr('patient', 'Patient')) + ': ' + esc(a.patient_display || '—') +
          ' · ' + esc(tr('ward', 'Ward:')) + ' ' + esc(a.ward_display || '—') + ' · ' + esc(tr('bed', 'Bed:')) + ' ' + esc(a.bed_display || '—') + '</small>' +
          '<div class="cda-actions">' +
          '<a href="' + inboxPath + '"><i class="fa fa-inbox"></i> ' + esc(tr('openInbox', 'Open inbox')) + '</a>' +
          '<button type="button" class="cda-dismiss" data-id="' + esc(a.id) + '"><i class="fa fa-check"></i> ' + esc(tr('dismiss', 'Dismiss for me')) + '</button>' +
          '</div></div>';
      } else {
        el.innerHTML =
          '<div class="cda-banner-inner">' +
          '<h6><i class="fa fa-bell"></i> ' + esc(trFmt('newOrder', 'New {{kind}} order · {{ctx}}', { kind: kindLabel, ctx: locLabel })) + '</h6>' +
          '<div class="cda-line">' + esc(a.test_display || tr('testDefault', 'Test')) + '</div>' +
          '<small>' + esc(tr('prescribedBy', 'Prescribed by:')) + ' ' + esc(a.doctor_display || '—') + ' · ' + esc(tr('patient', 'Patient')) + ': ' + esc(a.patient_display || '—') +
          ' · ' + esc(tr('ward', 'Ward:')) + ' ' + esc(a.ward_display || '—') + ' · ' + esc(tr('bed', 'Bed:')) + ' ' + esc(a.bed_display || '—') + '</small>' +
          '<div class="cda-actions">' +
          '<a href="' + inboxPath + '">' + esc(tr('openInbox', 'Open inbox')) + '</a>' +
          '<button type="button" class="cda-dismiss" data-id="' + esc(a.id) + '">' + esc(tr('dismiss', 'Dismiss for me')) + '</button>' +
          '</div></div>';
      }
      mount.appendChild(el);
    });
    mount.querySelectorAll('.cda-dismiss').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('data-id');
        fetch('/api/clinical-dept-alerts/' + encodeURIComponent(id) + '/ack', {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded' },
          body: '_format=json',
          credentials: 'same-origin'
        }).then(function () { load(); }).catch(function () { load(); });
      });
    });
  }
  function load() {
    fetch('/api/clinical-dept-alerts?dept=' + encodeURIComponent(dept), { credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (j) { if (j && j.ok && j.items) render(j.items); else render([]); })
      .catch(function () { render([]); });
  }
  load();
  setInterval(load, 60000);
})();
</script>

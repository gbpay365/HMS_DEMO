<%
var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
var _statBands = (typeof hubStatBands !== 'undefined' && Array.isArray(hubStatBands)) ? hubStatBands : [];
var _moduleBands = (typeof hubModuleBands !== 'undefined' && Array.isArray(hubModuleBands)) ? hubModuleBands : [];
var _showOpd = uiVisible('hub.panel.opd_today');
%>
<div class="hms-hub-layout<%= _showOpd ? ' hms-hub-layout--with-opd' : '' %>">
 <div class="hms-hub-layout__main">
  <% if (_statBands.length) { %>
  <section class="hms-stat-section mb-4">
   <% _statBands.forEach(function (band) { %>
   <div class="mb-3">
    <h2 class="hms-hub-section-title"><%= _t(band.i18nKey, { ns: 'legacy', defaultValue: band.fallback }) %></h2>
    <div class="hms-stat-grid--band">
     <% band.items.forEach(function (s) {
       var raw = (stats||{})[s.statKey];
       var val = s.format === 'money' ? Number(raw||0).toLocaleString('fr-FR') : (raw||0);
     %>
     <%- include('hms-stat-link', { href: s.href, label: _t(s.i18nKey, { ns: 'legacy', defaultValue: s.fallback }), value: val, icon: s.icon, color: s.color, compact: true }) %>
     <% }); %>
    </div>
   </div>
   <% }); %>
  </section>
  <% } %>

  <% if (_moduleBands.length) { %>
  <section class="mb-2">
   <% _moduleBands.forEach(function (band) { %>
   <div class="mb-4">
    <h2 class="hms-hub-section-title"><%= _t(band.i18nKey, { ns: 'legacy', defaultValue: band.fallback }) %></h2>
    <div class="hms-hub-module-grid--grouped">
     <% band.items.forEach(function (m) { %>
     <a href="<%=m.href%>" class="hms-surface-card hms-hub-module-tile hms-hub-module-tile--compact" style="--hms-tile-accent: <%= m.color %>;">
      <i class="fa <%=m.icon%> hms-hub-module-tile__ico" aria-hidden="true"></i>
      <strong><%= _t(m.i18nKey, { ns: 'legacy', defaultValue: m.fallback }) %></strong>
     </a>
     <% }); %>
    </div>
   </div>
   <% }); %>
  </section>
  <% } %>
 </div>

 <% if (_showOpd) { %>
 <div class="hms-hub-layout__opd">
  <h2 class="hms-hub-section-title"><%= _t('hub.today_opd', { ns: 'legacy', defaultValue: "Today's OPD" }) %></h2>
  <div class="hms-surface-card">
   <ul class="list-group list-group-flush">
    <% if(!todayVisits || !todayVisits.length){ %><li class="list-group-item small text-muted"><%= _t('hub.no_visits_today', { ns: 'legacy', defaultValue: 'No visits today.' }) %></li><% } %>
    <% (todayVisits || []).forEach(function(v){ %>
    <li class="list-group-item py-2">
     <div class="d-flex justify-content-between align-items-start">
      <div>
       <strong><%=v.first_name%> <%=v.last_name%></strong>
       <div class="small text-muted"><%=v.ticket_number||('#'+v.id)%> · <%= _t('opd.status.' + (v.queue_status || ''), { ns: 'clinical', defaultValue: v.queue_status || '—' }) %></div>
      </div>
      <% if(uiVisible('hub.card.opd_queue')){ %><a href="/opd-queue?q=<%=v.id%>" class="hms-btn hms-btn-secondary hms-btn-sm"><%= _t('hub.open', { ns: 'legacy', defaultValue: 'Open' }) %></a><% } %>
     </div>
    </li>
    <% }); %>
   </ul>
   <% if(uiVisible('hub.card.opd_queue')){ %><div class="card-footer bg-white border-0"><a href="/opd-queue" class="small font-weight-bold"><%= _t('hub.full_opd_queue', { ns: 'legacy', defaultValue: 'Full OPD queue' }) %></a></div><% } %>
  </div>
 </div>
 <% } %>
</div>

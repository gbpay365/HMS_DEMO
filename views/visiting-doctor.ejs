<!DOCTYPE html>
<html lang="<%= locals.lang || 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <% var b = locals.brand || {}; %>
  <title><%= b.loginTitle || 'Visiting Doctor — ZAIZENS' %></title>
  <link rel="icon" type="image/svg+xml" href="<%= b.faviconPath || '/img/zaizens-favicon.svg' %>">
  <link rel="stylesheet" href="/css/hms-fonts-local.css">
  <link rel="stylesheet" href="/css/font-awesome.min.css">
  <link rel="stylesheet" href="/css/hms-notify.css?v=2">
  <link rel="stylesheet" href="/css/hms-tokens.css">
  <link rel="stylesheet" href="/css/login.css?v=21">
  <link rel="stylesheet" href="/css/hms-login-surface.css?v=2">
</head>
<body class="login-page hms-body--login">
  <div id="hms-notify-root"></div>
  <div id="hms-react-root" data-page="visiting-doctor"></div>
  <script id="hms-page-data" type="application/json"><%- JSON.stringify(locals.pageData || {}).replace(/</g, '\\u003c') %></script>
  <% if (locals.hmsUiMissing) { %>
  <div style="max-width:400px;margin:1rem auto;padding:1rem;background:#fef3c7;border-radius:12px;font-family:system-ui,sans-serif;font-size:14px;">
    <strong>UI bundle missing.</strong> Run <code>npm run build:ui</code> from the project root.
  </div>
  <% } %>
  <script src="/dist/hms-login.js?v=24" defer onerror="window.__HMS_UI_LOAD_FAILED=1"></script>
</body>
</html>

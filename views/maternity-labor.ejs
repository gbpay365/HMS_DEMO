<%- include('partials/hms-date-helpers') %>
<%- include('partials/header') %>
<%- include('partials/maternity-odoo-start', {
  matOdooMenu: 'labor',
  matOdooTitle: _tl('maternity_labor.title', 'Labor ward & partograph')
}) %>
<link rel="stylesheet" href="/css/maternity-partograph.css?v=1">
<div class="o_content">

<div class="row">
 <div class="col-lg-3 mb-3">
  <div class="mat-card p-2">
   <div class="mat-card-head"><%= _tl('maternity_labor.active_labors', 'Active labors') %></div>
   <% (active||[]).forEach(function(a){ %>
   <a href="?labor_id=<%= a.id %>" class="d-block p-2 border-bottom small <%= labor && labor.id===a.id ? 'bg-light font-weight-bold':'' %>">
    <%= a.antenatal_number %> — <%= a.first_name %> <%= a.last_name %>
   </a>
   <% }) %>
   <% if (!active || !active.length) { %><p class="small text-muted p-2 mb-0"><%= _tl('maternity_labor.none', 'None') %></p><% } %>
  </div>
 </div>
 <div class="col-lg-9">
  <% if (labor) { %>
  <div class="mat-card p-3 mb-3">
   <h5 class="font-weight-bold"><%= labor.antenatal_number %> — <%= labor.first_name %> <%= labor.last_name %></h5>
   <p class="small mb-0"><%= _tl('maternity_labor.admitted_line', 'Admitted {{date}} · {{type}} · dilation {{dilation}} cm', { date: fmtDate(labor.admission_date), type: labor.admission_type, dilation: labor.cervical_dilation || '—' }) %></p>
   <a href="/maternity/chart/<%= labor.maternity_patient_id %>?tab=delivery" class="hms-btn hms-btn-success hms-btn-sm mt-2"><i class="fa fa-medkit mr-1"></i> <%= _tl('maternity_labor.record_delivery', 'Record delivery') %></a>
  </div>

  <form method="post" action="/maternity/labor/<%= labor.id %>/partograph" class="mat-card p-3 mb-3">
   <h6 class="font-weight-bold"><%= _tl('maternity_labor.partograph_entry', 'WHO partograph entry') %></h6>
   <div class="form-row">
    <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.time', 'Time') %></label><input type="text" name="time_label" class="hms-input w-full" placeholder="<%= _tl('maternity_labor.time_placeholder', 'HHMM') %>"></div>
    <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.dilation', 'Dilation') %></label><input type="number" name="cervical_dilation" class="hms-input w-full" min="0" max="10"></div>
    <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.station', 'Station') %></label><input type="text" name="descent_station" class="hms-input w-full"></div>
    <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.ctx', 'CTX /10min') %></label><input type="number" name="contractions_in_10min" class="hms-input w-full" min="0" max="10"></div>
    <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.fhr', 'FHR') %></label><input type="number" name="fhr" class="hms-input w-full"></div>
    <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.bp', 'BP') %></label><input type="number" name="bp_systolic" class="hms-input w-full mb-1" placeholder="<%= _tl('maternity_labor.bp_sys', 'sys') %>"><input type="number" name="bp_diastolic" class="hms-input w-full" placeholder="<%= _tl('maternity_labor.bp_dia', 'dia') %>"></div>
   </div>
   <button type="button" class="mat-who-advanced-toggle" data-mat-who-advanced-toggle aria-expanded="false">
    <i class="fa fa-chevron-down mr-1"></i> <%= _tl('maternity_labor.advanced_who', 'WHO fields (liquor, moulding, vitals, urine)') %>
   </button>
   <div id="matWhoAdvancedFields" class="mat-who-advanced-fields d-none">
    <div class="form-row">
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.liquor', 'Amniotic fluid') %></label>
      <select name="liquor" class="hms-input w-full">
       <option value=""></option>
       <option value="intact"><%= _tl('maternity_labor.liquor_intact', 'Intact') %></option>
       <option value="clear"><%= _tl('maternity_labor.liquor_clear', 'Clear') %></option>
       <option value="meconium"><%= _tl('maternity_labor.liquor_meconium', 'Meconium') %></option>
       <option value="absent"><%= _tl('maternity_labor.liquor_absent', 'Absent') %></option>
      </select>
     </div>
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.moulding', 'Moulding') %></label>
      <select name="moulding" class="hms-input w-full">
       <option value=""></option>
       <option value="0">0</option><option value="+">+</option><option value="++">++</option><option value="+++">+++</option>
      </select>
     </div>
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.caput', 'Caput') %></label>
      <select name="caput" class="hms-input w-full">
       <option value=""></option>
       <option value="0">0</option><option value="+">+</option><option value="++">++</option><option value="+++">+++</option>
      </select>
     </div>
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.ctx_duration', 'CTX duration (s)') %></label><input type="number" name="contraction_duration" class="hms-input w-full"></div>
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.pulse', 'Pulse') %></label><input type="number" name="pulse" class="hms-input w-full"></div>
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.temperature', 'Temp °C') %></label><input type="number" name="temperature" class="hms-input w-full" step="0.1"></div>
    </div>
    <div class="form-row">
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.oxytocin_units', 'Oxytocin U/L') %></label><input type="number" name="oxytocin_units" class="hms-input w-full"></div>
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.oxytocin_drops', 'Drops/min') %></label><input type="number" name="oxytocin_drops" class="hms-input w-full"></div>
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.urine_volume', 'Urine vol (ml)') %></label><input type="number" name="urine_volume" class="hms-input w-full"></div>
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.urine_protein', 'Protein') %></label><input type="text" name="urine_protein" class="hms-input w-full"></div>
     <div class="form-group col-md-2"><label class="small"><%= _tl('maternity_labor.urine_acetone', 'Acetone') %></label><input type="text" name="urine_acetone" class="hms-input w-full"></div>
     <div class="form-group col-md-4"><label class="small"><%= _tl('maternity_labor.drugs_given', 'Drugs & IV fluids') %></label><input type="text" name="drugs_given" class="hms-input w-full"></div>
    </div>
    <div class="form-row">
     <div class="form-group col-md-12"><label class="small"><%= _tl('maternity_labor.notes', 'Notes') %></label><input type="text" name="notes" class="hms-input w-full"></div>
    </div>
   </div>
   <button class="hms-btn hms-btn-primary hms-btn-sm mt-2"><i class="fa fa-plus mr-1"></i> <%= _tl('maternity_labor.add_entry', 'Add entry') %></button>
  </form>

  <div class="mat-card mat-partograph-panel p-0">
   <div class="mat-card-head mat-partograph-panel__head px-3 pt-3">
    <span><i class="fa fa-line-chart mr-1 text-danger"></i> <%= _tl('maternity_labor.graph_title', 'WHO partograph graph') %></span>
    <div class="btn-group mat-partograph-view-toggle" role="group" aria-label="<%= _tl('maternity_labor.view_toggle', 'Partograph view') %>">
     <button type="button" class="btn btn-sm btn-outline-secondary active" data-mat-partograph-view="graph"><%= _tl('maternity_labor.view_graph', 'Graph') %></button>
     <button type="button" class="btn btn-sm btn-outline-secondary" data-mat-partograph-view="timeline"><%= _tl('maternity_labor.view_timeline', 'Timeline') %></button>
    </div>
   </div>

   <div id="matPartographGraph" class="mat-partograph-graph"></div>

   <div id="matPartographTimeline" class="d-none px-3 pb-3">
    <div class="table-responsive">
     <table class="table table-sm mb-0 mat-who-timeline">
      <thead><tr>
       <th><%= _tl('maternity_labor.th_time', 'Time') %></th>
       <th><%= _tl('maternity_labor.th_dil', 'Dil.') %></th>
       <th><%= _tl('maternity_labor.th_station', 'Station') %></th>
       <th><%= _tl('maternity_labor.th_ctx', 'CTX') %></th>
       <th><%= _tl('maternity_labor.th_fhr', 'FHR') %></th>
       <th><%= _tl('maternity_labor.th_bp', 'BP') %></th>
       <th><%= _tl('maternity_labor.th_liquor', 'Liquor') %></th>
       <th><%= _tl('maternity_labor.th_moulding', 'Moulding') %></th>
       <th><%= _tl('maternity_labor.th_pulse', 'Pulse') %></th>
       <th><%= _tl('maternity_labor.th_temp', 'Temp') %></th>
       <th><%= _tl('maternity_labor.th_urine', 'Urine') %></th>
       <th><%= _tl('maternity_labor.th_drugs', 'Drugs') %></th>
       <th><%= _tl('maternity_labor.th_alert', 'Alert') %></th>
       <th><%= _tl('maternity_labor.th_action', 'Action') %></th>
      </tr></thead>
      <tbody>
      <% if (!partograph || !partograph.length) { %>
      <tr><td colspan="14" class="text-muted text-center py-3"><%= _tl('maternity_labor.timeline_empty', 'No entries yet.') %></td></tr>
      <% } %>
      <% (partograph||[]).forEach(function(e){ %>
      <tr class="<%= e.alert_line_crossed || e.action_line_crossed ? 'partograph-alert':'' %>">
       <td><%= e.time_label || new Date(e.recorded_at).toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}) %></td>
       <td><%= e.cervical_dilation %></td><td><%= e.descent_station %></td><td><%= e.contractions_in_10min %></td>
       <td><%= e.fhr %></td><td><%= e.bp_systolic %>/<%= e.bp_diastolic %></td>
       <td><%= e.liquor || '' %></td>
       <td><%= [e.moulding, e.caput].filter(Boolean).join('/') %></td>
       <td><%= e.pulse != null ? e.pulse : '' %></td>
       <td><%= e.temperature != null ? e.temperature : '' %></td>
       <td><%= [e.urine_volume, e.urine_protein, e.urine_acetone].filter(function(x){ return x != null && x !== ''; }).join(' · ') %></td>
       <td><%= e.drugs_given || '' %></td>
       <td><%= e.alert_line_crossed ? '⚠' : '' %></td><td><%= e.action_line_crossed ? '‼' : '' %></td>
      </tr>
      <% }) %>
      </tbody>
     </table>
    </div>
   </div>
  </div>

  <%
  var _brand = locals.brand || {};
  var _facility = _brand.facilityName || _brand.name || '';
  var _admissionFmt = labor.admission_date
    ? new Date(labor.admission_date).toLocaleString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })
    : '—';
  var _pgData = {
    laborId: labor.id,
    admissionDate: labor.admission_date,
    admissionFormatted: _admissionFmt,
    facilityName: _facility,
    patient: {
      first_name: labor.first_name,
      last_name: labor.last_name,
      antenatal_number: labor.antenatal_number,
      gravida: labor.gravida,
      para: labor.para,
      abortion: labor.abortion,
      ega_at_admission: labor.ega_at_admission,
      ega_at_booking: labor.ega_at_booking,
      blood_group: labor.blood_group,
      rhesus_factor: labor.rhesus_factor,
      risk_level: labor.risk_level
    },
    entries: partograph || [],
    labels: {
      chartTitle: _tl('maternity_labor.chart_title', 'WHO Partograph'),
      patient: _tl('maternity_labor.print_patient', 'Patient'),
      ancNo: _tl('maternity_labor.print_anc', 'ANC #'),
      gpa: _tl('maternity_labor.print_gpa', 'G/P/A'),
      admission: _tl('maternity_labor.print_admission', 'Admitted'),
      ega: _tl('maternity_labor.print_ega', 'EGA'),
      facility: _tl('maternity_labor.print_facility', 'Facility'),
      bloodGroup: _tl('maternity_labor.print_blood', 'Blood group'),
      risk: _tl('maternity_labor.print_risk', 'Risk'),
      fhr: _tl('maternity_labor.row_fhr', 'Fetal heart rate'),
      liquor: _tl('maternity_labor.row_liquor', 'Amniotic fluid'),
      moulding: _tl('maternity_labor.row_moulding', 'Fetal moulding'),
      dilation: _tl('maternity_labor.graph_dilation', 'Cervical dilation (cm)'),
      descent: _tl('maternity_labor.row_descent', 'Descent of head'),
      ctx: _tl('maternity_labor.ctx', 'Contractions / 10 min'),
      oxytocin: _tl('maternity_labor.row_oxytocin', 'Oxytocin U/L · drops/min'),
      drugs: _tl('maternity_labor.row_drugs', 'Drugs & IV fluids'),
      pulse: _tl('maternity_labor.row_pulse', 'Pulse'),
      bp: _tl('maternity_labor.bp', 'Blood pressure'),
      temperature: _tl('maternity_labor.row_temp', 'Temperature °C'),
      urine: _tl('maternity_labor.row_urine', 'Urine (vol · protein · acetone)'),
      alertLine: _tl('maternity_labor.alert_line', 'Alert line'),
      actionLine: _tl('maternity_labor.action_line', 'Action line'),
      recorded: _tl('maternity_labor.recorded_line', 'Recorded'),
      whoNote: _tl('maternity_labor.who_note', '30-min intervals · WHO active phase monitoring'),
      empty: _tl('maternity_labor.graph_empty', 'Add partograph entries to plot the graph.'),
      print: _tl('maternity_labor.print_record', 'Print record'),
      fullscreen: _tl('maternity_labor.fullscreen', 'Full screen')
    }
  };
  %>
  <script id="mat-partograph-data" type="application/json"><%- JSON.stringify(_pgData).replace(/</g, '\\u003c') %></script>
  <script src="/js/maternity-partograph.js?v=2" defer></script>
  <% } else { %>
  <div class="mat-card p-4">
   <p class="mb-3 text-muted"><%= _tl('maternity_labor.select_help', 'Select a patient from Active labors on the left, or admit from a maternity chart.') %></p>
   <a href="/maternity/patients" class="hms-btn hms-btn-outline-primary btn-sm mr-2"><%= _tl('maternity_labor.anc_registry', 'ANC registry') %></a>
   <% if (active && active.length) { %>
   <p class="small text-muted mt-3 mb-2"><%= _tl('maternity_labor.click_sidebar', 'Click a name in the sidebar to open the partograph.') %></p>
   <% } else { %>
   <p class="small text-muted mt-3 mb-0"><%= _tl('maternity_labor.no_active', 'No active labors yet. Open a patient chart → Labor tab → Admit & open partograph.') %></p>
   <% } %>
  </div>
  <% } %>
 </div>
</div>

</div>
<%- include('partials/maternity-odoo-end') %>
<%- include('partials/footer') %>

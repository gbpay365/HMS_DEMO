<!DOCTYPE html>
<html lang="<%= locals.lang || 'en' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/print-epson-lq.css?v=40" media="print">
  <style>
    body { font-family: Arial, sans-serif; font-size: 12px; color: #111; margin: 16px; }
    h1 { font-size: 16px; margin: 0 0 4px; }
    .meta { font-size: 11px; color: #444; margin-bottom: 12px; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 14px; }
    th, td { border: 1px solid #ccc; padding: 4px 6px; text-align: left; }
    th { background: #f3f4f6; font-size: 11px; }
    .text-right { text-align: right; }
    .total-row { font-weight: bold; background: #f9fafb; }
    .section-title { font-size: 13px; font-weight: bold; margin: 12px 0 6px; }
    .warn { color: #b45309; }
    .ok { color: #059669; }
    @media print { .no-print { display: none; } }
  </style>
</head>
<body>
<%
if (typeof _t !== 'function') {
  var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
}
var _te = function (key, fallback, opts) {
  var o = { ns: 'clinical', defaultValue: fallback };
  if (opts && typeof opts === 'object') { for (var pk in opts) { if (Object.prototype.hasOwnProperty.call(opts, pk)) o[pk] = opts[pk]; } }
  return _t('cashier.eod.' + key, o);
};
var _tc = function (key, fallback, opts) {
  var o = { ns: 'clinical', defaultValue: fallback };
  if (opts && typeof opts === 'object') { for (var pk in opts) { if (Object.prototype.hasOwnProperty.call(opts, pk)) o[pk] = opts[pk]; } }
  return _t('cashier.daily_summary.' + key, o);
};
var _catLabel = function (key) {
  return _tc('cat_' + key, key.replace(/_/g, ' '));
};
%>
<div class="no-print" style="margin-bottom:12px;">
  <button onclick="window.print()"><%= _te('print', 'Print report') %></button>
</div>

<h1><%= facilityName %> — <%= _te('title', 'End of day reconciliation') %></h1>
<div class="meta">
  <%= _te('business_date', 'Business date') %>: <strong><%= report.bounds.label %></strong>
  · <%= _tc('kpi_collected', 'Total collected') %>: <%= report.summary.summary.grandTotal_fmt %>
  · <%= _tc('kpi_tickets', 'Paid tickets') %>: <%= report.summary.summary.ticketCount %>
</div>
<% if (report.saved) { %>
<div class="meta"><%= _te('saved_hint', 'Reconciliation submitted for this date.') %></div>
<% } %>

<div class="section-title"><%= _te('reconciliation', 'Reconciliation') %></div>
<table>
  <thead>
    <tr>
      <th><%= _tc('col_method', 'Method') %></th>
      <th class="text-right"><%= _te('col_system', 'System') %></th>
      <th class="text-right"><%= _te('col_declared', 'Declared') %></th>
      <th class="text-right"><%= _te('col_variance', 'Variance') %></th>
    </tr>
  </thead>
  <tbody>
    <% report.reconciliationRows.forEach(function(row){ %>
    <tr>
      <td><%= row.label %></td>
      <td class="text-right"><%= row.system_fmt %></td>
      <td class="text-right"><%= row.declared_fmt %></td>
      <td class="text-right <%= row.balanced ? 'ok' : 'warn' %>"><%= row.variance_fmt %></td>
    </tr>
    <% }); %>
    <tr class="total-row">
      <td><%= _te('total_variance', 'Net variance') %></td>
      <td colspan="2"></td>
      <td class="text-right <%= report.isBalanced ? 'ok' : 'warn' %>"><%= report.totalVariance_fmt %></td>
    </tr>
  </tbody>
</table>

<div class="meta">
  <%= _te('opening_float', 'Opening float') %>: <%= report.openingFloat_fmt %>
  · <%= _te('expected_drawer', 'Expected cash in drawer') %>: <%= report.expectedCashDrawer_fmt %>
</div>
<% if (report.saved && report.saved.notes) { %>
<div class="meta"><strong><%= _te('notes', 'Notes') %>:</strong> <%= report.saved.notes %></div>
<% } %>

<div class="section-title"><%= _tc('by_category', 'By service category') %></div>
<table>
  <thead>
    <tr>
      <th><%= _tc('col_category', 'Category') %></th>
      <th class="text-right"><%= _tc('col_amount', 'Amount') %></th>
    </tr>
  </thead>
  <tbody>
    <% report.summary.categoryRows.forEach(function(row){ %>
    <tr>
      <td><%= _catLabel(row.key) %></td>
      <td class="text-right"><%= row.amount_fmt %></td>
    </tr>
    <% }); %>
  </tbody>
</table>

<% if (report.cashierBreakdown.length) { %>
<div class="section-title"><%= _te('by_cashier', 'By cashier') %></div>
<table>
  <thead>
    <tr>
      <th><%= _te('cashier', 'Cashier') %></th>
      <th class="text-right"><%= _tc('kpi_tickets', 'Paid tickets') %></th>
      <th class="text-right"><%= _tc('col_amount', 'Amount') %></th>
    </tr>
  </thead>
  <tbody>
    <% report.cashierBreakdown.forEach(function(row){ %>
    <tr>
      <td><%= row.cashier_name %></td>
      <td class="text-right"><%= row.ticket_count %></td>
      <td class="text-right"><%= row.total_collected_fmt %></td>
    </tr>
    <% }); %>
  </tbody>
</table>
<% } %>

<div class="meta"><%= _tc('generated', 'Generated') %>: <%= report.generatedAt %></div>
</body>
</html>

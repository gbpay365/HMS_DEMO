<%- include('partials/header') %>
<% var _hub = locals.procHubUrl || '/procurement'; var _prBase = locals.procPrBase || '/procurement/purchase-requests'; %>
<% if (locals.pharmacyOdooApp) { %>
<%- include('partials/pharmacy-odoo-start', { phaOdooMenu: 'purchase', phaOdooSub: 'procurement', phaOdooTitle: locals.phaOdooTitle || 'Purchase requests', nursingSupplyPending, flash, error }) %>
<div class="o_content p-3 hms-surface-module"><div class="content">
<% } else { %>
<div class="page-wrapper hms-surface-module"><div class="content">
<% } %>
 <% if(locals.flash){ %><div class="alert alert-success border-0 shadow-sm mb-3"><%= flash %></div><% } %>
 <% if(locals.error){ %><div class="alert alert-danger border-0 shadow-sm mb-3"><%= error %></div><% } %>

 <div class="row align-items-center mb-4">
  <div class="col-sm-8">
   <h4 class="page-title font-weight-bold text-dark">Purchase Requests</h4>
   <p class="text-muted small mb-0">Create a request → download & send to vendor → review → convert to draft PO → approve & send.</p>
  </div>
  <div class="col-sm-4 text-right">
   <% if (canWrite && !pr) { %>
   <button class="btn btn-primary hms-btn-premium" data-toggle="modal" data-target="#newPrModal"><i class="fa fa-plus mr-2"></i>New request</button>
   <% } %>
  </div>
 </div>

 <% if (pr) { %>
 <!-- PR Detail -->
 <div class="card border-0 shadow-sm rounded-xl mb-3">
  <div class="card-body">
   <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
    <div>
     <h5 class="font-weight-bold mb-1"><%= pr.pr_number %> — <%= pr.title %></h5>
     <span class="badge badge-<%= pr.status==='draft'?'warning':(pr.status==='issued'?'info':'success') %>-light text-uppercase"><%= pr.status %></span>
     <% if (pr.source_department) { %>
     <span class="badge badge-primary-light text-uppercase ml-1"><%= pr.source_department === 'laboratory' ? 'Laboratory' : (pr.source_department === 'radiology' ? 'Radiology' : pr.source_department) %></span>
     <% if (pr.source_requisition_id) { %><span class="badge badge-secondary-light ml-1">Req #<%= pr.source_requisition_id %></span><% } %>
     <% } %>
     <% if (pr.vendor_name) { %> · Vendor: <strong><%= pr.vendor_name %></strong><% } %>
     <% if (pr.estimated_total) { %> · Est. <%= Number(pr.estimated_total).toLocaleString() %> XAF<% } %>
    </div>
    <div class="d-flex flex-wrap gap-2">
     <a href="<%= _prBase %>/<%= pr.id %>/print?print=1" target="_blank" class="btn btn-outline-secondary btn-sm"><i class="fa fa-print mr-1"></i>Download / Print</a>
     <% if (canWrite && pr.status === 'draft') { %>
     <form method="post" action="/procurement/purchase-requests" class="d-inline">
      <input type="hidden" name="pr_action" value="issue">
      <input type="hidden" name="pr_id" value="<%= pr.id %>">
      <button type="submit" class="btn btn-info btn-sm">Issue to vendor</button>
     </form>
     <% } %>
     <% if (canWrite && pr.status === 'issued') { %>
     <form method="post" action="/procurement/purchase-requests" class="d-inline">
      <input type="hidden" name="pr_action" value="review">
      <input type="hidden" name="pr_id" value="<%= pr.id %>">
      <button type="submit" class="btn btn-success btn-sm">Mark reviewed</button>
     </form>
     <% } %>
     <% if (canWrite && ['issued','reviewed'].includes(pr.status) && !pr.converted_po_id) { %>
     <form method="post" action="/procurement/purchase-requests" class="d-inline">
      <input type="hidden" name="pr_action" value="convert_po">
      <input type="hidden" name="pr_id" value="<%= pr.id %>">
      <button type="submit" class="btn btn-primary btn-sm">Create draft PO</button>
     </form>
     <% } %>
     <% if (pr.converted_po_id) { %>
     <% var _poDetail = (locals.procLinks && locals.procLinks.purchaseOrderDetail) || '/procurement/purchase-orders/'; %>
     <a href="<%= _poDetail %><%= pr.converted_po_id %>" class="btn btn-outline-primary btn-sm">View PO</a>
     <% } %>
    </div>
   </div>
   <% if (pr.summary_description) { %><p class="mt-3 mb-0 small"><%= pr.summary_description %></p><% } %>
  </div>
 </div>

 <% if (canWrite && pr.status === 'draft') { %>
 <div class="card border-0 shadow-sm rounded-xl mb-3">
  <div class="card-header bg-white font-weight-bold">Add line</div>
  <div class="card-body">
   <form method="post" action="/procurement/purchase-requests" class="form-row align-items-end">
    <input type="hidden" name="pr_action" value="add_line">
    <input type="hidden" name="pr_id" value="<%= pr.id %>">
    <div class="form-group col-md-4">
     <label class="small font-weight-bold">Description</label>
     <input name="line_desc" class="form-control" required placeholder="Item / material">
    </div>
    <div class="form-group col-md-3">
     <label class="small font-weight-bold">Qty</label>
     <input type="text" name="line_qty" class="form-control" value="1 Pack" placeholder="e.g. 50 Cartons">
    </div>
    <div class="form-group col-md-3">
     <label class="small font-weight-bold">Inventory SKU (optional)</label>
     <select name="line_inventory_item_id" class="form-control">
      <option value="">—</option>
      <% (inventoryItems||[]).forEach(function(it){ %><option value="<%= it.id %>"><%= it.name %></option><% }); %>
     </select>
    </div>
    <div class="form-group col-md-1 mb-0"><button type="submit" class="btn btn-primary btn-block">Add</button></div>
   </form>
  </div>
 </div>
 <% } %>

 <div class="card border-0 shadow-sm rounded-xl mb-3">
  <div class="card-header bg-white font-weight-bold">Request lines</div>
  <div class="table-responsive">
   <table class="table table-sm mb-0">
    <thead class="bg-light"><tr><th>#</th><th>Description</th><th class="text-right">Qty</th><th>SKU</th></tr></thead>
    <tbody>
     <% (lines||[]).forEach(function(ln){ %>
     <tr>
      <td><%= ln.line_no %></td>
      <td><%= ln.description %></td>
      <td class="text-right"><%= typeof fmtPoQty === 'function' ? fmtPoQty(ln.quantity, ln.uom) : ln.quantity %></td>
      <td><%= ln.inv_sku || '—' %></td>
     </tr>
     <% }) %>
     <% if (!(lines||[]).length) { %><tr><td colspan="4" class="text-center text-muted py-4">No lines yet.</td></tr><% } %>
    </tbody>
   </table>
  </div>
 </div>

 <a href="<%= _prBase %>" class="btn btn-link btn-sm">← All purchase requests</a>

 <% } else { %>
 <!-- PR List -->
 <% var _pst = locals.prFilter || ''; var _dept = locals.prDeptFilter || ''; var _prs = locals.prStats || { total: 0, draft: 0, issued: 0, reviewed: 0 }; var _search = locals.prSearch || ''; %>

 <div class="hms-stat-grid">
  <div class="hms-stat-card hms-stat-card--brand"><div class="hms-stat-card__value"><%= _prs.total %></div><div class="hms-stat-card__label">Total PRs</div></div>
  <div class="hms-stat-card hms-stat-card--warning"><div class="hms-stat-card__value"><%= _prs.draft %></div><div class="hms-stat-card__label">Draft</div></div>
  <div class="hms-stat-card hms-stat-card--info"><div class="hms-stat-card__value"><%= _prs.issued %></div><div class="hms-stat-card__label">Issued</div></div>
  <div class="hms-stat-card hms-stat-card--success"><div class="hms-stat-card__value"><%= _prs.reviewed %></div><div class="hms-stat-card__label">Reviewed</div></div>
 </div>

 <form method="get" action="<%= _prBase %>" class="hms-filter-bar">
  <input type="search" name="q" class="form-control hms-filter-bar__search" value="<%= _search %>" placeholder="Search PR #, title or vendor">
  <% if (_pst) { %><input type="hidden" name="status" value="<%= _pst %>"><% } %>
  <button type="submit" class="btn btn-outline-secondary">Search</button>
  <% if (_search || _pst) { %><a href="<%= _prBase %>" class="btn btn-link">Reset</a><% } %>
 </form>

 <div class="hms-chip-row">
  <a href="<%= _prBase %><%= _search ? ('?q=' + encodeURIComponent(_search)) : '' %><%= _dept ? ((_search ? '&' : '?') + 'dept=' + encodeURIComponent(_dept)) : '' %>" class="hms-chip<%= !_pst && !_dept ? ' active' : '' %>">All</a>
  <a href="<%= _prBase %>?dept=laboratory<%= _search ? ('&q=' + encodeURIComponent(_search)) : '' %>" class="hms-chip<%= _dept === 'laboratory' ? ' active' : '' %>">Laboratory</a>
  <a href="<%= _prBase %>?dept=radiology<%= _search ? ('&q=' + encodeURIComponent(_search)) : '' %>" class="hms-chip<%= _dept === 'radiology' ? ' active' : '' %>">Radiology</a>
  <a href="<%= _prBase %>?status=draft<%= _search ? ('&q=' + encodeURIComponent(_search)) : '' %><%= _dept ? ('&dept=' + encodeURIComponent(_dept)) : '' %>" class="hms-chip<%= _pst === 'draft' ? ' active' : '' %>">Draft</a>
  <a href="<%= _prBase %>?status=issued<%= _search ? ('&q=' + encodeURIComponent(_search)) : '' %><%= _dept ? ('&dept=' + encodeURIComponent(_dept)) : '' %>" class="hms-chip<%= _pst === 'issued' ? ' active' : '' %>">Issued</a>
  <a href="<%= _prBase %>?status=reviewed<%= _search ? ('&q=' + encodeURIComponent(_search)) : '' %><%= _dept ? ('&dept=' + encodeURIComponent(_dept)) : '' %>" class="hms-chip<%= _pst === 'reviewed' ? ' active' : '' %>">Reviewed</a>
 </div>

 <div class="hms-surface-card">
  <div class="table-responsive">
   <table class="table table-hover mb-0 hms-table-v3">
    <thead class="bg-light">
     <tr><th>PR #</th><th>Title</th><th>Source</th><th>Vendor</th><th>Status</th><th>Needed by</th><th class="text-right">Action</th></tr>
    </thead>
    <tbody>
     <% (prList||[]).forEach(function(row){ %>
     <tr>
      <td class="font-weight-bold"><%= row.pr_number %></td>
      <td><%= row.title %></td>
      <td><% if (row.source_department) { %><span class="badge badge-light text-uppercase extra-small"><%= row.source_department === 'laboratory' ? 'Lab' : (row.source_department === 'radiology' ? 'Rad' : row.source_department) %></span><% } else { %>—<% } %></td>
      <td><%= row.vendor_name || '—' %></td>
      <td><span class="badge badge-light text-uppercase extra-small"><%= row.status %></span></td>
      <td><%= row.needed_by || '—' %></td>
      <td class="text-right">
       <a href="<%= _prBase %>/<%= row.id %>" class="btn btn-outline-primary btn-sm rounded-pill">Open</a>
       <a href="<%= _prBase %>/<%= row.id %>/print" target="_blank" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="fa fa-print"></i></a>
      </td>
     </tr>
     <% }) %>
     <% if (!(prList||[]).length) { %><tr><td colspan="7" class="text-center py-5 text-muted">No purchase requests yet.</td></tr><% } %>
    </tbody>
   </table>
  </div>
 </div>
 <% } %>

<% if (canWrite && !pr) { %>
<div class="modal fade" id="newPrModal" tabindex="-1" role="dialog" aria-labelledby="newPrModalTitle">
 <div class="modal-dialog modal-lg">
  <form method="post" action="/procurement/purchase-requests" class="modal-content">
   <input type="hidden" name="pr_action" value="create">
   <div class="modal-header">
    <h5 class="modal-title font-weight-bold" id="newPrModalTitle">New purchase request</h5>
    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
   </div>
   <div class="modal-body">
    <div class="form-row">
     <div class="form-group col-md-8"><label class="font-weight-bold small">Title</label><input name="title" class="hms-input w-full" required placeholder="e.g. Q2 pharmacy consumables"></div>
     <div class="form-group col-md-4"><label class="font-weight-bold small">Needed by</label><input type="date" name="needed_by" class="hms-input w-full"></div>
    </div>
    <div class="form-row">
     <div class="form-group col-md-6"><label class="font-weight-bold small">Preferred vendor</label>
      <select name="vendor_id" class="hms-input w-full"><option value="">— Optional —</option>
       <% (vendors||[]).forEach(function(v){ %><option value="<%= v.id %>"><%= v.name %></option><% }); %>
      </select>
     </div>
     <div class="form-group col-md-6"><label class="font-weight-bold small">Estimated total (XAF)</label><input type="number" name="estimated_total" class="hms-input w-full" min="0" step="1"></div>
    </div>
    <div class="form-group mb-0"><label class="font-weight-bold small">Summary / scope</label><textarea name="summary_description" class="hms-input w-full" rows="3" placeholder="Describe what you need from the vendor"></textarea></div>
   </div>
   <div class="modal-footer">
    <button type="button" class="hms-btn hms-btn-secondary" data-dismiss="modal">Cancel</button>
    <button type="submit" class="hms-btn hms-btn-primary">Create draft PR</button>
   </div>
  </form>
 </div>
</div>
<% } %>

<style>.extra-small{font-size:0.65rem;}</style>
</div></div>
<% if (locals.pharmacyOdooApp) { %>
<%- include('partials/pharmacy-odoo-end') %>
<% } %>
<%- include('partials/footer') %>

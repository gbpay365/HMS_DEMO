<% if (locals.hmsSessionIdle && locals.hmsSessionIdle.active) { %>
<script>window.HMS_SESSION_IDLE = <%- JSON.stringify(locals.hmsSessionIdle) %>;</script>
<script src="/js/hms-session-idle.js" defer></script>
<% } %>

<!DOCTYPE html>
<html lang="<%= locals.lang || 'en' %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%
  var _lang = locals.lang || 'en';
  var _t = locals.t || function (k, o) { return (o && o.defaultValue) || k; };
  function _tp(key, fallback, opts) {
    var o = { ns: 'portal', defaultValue: fallback };
    if (opts && typeof opts === 'object') { for (var pk in opts) { o[pk] = opts[pk]; } }
    return _t(key, o);
  }
%>
<title><%= title %></title>
<link rel="stylesheet" href="/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/font-awesome.min.css">
<style>
  body { background: linear-gradient(135deg,#0f172a,#1e3a5f); min-height:100vh; display:flex; align-items:center; justify-content:center; font-family:'Segoe UI',sans-serif; }
  .wrap { max-width:420px; width:100%; padding:20px; }
  .card { background:rgba(255,255,255,0.07); backdrop-filter:blur(16px); border:1px solid rgba(255,255,255,0.12); border-radius:20px; padding:40px 36px; box-shadow:0 24px 60px rgba(0,0,0,0.4); }
  .icon { width:64px; height:64px; background:linear-gradient(135deg,#10b981,#059669); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:1.6rem; color:#fff; box-shadow:0 8px 24px rgba(16,185,129,0.35); }
  h1 { color:#fff; font-size:1.4rem; font-weight:700; text-align:center; margin-bottom:6px; }
  .sub { color:rgba(255,255,255,0.55); font-size:.82rem; text-align:center; margin-bottom:24px; }
  label { color:rgba(255,255,255,0.75); font-size:.8rem; font-weight:600; display:block; margin-bottom:5px; }
  input[type=password] { background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:10px; color:#fff; padding:11px 16px; width:100%; font-size:.9rem; outline:none; margin-bottom:16px; }
  input[type=password]:focus { border-color:#10b981; background:rgba(255,255,255,0.12); }
  .btn-set { background:linear-gradient(135deg,#10b981,#059669); color:#fff; border:none; border-radius:10px; padding:13px; width:100%; font-size:.95rem; font-weight:600; cursor:pointer; }
  .btn-set:hover { opacity:.9; }
  .err { background:rgba(239,68,68,0.15); border:1px solid rgba(239,68,68,0.3); border-radius:10px; color:#fca5a5; font-size:.83rem; padding:10px 14px; margin-bottom:16px; }
</style>
</head>
<body>
<div class="wrap">
 <div class="card">
  <div class="icon"><i class="fa fa-key"></i></div>
  <h1><%= _tp('set_password.title', 'Set Your Portal Password') %></h1>
  <p class="sub"><%= _tp('set_password.subtitle', 'Welcome, {{name}}. Choose a secure password to access My Care Portal.', { name: patient.first_name }) %></p>
  <% if (locals.error) { %><div class="err"><i class="fa fa-exclamation-circle mr-1"></i><%= locals.error %></div><% } %>
  <form method="POST" action="/portal/set-password">
   <input type="hidden" name="token" value="<%= token %>">
   <label><%= _tp('set_password.new_password', 'New Password') %></label>
   <input type="password" name="password" required minlength="6" placeholder="<%= _tp('set_password.new_ph', 'At least 6 characters') %>">
   <label><%= _tp('set_password.confirm_password', 'Confirm Password') %></label>
   <input type="password" name="password2" required minlength="6" placeholder="<%= _tp('set_password.confirm_ph', 'Repeat your password') %>">
   <button type="submit" class="btn-set"><i class="fa fa-check mr-2"></i><%= _tp('set_password.submit', 'Save & Sign In') %></button>
  </form>
 </div>
</div>
</body>
</html>

<%- include('partials/header') %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>

<div class="page-wrapper">
  <div class="content">
    <div class="row align-items-center mb-4">
      <div class="col-md-8">
        <h4 class="page-title font-weight-bold text-dark"><%= _t('payment_validity.title', { ns: 'legacy', defaultValue: 'Payment validity' }) %></h4>
        <p class="text-muted small mb-0">
          <%= _t('payment_validity.subtitle', { ns: 'legacy', defaultValue: 'Expiry dates and doctor follow-up blending apply only to Consultation and Telemedicine tickets. Other payment types (lab, radiology, hospitalisation, pharmacy, etc.) stay valid while paid — usage limits still apply where configured.' }) %>
        </p>
      </div>
      <div class="col-md-4 text-md-right mt-2 mt-md-0">
        <form action="/payment-validity/sync" method="post" class="d-inline">
          <button type="submit" class="hms-btn hms-btn-outline-primary btn-sm">
            <i class="fa fa-refresh mr-1"></i> <%= _t('payment_validity.sync_btn', { ns: 'legacy', defaultValue: 'Sync kinds from catalog' }) %>
          </button>
        </form>
      </div>
    </div>

    <% if (flash) { %>
    <div class="hms-flash hms-flash--success rounded-lg"><%= flash %></div>
    <% } %>
    <% if (error) { %>
    <div class="hms-flash hms-flash--error rounded-lg"><%= error %></div>
    <% } %>

    <div class="card border-0 shadow-sm rounded-xl mb-3">
      <div class="card-body py-3">
        <div class="small text-muted">
          <strong><%= _t('payment_validity.policies_label', { ns: 'legacy', defaultValue: 'Policies:' }) %></strong>
          <em><%= _t('payment_validity.policy_system_only', { ns: 'legacy', defaultValue: 'System only' }) %></em> — <%= _t('payment_validity.policy_system_only_desc', { ns: 'legacy', defaultValue: 'use validity days from this screen.' }) %>
          <em><%= _t('payment_validity.policy_doctor_blend', { ns: 'legacy', defaultValue: 'Doctor + system (shortest / longest)' }) %></em> — <%= _t('payment_validity.policy_doctor_blend_desc', { ns: 'legacy', defaultValue: 'compare system days with the last documented follow-up interval (from consultation, before the ticket was paid) and take the tighter or looser value when follow-up is set.' }) %>
          <em><%= _t('payment_validity.policy_doctor_overrides', { ns: 'legacy', defaultValue: 'Doctor overrides' }) %></em> — <%= _t('payment_validity.policy_doctor_overrides_desc', { ns: 'legacy', defaultValue: 'follow-up days replace the system value when present.' }) %>
          <em><%= _t('payment_validity.policy_system_overrides', { ns: 'legacy', defaultValue: 'System overrides doctor' }) %></em> — <%= _t('payment_validity.policy_system_overrides_desc', { ns: 'legacy', defaultValue: 'ignore follow-up for this payment kind.' }) %>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm rounded-xl overflow-hidden">
      <div class="table-responsive">
        <table class="table table-hover mb-0 hms-table-v3">
          <thead class="bg-light">
            <tr>
              <th style="min-width:120px;"><%= _t('payment_validity.col_kind', { ns: 'legacy', defaultValue: 'Kind' }) %></th>
              <th><%= _t('payment_validity.col_label', { ns: 'legacy', defaultValue: 'Label' }) %></th>
              <th class="text-right" style="width:110px;"><%= _t('payment_validity.col_days', { ns: 'legacy', defaultValue: 'Days' }) %></th>
              <th class="text-right" style="width:100px;"><%= _t('payment_validity.col_max_uses', { ns: 'legacy', defaultValue: 'Max uses' }) %></th>
              <th style="min-width:220px;"><%= _t('payment_validity.col_policy', { ns: 'legacy', defaultValue: 'Policy' }) %></th>
              <th class="text-right" style="width:90px;"></th>
            </tr>
          </thead>
          <tbody>
            <% (rules || []).forEach(function(r){ %>
            <tr>
              <td class="small text-monospace align-middle"><%= r.payment_kind %></td>
              <td colspan="5" class="p-0">
                <form action="/payment-validity/update" method="post" class="p-2 m-0">
                  <input type="hidden" name="id" value="<%= r.id %>">
                  <div class="form-row align-items-center">
                    <div class="col-md-3 mb-2 mb-md-0">
                      <input type="text" name="label" class="hms-input w-full text-sm" value="<%= r.label %>" maxlength="255">
                    </div>
                    <div class="col-6 col-md-2 mb-2 mb-md-0">
                      <input type="number" name="validity_days" class="hms-input w-full text-sm text-right" min="1" max="3650" value="<%= r.validity_days %>" title="<%= _t('payment_validity.validity_days_title', { ns: 'legacy', defaultValue: 'Validity in days after payment' }) %>">
                    </div>
                    <div class="col-6 col-md-2 mb-2 mb-md-0">
                      <input type="number" name="max_uses" class="hms-input w-full text-sm text-right" min="1" max="999" value="<%= r.max_uses %>" title="<%= _t('payment_validity.max_uses_title', { ns: 'legacy', defaultValue: 'Maximum registrations / uses' }) %>">
                    </div>
                    <div class="col-md-3 mb-2 mb-md-0">
                      <select name="interval_policy" class="hms-input w-full text-sm">
                        <% const pols = [
                          ['system_only', _t('payment_validity.opt_system_only', { ns: 'legacy', defaultValue: 'System only' })],
                          ['doctor_shortest', _t('payment_validity.opt_doctor_shortest', { ns: 'legacy', defaultValue: 'Doctor + system (shortest)' })],
                          ['doctor_longest', _t('payment_validity.opt_doctor_longest', { ns: 'legacy', defaultValue: 'Doctor + system (longest)' })],
                          ['doctor_overrides', _t('payment_validity.opt_doctor_overrides', { ns: 'legacy', defaultValue: 'Doctor overrides' })],
                          ['system_overrides_doctor', _t('payment_validity.opt_system_overrides', { ns: 'legacy', defaultValue: 'System overrides doctor' })]
                        ];
                        pols.forEach(function(p){
                          var sel = String(r.interval_policy||'') === p[0] ? ' selected' : '';
                        %>
                        <option value="<%= p[0] %>"<%= sel %>><%= p[1] %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="col-md-2 text-md-right">
                      <button type="submit" class="hms-btn hms-btn-primary hms-btn-sm btn-block"><%= _t('payment_validity.save', { ns: 'legacy', defaultValue: 'Save' }) %></button>
                    </div>
                  </div>
                </form>
              </td>
            </tr>
            <% }); %>
            <% if (!(rules||[]).length) { %>
            <tr><td colspan="6" class="text-center text-muted py-4"><%= _t('payment_validity.empty', { ns: 'legacy', defaultValue: 'No rules yet — use “Sync kinds from catalog”.' }) %></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>

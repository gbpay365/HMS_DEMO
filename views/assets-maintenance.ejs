<% locals.hmsSurfaceBodyClass = ' hms-body--assets'; %>
<%- include('partials/header') %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>

<div class="page-wrapper hms-surface-module">
 <div class="content">
  <% if(locals.flash){ %><div class="hms-flash hms-flash--success"><%= flash %></div><% } %>
  <% if(locals.error){ %><div class="hms-flash hms-flash--error"><%= error %></div><% } %>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
   <div>
    <h4 class="page-title font-weight-bold text-dark mb-1"><%= _t('assets_maint.title', { ns: 'legacy', defaultValue: 'Maintenance log' }) %></h4>
    <p class="text-muted small mb-0"><%= _t('assets_maint.subtitle', { ns: 'legacy', defaultValue: 'Scheduled service, repairs, calibration, and inspections.' }) %></p>
   </div>
   <a href="/assets" class="hms-btn hms-btn-secondary btn-sm"><i class="fa fa-arrow-left mr-1"></i><%= _t('assets_registry.back_hub', { ns: 'legacy', defaultValue: 'Assets hub' }) %></a>
  </div>

  <form method="get" action="/assets/maintenance" class="hms-filter-bar mb-3">
   <select name="asset" class="hms-input" style="max-width:240px;">
    <option value=""><%= _t('assets_maint.all_assets', { ns: 'legacy', defaultValue: 'All assets' }) %></option>
    <% assets.forEach(function(a) { %>
    <option value="<%= a.id %>" <%= String(filters.asset) === String(a.id) ? 'selected' : '' %>><%= a.asset_tag %> — <%= a.name %></option>
    <% }); %>
   </select>
   <select name="status" class="hms-input" style="max-width:160px;">
    <option value=""><%= _t('assets_registry.all_statuses', { ns: 'legacy', defaultValue: 'All statuses' }) %></option>
    <% maintStatuses.forEach(function(s) { %>
    <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
    <% }); %>
   </select>
   <button type="submit" class="hms-btn hms-btn-secondary"><%= _t('assets_registry.filter', { ns: 'legacy', defaultValue: 'Filter' }) %></button>
  </form>

  <% if (canWrite) { %>
  <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
   <div class="card-header bg-white font-weight-bold"><%= _t('assets_maint.add', { ns: 'legacy', defaultValue: 'Add maintenance record' }) %></div>
   <div class="card-body">
    <form method="post" action="/assets/maintenance" class="row">
     <div class="col-md-4 form-group">
      <label class="font-weight-bold small" for="newMaintAsset"><%= _t('assets_maint.col_asset', { ns: 'legacy', defaultValue: 'Asset' }) %> *</label>
      <select id="newMaintAsset" name="asset_id" class="hms-input w-full" required>
       <option value=""><%= _t('assets_maint.select_asset', { ns: 'legacy', defaultValue: '— Select asset —' }) %></option>
       <% assets.forEach(function(a) { %>
       <option value="<%= a.id %>" <%= String(filters.asset) === String(a.id) ? 'selected' : '' %>><%= a.asset_tag %> — <%= a.name %></option>
       <% }); %>
      </select>
     </div>
     <div class="col-md-2 form-group">
      <label class="font-weight-bold small" for="newMaintType"><%= _t('assets_maint.col_type', { ns: 'legacy', defaultValue: 'Type' }) %></label>
      <select id="newMaintType" name="maintenance_type" class="hms-input w-full">
       <% maintTypes.forEach(function(tp) { %><option value="<%= tp %>"><%= tp %></option><% }); %>
      </select>
     </div>
     <div class="col-md-2 form-group">
      <label class="font-weight-bold small" for="newMaintDate"><%= _t('assets_maint.col_scheduled', { ns: 'legacy', defaultValue: 'Scheduled' }) %></label>
      <input type="date" id="newMaintDate" name="scheduled_date" class="hms-input w-full">
     </div>
     <div class="col-md-2 form-group">
      <label class="font-weight-bold small" for="newMaintCost"><%= _t('assets_maint.col_cost', { ns: 'legacy', defaultValue: 'Cost' }) %></label>
      <input type="number" step="0.01" id="newMaintCost" name="cost" class="hms-input w-full">
     </div>
     <div class="col-md-2 form-group">
      <label class="font-weight-bold small" for="newMaintStatus"><%= _t('assets_maint.col_status', { ns: 'legacy', defaultValue: 'Status' }) %></label>
      <select id="newMaintStatus" name="status" class="hms-input w-full">
       <% maintStatuses.forEach(function(st) { %><option value="<%= st %>" <%= st === 'scheduled' ? 'selected' : '' %>><%= st %></option><% }); %>
      </select>
     </div>
     <div class="col-md-4 form-group">
      <label class="font-weight-bold small" for="newMaintVendor"><%= _t('assets_maint.col_vendor', { ns: 'legacy', defaultValue: 'Vendor' }) %></label>
      <input type="text" id="newMaintVendor" name="vendor_name" class="hms-input w-full">
     </div>
     <div class="col-md-6 form-group">
      <label class="font-weight-bold small" for="newMaintDesc"><%= _t('assets_maint.col_description', { ns: 'legacy', defaultValue: 'Description' }) %></label>
      <input type="text" id="newMaintDesc" name="description" class="hms-input w-full">
     </div>
     <div class="col-md-2 form-group d-flex align-items-end">
      <button type="submit" class="hms-btn hms-btn-primary font-weight-bold w-100"><%= _t('assets_maint.save', { ns: 'legacy', defaultValue: 'Save' }) %></button>
     </div>
    </form>
   </div>
  </div>
  <% } %>

  <div class="hms-surface-card">
   <div class="table-responsive">
    <table class="table table-hover mb-0 hms-table-v3" data-hms-table-paginate="15">
     <thead class="bg-light"><tr>
      <th><%= _t('assets_maint.col_asset', { ns: 'legacy', defaultValue: 'Asset' }) %></th>
      <th><%= _t('assets_maint.col_type', { ns: 'legacy', defaultValue: 'Type' }) %></th>
      <th><%= _t('assets_maint.col_scheduled', { ns: 'legacy', defaultValue: 'Scheduled' }) %></th>
      <th><%= _t('assets_maint.col_status', { ns: 'legacy', defaultValue: 'Status' }) %></th>
      <th><%= _t('assets_maint.col_vendor', { ns: 'legacy', defaultValue: 'Vendor' }) %></th>
      <th><%= _t('assets_maint.col_cost', { ns: 'legacy', defaultValue: 'Cost' }) %></th>
      <th class="text-right"><%= _t('assets_registry.col_actions', { ns: 'legacy', defaultValue: 'Actions' }) %></th>
     </tr></thead>
     <tbody>
      <% if (!rows || !rows.length) { %>
      <tr><td colspan="7" class="text-center text-muted py-4"><%= _t('assets_maint.empty', { ns: 'legacy', defaultValue: 'No maintenance records yet.' }) %></td></tr>
      <% } %>
      <% (rows || []).forEach(function(m) { %>
      <tr>
       <td><a href="/assets/registry/<%= m.asset_id %>"><code><%= m.asset_tag %></code></a><div class="small text-muted"><%= m.asset_name %></div></td>
       <td class="text-uppercase small"><%= m.maintenance_type %></td>
       <td><%= m.scheduled_date ? String(m.scheduled_date).slice(0,10) : '—' %></td>
       <td><span class="badge badge-<%= statusBadge(m.status) %> text-uppercase extra-small"><%= m.status %></span></td>
       <td><%= m.vendor_name || '—' %></td>
       <td><%= m.cost != null ? Number(m.cost).toLocaleString() : '—' %></td>
       <td class="text-right">
        <% if (canWrite && m.status !== 'completed' && m.status !== 'cancelled') { %>
        <form method="post" action="/assets/maintenance/<%= m.id %>/complete" class="d-inline">
         <input type="hidden" name="return_to" value="/assets/maintenance">
         <button type="submit" class="hms-btn hms-btn-secondary btn-sm"><%= _t('assets_maint.complete', { ns: 'legacy', defaultValue: 'Complete' }) %></button>
        </form>
        <% } else { %>—<% } %>
       </td>
      </tr>
      <% }); %>
     </tbody>
    </table>
   </div>
  </div>
 </div>
</div>

<%- include('partials/footer') %>

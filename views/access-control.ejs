</div></div><!-- /content /page-wrapper -->

<style>
.main-tab-btn{padding:.55rem 1.25rem;border-radius:8px;border:none;font-weight:700;font-size:.85rem;cursor:pointer;background:transparent;color:#64748b;transition:all .25s;}
.main-tab-btn:hover{color:#1e293b;background:#f8fafc;}
.main-tab-btn.active{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;box-shadow:0 4px 12px rgba(102,126,234,.4);}
.section-panel{display:none;}.section-panel.active{display:block;}

/* Portal Dashboard Tiles � tabs by portal */
.acl-ptile-tabbar{display:flex;flex-wrap:wrap;align-items:center;gap:6px;padding:8px;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:10px;margin-bottom:1rem;}
.acl-ptile-tab{display:inline-flex;align-items:center;border:1px solid #e2e8f0;background:#fff;color:#475569;font-size:.78rem;font-weight:600;padding:.42rem .85rem;border-radius:8px;cursor:pointer;white-space:nowrap;transition:background .15s,color .15s,border-color .15s,box-shadow .15s;}
.acl-ptile-tab:hover{background:#f8fafc;color:#1e293b;border-color:#cbd5e1;}
.acl-ptile-tab.active{background:linear-gradient(135deg,#1a6bd8,#0c8b8b);color:#fff;border-color:transparent;box-shadow:0 2px 8px rgba(26,107,216,.25);}
.acl-ptile-tab .badge{background:rgba(255,255,255,.95);color:#334155;}
.acl-ptile-tab.active .badge{background:rgba(255,255,255,.22);color:#fff;border-color:transparent!important;}
.acl-ptile-panel{display:none;}
.acl-ptile-panel.active{display:block;}

/* UI visibility � jump bar + top navigation cards */
.acl-ui-jumpbar{display:flex;flex-wrap:wrap;align-items:center;gap:8px;padding:12px 14px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;box-shadow:0 1px 3px rgba(15,23,42,.04);}
.acl-ui-jumpbar__label{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#64748b;margin-right:4px;}
.acl-ui-jumpbar__link{display:inline-flex;align-items:center;padding:.45rem .9rem;border-radius:8px;font-size:.8rem;font-weight:600;color:#475569;background:#f8fafc;border:1px solid #e2e8f0;text-decoration:none;transition:background .15s,color .15s,border-color .15s;}
.acl-ui-jumpbar__link:hover{background:#eef2f7;color:#1e293b;text-decoration:none;}
.acl-ui-jumpbar__link--primary{background:linear-gradient(135deg,#1a6bd8,#0c8b8b);color:#fff;border-color:transparent;}
.acl-ui-jumpbar__link--primary:hover{color:#fff;opacity:.92;}
.acl-topnav-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;height:100%;display:flex;flex-direction:column;box-shadow:0 2px 8px rgba(15,23,42,.04);transition:opacity .2s,border-color .2s;}
.acl-topnav-card--off{opacity:.55;border-style:dashed;background:#f8fafc;}
.acl-topnav-card__head{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;padding:12px 14px;border-bottom:1px solid #eef2f7;background:linear-gradient(180deg,#f8fafc,#fff);}
.acl-topnav-card__title{display:flex;align-items:center;gap:8px;font-weight:700;font-size:.9rem;color:#1e293b;}
.acl-topnav-card__icon{width:32px;height:32px;border-radius:8px;background:rgba(26,107,216,.1);color:#1a6bd8;display:flex;align-items:center;justify-content:center;font-size:.95rem;}
.acl-topnav-card__switch{display:flex;align-items:center;gap:6px;cursor:pointer;white-space:nowrap;}
.acl-topnav-card__switch input{margin:0;}
.acl-topnav-card__switch-label{font-size:.7rem;font-weight:700;color:#0f766e;text-transform:uppercase;letter-spacing:.04em;}
.acl-topnav-card--off .acl-topnav-card__switch-label{color:#94a3b8;}
.acl-topnav-card__body{padding:10px 12px;flex:1;display:flex;flex-direction:column;gap:4px;}
.acl-topnav-link-row{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;cursor:pointer;margin:0;font-size:.8rem;font-weight:500;color:#334155;}
.acl-topnav-link-row:hover{background:#f1f5f9;}
.acl-topnav-link-row--off{opacity:.5;}
.acl-topnav-link-row input{margin:0;flex-shrink:0;}
.acl-topnav-card__foot{padding:8px 12px;border-top:1px solid #eef2f7;background:#fafbfc;}
.acl-ui-row--hidden{opacity:.45;}
.acl-ui-section{scroll-margin-top:80px;}

/* ── Portal pills horizontal toolbar  */
.wf-pills-toolbar{
  background:#fff;border-radius:12px;border:1px solid #e8edf5;
  padding:.65rem 1rem;
  display:flex;flex-wrap:wrap;align-items:center;gap:.55rem;
  box-shadow:0 1px 4px rgba(0,0,0,.05);
}
.wf-pills-label{font-size:.72rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.04em;white-space:nowrap;margin-right:.3rem;}

/* ── Portal pills  */
.portal-pill{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border-radius:20px;padding:.35rem .9rem;font-size:.8rem;font-weight:600;cursor:grab;user-select:none;box-shadow:0 2px 6px rgba(102,126,234,.35);transition:all .2s;display:inline-flex;align-items:center;gap:.35rem;}
.portal-pill:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(102,126,234,.45);}
.portal-pill[data-code="front_desk"]{background:linear-gradient(135deg,#11998e,#38ef7d);box-shadow:0 2px 6px rgba(17,153,142,.35);}
.portal-pill[data-code="doctors"]{background:linear-gradient(135deg,#8e44ad,#c39bd3);box-shadow:0 2px 6px rgba(142,68,173,.35);}
.portal-pill[data-code="nursing"]{background:linear-gradient(135deg,#e84393,#f093fb);box-shadow:0 2px 6px rgba(232,67,147,.35);}
.portal-pill[data-code="laboratory"]{background:linear-gradient(135deg,#f7971e,#ffd200);box-shadow:0 2px 6px rgba(247,151,30,.35);}
.portal-pill[data-code="pharmacy"]{background:linear-gradient(135deg,#575fcf,#43e97b);box-shadow:0 2px 6px rgba(87,95,207,.35);}
.portal-pill[data-code="radiology"]{background:linear-gradient(135deg,#00b09b,#96c93d);box-shadow:0 2px 6px rgba(0,176,155,.35);}
.portal-pill[data-code="cashier"]{background:linear-gradient(135deg,#e67e22,#f39c12);box-shadow:0 2px 6px rgba(230,126,34,.35);}
.portal-pill[data-code="accountant"]{background:linear-gradient(135deg,#f093fb,#f5576c);box-shadow:0 2px 6px rgba(245,87,108,.35);}
.portal-pill[data-code="patient"]{background:linear-gradient(135deg,#30cfd0,#330867);box-shadow:0 2px 6px rgba(48,207,208,.35);}

/* ── Workflow canvas card  */
.wf-canvas-card{border-radius:14px;overflow:hidden;}
.wf-tab-bar{background:#f8fafc;padding:.75rem 1.25rem;border-bottom:1px solid #e8edf5;display:flex;gap:.5rem;}
.wf-tab-btn{padding:.4rem 1.1rem;border-radius:20px;border:none;font-weight:600;font-size:.82rem;cursor:pointer;background:#fff;color:#64748b;transition:all .2s;border:1px solid #e2e8f0;}
.wf-tab-btn.active{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border-color:transparent;box-shadow:0 3px 8px rgba(102,126,234,.4);}

/* ── Flow wrap & horizontal scroll  */
.wf-flow-wrap{padding:1.25rem 1.25rem 1rem;overflow-x:auto;}
.wf-flow{display:flex;flex-wrap:nowrap;align-items:flex-start;gap:0;width:max-content;padding:.5rem 0;}
.wf-arrow{color:#cbd5e1;padding:0 .3rem;align-self:center;margin-top:-18px;font-size:1rem;}

/* ── Workflow step cards  */
.wf-step{width:155px;min-height:95px;border-radius:10px;padding:.8rem 1rem;color:#fff;position:relative;transition:all .2s;flex-shrink:0;}
.wf-step.drop-over{transform:scale(1.06);box-shadow:0 0 0 3px #fff,0 0 0 6px #667eea;}
.wf-step-label{font-size:.73rem;font-weight:700;line-height:1.3;margin-bottom:.5rem;display:flex;justify-content:space-between;align-items:flex-start;}
.wf-step-edit{background:rgba(255,255,255,.25);border:none;color:#fff;border-radius:4px;width:20px;height:20px;cursor:pointer;font-size:.6rem;flex-shrink:0;margin-left:2px;}
.wf-step-portals{display:flex;flex-wrap:wrap;gap:.25rem;min-height:20px;}
.wf-badge{background:rgba(255,255,255,.25);border-radius:10px;padding:.15rem .5rem;font-size:.65rem;font-weight:600;display:inline-flex;align-items:center;gap:.25rem;backdrop-filter:blur(4px);}
.wf-badge-x{background:rgba(255,255,255,.4);border:none;color:#fff;border-radius:50%;width:13px;height:13px;font-size:.5rem;cursor:pointer;line-height:1;padding:0;}
.wf-add-step{border:2px dashed #cbd5e1;background:#f8fafc;border-radius:10px;width:105px;min-height:85px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;color:#94a3b8;font-size:.73rem;font-weight:600;transition:all .2s;flex-shrink:0;gap:.3rem;}
.wf-add-step:hover{border-color:#667eea;color:#667eea;background:#f0f0ff;}
.wf-tab-btn{padding:.45rem 1.1rem;border-radius:20px;border:none;font-weight:600;font-size:.83rem;cursor:pointer;background:#f1f5f9;color:#64748b;transition:all .2s;}
.wf-tab-btn.active{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;box-shadow:0 3px 8px rgba(102,126,234,.4);}
.perm-board{display:grid;grid-template-columns:200px 1fr 1fr;gap:1.5rem;}
.perm-roles{border-right:1px solid #f1f5f9;padding-right:1rem;}
.perm-role-item{display:block;padding:.55rem 1rem;border-left:3px solid transparent;color:#64748b;text-decoration:none;font-weight:500;font-size:.85rem;transition:all .2s;border-radius:0 6px 6px 0;}
.perm-role-item:hover{background:#f8fafc;color:#1e293b;}
.perm-role-item.active{border-left-color:#667eea;background:#f0f0ff;color:#667eea;}
.perm-col{background:#f8fafc;border-radius:12px;border:2px dashed #e2e8f0;padding:1.1rem;height:500px;overflow-y:auto;transition:all .2s;scrollbar-width:thin;}
.perm-col.assigned{background:#f0fdf4;border-color:#86efac;}
.perm-col.drag-over{border-color:#667eea;background:#f0f0ff;transform:scale(1.01);}
.perm-card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:.75rem;margin-bottom:.65rem;cursor:grab;display:flex;align-items:center;gap:.75rem;transition:all .2s;font-size:.83rem;}
.perm-card:hover{box-shadow:0 4px 12px rgba(0,0,0,.08);border-color:#667eea;transform:translateY(-2px);}
.perm-card-icon{width:30px;height:30px;border-radius:8px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#64748b;font-size:.78rem;}
.perm-card.assigned .perm-card-icon{background:#dcfce7;color:#16a34a;}
.perm-code{font-family:monospace;font-size:.7rem;background:#f1f5f9;padding:2px 5px;border-radius:4px;color:#64748b;}

/* Module groups inside permission columns */
.perm-col-group{margin-bottom:1.1rem;}
.perm-col-group:last-child{margin-bottom:.25rem;}
.perm-col-group-head{display:flex;align-items:center;gap:.5rem;margin-bottom:.45rem;padding:0 .15rem;flex-wrap:wrap;}
.perm-col-group-icon{width:24px;height:24px;border-radius:6px;display:inline-flex;align-items:center;justify-content:center;font-size:.7rem;flex-shrink:0;}
.perm-col-group-title{font-size:.74rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#334155;flex:1;min-width:72px;}
.perm-col-group-count{font-size:.68rem;font-weight:700;background:#e2e8f0;color:#475569;border-radius:9px;padding:1px 7px;flex-shrink:0;}

/* Permission Manager accordion (Section 3) */
.perm-mgr{display:flex;flex-direction:column;gap:.6rem;}
.perm-mgr-group{border:1px solid #e2e8f0;border-radius:10px;background:#fff;overflow:hidden;}
.perm-mgr-head{width:100%;display:flex;align-items:center;gap:.6rem;background:#f8fafc;border:none;padding:.6rem .85rem;cursor:pointer;text-align:left;color:#1e293b;font-weight:600;font-size:.88rem;}
.perm-mgr-head:hover{background:#eef2f7;}
.perm-mgr-icon-wrap{width:28px;height:28px;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0;}
.perm-mgr-title{flex:1;}
.perm-mgr-count{font-size:.7rem;font-weight:700;background:#e2e8f0;color:#475569;border-radius:9px;padding:1px 8px;margin-right:.4rem;}
.perm-mgr-chev{font-size:.7rem;color:#64748b;transition:transform .2s;}
.perm-mgr-group.collapsed .perm-mgr-chev{transform:rotate(-90deg);}
.perm-mgr-group.collapsed .perm-mgr-body{display:none;}
.perm-mgr-body{padding:0;}
.perm-mgr-body table{margin:0;}
.perm-mgr-row td{vertical-align:middle;}

@media(max-width:768px){.perm-board{grid-template-columns:1fr;}}
</style>


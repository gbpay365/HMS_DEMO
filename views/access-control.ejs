<%- include('partials/header') %>
<% var _ac = function(k, d, opts) {
  if (typeof t !== 'function') return d || k;
  var o = { ns: 'access', defaultValue: d || k };
  if (opts) Object.assign(o, opts);
  return t(k, o);
}; %>
<div class="page-wrapper"><div class="content">



<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap" style="gap:12px;">
  <div>
 <h1 class="h4 font-weight-bold mb-1" style="color:#1b2559;"><i class="fa fa-sitemap mr-2" style="color:#667eea;"></i><%= _ac('legacy_page.title', 'Workflow & Access Control') %></h1>
    <p class="text-muted small mb-0"><%= _ac('legacy_page.subtitle', 'Grant capabilities under Modules & permissions. Configure menus under Navigation. Map clinical steps under Workflow. Admin (1) and Super Admin (99) bypass all checks.') %></p>
  </div>
  <a href="/workflow-guides" class="hms-btn hms-btn-outline-primary btn-sm font-weight-bold"><i class="fa fa-book mr-1"></i><%= _ac('header.staff_guides', 'Staff guides') %></a>
</div>

<div class="alert border-0 shadow-sm mb-4 py-3 px-4" style="border-radius:12px;background:#f0f9ff;border:1px solid #e2e8f0 !important;">
  <div class="small" style="color:#334155;line-height:1.8;">
    <%= _ac('legacy_page.steps', '1. Modules � grant permissions per module and sub-capability. 2. Navigation � top tabs, menus, sub-menus, tiles (visibility only). 3. Workflow � OPD/IPD step map (documentation).') %>
  </div>
</div>

<!-- Main Tabs -->
<div class="d-flex mb-4" style="background:#fff;border-radius:12px;padding:.35rem;box-shadow:0 2px 8px rgba(0,0,0,.06);width:fit-content;gap:4px;">
  <button class="main-tab-btn active" id="mtab-modules" onclick="switchSection('modules',this)"><i class="fa fa-cubes mr-1"></i><%= _ac('legacy_page.tab_modules', 'Modules & permissions') %></button>
  <button class="main-tab-btn" id="mtab-navigation" onclick="switchSection('navigation',this)"><i class="fa fa-compass mr-1"></i><%= _ac('legacy_page.tab_navigation', 'Navigation') %></button>
  <button class="main-tab-btn" id="mtab-workflow" onclick="switchSection('workflow',this)"><i class="fa fa-sitemap mr-1"></i><%= _ac('legacy_page.tab_workflow', 'Workflow') %></button>
  <button class="main-tab-btn" id="mtab-setup" onclick="switchSection('setup',this)"><i class="fa fa-cog mr-1"></i><%= _ac('legacy_page.tab_setup', 'Catalogue & roles') %></button>
  <button class="main-tab-btn" id="mtab-audit" onclick="switchSection('audit',this)"><i class="fa fa-history mr-1"></i><%= _ac('legacy_page.tab_audit', 'Audit log') %></button>
</div>

<!-- Workflow map (documentation � does not grant permissions) -->
<div class="section-panel" id="section-workflow">
  <div class="d-flex justify-content-end mb-2">
    <button type="button" class="hms-btn hms-btn-primary btn-sm font-weight-bold" onclick="hmsWfSave()"><i class="fa fa-save mr-1"></i><%= _ac('legacy_page.save_workflow', 'Save workflow') %></button>
  </div>

  <!-- Portal Pills Toolbar � HORIZONTAL row matching PHP version -->
  <div class="wf-pills-toolbar mb-3">
 <span class="wf-pills-label"><i class="fa fa-long-arrow-right mr-1"></i><%= _ac('legacy_page.drag_portals', 'DRAG A PORTAL ONTO A STEP:') %></span>
 <% portals.forEach(function(p){ %>
 <div class="portal-pill" draggable="true" data-code="<%=p.code%>" data-label="<%=p.label%>" id="pill-<%=p.code%>">
 <i class="fa fa-th-large"></i> <%=p.label%>
 </div>
 <% }); %>
  </div>

  <!-- Workflow Canvas -->
  <div class="card border-0 shadow-sm mb-4 wf-canvas-card">

 <!-- OPD / IPD Tabs -->
 <div class="wf-tab-bar">
 <button class="wf-tab-btn active" onclick="switchWfTab('opd',this)"><i class="fa fa-hospital-o mr-1"></i><%= _ac('legacy_page.opd_tab', 'OPD � Outpatient Workflow') %></button>
 <button class="wf-tab-btn" onclick="switchWfTab('ipd',this)"><i class="fa fa-bed mr-1"></i><%= _ac('legacy_page.ipd_tab', 'IPD � Inpatient Workflow') %></button>
 </div>

 <!-- OPD Flow -->
 <div id="tab-opd" class="wf-flow-wrap">
 <div class="wf-flow" id="flow-opd">
 <% opdSteps.forEach(function(step, i){ %>
 <% if(i>0){ %><span class="wf-arrow"><i class="fa fa-arrow-right"></i></span><% } %>
 <div class="wf-step" id="step-opd-<%=step.step_key%>" style="background:<%=step.step_color||'#3182ce'%>"
 data-workflow="opd" data-key="<%=step.step_key%>"
 ondragover="allowDrop(event)" ondrop="dropOnStep(event)"
 ondragenter="this.classList.add('drop-over')" ondragleave="this.classList.remove('drop-over')">
 <div class="wf-step-label">
 <span class="step-label-text"><%=step.step_label%></span>
 <div style="display:flex;gap:3px;flex-shrink:0;">
 <button class="wf-step-edit" onclick="renameStep('opd','<%=step.step_key%>',this)" title="<%= _ac('shared.rename', 'Rename') %>"><i class="fa fa-pencil"></i></button>
 <% if(step.is_custom){ %><button class="wf-step-edit" onclick="deleteStep('opd','<%=step.step_key%>',this)" title="<%= _ac('shared.delete', 'Delete') %>" style="background:rgba(220,38,38,.4)"><i class="fa fa-trash"></i></button><% } %>
 </div>
 </div>
 <div class="wf-step-portals">
 <% (step.portals||[]).forEach(function(pc){ %>
 <span class="wf-badge" data-portal="<%=pc%>"><%=plMap[pc]||pc%> <button class="wf-badge-x" onclick="removePortal('opd','<%=step.step_key%>','<%=pc%>')">&times;</button></span>
 <% }); %>
 </div>
 </div>
 <% }); %>
 <span class="wf-arrow"><i class="fa fa-arrow-right"></i></span>
 <div class="wf-add-step" onclick="addStep('opd')"><i class="fa fa-plus fa-lg"></i><span><%= _ac('legacy_page.add_step', 'Add Step') %></span></div>
 </div>
 </div>

 <!-- IPD Flow -->
 <div id="tab-ipd" class="wf-flow-wrap" style="display:none">
 <div class="wf-flow" id="flow-ipd">
 <% ipdSteps.forEach(function(step, i){ %>
 <% if(i>0){ %><span class="wf-arrow"><i class="fa fa-arrow-right"></i></span><% } %>
 <div class="wf-step" id="step-ipd-<%=step.step_key%>" style="background:<%=step.step_color||'#3182ce'%>"
 data-workflow="ipd" data-key="<%=step.step_key%>"
 ondragover="allowDrop(event)" ondrop="dropOnStep(event)"
 ondragenter="this.classList.add('drop-over')" ondragleave="this.classList.remove('drop-over')">
 <div class="wf-step-label">
 <span class="step-label-text"><%=step.step_label%></span>
 <div style="display:flex;gap:3px;flex-shrink:0;">
 <button class="wf-step-edit" onclick="renameStep('ipd','<%=step.step_key%>',this)" title="<%= _ac('shared.rename', 'Rename') %>"><i class="fa fa-pencil"></i></button>
 <% if(step.is_custom){ %><button class="wf-step-edit" onclick="deleteStep('ipd','<%=step.step_key%>',this)" title="<%= _ac('shared.delete', 'Delete') %>" style="background:rgba(220,38,38,.4)"><i class="fa fa-trash"></i></button><% } %>
 </div>
 </div>
 <div class="wf-step-portals">
 <% (step.portals||[]).forEach(function(pc){ %>
 <span class="wf-badge" data-portal="<%=pc%>"><%=plMap[pc]||pc%> <button class="wf-badge-x" onclick="removePortal('ipd','<%=step.step_key%>','<%=pc%>')">&times;</button></span>
 <% }); %>
 </div>
 </div>
 <% }); %>
 <span class="wf-arrow"><i class="fa fa-arrow-right"></i></span>
 <div class="wf-add-step" onclick="addStep('ipd')"><i class="fa fa-plus fa-lg"></i><span><%= _ac('legacy_page.add_step', 'Add Step') %></span></div>
 </div>
 </div>
  </div><!-- /wf-canvas-card -->

  <!-- Bottom 2-col: Workflow Summary + How to Use -->
  <div class="row">
 <div class="col-lg-6 mb-3">
 <div class="card border-0 shadow-sm p-4" style="border-radius:12px;height:100%;">
 <h6 class="font-weight-bold mb-3"><i class="fa fa-file-text-o mr-2 text-primary"></i><%= _ac('legacy_page.wf_summary_title', 'Workflow Summary') %></h6>
 <div class="form-group mb-3">
 <select id="summaryPortalSel" class="hms-input w-full text-sm" onchange="loadSummary(this.value)">
 <option value=""><%= _ac('legacy_page.select_portal', '� Select a Portal �') %></option>
 <% portals.forEach(function(p){ %>
 <option value="<%=p.code%>"><%=p.label%></option>
 <% }); %>
 </select>
 </div>
 <div id="summaryText" class="small text-muted p-3 rounded" style="background:#f8fafc;min-height:90px;border:1px solid #e2e8f0;">
 <%= _ac('legacy_page.summary_placeholder', 'Select a portal above to see its auto-generated workflow summary.') %>
 </div>
 <div class="mt-3">
 <button class="hms-btn hms-btn-primary btn-sm font-weight-bold w-100" onclick="copySummary()"><i class="fa fa-copy mr-1"></i> <%= _ac('legacy_page.copy_summary', 'Copy Summary') %></button>
 </div>
 </div>
 </div>
 <div class="col-lg-6 mb-3">
 <div class="card border-0 shadow-sm p-4" style="border-radius:12px;height:100%;">
 <h6 class="font-weight-bold mb-3"><i class="fa fa-info-circle mr-2 text-primary"></i><%= _ac('legacy_page.how_to_title', 'How to Use the Designer') %></h6>
 <div style="font-size:.83rem;color:#475569;line-height:2.4;">
 <div><i class="fa fa-hand-pointer-o mr-2 text-primary"></i><%= _ac('legacy_page.how_to_1', 'Drag a portal pill onto a step to show which portal handles that stage.') %></div>
 <div><i class="fa fa-times-circle mr-2 text-danger"></i><%= _ac('legacy_page.how_to_2', 'Click � on a badge to remove a portal from that step.') %></div>
 <div><i class="fa fa-pencil mr-2 text-warning"></i><%= _ac('legacy_page.how_to_3', 'Click the pencil icon on any step to rename it.') %></div>
 <div><i class="fa fa-plus-circle mr-2 text-success"></i><%= _ac('legacy_page.how_to_4', 'Click Add Step to insert a new custom clinical stage.') %></div>
 <div><i class="fa fa-refresh mr-2" style="color:#0c8b8b;"></i><%= _ac('legacy_page.how_to_5', 'Portal assignment is documentation only. Grant access under Role access.') %></div>
 </div>
 </div>
 </div>
  </div>

</div><!-- /section-workflow -->

<!-- - SECTION 2: Role Permissions - -->

<div class="section-panel active" id="section-acl">
  <div class="card border-0 shadow-sm p-4" style="border-radius:12px;">
 <h5 class="font-weight-bold mb-1"><i class="fa fa-cubes mr-2 text-primary"></i><%= _ac('legacy_page.modules_heading', 'Modules & permissions') %></h5>
 <p class="text-muted small mb-3"><%= _ac('legacy_page.modules_desc', 'Grant or revoke capabilities by module and sub-capability (drag cards or use All / None on each module). This is the only place that grants real access. Configure menus on the Navigation tab.') %></p>
 <% if (selRole && !['1','99'].includes(String(selRole))) { %>
 <div class="d-flex flex-wrap align-items-center mb-4 p-3 rounded" style="background:#f8fafc;border:1px solid #e2e8f0;gap:10px;">
   <span class="small font-weight-bold text-secondary mb-0 text-uppercase" style="letter-spacing:.04em;"><i class="fa fa-copy mr-1"></i><%= _ac('legacy_page.copy_from_role', 'Copy from role') %></span>
   <select id="aclCopyFrom" class="hms-input w-full text-sm" style="max-width:280px;">
     <option value=""><%= _ac('legacy_page.select_source_role', '� Select source role �') %></option>
     <% roles.forEach(function(r){
       if (String(r.role)===String(selRole)) return;
       if (['1','99'].indexOf(String(r.role))>=0) return;
     %>
     <option value="<%= r.role %>"><%= r.title %> (#<%= r.role %>)</option>
     <% }); %>
   </select>
   <button type="button" class="hms-btn hms-btn-primary hms-btn-sm font-weight-bold" onclick="aclCopyFromRole()"><i class="fa fa-check mr-1"></i><%= _ac('legacy_page.replace_grants', 'Replace grants') %></button>
   <span class="small text-muted"><%= _ac('legacy_page.copy_grants_hint', 'Copies every permission from the source role onto {{role}} (portals are unchanged).', { role: selRoleTitle }) %></span>
 </div>
 <% } %>
 <% if (selRole && aclRoleSummary) { %>
 <div class="card border-0 shadow-sm mb-4" style="border-radius:12px;background:linear-gradient(135deg,#f8fafc 0%,#f0fdf4 100%);border:1px solid #e2e8f0 !important;">
   <div class="card-body py-3 px-4">
     <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap" style="gap:8px;">
       <span class="font-weight-bold" style="color:#1e293b;"><i class="fa fa-dashboard mr-2 text-primary"></i><%= _ac('legacy_page.footprint', 'Role footprint � {{role}} (#{{id}})', { role: selRoleTitle, id: selRole }) %></span>
       <span class="badge badge-light border"><i class="fa fa-info-circle mr-1"></i><%= _ac('legacy_page.at_glance', 'At-a-glance') %></span>
     </div>
     <div class="row text-center">
       <div class="col-6 col-md-3 mb-2 mb-md-0">
         <div class="small text-muted text-uppercase" style="letter-spacing:.06em;font-size:.65rem;"><%= _ac('permissions.capabilities', 'Capabilities') %></div>
         <div class="font-weight-bold" style="font-size:1.35rem;color:#1a6bd8;"><%= aclRoleSummary.permissionsGranted %><span class="text-muted font-weight-normal" style="font-size:.85rem;"> / <%= aclRoleSummary.permissionsTotal %></span></div>
       </div>
       <div class="col-6 col-md-3 mb-2 mb-md-0">
         <div class="small text-muted text-uppercase" style="letter-spacing:.06em;font-size:.65rem;"><%= _ac('permissions.portals_kpi', 'Portals') %></div>
         <div class="font-weight-bold" style="font-size:1.35rem;color:#0c8b8b;"><%= aclRoleSummary.portalsAllowed %><span class="text-muted font-weight-normal" style="font-size:.85rem;"> / <%= aclRoleSummary.portalsTotal %></span></div>
       </div>
       <div class="col-6 col-md-3 mb-2 mb-md-0">
         <div class="small text-muted text-uppercase" style="letter-spacing:.06em;font-size:.65rem;"><%= _ac('legacy_page.home_portal', 'Home portal') %></div>
         <div class="font-weight-bold" style="font-size:.95rem;color:#15803d;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="<%= aclRoleSummary.homePortalLabel || '' %>">
           <% if (aclRoleSummary.homePortalLabel) { %><%= aclRoleSummary.homePortalLabel %><% } else { %><span class="text-muted font-weight-normal">�</span><% } %>
         </div>
       </div>
       <div class="col-6 col-md-3">
         <div class="small text-muted text-uppercase" style="letter-spacing:.06em;font-size:.65rem;"><%= _ac('legacy_page.ui_hides', 'UI hides') %></div>
         <div class="font-weight-bold" style="font-size:1.35rem;color:#7c3aed;"><%= aclRoleSummary.uiHideRowCount %><span class="text-muted font-weight-normal" style="font-size:.72rem;"> <%= _ac('legacy_page.rows', 'rows') %></span></div>
         <div class="small text-muted" style="font-size:.68rem;"><%= _ac('legacy_page.tiles_hidden', '{{hidden}} / {{total}} tiles hidden', { hidden: aclRoleSummary.uiHiddenTiles, total: aclRoleSummary.uiTotalTiles }) %></div>
         <div class="small text-muted" style="font-size:.68rem;"><%= _ac('legacy_page.row_actions_hidden', '{{hidden}} / {{total}} row actions hidden', { hidden: aclRoleSummary.actionMenuHidden, total: aclRoleSummary.actionMenuTotal }) %></div>
       </div>
     </div>
   </div>
 </div>
 <% } %>

 <div class="perm-board">
 <!-- Role list -->
 <div class="perm-roles">
 <div class="small font-weight-bold text-muted text-uppercase mb-2 px-3"><%= _ac('roles.title', 'Roles') %></div>
 <input type="text" id="roleListFilter" class="hms-input w-full text-sm mx-2 mb-2" style="max-width:calc(100% - 1rem);" placeholder="<%= _ac('roles.search_ph', 'Search roles�') %>" onkeyup="filterRoleList(this)">
 <% roles.forEach(function(r){ %>
 <a href="/access-control?role=<%=r.role%>#section-modules"
 class="perm-role-item <%=String(r.role)===String(selRole)?'active':''%>"
 data-search="<%= String(r.title + ' ' + r.role).toLowerCase().replace(/"/g, '') %>"
 onclick="switchSection('modules',document.getElementById('mtab-modules'))">
 <span><%=r.title%></span>
 <span class="text-muted small" style="float:right;">#<%=r.role%></span>
 </a>
 <% }); %>
 </div>

 <% if(selRole){ %>
 <!-- Hidden perms -->
 <div class="perm-col-wrap">
 <div class="mb-3 d-flex justify-content-between align-items-center">
 <span class="small font-weight-bold text-muted"><i class="fa fa-minus-circle mr-1"></i><%= _ac('legacy_page.not_granted', 'Not granted to role') %></span>
 <span class="small text-muted"><%= _ac('legacy_page.role_label', 'Role:') %> <strong><%=selRoleTitle%></strong></span>
 </div>
 <input type="text" class="hms-input w-full text-sm mb-2" placeholder="<%= _ac('legacy_page.filter_not_granted_ph', 'Filter not granted...') %>" onkeyup="filterPerms(this,'col-available')">
 <div class="small text-muted mb-2"><%= _ac('legacy_page.not_granted_count', '{{count}} not granted', { count: availablePerms.length }) %></div>
 <div class="perm-col" id="col-available" ondragover="allowDrop(event)" ondrop="permDrop(event,'revoke')" ondragenter="this.classList.add('drag-over')" ondragleave="this.classList.remove('drag-over')">
   <% availablePermsGrouped.forEach(function(g){ %>
   <div class="perm-col-group" data-mod="<%= g.meta.code %>">
     <div class="perm-col-group-head">
       <span class="perm-col-group-icon" style="background:<%= (g.meta.color || '#1a6bd8') %>1a;color:<%= g.meta.color || '#1a6bd8' %>;"><i class="fa <%= g.meta.icon || 'fa-cube' %>"></i></span>
       <span class="perm-col-group-title"><%= g.meta.label %></span>
       <% if (selRole && ['1','99'].indexOf(String(selRole)) === -1) { %>
       <span class="perm-col-group-actions d-inline-flex align-items-center" style="gap:4px;">
         <button type="button" class="hms-btn hms-btn-outline-success hms-btn-sm py-0 px-1" title="<%= _ac('legacy_page.grant_module', 'Grant entire module') %>" onclick="aclModuleBulk('<%= g.meta.code %>', true)"><%= _ac('legacy_page.all', 'All') %></button>
         <button type="button" class="hms-btn hms-btn-secondary hms-btn-sm py-0 px-1" title="<%= _ac('legacy_page.revoke_module', 'Revoke entire module') %>" onclick="aclModuleBulk('<%= g.meta.code %>', false)"><%= _ac('legacy_page.none', 'None') %></button>
       </span>
       <% } %>
       <span class="perm-col-group-count"><%= g.items.length %></span>
     </div>
     <% g.items.forEach(function(p){ %>
     <div class="perm-card" draggable="true" ondragstart="permDrag(event)" data-id="<%=p.id%>" data-mod="<%= g.meta.code %>">
       <div class="perm-card-icon" style="color:<%= g.meta.color || '#475569' %>;"><i class="fa <%= g.meta.icon || 'fa-cube' %>"></i></div>
       <div><div style="font-weight:600;color:#1e293b;margin-bottom:2px;font-size:.83rem;"><%=p.label%><% if (p.action) { %> <span class="badge badge-light border ml-1" style="font-size:.65rem;font-weight:600;"><%= p.action %></span><% } %></div><code class="perm-code"><%=p.code%></code></div>
     </div>
     <% }); %>
   </div>
   <% }); %>
 </div>
 </div>
<!-- Assigned perms -->
<div class="perm-col-wrap">
<div class="mb-3 d-flex justify-content-between align-items-center flex-wrap" style="gap:6px;">
<span class="small font-weight-bold text-success"><i class="fa fa-check-circle mr-1"></i><%= _ac('legacy_page.granted_to_role', 'Granted to role') %></span>
<div class="d-flex" style="gap:6px;">
  <button class="hms-btn hms-btn-success hms-btn-sm py-1 px-3 font-weight-bold" onclick="hmsAclSave()"><i class="fa fa-save mr-1"></i><%= _ac('shared.save', 'Save') %></button>
</div>
</div>
 <input type="text" class="hms-input w-full text-sm mb-2" placeholder="<%= _ac('legacy_page.filter_granted_ph', 'Filter granted...') %>" onkeyup="filterPerms(this,'col-assigned')">
 <div class="small text-muted mb-2"><%= _ac('legacy_page.granted_count', '{{count}} granted', { count: assignedPerms.length }) %></div>
 <div class="perm-col assigned" id="col-assigned" ondragover="allowDrop(event)" ondrop="permDrop(event,'grant')" ondragenter="this.classList.add('drag-over')" ondragleave="this.classList.remove('drag-over')">
   <% assignedPermsGrouped.forEach(function(g){ %>
   <div class="perm-col-group" data-mod="<%= g.meta.code %>">
     <div class="perm-col-group-head">
       <span class="perm-col-group-icon" style="background:<%= (g.meta.color || '#16a34a') %>1a;color:<%= g.meta.color || '#16a34a' %>;"><i class="fa <%= g.meta.icon || 'fa-check' %>"></i></span>
       <span class="perm-col-group-title"><%= g.meta.label %></span>
       <% if (selRole && ['1','99'].indexOf(String(selRole)) === -1) { %>
       <span class="perm-col-group-actions d-inline-flex align-items-center" style="gap:4px;">
         <button type="button" class="hms-btn hms-btn-outline-success hms-btn-sm py-0 px-1" title="<%= _ac('legacy_page.grant_module', 'Grant entire module') %>" onclick="aclModuleBulk('<%= g.meta.code %>', true)"><%= _ac('legacy_page.all', 'All') %></button>
         <button type="button" class="hms-btn hms-btn-secondary hms-btn-sm py-0 px-1" title="<%= _ac('legacy_page.revoke_module', 'Revoke entire module') %>" onclick="aclModuleBulk('<%= g.meta.code %>', false)"><%= _ac('legacy_page.none', 'None') %></button>
       </span>
       <% } %>
       <span class="perm-col-group-count"><%= g.items.length %></span>
     </div>
     <% g.items.forEach(function(p){ %>
     <div class="perm-card assigned" draggable="true" ondragstart="permDrag(event)" data-id="<%=p.id%>" data-mod="<%= g.meta.code %>">
       <div class="perm-card-icon" style="color:<%= g.meta.color || '#16a34a' %>;"><i class="fa fa-check"></i></div>
       <div><div style="font-weight:600;color:#1e293b;margin-bottom:2px;font-size:.83rem;"><%=p.label%><% if (p.action) { %> <span class="badge badge-light border ml-1" style="font-size:.65rem;font-weight:600;"><%= p.action %></span><% } %></div><code class="perm-code"><%=p.code%></code></div>
     </div>
     <% }); %>
   </div>
   <% }); %>
 </div>
 </div>
 <% } else { %>
 <div class="perm-col" style="grid-column:span 2;display:flex;align-items:center;justify-content:center;color:#94a3b8;min-height:200px;"><%= _ac('legacy_page.select_role_left', 'Select a role from the left to manage permissions.') %></div>
 <% } %>
 </div>
  </div>

  <% if (selRole && !['1','99'].includes(String(selRole)) && Array.isArray(rolePortalRows) && rolePortalRows.length) { %>
  <!-- Role Portals � drives staffHomeUrl(role) -->
  <div class="card border-0 shadow-sm p-4 mt-4" style="border-radius:12px;">
    <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap" style="gap:8px;">
      <div>
        <h5 class="font-weight-bold mb-1"><i class="fa fa-compass mr-2 text-primary"></i><%= _ac('legacy_page.role_portals_title', 'Role Portals') %></h5>
        <p class="text-muted small mb-0">
          <%= _ac('legacy_page.role_portals_desc', 'Choose which staff portals {{role}} can open, and which one is its Home (the page they land on after login). Changes apply immediately.', { role: selRoleTitle }) %>
        </p>
      </div>
      <span class="badge badge-light border align-self-center"><i class="fa fa-home mr-1"></i><%= _ac('legacy_page.login_home_badge', 'Login & "My Home" target') %></span>
    </div>

    <div class="table-responsive">
    <table class="table table-sm mb-0" style="font-size:.88rem;">
      <thead style="background:#f8fafc;">
        <tr>
          <th style="width:64px;font-size:.7rem;text-transform:uppercase;color:#64748b;" class="text-center"><%= _ac('legacy_page.col_allow', 'Allow') %></th>
          <th style="width:64px;font-size:.7rem;text-transform:uppercase;color:#64748b;" class="text-center"><%= _ac('shared.home', 'Home') %></th>
          <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;"><%= _ac('shared.portal', 'Portal') %></th>
          <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;"><%= _ac('shared.code', 'Code') %></th>
        </tr>
      </thead>
      <tbody>
        <% rolePortalRows.forEach(function(rp){ %>
        <tr>
          <td class="text-center align-middle">
            <input type="checkbox" class="rp-assign" data-code="<%= rp.code %>" <% if (rp.assigned) { %>checked<% } %>
                   onchange="rpToggleAssign(this)">
          </td>
          <td class="text-center align-middle">
            <input type="radio" name="rp_home_<%=selRole%>" class="rp-home" data-code="<%= rp.code %>"
                   <% if (rp.is_home) { %>checked<% } %>
                   <% if (!rp.assigned) { %>disabled<% } %>
                   onchange="rpSetHome(this)">
          </td>
          <td class="align-middle font-weight-600" style="color:#1e293b;"><%= rp.label %></td>
          <td class="align-middle"><code style="font-size:.74rem;background:#f1f5f9;padding:2px 6px;border-radius:4px;color:#475569;"><%= rp.code %></code></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    </div>
    <div class="small text-muted mt-2">
      <i class="fa fa-info-circle mr-1"></i>
      <%= _ac('portals.home_hint', 'The first portal assigned is set as Home automatically. Removing the Home portal promotes the next assigned one.') %>
    </div>
  </div>
  <% } %>

</div><!-- /section-acl -->

<div class="section-panel" id="section-navigation">
  <%- include('partials/access-control-navigation-hub') %>
</div>

<!-- - SECTION 3: Permission Manager - -->
<div class="section-panel" id="section-perm">
  <div class="card border-0 shadow-sm p-4" style="border-radius:12px;">
 <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap" style="gap:8px;">
   <div>
     <h5 class="font-weight-bold mb-1"><i class="fa fa-list mr-2 text-primary"></i><%= _ac('legacy_page.perm_mgr_title', 'Permission Manager') %></h5>
     <p class="text-muted small mb-0"><%= _ac('legacy_page.perm_mgr_sub', 'System-wide granular permission definitions, grouped by module.') %></p>
   </div>
   <div class="d-flex" style="gap:6px;">
     <input type="text" id="permMgrFilter" class="hms-input w-full text-sm"
            placeholder="<%= _ac('legacy_page.filter_permissions_ph', 'Filter permissions...') %>" style="width:240px;" onkeyup="permMgrFilter(this.value)">
     <button class="hms-btn hms-btn-primary btn-sm font-weight-bold" onclick="permAddModal()"><i class="fa fa-plus mr-1"></i><%= _ac('shared.add', '+ Add') %></button>
   </div>
 </div>

 <% if (!Array.isArray(allPermsGrouped) || !allPermsGrouped.length) { %>
   <div class="text-muted small p-4 text-center"><%= _ac('legacy_page.no_permissions', 'No permissions defined yet.') %></div>
 <% } else { %>
 <div class="perm-mgr">
   <% allPermsGrouped.forEach(function(g){ %>
   <div class="perm-mgr-group" data-mod="<%= g.meta.code %>">
     <button type="button" class="perm-mgr-head" onclick="permMgrToggle(this)" aria-expanded="true">
       <span class="perm-mgr-icon-wrap" style="background:<%= (g.meta.color || '#1a6bd8') %>1a;">
         <i class="fa <%= g.meta.icon || 'fa-cube' %>" style="color:<%= g.meta.color || '#1a6bd8' %>;"></i>
       </span>
       <span class="perm-mgr-title"><%= g.meta.label %></span>
       <span class="perm-mgr-count"><%= g.items.length %></span>
       <i class="fa fa-chevron-down perm-mgr-chev"></i>
     </button>
     <div class="perm-mgr-body">
       <table class="table table-hover table-sm mb-0" style="font-size:.85rem;">
         <thead style="background:#f8fafc;">
           <tr>
             <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;width:60px;">ID</th>
             <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;"><%= _ac('shared.code', 'Code') %></th>
             <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;"><%= _ac('shared.label', 'Label') %></th>
             <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;width:90px;"><%= _ac('shared.action', 'Action') %></th>
             <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;" class="text-right" width="120"><%= _ac('shared.actions', 'Actions') %></th>
           </tr>
         </thead>
         <tbody>
           <% g.items.forEach(function(p){ %>
           <tr class="perm-mgr-row" data-search="<%= ((p.code||'')+' '+(p.label||'')+' '+(p.module_code||'')+' '+(p.action||'')).toLowerCase() %>">
             <td class="text-muted">#<%=p.id%></td>
             <td><code style="font-size:.78rem;background:#f1f5f9;padding:2px 6px;border-radius:4px;color:#475569;"><%=p.code%></code></td>
             <td class="font-weight-600"><%=p.label%></td>
             <td><span class="badge badge-light border text-uppercase" style="letter-spacing:.04em;"><%= p.action || '�' %></span></td>
             <td class="text-right">
               <button class="hms-btn hms-btn-outline-primary hms-btn-sm mr-1" onclick='permEditModal(<%- JSON.stringify(p) %>)'><i class="fa fa-pencil"></i></button>
               <button class="hms-btn hms-btn-outline-danger hms-btn-sm" onclick="permDelete(<%=p.id%>)"><i class="fa fa-trash"></i></button>
             </td>
           </tr>
           <% }); %>
         </tbody>
       </table>
     </div>
   </div>
   <% }); %>
 </div>
 <% } %>
  </div>
</div><!-- /section-perm -->

<!-- - SECTION 4: Role Manager - -->
<div class="section-panel" id="section-role">
  <div class="card border-0 shadow-sm p-4" style="border-radius:12px;">
 <div class="d-flex justify-content-between align-items-center mb-4">
 <div><h5 class="font-weight-bold mb-1"><i class="fa fa-users mr-2 text-primary"></i><%= _ac('legacy_page.role_mgr_title', 'Role Manager') %></h5>
 <p class="text-muted small mb-0"><%= _ac('legacy_page.role_mgr_sub', 'Define and manage hospital staff roles.') %></p></div>
 <button class="hms-btn hms-btn-primary btn-sm font-weight-bold" onclick="roleAddModal()"><i class="fa fa-plus mr-1"></i><%= _ac('legacy_page.add_role_btn', 'Add Role') %></button>
 </div>
 <div class="table-responsive">
 <table class="table table-hover mb-0" style="font-size:.85rem;">
 <thead style="background:#f8fafc;"><tr>
 <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;width:100px;"><%= _ac('shared.code', 'Code') %></th>
 <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;"><%= _ac('legacy_page.role_title_col', 'Role Title') %></th>
 <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;" class="text-right"><%= _ac('shared.actions', 'Actions') %></th>
 </tr></thead>
 <tbody>
 <% allRoles.forEach(function(r){ %>
 <tr>
 <td><code style="font-size:.78rem;background:#f1f5f9;padding:2px 6px;border-radius:4px;color:#475569;"><%=r.role%></code></td>
 <td class="font-weight-600"><%=r.title%></td>
 <td class="text-right">
 <button class="hms-btn hms-btn-outline-primary hms-btn-sm mr-1" onclick='roleEditModal(<%- JSON.stringify(r) %>)'><i class="fa fa-pencil"></i></button>
 <% if(!['1','99'].includes(String(r.role))){ %>
 <button class="hms-btn hms-btn-outline-danger hms-btn-sm" onclick="roleDelete('<%=r.role%>')"><i class="fa fa-trash"></i></button>
 <% } %>
 </td>
 </tr>
 <% }); %>
 </tbody>
 </table>
 </div>
  </div>
</div><!-- /section-role -->

<!-- - SECTION 5: Audit Log - -->
<div class="section-panel" id="section-audit">
  <div class="card border-0 shadow-sm p-4" style="border-radius:12px;">
    <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap" style="gap:8px;">
      <div>
        <h5 class="font-weight-bold mb-1"><i class="fa fa-history mr-2 text-primary"></i><%= _ac('audit.title', 'ACL audit log') %></h5>
        <p class="text-muted small mb-0"><%= _ac('legacy_page.audit_sub', 'Every permission grant/revoke, role / portal / UI-visibility change, and workflow designer step edit is recorded here. Filter to narrow down the trail.') %></p>
      </div>
      <div class="d-flex flex-wrap" style="gap:6px;">
      <a class="hms-btn hms-btn-secondary hms-btn-sm" href="/access-control?audit_limit=<%= (auditFilter && auditFilter.limit) || 100 %>#section-audit"
         onclick="switchSection('audit',document.getElementById('mtab-audit'))">
         <i class="fa fa-refresh mr-1"></i><%= _ac('shared.refresh', 'Refresh') %>
      </a>
      <button type="button" class="hms-btn hms-btn-outline-primary hms-btn-sm font-weight-bold" onclick="auditExportCsv()">
        <i class="fa fa-download mr-1"></i><%= _ac('shared.export_csv', 'Export CSV') %>
      </button>
      </div>
    </div>

    <form id="auditFilterForm" method="get" action="/access-control" class="form-row align-items-end mb-3"
          onsubmit="setTimeout(function(){switchSection('audit',document.getElementById('mtab-audit'));}, 50);">
      <input type="hidden" name="role" value="<%= selRole %>">
      <div class="col-md-3 mb-2">
        <label class="small text-uppercase font-weight-bold text-muted mb-1" style="letter-spacing:.05em;"><%= _ac('shared.role', 'Role') %></label>
        <select name="audit_role" class="hms-input w-full text-sm">
          <option value=""><%= _ac('shared.all_roles', 'All roles') %></option>
          <% (allRoles || []).forEach(function(r){ %>
            <option value="<%= r.role %>" <% if (auditFilter && String(auditFilter.role)===String(r.role)) { %>selected<% } %>><%= r.title %> (#<%= r.role %>)</option>
          <% }); %>
        </select>
      </div>
      <div class="col-md-3 mb-2">
        <label class="small text-uppercase font-weight-bold text-muted mb-1" style="letter-spacing:.05em;"><%= _ac('shared.action', 'Action') %></label>
        <select name="audit_action" class="hms-input w-full text-sm">
          <option value=""><%= _ac('shared.all_actions', 'All actions') %></option>
          <% (auditActionOptions || []).forEach(function(a){ %>
            <option value="<%= a.action %>" <% if (auditFilter && auditFilter.action===a.action) { %>selected<% } %>><%= a.action %> (<%= a.n %>)</option>
          <% }); %>
        </select>
      </div>
      <div class="col-md-3 mb-2">
        <label class="small text-uppercase font-weight-bold text-muted mb-1" style="letter-spacing:.05em;"><%= _ac('shared.actor', 'Actor') %></label>
        <input type="text" name="audit_actor" class="hms-input w-full text-sm"
               placeholder="<%= _ac('audit.actor_ph', 'name or user id') %>"
               value="<%= (auditFilter && auditFilter.actor) || '' %>">
      </div>
      <div class="col-md-2 mb-2">
        <label class="small text-uppercase font-weight-bold text-muted mb-1" style="letter-spacing:.05em;"><%= _ac('audit.show', 'Show') %></label>
        <select name="audit_limit" class="hms-input w-full text-sm">
          <% [50,100,200,500,1000,2000].forEach(function(n){ %>
            <option value="<%= n %>" <% if (auditFilter && Number(auditFilter.limit)===n) { %>selected<% } %>><%= _ac('shared.show_last', 'Last {{n}}', { n: n }) %></option>
          <% }); %>
        </select>
      </div>
      <div class="col-md-1 mb-2 text-right">
        <button type="submit" class="hms-btn hms-btn-primary btn-sm font-weight-bold w-100">
          <i class="fa fa-filter"></i>
        </button>
      </div>
    </form>

    <% if (!Array.isArray(auditRows) || !auditRows.length) { %>
      <div class="text-muted small p-4 text-center border rounded" style="background:#f8fafc;">
        <i class="fa fa-inbox mr-1"></i><%= _ac('legacy_page.audit_empty', 'No audit entries match this filter yet.') %>
      </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover table-sm mb-0" style="font-size:.85rem;">
        <thead style="background:#f8fafc;">
          <tr>
            <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;width:170px;"><%= _ac('shared.when', 'When') %></th>
            <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;width:160px;"><%= _ac('shared.actor', 'Actor') %></th>
            <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;width:130px;"><%= _ac('shared.action', 'Action') %></th>
            <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;width:90px;"><%= _ac('shared.role', 'Role') %></th>
            <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;"><%= _ac('shared.target', 'Target') %></th>
            <th style="font-size:.7rem;text-transform:uppercase;color:#64748b;"><%= _ac('shared.detail', 'Detail') %></th>
          </tr>
        </thead>
        <tbody>
          <% auditRows.forEach(function(a){
               // action → bootstrap colour buckets so a reviewer can scan quickly
               var actClass = 'secondary';
               if (/^grant$|portal_assign|portal_set_home|role_add|perm_add|ui_show/.test(a.action)) actClass = 'success';
               else if (/^revoke$|portal_unassign|role_delete|perm_delete|ui_hide/.test(a.action))  actClass = 'danger';
               else if (/_edit$/.test(a.action)) actClass = 'info';
               else if (/^wf_/.test(a.action)) actClass = 'warning';
          %>
          <tr>
            <td class="text-muted"><%= a.created_at ? new Date(a.created_at).toLocaleString() : '' %></td>
            <td>
              <% if (a.actor_name) { %>
                <span class="font-weight-600" style="color:#1e293b;"><%= a.actor_name %></span>
                <% if (a.actor_id) { %><span class="text-muted small">#<%= a.actor_id %></span><% } %>
              <% } else { %>
                <span class="text-muted">�</span>
              <% } %>
            </td>
            <td><span class="badge badge-<%= actClass %>"><%= a.action %></span></td>
            <td><% if (a.role) { %><code style="font-size:.74rem;background:#f1f5f9;padding:2px 6px;border-radius:4px;color:#475569;">#<%= a.role %></code><% } else { %><span class="text-muted">�</span><% } %></td>
            <td><% if (a.target) { %><code style="font-size:.74rem;background:#f1f5f9;padding:2px 6px;border-radius:4px;color:#475569;"><%= a.target %></code><% } else { %><span class="text-muted">�</span><% } %></td>
            <td class="small text-muted" style="max-width:340px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= a.detail || '' %>"><%= a.detail || '' %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <div class="small text-muted mt-2">
      <i class="fa fa-info-circle mr-1"></i>
      <%= _ac('legacy_page.audit_showing', 'Showing the {{count}} most recent entries', { count: auditRows.length }) %>
      <% if ((auditFilter && (auditFilter.role || auditFilter.action || auditFilter.actor))) { %>
        <%= _ac('legacy_page.audit_filtered', 'matching the current filter.') %>
      <% } else { %><%= _ac('legacy_page.audit_unfiltered', '(unfiltered).') %><% } %>
    </div>
    <% } %>
  </div>
</div><!-- /section-audit -->

<!-- Modals -->
<div class="modal fade" id="modalPerm" tabindex="-1" role="dialog" aria-labelledby="modalPermTitle">
  <div class="modal-dialog"><div class="modal-content">
 <div class="modal-header bg-primary text-white"><h5 class="modal-title" id="modalPermTitle"><%= _ac('legacy_page.modal_add_perm', 'Add Permission') %></h5><button type="button" class="close text-white" data-dismiss="modal" aria-label="<%= _ac('shared.cancel', 'Cancel') %>"><span aria-hidden="true">&times;</span></button></div>
 <div class="modal-body">
 <input type="hidden" id="p_id">
 <div class="form-group"><label class="font-weight-bold small"><%= _ac('shared.code', 'Code') %></label><input type="text" id="p_code" class="hms-input w-full" placeholder="<%= _ac('legacy_page.code_ph', 'e.g. pharmacy.read') %>"></div>
 <div class="form-group"><label class="font-weight-bold small"><%= _ac('shared.label', 'Label') %></label><input type="text" id="p_label" class="hms-input w-full" placeholder="<%= _ac('legacy_page.label_ph', 'e.g. View pharmacy stock') %>"></div>
 <div class="form-group"><label class="font-weight-bold small"><%= _ac('legacy_page.group_area', 'Group Area') %></label><input type="number" id="p_gap" class="hms-input w-full" value="0"></div>
 </div>
 <div class="modal-footer"><button type="button" class="hms-btn hms-btn-secondary" data-dismiss="modal"><%= _ac('shared.cancel', 'Cancel') %></button><button type="button" class="hms-btn hms-btn-primary font-weight-bold" onclick="permSave()"><%= _ac('legacy_page.save_permission', 'Save Permission') %></button></div>
  </div></div>
</div>

<div class="modal fade" id="modalRole" tabindex="-1" role="dialog" aria-labelledby="modalRoleTitle">
  <div class="modal-dialog"><div class="modal-content">
 <div class="modal-header bg-primary text-white"><h5 class="modal-title" id="modalRoleTitle"><%= _ac('legacy_page.modal_add_role', 'Add Role') %></h5><button type="button" class="close text-white" data-dismiss="modal" aria-label="<%= _ac('shared.cancel', 'Cancel') %>"><span aria-hidden="true">&times;</span></button></div>
 <div class="modal-body">
 <input type="hidden" id="r_id">
 <div class="form-group"><label class="font-weight-bold small"><%= _ac('legacy_page.role_title_col', 'Role Title') %></label><input type="text" id="r_title" class="hms-input w-full" placeholder="<%= _ac('legacy_page.role_title_ph', 'e.g. Finance Manager') %>"></div>
 <div class="form-group" id="r_clone_wrap">
   <label class="font-weight-bold small d-flex align-items-center" style="gap:.4rem;">
     <i class="fa fa-clone text-muted" aria-hidden="true"></i> <%= _ac('legacy_page.clone_from_role', 'Start from existing role') %>
     <span class="badge badge-light border ml-auto" style="font-weight:500;color:#64748b;"><%= _ac('legacy_page.optional', 'optional') %></span>

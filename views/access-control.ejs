       <option value="<%= rr.role %>"><%= rr.title %> (#<%= rr.role %>)</option>
     <% }); %>
   </select>
   <div class="small text-muted mt-1">
     <i class="fa fa-info-circle mr-1"></i>
     <%= _ac('legacy_page.clone_hint', "Copies permissions, portal access, Home portal, and any UI hide overrides from the chosen role. The new role's title still needs to be unique.") %>

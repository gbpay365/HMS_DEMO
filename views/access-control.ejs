<script>
var _L = <%- JSON.stringify(_aclJs) %>;
var currentRole = "<%=selRole%>";
var draggingPortal = null;

// ── Tab switching 
var ACL_TAB_GROUPS = {
  modules: ['acl'],
  navigation: ['navigation'],
  workflow: ['workflow'],
  setup: ['perm', 'role'],
  audit: ['audit'],
  roles: ['acl'],
  acl: ['acl'],
  perm: ['perm', 'role'],
  role: ['perm', 'role']
};
function switchSection(name, btn) {
  var key = String(name || '');
  if (key === 'acl' || key === 'roles') key = 'modules';
  if (key === 'navstudio' || key === 'am') key = 'navigation';
  if (key === 'perm' || key === 'role') key = 'setup';
  document.querySelectorAll('.section-panel').forEach(function(p) { p.classList.remove('active'); });
  document.querySelectorAll('.main-tab-btn').forEach(function(b) { b.classList.remove('active'); });
  var ids = ACL_TAB_GROUPS[key] || [key];
  ids.forEach(function(id) {
    var el = document.getElementById('section-' + id);
    if (el) el.classList.add('active');
  });
  var tabBtn = document.getElementById('mtab-' + key) || btn;
  if (tabBtn) tabBtn.classList.add('active');
}
function switchWfTab(tab, btn) {
  document.getElementById('tab-opd').style.display = tab==='opd' ? '' : 'none';
  document.getElementById('tab-ipd').style.display = tab==='ipd' ? '' : 'none';
  document.querySelectorAll('.wf-tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// ── Handle hash on load 
window.addEventListener('DOMContentLoaded', function(){
  // Accept both "#audit" and "#section-audit" so links like
  //   /access-control?audit_role=11#section-audit
  // pre-select the right tab. Strips the optional 'section-' prefix.
  var hash = location.hash.replace('#','').replace(/^section-/, '');
  if (hash === 'acl' || hash === 'roles') hash = 'modules';
  if (hash === 'navstudio' || hash === 'am') hash = 'navigation';
  if (hash === 'perm' || hash === 'role') hash = 'setup';
  if (hash && (document.getElementById('section-'+hash) || ACL_TAB_GROUPS[hash])) {
    var btn = document.getElementById('mtab-'+hash);
    switchSection(hash, btn);
  } else if (!location.hash) {
    switchSection('modules', document.getElementById('mtab-modules'));
  }
  document.querySelectorAll('.portal-pill').forEach(function(pill){
 pill.addEventListener('dragstart', function(e){
 draggingPortal = {code: pill.dataset.code, label: pill.dataset.label};
 e.dataTransfer.effectAllowed = 'copy';
 });
 pill.addEventListener('dragend', () => draggingPortal = null);
  });
});

function allowDrop(e){ e.preventDefault(); }

// ── Workflow drag/drop 
function dropOnStep(e) {
  e.preventDefault();
  var step = e.currentTarget;
  step.classList.remove('drop-over');
  if(!draggingPortal) return;
  var wf = step.dataset.workflow, key = step.dataset.key, code = draggingPortal.code, label = draggingPortal.label;
  var existing = step.querySelectorAll('.wf-badge');
  for(var b of existing){ if(b.dataset.portal===code) return; }
  var badge = document.createElement('span');
  badge.className='wf-badge'; badge.dataset.portal=code;
  badge.innerHTML=label+' <button class="wf-badge-x" onclick="removePortal(\''+wf+'\',\''+key+'\',\''+code+'\')">&times;</button>';
  step.querySelector('.wf-step-portals').appendChild(badge);
  ajax({wf_action:'assign_portal', workflow:wf, step_key:key, portal_code:code});
}
function removePortal(wf, key, code) {
  var stepEl = document.getElementById('step-'+wf+'-'+key);
  if(!stepEl) return;
  stepEl.querySelectorAll('.wf-badge').forEach(b => { if(b.dataset.portal===code) b.remove(); });
  ajax({wf_action:'unassign_portal', workflow:wf, step_key:key, portal_code:code});
}
function addStep(wf) {
  Swal.fire({
    title: _L.newStepName,
    input: 'text',
    inputPlaceholder: _L.stepPh,
    showCancelButton: true,
    confirmButtonText: _L.addStep,
    background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
    color: document.documentElement.classList.contains('dark') ? '#f8fafc' : '#1e293b'
  }).then((res) => {
    if (res.value) {
      var label = res.value;
      ajax({wf_action:'add_step', workflow:wf, step_label:label, step_color:'#3182ce'}, function(r){ if(r.ok) location.reload(); });
    }
  });
}
function renameStep(wf, key, btn) {
  var span = btn.closest('.wf-step-label').querySelector('.step-label-text');
  var cur = span ? span.textContent.trim() : '';
  Swal.fire({
    title: _L.renameStep,
    input: 'text',
    inputValue: cur,
    showCancelButton: true,
    confirmButtonText: _L.rename,
    background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
    color: document.documentElement.classList.contains('dark') ? '#f8fafc' : '#1e293b'
  }).then((res) => {
    if (res.value) {
      var newL = res.value;
      ajax({wf_action:'rename_step', workflow:wf, step_key:key, step_label:newL}, function(r){ if(r.ok && span) span.textContent=newL; });
    }
  });
}
function deleteStep(wf, key, btn) {
  HMS.confirm(_L.deleteStepTitle, _L.deleteStepBody, 'warning', _L.yesDelete)
  .then((result) => {
    if (result.isConfirmed) {
      ajax({wf_action:'delete_step', workflow:wf, step_key:key}, function(r){ if(r.ok){ location.reload(); }});
    }
  });
}
function hmsWfSave(){ HMS.toast.fire({ icon: 'success', title: _L.wfSaved }); }

// ── Workflow Summary panel 
function loadSummary(code) {
  var el = document.getElementById('summaryText');
  if(!code){ el.textContent=_L.summaryPlaceholder; return; }
  el.innerHTML='<span class="text-muted"><i class="fa fa-spin fa-spinner mr-2"></i>'+_L.loading+'</span>';
  // Build summary from DOM
  var lines = [];
  document.querySelectorAll('.wf-flow .wf-step').forEach(function(s){
 var portals = Array.from(s.querySelectorAll('.wf-badge')).map(function(b){ return b.textContent.replace('×','').trim(); });
 if(portals.length===0) return;
 var lbl = (s.querySelector('.step-label-text')||{}).textContent||'';
 lines.push('<strong>'+lbl+':</strong> '+portals.join(', '));
  });
  var msg = lines.length ? lines.join('<br>') : _L.noPortalsAssigned;
  el.innerHTML = msg;
}
function copySummary(){
  var txt = document.getElementById('summaryText').innerText||'';
  if(!txt){ HMS.toast.fire({ icon: 'warning', title: _L.nothingCopy }); return; }
  navigator.clipboard.writeText(txt).then(function(){ HMS.toast.fire({ icon: 'success', title: _L.summaryCopied }); }).catch(function(){ HMS.alert(_L.summary, txt); });
}

// ── Permission drag/drop 
var draggingPermId = null;
function permDrag(e){ draggingPermId = e.currentTarget.dataset.id; e.dataTransfer.effectAllowed='move'; }
function permDrop(e, action) {
  e.preventDefault();
  var col = e.currentTarget; col.classList.remove('drag-over');
  if(!draggingPermId) return;
  var card = document.querySelector('.perm-card[data-id="'+draggingPermId+'"]');
  if(!card) { draggingPermId=null; return; }

  // Drop the card into the matching module group inside the target column so
  // grouping stays consistent across grants/revokes. If the group doesn't
  // exist yet (first card of that module on this side), create it on the fly.
  var mod = card.dataset.mod || 'misc';
  var group = col.querySelector('.perm-col-group[data-mod="'+mod+'"]');
  if (!group) {
    // Clone styling from the sibling column's group if present, otherwise build minimal one.
    var other = (col.id === 'col-available') ? 'col-assigned' : 'col-available';
    var template = document.querySelector('#'+other+' .perm-col-group[data-mod="'+mod+'"]');
    if (template) {
      group = template.cloneNode(false);
      group.innerHTML = template.querySelector('.perm-col-group-head').outerHTML;
      var cnt = group.querySelector('.perm-col-group-count'); if (cnt) cnt.textContent = '0';
    } else {
      group = document.createElement('div');
      group.className = 'perm-col-group'; group.dataset.mod = mod;
    }
    col.appendChild(group);
  }
  group.appendChild(card);
  if(action==='grant') card.classList.add('assigned'); else card.classList.remove('assigned');

  // Refresh per-group counts on both columns.
  ['col-available','col-assigned'].forEach(function(cid){
    var c = document.getElementById(cid); if (!c) return;
    c.querySelectorAll('.perm-col-group').forEach(function(g){
      var n = g.querySelectorAll('.perm-card').length;
      var lbl = g.querySelector('.perm-col-group-count');
      if (lbl) lbl.textContent = n;
      g.style.display = n ? '' : 'none';
    });
  });

  ajax({ wf_action: action, role_val: currentRole, permission_id: draggingPermId }, function (r) {
    if (!r || !r.ok) {
      HMS.toast.fire({
        icon: 'error',
        title: (r && r.error) || _L.permSaveFail,
        text: _L.reloadServer
      });
      setTimeout(function () { location.reload(); }, 800);
    }
  });
  draggingPermId = null;
}
function hmsAclSave(){ HMS.toast.fire({ icon: 'success', title: _L.permsSaved }); }

function aclModuleBulk(mod, grant){
  var role = '<%= selRole || "" %>';
  if(!role || role === '1' || role === '99'){ Swal.fire(_L.selectRole,_L.chooseNonAdmin,'warning'); return; }
  if(!mod){ return; }
  var verb = grant ? _L.grant : _L.revoke;
  Swal.fire({
    icon: 'question',
    title: grant ? _L.grantWhole : _L.revokeWhole,
    text: _L.module + ' ' + mod,
    showCancelButton: true,
    confirmButtonText: _L.yesVerb.replace('{{verb}}', verb),
    cancelButtonText: _L.cancel
  }).then(function(r){
    if(!r.isConfirmed) return;
    fetch('/access-control/api', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ action: 'bulk_module_perms', role_val: role, module_code: mod, grant: grant ? '1' : '0' })
    }).then(function(x){ return x.json(); }).then(function(d){
      if(d.ok){
        Swal.fire({ icon: 'success', title: _L.updated, text: _L.permsAffected.replace('{{count}}', d.affected || 0), timer: 1600, showConfirmButton: false });
        setTimeout(function(){ location.reload(); }, 900);
      } else {
        Swal.fire({ icon: 'error', title: _L.error, text: d.error || _L.unknownError });
      }
    }).catch(function(e){ Swal.fire({ icon: 'error', title: _L.networkError, text: e.message }); });
  });
}

function aclCopyFromRole(){
  var role = '<%= selRole || "" %>';
  var from = document.getElementById('aclCopyFrom') && document.getElementById('aclCopyFrom').value;
  if(!role || role === '1' || role === '99'){ Swal.fire(_L.selectRole,'','warning'); return; }
  if(!from){ Swal.fire(_L.pickSource,'','warning'); return; }
  Swal.fire({
    icon: 'warning',
    title: _L.replaceAllTitle,
    html: _L.replaceAllBody,
    showCancelButton: true,
    confirmButtonText: _L.yesReplace,
    confirmButtonColor: '#1a6bd8'
  }).then(function(r){
    if(!r.isConfirmed) return;
    fetch('/access-control/api', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ action: 'copy_role_perms_from', role_val: role, copy_from_role: from })
    }).then(function(x){ return x.json(); }).then(function(d){
      if(d.ok){
        Swal.fire({ icon: 'success', title: _L.done, text: _L.permsCopied.replace('{{count}}', d.copied || 0), timer: 1800, showConfirmButton: false });
        setTimeout(function(){ location.reload(); }, 1000);
      } else {
        Swal.fire({ icon: 'error', title: _L.error, text: d.error || _L.unknownError });
      }
    }).catch(function(e){ Swal.fire({ icon: 'error', title: _L.networkError, text: e.message }); });
  });
}
function filterPerms(inp, colId) {
  var q=inp.value.toLowerCase(); var col=document.getElementById(colId);
  // Match against card text; hide cards that don't match, and collapse any
  // group whose visible card count drops to zero.
  col.querySelectorAll('.perm-card').forEach(function(c){
    var txt=(c.textContent||'').toLowerCase();
    c.style.display = (!q || txt.indexOf(q)!==-1) ? '' : 'none';
  });
  col.querySelectorAll('.perm-col-group').forEach(function(g){
    var visible = Array.prototype.some.call(g.querySelectorAll('.perm-card'),
                  function(c){ return c.style.display !== 'none'; });
    g.style.display = visible ? '' : 'none';
  });
}

function filterRoleList(inp){
  var q = (inp && inp.value || '').toLowerCase().trim();
  document.querySelectorAll('.perm-role-item').forEach(function(a){
    var hay = (a.dataset.search || a.textContent || '').toLowerCase();
    a.style.display = (!q || hay.indexOf(q) !== -1) ? '' : 'none';
  });
}

function auditExportCsv(){
  var f = document.getElementById('auditFilterForm');
  var qs = new URLSearchParams();
  if (f) {
    var fd = new FormData(f);
    fd.forEach(function(val, key){
      if (key === 'role') return;
      if (val != null && String(val).trim() !== '') qs.append(key, val);
    });
  }
  if (!qs.has('audit_limit')) qs.set('audit_limit', '500');
  window.location.href = '/access-control/audit-export.csv?' + qs.toString();
}

// ── Permission Manager accordion + filter ─────────────────────────────────
function permMgrToggle(btn){
  var g = btn.closest('.perm-mgr-group');
  if (!g) return;
  g.classList.toggle('collapsed');
  btn.setAttribute('aria-expanded', g.classList.contains('collapsed') ? 'false' : 'true');
}
function permMgrFilter(q){
  q = (q || '').toLowerCase().trim();
  document.querySelectorAll('.perm-mgr-group').forEach(function(g){
    var rows = g.querySelectorAll('.perm-mgr-row');
    var visible = 0;
    rows.forEach(function(r){
      var hit = !q || (r.dataset.search || '').indexOf(q) !== -1;
      r.style.display = hit ? '' : 'none';
      if (hit) visible++;
    });
    g.style.display = visible ? '' : 'none';
    if (q && visible) g.classList.remove('collapsed');
  });
}

// ── Permission CRUD 
function permAddModal(){ document.getElementById('p_id').value=''; document.getElementById('p_code').value=''; document.getElementById('p_label').value=''; document.getElementById('p_gap').value='0'; document.getElementById('modalPermTitle').textContent=_L.addPerm; $('#modalPerm').modal('show'); }
function permEditModal(p){ document.getElementById('p_id').value=p.id; document.getElementById('p_code').value=p.code; document.getElementById('p_label').value=p.label; document.getElementById('p_gap').value=p.gap_area||0; document.getElementById('modalPermTitle').textContent=_L.editPerm; $('#modalPerm').modal('show'); }
function permSave(){
  var id=document.getElementById('p_id').value, code=document.getElementById('p_code').value, label=document.getElementById('p_label').value, gap=document.getElementById('p_gap').value;
  ajax({wf_action: id?'perm_edit':'perm_add', id:id, code:code, label:label, gap_area:gap}, function(r){ if(r.ok){ $('#modalPerm').modal('hide'); location.reload(); } else HMS.toast.fire({ icon: 'error', title: r.error||_L.error }); });
}
function permDelete(id){
  HMS.confirm(_L.deletePermTitle, _L.deletePermBody, 'warning', _L.yesDelete)
  .then((result) => {
    if (result.isConfirmed) {
      ajax({wf_action:'perm_delete', id:id}, function(r){ if(r.ok) location.reload(); else HMS.toast.fire({ icon: 'error', title: r.error||_L.error }); });
    }
  });
}

// ── Role CRUD 
function roleAddModal(){
  document.getElementById('r_id').value='';
  document.getElementById('r_title').value='';
  var cf = document.getElementById('r_clone_from'); if (cf) cf.value = '';
  var w  = document.getElementById('r_clone_wrap'); if (w) w.style.display = '';
  document.getElementById('modalRoleTitle').textContent=_L.addRole;
  $('#modalRole').modal('show');
}
function roleEditModal(r){
  document.getElementById('r_id').value=r.role;
  document.getElementById('r_title').value=r.title;
  var w = document.getElementById('r_clone_wrap'); if (w) w.style.display='none';
  document.getElementById('modalRoleTitle').textContent=_L.editRole;
  $('#modalRole').modal('show');
}
function roleSave(){
  var id    = document.getElementById('r_id').value,
      title = document.getElementById('r_title').value,
      cloneSel = document.getElementById('r_clone_from'),
      cloneFrom = cloneSel ? cloneSel.value : '';
  var payload = { wf_action: id ? 'role_edit' : 'role_add', role_id: id, title: title };
  if (!id && cloneFrom) payload.clone_from = cloneFrom;
  ajax(payload, function(r){
    if(r && r.ok){
      $('#modalRole').modal('hide');
      if (r.clone_summary) {
        HMS.toast.fire({ icon: 'success', title: _L.roleCreated.replace('{{summary}}', r.clone_summary) });
      }
      location.reload();
    } else {
      HMS.toast.fire({ icon: 'error', title: (r && r.error) || _L.error });
    }
  });
}
function roleDelete(rid){
  HMS.confirm(_L.deleteRoleTitle, _L.deleteRoleBody, 'warning', _L.yesDelete)
  .then((result) => {
    if (result.isConfirmed) {
      ajax({wf_action:'role_delete', role_id:rid}, function(r){ if(r.ok) location.reload(); else HMS.toast.fire({ icon: 'error', title: r.error||_L.error }); });
    }
  });
}

// ── AJAX Helper 
function ajax(data, cb){
  fetch('/access-control/api', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:new URLSearchParams(data) })
 .then(r=>r.json()).then(function(j){ if(cb) cb(j); }).catch(function(e){ console.error(e); });
}

// ── Portal Dashboard Tiles: tab switcher (by portal / global sidebar) ───────
function aclPortalTileTab(btn){
  if (!btn) return;
  var code = btn.getAttribute('data-portal-code');
  if (!code) return;
  document.querySelectorAll('.acl-ptile-tab').forEach(function(b){
    b.classList.toggle('active', b === btn);
    b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
  });
  document.querySelectorAll('.acl-ptile-panel').forEach(function(p){
    p.classList.toggle('active', p.id === 'acl-ptile-panel-' + code);
  });
}

// ── Portal Dashboard Tile visibility (per role) ─────────────────────────────
function uiToggleTile(cb){
  if(!currentRole){ HMS.toast.fire({ icon:'warning', title:_L.pickRoleFirst }); cb.checked = !cb.checked; return; }
  var code = cb.dataset.code;
  var act  = cb.checked ? 'ui_show' : 'ui_hide';
  ajax({ wf_action: act, role_val: currentRole, element_code: code }, function(r){
    if(!r || !r.ok){
      cb.checked = !cb.checked;
      HMS.toast.fire({ icon: 'error', title: (r && r.error) || _L.updateFail });
    } else {
      HMS.toast.fire({ icon: 'success', title: cb.checked ? _L.tileShown : _L.tileHidden });
    }
  });
}
function uiToggleActionMenu(cb){
  if(!currentRole){ HMS.toast.fire({ icon:'warning', title:_L.pickRoleFirst }); cb.checked = !cb.checked; return; }
  var code = cb.dataset.code;
  var act  = cb.checked ? 'ui_show' : 'ui_hide';
  ajax({ wf_action: act, role_val: currentRole, element_code: code }, function(r){
    if(!r || !r.ok){
      cb.checked = !cb.checked;
      HMS.toast.fire({ icon: 'error', title: (r && r.error) || _L.updateFail });
    } else {
      HMS.toast.fire({ icon: 'success', title: cb.checked ? _L.actionShown : _L.actionHidden });
    }
  });
}
function uiBulkPortal(portal, show){
  var boxes = document.querySelectorAll('.ui-tile-toggle[data-portal="'+portal+'"]');
  boxes.forEach(function(cb){
    if(cb.checked !== !!show){ cb.checked = !!show; uiToggleTile(cb); }
  });
}
function uiBulkTopnav(show){
  document.querySelectorAll('.ui-tile-toggle[data-portal="global_topnav"]').forEach(function(cb){
    if(cb.checked !== !!show){ cb.checked = !!show; uiToggleTile(cb); }
    uiSyncTopnavCard(cb);
  });
}
function uiBulkSidebar(show){
  document.querySelectorAll('.ui-sidebar-toggle').forEach(function(cb){
    if(cb.checked !== !!show){ cb.checked = !!show; uiToggleTile(cb); }
  });
}
function uiToggleTopnavParent(cb){
  uiToggleTile(cb);
  uiSyncTopnavCard(cb);
}
function uiSyncTopnavCard(cb){
  var card = cb && cb.closest ? cb.closest('.acl-topnav-card') : null;
  if(!card) return;
  var parentOn = card.querySelector('.ui-topnav-parent');
  card.classList.toggle('acl-topnav-card--off', !(parentOn && parentOn.checked));
  card.querySelectorAll('.acl-topnav-link-row').forEach(function(row){
    var child = row.querySelector('.ui-topnav-child');
    row.classList.toggle('acl-topnav-link-row--off', !(child && child.checked));
  });
}

// ── Role Portals (tbl_acl_role_portal) ─────────────────────────────────────
function rpToggleAssign(cb){
  if(!currentRole){ HMS.toast.fire({ icon:'warning', title:_L.pickRoleFirst }); cb.checked = !cb.checked; return; }
  var code = cb.dataset.code;
  var act  = cb.checked ? 'portal_assign' : 'portal_unassign';
  ajax({ wf_action: act, role_val: currentRole, portal_code: code }, function(r){
    if(!r || !r.ok){
      cb.checked = !cb.checked;
      HMS.toast.fire({ icon: 'error', title: (r && r.error) || _L.updateFail });
      return;
    }
    var radio = document.querySelector('.rp-home[data-code="'+code+'"]');
    if (radio) radio.disabled = !cb.checked;
    HMS.toast.fire({ icon: 'success', title: cb.checked ? _L.portalAllowed : _L.portalRemoved });
    setTimeout(function(){ location.reload(); }, 250);
  });
}
function rpSetHome(radio){
  if(!currentRole){ HMS.toast.fire({ icon:'warning', title:_L.pickRoleFirst }); return; }
  if(radio.disabled) return;
  var code = radio.dataset.code;
  ajax({ wf_action: 'portal_set_home', role_val: currentRole, portal_code: code }, function(r){
    if(!r || !r.ok){
      HMS.toast.fire({ icon: 'error', title: (r && r.error) || _L.setHomeFail });
      return;
    }
    HMS.toast.fire({ icon: 'success', title: _L.homeUpdated });
  });
}
</script>

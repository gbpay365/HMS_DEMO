 </div>
 </div>
 <div class="modal-footer"><button type="button" class="hms-btn hms-btn-secondary" data-dismiss="modal"><%= _ac('shared.cancel', 'Cancel') %></button><button type="button" class="hms-btn hms-btn-primary font-weight-bold" onclick="roleSave()"><%= _ac('legacy_page.save_role', 'Save Role') %></button></div>

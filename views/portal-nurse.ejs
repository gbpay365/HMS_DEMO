<%- include('partials/header') %>
<%
var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
var _up = locals.userPerms || [];
function hasP(){ if (_up.includes('*')) return true; for (var i=0;i<arguments.length;i++) if (_up.includes(arguments[i])) return true; return false; }
var _nurseName = userDisplayName || locals.user?.name || _t('portal_nurse.default_role', { ns: 'legacy', defaultValue: 'Nurse' });
var _nurseDate = fmtDate(new Date());
var _nurseKpis = [
  [_t('portal_nurse.kpi_patients_today', { ns: 'legacy', defaultValue: 'Patients Today' }), stats.visits, 'fa-calendar-check-o','#ea580c','#fff7ed'],
  [_t('portal_nurse.kpi_pending_triage', { ns: 'legacy', defaultValue: 'Pending Triage' }), stats.pending, 'fa-clock-o', '#f59e0b','#fef3c7'],
  [_t('portal_nurse.kpi_beds_occupied', { ns: 'legacy', defaultValue: 'Beds Occupied' }), stats.beds, 'fa-bed', '#f43f5e','#ffe4e6'],
  [_t('portal_nurse.kpi_total_patients', { ns: 'legacy', defaultValue: 'Total Patients' }), stats.patients,'fa-users', '#8b5cf6','#ede9fe']
];
var qsMap={
  registered:['info', _t('portal_shared.queue_status_registered', { ns: 'legacy', defaultValue: 'Registered' })],
  triage:['warning', _t('portal_shared.queue_status_triage', { ns: 'legacy', defaultValue: 'Triage' })],
  waiting_doctor:['primary', _t('portal_shared.queue_status_waiting_doctor', { ns: 'legacy', defaultValue: 'Waiting' })],
  in_consultation:['primary', _t('portal_shared.queue_status_in_consultation', { ns: 'legacy', defaultValue: 'In Consult' })],
  completed:['success', _t('portal_shared.queue_status_completed', { ns: 'legacy', defaultValue: 'Completed' })],
  cancelled:['danger', _t('portal_shared.queue_status_cancelled', { ns: 'legacy', defaultValue: 'Cancelled' })]
};
%>
<div class="page-wrapper"><div class="content">
<%- include('partials/portal-flash') %>

<!-- Hero Banner -->
<div class="card border-0 shadow mb-4 hms-page-hero">
  <div class="card-body py-4 px-4 d-flex align-items-center justify-content-between flex-wrap" style="gap:12px;">
 <div>
 <h1 class="h4 mb-1 font-weight-bold" style="color:#fff;"><i class="fa fa-heartbeat mr-2"></i><%= _t('portal_nurse.title', { ns: 'legacy', defaultValue: 'Nurse Station' }) %></h1>
 <p class="mb-0 small" style="color:rgba(255,255,255,.85);"><%= _t('portal_shared.welcome_named_date', { ns: 'legacy', name: _nurseName, date: _nurseDate, defaultValue: 'Welcome, ' + _nurseName + ' — ' + _nurseDate }) %></p>
 </div>
 <div class="d-flex flex-wrap" style="gap:8px;">
 <% if (uiVisible('nur.hero.guides')) { %><a href="/workflow-guides" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-sitemap mr-1"></i><%= _t('portal_shared.workflow_guide', { ns: 'legacy', defaultValue: 'Workflow Guide' }) %></a><% } %>
 <% if(hasP('nursing.read','nursing.write')){ %><a href="/nursing/supply-requests" class="btn btn-light btn-sm font-weight-bold" style="color:#ea580c;"><i class="fa fa-medkit mr-1"></i><%= _t('portal_nurse.pharmacy_requests', { ns: 'legacy', defaultValue: 'Pharmacy requests' }) %></a><% } %>
 <% if(hasP('opd.read','clinical.read','clinical.write','scheduling.read','nursing.read')){ %><a href="/opd-queue" class="btn btn-light btn-sm font-weight-bold" style="color:#ea580c;"><i class="fa fa-list-alt mr-1"></i><%= _t('portal_nurse.opd_queue', { ns: 'legacy', defaultValue: 'OPD Queue' }) %></a><% } %>
 <% if(hasP('adt.read','adt.write','nursing.read')){ %><a href="/wards" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-bed mr-1"></i><%= _t('portal_nurse.ward_board', { ns: 'legacy', defaultValue: 'Ward Board' }) %></a><% } %>
 <% if(hasP('nursing.read','nursing.write')){ %><a href="/nursing/vitals" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-heartbeat mr-1"></i><%= _t('portal_nurse.record_vitals', { ns: 'legacy', defaultValue: 'Record Vitals' }) %></a><% } %>
 </div>
  </div>
</div>

<!-- KPI Stats -->
<div class="row mb-4">
  <% _nurseKpis.forEach(function(s){ %>
  <div class="col-6 col-md-3 mb-3">
 <div class="card border-0 shadow-sm h-100" style="border-left:4px solid <%=s[3]%>;border-radius:12px;">
 <div class="card-body d-flex align-items-center">
 <span class="rounded-circle mr-3 d-flex align-items-center justify-content-center" style="width:50px;height:50px;background:<%=s[4]%>;flex-shrink:0;">
 <i class="fa <%=s[2]%>" style="color:<%=s[3]%>;font-size:1.2rem;"></i>
 </span>
 <div><div style="font-size:1.9rem;font-weight:800;color:#1e293b;"><%=s[1]%></div><div class="text-muted small"><%=s[0]%></div></div>
 </div>
 </div>
  </div>
  <% }); %>
</div>

<%- include('partials/portal-tiles', { portal: 'nursing', title: _t('portal_nurse.clinical_tools', { ns: 'legacy', defaultValue: 'Clinical Tools' }) }) %>

<!-- Today's Patient Activity + Emergency Side by Side -->
<div class="row">
  <div class="col-lg-8 mb-4">
 <div class="card border-0 shadow-sm h-100" style="border-radius:14px;">
 <div class="card-header bg-white d-flex justify-content-between align-items-center py-3" style="border-bottom:2px solid #e2e8f0;">
 <span class="font-weight-bold"><i class="fa fa-heartbeat mr-1" style="color:#ea580c;"></i><%= _t('portal_nurse.today_activity', { ns: 'legacy', defaultValue: "Today's Patient Activity" }) %></span>
 <a href="/opd-queue" class="btn btn-sm btn-outline-primary" style="border-radius:8px;"><%= _t('portal_shared.view_all', { ns: 'legacy', defaultValue: 'View All' }) %></a>
 </div>
 <div class="card-body p-0" data-hms-table-paginate data-hms-page-size="5"><div class="table-responsive">
 <table class="table table-hover mb-0">
 <thead class="thead-light"><tr><th><%= _t('portal_shared.patient', { ns: 'legacy', defaultValue: 'Patient' }) %></th><th><%= _t('portal_shared.status', { ns: 'legacy', defaultValue: 'Status' }) %></th><th><%= _t('portal_shared.complaint', { ns: 'legacy', defaultValue: 'Complaint' }) %></th><th><%= _t('portal_shared.check_in', { ns: 'legacy', defaultValue: 'Check-in' }) %></th><th><%= _t('portal_shared.action', { ns: 'legacy', defaultValue: 'Action' }) %></th></tr></thead>
 <tbody>
 <% if(!recentVisits||recentVisits.length===0){ %><tr><td colspan="5" class="text-center text-muted py-4"><i class="fa fa-check-circle text-success mr-1"></i><%= _t('portal_shared.no_visits_today', { ns: 'legacy', defaultValue: 'No visits today.' }) %></td></tr>
 <% } else { recentVisits.forEach(function(v){ var qs=qsMap[v.queue_status]||['secondary',v.queue_status]; var t=v.queue_time?new Date(v.queue_time).toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}):'—'; %>
 <tr>
 <td class="font-weight-bold" style="font-size:.88rem;"><%=v.first_name||''%> <%=v.last_name||''%></td>
 <td><span class="badge badge-<%=qs[0]%>"><%=qs[1]%></span></td>
 <td class="small text-muted" style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%=v.chief_complaint||'—'%></td>
 <td class="small text-muted"><%=t%></td>
 <td>
 <% if(v.queue_status==='registered'||v.queue_status==='triage'){ %>
 <a href="/nursing/vitals?patient_id=<%=v.patient_id%>&opd_visit_id=<%=v.id%>&redirect_to=<%=encodeURIComponent('/opd-queue')%>" class="btn btn-xs btn-warning" style="font-size:.7rem;padding:2px 7px;border-radius:6px;"><%= _t('portal_shared.triage', { ns: 'legacy', defaultValue: 'Triage' }) %></a>
 <% } else { %>
 <a href="/patient-chart/<%=v.patient_id%>" class="btn btn-xs btn-outline-secondary" style="font-size:.7rem;padding:2px 7px;border-radius:6px;"><%= _t('portal_shared.chart', { ns: 'legacy', defaultValue: 'Chart' }) %></a>
 <% } %>
 </td>
 </tr>
 <% }); } %>
 </tbody>
 </table>
 </div></div>
 </div>
  </div>
  <div class="col-lg-4 mb-4">
 <div class="card border-0 shadow-sm h-100" style="border-radius:14px;border:2px solid #fecaca !important;">
 <div class="card-header d-flex justify-content-between align-items-center py-3" style="background:#fef2f2;border-bottom:2px solid #fecaca;border-radius:12px 12px 0 0;">
 <span class="font-weight-bold" style="color:#ef4444;"><i class="fa fa-ambulance mr-1"></i><%= _t('portal_shared.emergency', { ns: 'legacy', defaultValue: 'Emergency' }) %></span>
 <span class="badge badge-danger"><%=(emergency||[]).length%></span>
 </div>
 <div class="card-body p-0" data-hms-table-paginate data-hms-page-size="5">
 <% if(!emergency||emergency.length===0){ %>
 <div class="text-center py-5 text-muted"><i class="fa fa-check-circle text-success fa-2x mb-2 d-block"></i><%= _t('portal_shared.no_emergencies', { ns: 'legacy', defaultValue: 'No active emergencies.' }) %></div>
 <% } else { %>
 <div class="table-responsive"><table class="table table-hover mb-0">
 <thead style="background:#fef2f2;"><tr><th style="color:#ef4444;"><%= _t('portal_shared.patient', { ns: 'legacy', defaultValue: 'Patient' }) %></th><th style="color:#ef4444;"><%= _t('portal_shared.status', { ns: 'legacy', defaultValue: 'Status' }) %></th></tr></thead>
 <tbody>
 <% emergency.forEach(function(e){ %>
 <tr><td class="font-weight-bold small"><%=e.first_name%> <%=e.last_name%></td>
 <td><span class="badge badge-danger" style="font-size:.68rem;"><%=e.queue_status.replace(/_/g,' ')%></span></td></tr>
 <% }); %>
 </tbody>
 </table></div>
 <div class="p-2 text-right"><a href="/emergency" class="btn btn-sm btn-outline-danger" style="border-radius:8px;"><%= _t('portal_shared.open_ae', { ns: 'legacy', defaultValue: 'Open A&E' }) %></a></div>
 <% } %>
 </div>
 </div>
  </div>
</div>

</div></div><%- include('partials/footer') %>

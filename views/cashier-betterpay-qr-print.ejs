<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'en' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> — <%= ref %></title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: system-ui, 'Segoe UI', sans-serif; margin: 0; padding: 24px; color: #0f172a; }
    .sheet { max-width: 360px; margin: 0 auto; text-align: center; border: 2px solid #0e7490; border-radius: 16px; padding: 22px 20px; }
    .facility { font-size: 1rem; font-weight: 800; color: #0f172a; line-height: 1.3; margin: 0 0 6px; }
    .brand { font-size: 0.95rem; font-weight: 700; color: #0e7490; margin: 0 0 14px; letter-spacing: 0.02em; }
    #qr-host { display: inline-block; padding: 8px; background: #fff; border-radius: 8px; margin-bottom: 4px; }
    .lbl { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #64748b; margin-top: 10px; }
    .amount { font-size: 1.45rem; font-weight: 800; margin: 2px 0 0; color: #0f172a; }
    .service { font-size: 0.95rem; font-weight: 700; margin: 2px 0 0; color: #1e293b; }
    .patient { font-size: 0.8rem; color: #475569; margin-top: 2px; }
    .ref { font-family: ui-monospace, monospace; font-size: 0.72rem; color: #64748b; margin-top: 2px; word-break: break-all; }
    .hint { font-size: 0.68rem; color: #64748b; margin-top: 18px; line-height: 1.45; padding-top: 12px; border-top: 1px dashed #cbd5e1; }
    @media print {
      body { padding: 0; }
      .no-print { display: none; }
      .sheet { border-width: 1px; }
    }
  </style>
</head>
<body>
  <p class="no-print" style="text-align:center;margin-bottom:12px;">
    <button type="button" onclick="window.print()" style="padding:8px 16px;font-weight:700;cursor:pointer;border-radius:8px;border:1px solid #0e7490;background:#ecfeff;color:#0e7490;">Print</button>
  </p>
  <div class="sheet">
    <div class="facility"><%= facilityName %></div>
    <div class="brand">BetterPay</div>
    <div id="qr-host"></div>
    <div class="lbl"><%= labels.amount %></div>
    <div class="amount"><%= Number(amount || 0).toLocaleString('fr-FR') %></div>
    <div class="lbl"><%= labels.service %></div>
    <div class="service"><%= serviceLabel %></div>
    <% if (patientName) { %>
      <div class="lbl"><%= labels.patient %></div>
      <div class="patient"><%= patientName %><% if (patientPhone) { %> · <%= patientPhone %><% } %></div>
    <% } %>
    <div class="lbl"><%= labels.reference %></div>
    <div class="ref"><%= ref %></div>
    <p class="hint"><%= labels.hint %></p>
  </div>
  <script src="/vendor/qrcode/qrcode.min.js"></script>
  <script>
    (function () {
      var url = <%- JSON.stringify(paymentUrl || '') %>;
      var host = document.getElementById('qr-host');
      if (!url || !host) return;
      if (typeof QRCode !== 'undefined') {
        QRCode.toCanvas(host, url, { width: 200, margin: 1 }, function () {});
      } else {
        var img = document.createElement('img');
        img.src = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(url);
        img.width = 200;
        img.height = 200;
        img.alt = 'QR';
        host.appendChild(img);
      }
      window.addEventListener('load', function () { setTimeout(function () { window.print(); }, 400); });
    })();
  </script>
</body>
</html>

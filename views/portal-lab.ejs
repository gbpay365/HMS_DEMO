<%- include('partials/header') %>
<%
var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
var _up = locals.userPerms || [];
function hasP(){ if (_up.includes('*')) return true; for (var i=0;i<arguments.length;i++) if (_up.includes(arguments[i])) return true; return false; }
var _labName = userDisplayName || locals.user?.name || _t('portal_lab.default_role', { ns: 'legacy', defaultValue: 'Lab Tech' });
var _labDate = fmtDate(new Date());
var _labKpis = [
  [_t('portal_lab.kpi_total_tests', { ns: 'legacy', defaultValue: 'Total Tests' }), stats.total, 'fa-flask', '#7c3aed', '#ede9fe'],
  [_t('portal_lab.kpi_pending', { ns: 'legacy', defaultValue: 'Pending' }), stats.pending, 'fa-clock-o', '#f59e0b', '#fef3c7'],
  [_t('portal_lab.kpi_completed', { ns: 'legacy', defaultValue: 'Completed' }), stats.done, 'fa-check-circle', '#10b981', '#d1fae5'],
  [_t('portal_lab.kpi_today_tests', { ns: 'legacy', defaultValue: "Today's Tests" }), stats.today, 'fa-calendar', '#0ea5e9', '#e0f2fe']
];
%>
<div class="page-wrapper"><div class="content">
<%- include('partials/clinical-dept-alerts-strip', { clinicalDeptStripDept: 'laboratory' }) %>
<%- include('partials/portal-flash') %>
<!-- Banner -->
<div class="card border-0 shadow mb-4 hms-page-hero">
  <div class="card-body py-4 px-4 d-flex align-items-center justify-content-between flex-wrap" style="gap:12px;">
 <div>
 <h1 class="h4 mb-1 font-weight-bold" style="color:#fff;"><i class="fa fa-flask mr-2"></i><%= _t('portal_lab.title', { ns: 'legacy', defaultValue: 'Laboratory Portal' }) %></h1>
 <p class="mb-0 small" style="color:rgba(255,255,255,.85);"><%= _t('portal_shared.welcome_named_date', { ns: 'legacy', name: _labName, date: _labDate, defaultValue: 'Welcome, ' + _labName + ' — ' + _labDate }) %></p>
 </div>
 <div class="d-flex flex-wrap" style="gap:8px;">
 <% if (uiVisible('lab.hero.guides')) { %><a href="/workflow-guides" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-sitemap mr-1"></i><%= _t('portal_shared.workflow_guide', { ns: 'legacy', defaultValue: 'Workflow Guide' }) %></a><% } %>
 <% if(hasP('lab.read','lab.write')){ %><a href="/lims" class="btn btn-light btn-sm font-weight-bold" style="color:#7c3aed;"><i class="fa fa-flask mr-1"></i><%= _t('portal_lab.lims_hub', { ns: 'legacy', defaultValue: 'LIMS hub' }) %></a> <a href="/laboratory" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-list-alt mr-1"></i><%= _t('portal_lab.registry', { ns: 'legacy', defaultValue: 'Registry' }) %></a> <a href="/lab/templates" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-edit mr-1"></i><%= _t('portal_lab.templates', { ns: 'legacy', defaultValue: 'Templates' }) %></a><% } %>
 <% if(hasP('lab.write')){ %><a href="/laboratory/order-alerts" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-bell mr-1"></i><%= _t('portal_lab.order_alerts', { ns: 'legacy', defaultValue: 'Order alerts' }) %></a><% } %>
 <% if(hasP('patient.read','patient.write')){ %><a href="/patients" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-users mr-1"></i><%= _t('portal_lab.patients', { ns: 'legacy', defaultValue: 'Patients' }) %></a><% } %>
 </div>
  </div>
</div>
<!-- Stats -->
<div class="row mb-4">
  <% _labKpis.forEach(function(s){ %>
  <div class="col-6 col-md-3 mb-3">
 <div class="card border-0 shadow-sm h-100" style="border-left:4px solid <%=s[3]%>;border-radius:12px;">
 <div class="card-body d-flex align-items-center">
 <span class="rounded-circle mr-3 d-flex align-items-center justify-content-center" style="width:50px;height:50px;background:<%=s[4]%>;flex-shrink:0;">
 <i class="fa <%=s[2]%>" style="color:<%=s[3]%>;font-size:1.1rem;"></i>
 </span>
 <div><div style="font-size:1.9rem;font-weight:800;color:#1e293b;"><%=s[1]%></div><div class="text-muted small"><%=s[0]%></div></div>
 </div>
 </div>
  </div>
  <% }); %>
</div>
<%- include('partials/portal-tiles', { portal: 'laboratory', title: _t('portal_lab.lab_tools', { ns: 'legacy', defaultValue: 'Lab Tools' }) }) %>
<!-- Recent Results -->
<div class="card border-0 shadow-sm" style="border-radius:14px;">
  <div class="card-header bg-white d-flex justify-content-between align-items-center py-3" style="border-bottom:2px solid #e2e8f0;">
 <span class="font-weight-bold"><i class="fa fa-flask mr-1 text-primary"></i><%= _t('portal_lab.recent_results', { ns: 'legacy', defaultValue: 'Recent Lab Results' }) %></span>
 <a href="/laboratory" class="btn btn-sm btn-outline-primary" style="border-radius:8px;"><%= _t('portal_shared.view_all', { ns: 'legacy', defaultValue: 'View All' }) %></a>
  </div>
  <div class="card-body p-0" data-hms-table-paginate data-hms-page-size="5"><div class="table-responsive">
 <table class="table table-hover mb-0">
 <thead class="thead-light"><tr><th><%= _t('portal_shared.patient', { ns: 'legacy', defaultValue: 'Patient' }) %></th><th><%= _t('portal_lab.col_test', { ns: 'legacy', defaultValue: 'Test' }) %></th><th><%= _t('portal_shared.status', { ns: 'legacy', defaultValue: 'Status' }) %></th><th><%= _t('portal_shared.date', { ns: 'legacy', defaultValue: 'Date' }) %></th></tr></thead>
 <tbody>
 <% if(!recentLabs||recentLabs.length===0){ %><tr><td colspan="4" class="text-center text-muted py-4"><%= _t('portal_lab.no_recent', { ns: 'legacy', defaultValue: 'No recent lab results.' }) %></td></tr>
 <% } else { recentLabs.forEach(function(r){ var sBadge=r.status==='received'?'success':'warning'; var d=r.created_at?fmtDate(r.created_at):'—'; %>
 <tr><td class="font-weight-bold small"><%=r.first_name||''%> <%=r.last_name||''%></td>
 <td class="small"><%=r.test_name||'—'%></td>
 <td><span class="badge badge-<%=sBadge%>"><%=r.status||'pending'%></span></td>
 <td class="small text-muted"><%=d%></td></tr>
 <% }); } %>
 </tbody>
 </table>
  </div></div>
</div>
</div></div><%- include('partials/footer') %>

<%- include('partials/payroll-layout-start', { payNavActive: 'leaveadmin', showHrLeaveAdmin: true }) %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>

 <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
 <div>
 <h4 class="page-title font-weight-bold text-dark mb-1"><%= _t('hr_leave_requests.title', { ns: 'legacy', defaultValue: 'Leave requests' }) %></h4>
 <p class="text-muted small mb-0"><%= _t('hr_leave_requests.subtitle', { ns: 'legacy', defaultValue: 'Approve or reject pending leave. Most recent requests first.' }) %></p>
 </div>
 <div class="d-flex flex-wrap gap-2">
 <a href="/payroll" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="fa fa-arrow-left mr-1"></i><%= _t('hr_leave_requests.hr_hub', { ns: 'legacy', defaultValue: 'HR hub' }) %></a>
 </div>
 </div>

 <div class="card border-0 shadow-sm" style="border-radius:14px;">
 <div class="card-header bg-white font-weight-bold py-3"><%= _t('hr_leave_requests.queue', { ns: 'legacy', defaultValue: 'Queue' }) %></div>
 <div class="card-body p-0 table-responsive">
 <table class="table table-sm table-striped mb-0" data-hms-table-paginate="8">
 <thead><tr><th><%= _t('hr_leave_requests.col_employee', { ns: 'legacy', defaultValue: 'Employee' }) %></th><th><%= _t('hr_leave_requests.col_type', { ns: 'legacy', defaultValue: 'Type' }) %></th><th><%= _t('hr_leave_requests.col_from', { ns: 'legacy', defaultValue: 'From' }) %></th><th><%= _t('hr_leave_requests.col_to', { ns: 'legacy', defaultValue: 'To' }) %></th><th><%= _t('hr_leave_requests.col_days', { ns: 'legacy', defaultValue: 'Days' }) %></th><th><%= _t('hr_leave_requests.col_status', { ns: 'legacy', defaultValue: 'Status' }) %></th><th class="text-right"><%= _t('hr_leave_requests.col_actions', { ns: 'legacy', defaultValue: 'Actions' }) %></th></tr></thead>
 <tbody>
 <% if(!rows || !rows.length){ %>
 <tr><td colspan="7" class="text-center text-muted py-4"><%= _t('hr_leave_requests.no_requests', { ns: 'legacy', defaultValue: 'No leave requests yet.' }) %></td></tr>
 <% } %>
 <% (rows||[]).forEach(function(r){
 var st = String(r.status||'').toLowerCase();
 var rid = parseInt(r.id,10)||0;
 %>
 <tr>
 <td><%= r.first_name %> <%= r.last_name %></td>
 <td><%= r.leave_type %></td>
 <td><%= r.start_date_fmt || r.start_date %></td>
 <td><%= r.end_date_fmt || r.end_date %></td>
 <td><%= r.days_requested %></td>
 <td>
 <% if(st==='pending'){ %><span class="badge badge-warning"><%= _t('hr_leave_requests.status_pending', { ns: 'legacy', defaultValue: 'Pending' }) %></span>
 <% } else if(st==='approved'){ %><span class="badge badge-success"><%= _t('hr_leave_requests.status_approved', { ns: 'legacy', defaultValue: 'Approved' }) %></span>
 <% } else { %><span class="badge badge-secondary"><%= st %></span><% } %>
 </td>
 <td class="text-right text-nowrap">
 <% if(st==='pending' && rid > 0){ %>
 <form method="POST" action="/hr/leave-requests/action" class="d-inline" onsubmit="return confirm('<%= _t('hr_leave_requests.confirm_approve', { ns: 'legacy', defaultValue: 'Approve this request?' }).replace(/'/g, "\\'") %>');">
 <input type="hidden" name="request_id" value="<%= rid %>">
 <input type="hidden" name="action" value="approve">
 <button type="submit" class="btn btn-sm btn-success"><%= _t('hr_leave_requests.approve', { ns: 'legacy', defaultValue: 'Approve' }) %></button>
 </form>
 <form method="POST" action="/hr/leave-requests/action" class="d-inline ml-1" onsubmit="return confirm('<%= _t('hr_leave_requests.confirm_reject', { ns: 'legacy', defaultValue: 'Reject this request?' }).replace(/'/g, "\\'") %>');">
 <input type="hidden" name="request_id" value="<%= rid %>">
 <input type="hidden" name="action" value="reject">
 <button type="submit" class="btn btn-sm btn-outline-danger"><%= _t('hr_leave_requests.reject', { ns: 'legacy', defaultValue: 'Reject' }) %></button>
 </form>
 <% } else { %><span class="text-muted small">—</span><% } %>
 </td>
 </tr>
 <% }); %>
 </tbody>
 </table>
 </div>
 </div>

<%- include('partials/payroll-layout-end') %>

<%- include('partials/header') %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>
<%- include('partials/maternity-odoo-start', {
  matOdooMenu: 'register',
  matOdooTitle: _t('maternity_register.title', { ns: 'legacy', defaultValue: 'ANC registration' })
}) %>
<div class="o_content">

<div class="row">
 <div class="col-lg-5 mb-3">
  <div class="mat-card p-3">
   <p class="small text-muted mb-3"><%= _t('maternity_register.search_hint', { ns: 'legacy', defaultValue: 'Find an existing HMS patient by ID, name, or phone. If not found, create a new patient record first.' }) %></p>
   <form method="get" action="/maternity/register" class="mb-0">
    <div class="form-group mb-2">
     <label class="small font-weight-bold mb-1" for="mat_patient_id"><%= _t('maternity_register.patient_id_ph', { ns: 'legacy', defaultValue: 'Patient ID' }) %></label>
     <input type="number" id="mat_patient_id" name="patient_id" class="hms-input w-full" placeholder="<%= _t('maternity_register.patient_id_ph', { ns: 'legacy', defaultValue: 'Patient ID' }) %>" value="<%= patient ? patient.id : (typeof searchPatientId !== 'undefined' ? searchPatientId : '') %>" min="1">
    </div>
    <div class="form-group mb-2">
     <label class="small font-weight-bold mb-1" for="mat_patient_name"><%= _t('maternity_register.patient_name_ph', { ns: 'legacy', defaultValue: 'Patient name' }) %></label>
     <input type="text" id="mat_patient_name" name="patient_name" class="hms-input w-full" placeholder="<%= _t('maternity_register.patient_name_ph', { ns: 'legacy', defaultValue: 'Patient name' }) %>" value="<%= typeof searchPatientName !== 'undefined' ? searchPatientName : '' %>">
    </div>
    <div class="form-group mb-3">
     <label class="small font-weight-bold mb-1" for="mat_patient_phone"><%= _t('maternity_register.patient_phone_ph', { ns: 'legacy', defaultValue: 'Phone number' }) %></label>
     <input type="text" id="mat_patient_phone" name="patient_phone" class="hms-input w-full" placeholder="<%= _t('maternity_register.patient_phone_ph', { ns: 'legacy', defaultValue: 'Phone number' }) %>" value="<%= typeof searchPatientPhone !== 'undefined' ? searchPatientPhone : '' %>">
    </div>
    <button type="submit" class="hms-btn hms-btn-secondary w-full"><i class="fa fa-search mr-1" aria-hidden="true"></i><%= _t('maternity_register.search', { ns: 'legacy', defaultValue: 'Search patient' }) %></button>
   </form>

   <% if (patient) { %>
   <div class="hms-flash hms-flash--success mt-3 mb-0">
    <strong><%= patient.first_name %> <%= patient.last_name %></strong> (#<%= patient.id %>)<% if (patient.phone) { %> · <%= patient.phone %><% } %>
   </div>
   <% } else if (patientMatches && patientMatches.length) { %>
   <div class="mt-3">
    <p class="small font-weight-bold mb-2"><%= _t('maternity_register.multiple_matches', { ns: 'legacy', defaultValue: 'Multiple patients found — select one:' }) %></p>
    <ul class="list-unstyled mb-0">
     <% patientMatches.forEach(function(m) { %>
     <li class="mb-2">
      <a href="/maternity/register?patient_id=<%= m.id %>" class="d-block rounded border px-3 py-2 text-decoration-none" style="border-color:#fbcfe8!important;background:#fff;">
       <strong><%= m.first_name %> <%= m.last_name %></strong>
       <span class="text-muted small">#<%= m.id %><% if (m.phone) { %> · <%= m.phone %><% } %></span>
      </a>
     </li>
     <% }); %>
    </ul>
   </div>
   <% } else if (searched && searchNotFound) { %>
   <div class="hms-flash hms-flash--warning mt-3 mb-2"><%= _t('maternity_register.no_patient_found', { ns: 'legacy', defaultValue: 'No patient found for this search.' }) %></div>
   <% if (uiVisible('mat.btn.register_new_anc')) { %>
   <a href="<%= createPatientUrl || '/patients?from=maternity&action=new' %>" class="hms-btn hms-btn-primary w-full">
    <i class="fa fa-user-plus mr-1" aria-hidden="true"></i><%= _t('maternity_register.create_patient', { ns: 'legacy', defaultValue: 'Create patient' }) %>
   </a>
   <% } %>
   <% } else if (uiVisible('mat.btn.register_new_anc')) { %>
   <a href="/patients?from=maternity&action=new" class="hms-btn hms-btn-secondary w-full mt-3">
    <i class="fa fa-user-plus mr-1" aria-hidden="true"></i><%= _t('maternity_register.create_patient', { ns: 'legacy', defaultValue: 'Create patient' }) %>
   </a>
   <% } %>
  </div>
 </div>
 <div class="col-lg-7">
  <form method="post" action="/maternity/register" class="mat-card p-4">
   <% if (!patient) { %>
   <p class="text-muted"><%= _t('maternity_register.load_patient_first', { ns: 'legacy', defaultValue: 'Load a patient before completing booking.' }) %></p>
   <% } else { %>
   <input type="hidden" name="patient_id" value="<%= patient.id %>">
   <div class="form-row">
    <div class="form-group col-md-4"><label class="small font-weight-bold"><%= _t('maternity_register.gravida', { ns: 'legacy', defaultValue: 'Gravida' }) %></label><input type="number" name="gravida" class="hms-input w-full" value="1" min="1"></div>
    <div class="form-group col-md-4"><label class="small font-weight-bold"><%= _t('maternity_register.para', { ns: 'legacy', defaultValue: 'Para' }) %></label><input type="number" name="para" class="hms-input w-full" value="0" min="0"></div>
    <div class="form-group col-md-4"><label class="small font-weight-bold"><%= _t('maternity_register.abortions', { ns: 'legacy', defaultValue: 'Abortions' }) %></label><input type="number" name="abortion" class="hms-input w-full" value="0" min="0"></div>
   </div>
   <div class="form-row">
    <div class="form-group col-md-4"><label class="small font-weight-bold"><%= _t('maternity_register.lmp', { ns: 'legacy', defaultValue: 'LMP' }) %></label><input type="date" name="lmp" class="hms-input w-full" id="mat_lmp"></div>
    <div class="form-group col-md-4"><label class="small font-weight-bold"><%= _t('maternity_register.blood_group', { ns: 'legacy', defaultValue: 'Blood group' }) %></label>
     <select name="blood_group" class="hms-input w-full"><option value="">—</option>
      <% ['A+','A-','B+','B-','AB+','AB-','O+','O-'].forEach(function(bg){ %><option value="<%= bg %>"><%= bg %></option><% }) %>
     </select>
    </div>
    <div class="form-group col-md-4"><label class="small font-weight-bold"><%= _t('maternity_register.hiv_status', { ns: 'legacy', defaultValue: 'HIV status' }) %></label>
     <select name="hiv_status" class="hms-input w-full"><option value="unknown"><%= _t('maternity_register.hiv_unknown', { ns: 'legacy', defaultValue: 'Unknown' }) %></option><option value="negative"><%= _t('maternity_register.hiv_negative', { ns: 'legacy', defaultValue: 'Negative' }) %></option><option value="positive"><%= _t('maternity_register.hiv_positive', { ns: 'legacy', defaultValue: 'Positive' }) %></option></select>
    </div>
   </div>
   <div class="form-group"><label><input type="checkbox" name="pmtct_enrolled" value="1"> <%= _t('maternity_register.pmtct_enrolled', { ns: 'legacy', defaultValue: 'PMTCT enrolled' }) %></label></div>
   <p class="small text-muted"><%= _t('maternity_register.edd_hint', { ns: 'legacy', defaultValue: "EDD is calculated automatically from LMP (Naegele's rule). ANC number is assigned on save." }) %></p>
   <button type="submit" class="hms-btn hms-btn-primary hms-btn hms-btn-lg"><i class="fa fa-user-plus mr-1"></i> <%= _t('maternity_register.register_open', { ns: 'legacy', defaultValue: 'Register & open chart' }) %></button>
   <% } %>
  </form>
 </div>
</div>

</div>
<%- include('partials/maternity-odoo-end') %>
<%- include('partials/footer') %>

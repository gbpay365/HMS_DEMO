<%- include('partials/header') %>
<link rel="stylesheet" href="/css/portal-accountant.css">
<%
var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
var _up = locals.userPerms || [];
function hasP(){ if (_up.includes('*')) return true; for (var i=0;i<arguments.length;i++) if (_up.includes(arguments[i])) return true; return false; }
var _stats = stats || {};
var _fmtXaf = function(n){ return (Number(n)||0).toLocaleString('fr-FR'); };
var _dateLabel = fmtDate(new Date());
var _welcomeSuffix = userDisplayName ? ', ' + userDisplayName : '';
var _accKpis = [
  [_t('portal_accountant.kpi_txn_today', { ns: 'legacy', defaultValue: 'Transactions today' }), _stats.txnToday, 'fa-exchange', '#1e3a8a', '#dbeafe'],
  [_t('portal_accountant.kpi_collected_today', { ns: 'legacy', defaultValue: 'Collected today (XAF)' }), _fmtXaf(_stats.txnTodayXaf), 'fa-money', '#0f766e', '#ccfbf1'],
  [_t('portal_accountant.kpi_expenses_mtd', { ns: 'legacy', defaultValue: 'Expenses (MTD)' }), _stats.expensesMtd, 'fa-file-text-o', '#be185d', '#fce7f3'],
  [_t('portal_accountant.kpi_receipts_today', { ns: 'legacy', defaultValue: 'Receipts today' }), _stats.receiptsToday, 'fa-file-text', '#8b5cf6', '#ede9fe']
];
%>
<div class="page-wrapper acc-portal"><div class="content">
<%- include('partials/portal-flash') %>

<!-- Hero -->
<div class="card border-0 shadow acc-hero hms-page-hero mb-4">
  <div class="card-body py-4 px-4 d-flex align-items-center justify-content-between flex-wrap position-relative" style="z-index:1;gap:12px;">
    <div>
      <h1 class="h4 mb-1 font-weight-bold" style="color:#fff;"><i class="fa fa-calculator mr-2"></i><%= _t('portal_accountant.title', { ns: 'legacy', defaultValue: 'Accountant Portal' }) %></h1>
      <p class="mb-0 small" style="color:rgba(255,255,255,.9);"><%= _t('portal_accountant.welcome_date', { ns: 'legacy', suffix: _welcomeSuffix, date: _dateLabel, defaultValue: 'Welcome' + _welcomeSuffix + ' — ' + _dateLabel }) %></p>
    </div>
    <div class="d-flex flex-wrap" style="gap:8px;">
      <% if (uiVisible('acc.hero.guides')) { %><a href="/workflow-guides" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-sitemap mr-1"></i><%= _t('portal_shared.workflow_guides', { ns: 'legacy', defaultValue: 'Workflow guides' }) %></a><% } %>
      <button type="button" class="btn btn-outline-light btn-sm font-weight-bold" data-toggle="modal" data-target="#accPeriodModal"><i class="fa fa-calendar-check-o mr-1"></i><%= _t('portal_accountant.period_close', { ns: 'legacy', defaultValue: 'Period close' }) %></button>
      <% if(hasP('accounting.read','accounting.write','billing.read','billing.write')){ %>
      <a href="/billing" class="btn btn-light btn-sm font-weight-bold" style="color:#1e3a8a;"><i class="fa fa-th-large mr-1"></i><%= _t('portal_accountant.billing_workspace', { ns: 'legacy', defaultValue: 'Billing workspace' }) %></a>
      <% } %>
      <% if(hasP('accounting.read','accounting.write','financials.read','financials.write')){ %>
      <a href="/financials" class="btn btn-warning btn-sm font-weight-bold" style="color:#1e3a8a;"><i class="fa fa-line-chart mr-1"></i><%= _t('portal_accountant.accounting_books', { ns: 'legacy', defaultValue: 'Accounting (Books)' }) %></a>
      <% } %>
    </div>
  </div>
</div>

<!-- KPIs -->
<div class="row mb-4">
  <% _accKpis.forEach(function(s){ %>
  <div class="col-6 col-lg-3 mb-3">
    <div class="acc-kpi">
      <div class="card-body d-flex align-items-center py-3">
        <span class="rounded-circle mr-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;background:<%= s[4] %>;">
          <i class="fa <%= s[2] %>" style="color:<%= s[3] %>;font-size:1.1rem;"></i>
        </span>
        <div>
          <div class="acc-kpi-value"><%= s[1] %></div>
          <div class="acc-kpi-label"><%= s[0] %></div>
        </div>
      </div>
    </div>
  </div>
  <% }); %>
</div>

<%- include('partials/portal-tiles', { portal: 'accountant', title: _t('portal_accountant.financial_modules', { ns: 'legacy', defaultValue: 'Financial modules' }) }) %>

<div class="row">
  <div class="col-lg-8 mb-4">
    <div class="acc-table-card bg-white">
      <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 flex-wrap" style="border-bottom:2px solid #e2e8f0;gap:8px;">
        <span class="font-weight-bold"><i class="fa fa-exchange mr-1 text-primary"></i><%= _t('portal_accountant.recent_transactions', { ns: 'legacy', defaultValue: 'Recent transactions' }) %></span>
        <span class="small text-muted"><%= _t('portal_shared.click_row_details', { ns: 'legacy', defaultValue: 'Click a row for details' }) %></span>
        <% if(hasP('billing.read','billing.write')){ %>
        <a href="/billing/transactions" class="btn btn-sm btn-primary ml-auto" style="border-radius:8px;"><%= _t('portal_shared.view_all', { ns: 'legacy', defaultValue: 'View All' }) %></a>
        <% } else { %>
        <a href="/billing" class="btn btn-sm btn-outline-primary ml-auto" style="border-radius:8px;"><%= _t('portal_accountant.billing', { ns: 'legacy', defaultValue: 'Billing' }) %></a>
        <% } %>
      </div>
      <div class="card-body p-0" data-hms-table-paginate data-hms-page-size="8">
        <div class="table-responsive">
          <table class="table table-hover mb-0" id="accTxnTable">
            <thead>
              <tr>
                <th><%= _t('portal_shared.patient', { ns: 'legacy', defaultValue: 'Patient' }) %></th>
                <th class="text-right"><%= _t('portal_shared.amount_xaf', { ns: 'legacy', defaultValue: 'Amount (XAF)' }) %></th>
                <th><%= _t('portal_shared.method', { ns: 'legacy', defaultValue: 'Method' }) %></th>
                <th><%= _t('portal_shared.date', { ns: 'legacy', defaultValue: 'Date' }) %></th>
              </tr>
            </thead>
            <tbody>
              <% if(!recentTxn||recentTxn.length===0){ %>
              <tr><td colspan="4" class="text-center text-muted py-5"><i class="fa fa-inbox d-block mb-2" style="font-size:1.5rem;opacity:.4;"></i><%= _t('portal_accountant.no_transactions', { ns: 'legacy', defaultValue: 'No transactions found.' }) %></td></tr>
              <% } else { recentTxn.forEach(function(r){
                var d = r.created_at ? new Date(r.created_at) : null;
                var dShow = d ? (typeof fmtDateTime === 'function' ? fmtDateTime(d) : fmtDate(d)) : '—';
                var amt = parseFloat(r.amount) || 0;
                var pname = ((r.first_name||'') + ' ' + (r.last_name||'')).trim() || '—';
              %>
              <tr class="acc-txn-row" tabindex="0" role="button"
                  data-id="<%= r.id %>"
                  data-patient="<%= pname.replace(/"/g,'&quot;') %>"
                  data-amount="<%= amt %>"
                  data-method="<%= (r.payment_method||'').replace(/"/g,'&quot;') %>"
                  data-date="<%= dShow.replace(/"/g,'&quot;') %>"
                  data-ref="<%= (r.description||'').replace(/"/g,'&quot;') %>"
                  data-status="<%= (r.status||'').replace(/"/g,'&quot;') %>">
                <td class="font-weight-bold"><%= pname %></td>
                <td class="text-right font-weight-bold"><%= _fmtXaf(amt) %></td>
                <td class="small text-muted"><%= r.payment_method || '—' %></td>
                <td class="small text-muted"><%= dShow %></td>
              </tr>
              <% }); } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4 mb-4">
    <div class="acc-workflow card border-0 shadow-sm h-100">
      <div class="card-body">
        <h5 class="font-weight-bold mb-3" style="color:#1e3a8a;"><i class="fa fa-road mr-2"></i><%= _t('portal_accountant.typical_workflow', { ns: 'legacy', defaultValue: 'Typical workflow' }) %></h5>
        <div class="acc-workflow-step">
          <span class="acc-step-num">1</span>
          <div class="small"><%- _t('portal_accountant.step1', { ns: 'legacy', defaultValue: 'Review <strong>billing & cashier</strong> activity; reconcile with bank and GL class 5.' }) %></div>
        </div>
        <div class="acc-workflow-step">
          <span class="acc-step-num">2</span>
          <div class="small"><%- _t('portal_accountant.step2', { ns: 'legacy', defaultValue: 'Post and verify <strong>expenses</strong>; confirm GL posting on the expense register.' }) %></div>
        </div>
        <div class="acc-workflow-step">
          <span class="acc-step-num">3</span>
          <div class="small"><%- _t('portal_accountant.step3', { ns: 'legacy', defaultValue: 'Run <strong>trial balance</strong>, monthly statement, and tax worksheets before close.' }) %></div>
        </div>
        <div class="mt-3 pt-3 border-top">
          <a href="/financials/platform-overview" class="btn btn-outline-primary btn-sm btn-block mb-2"><i class="fa fa-life-ring mr-1"></i><%= _t('portal_accountant.help_setup', { ns: 'legacy', defaultValue: 'Help & setup' }) %></a>
          <a href="/docs/user-guide" class="btn btn-outline-secondary btn-sm btn-block"><i class="fa fa-book mr-1"></i><%= _t('portal_accountant.user_guide_pdf', { ns: 'legacy', defaultValue: 'User Guide (PDF)' }) %></a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/portal-accountant-modals') %>

</div></div>
<%- include('partials/footer') %>

<script>
(function () {
  var _txnPrefix = <%- JSON.stringify(_t('portal_accountant.txn_patient_payment', { ns: 'legacy', defaultValue: 'Patient payment — ' })) %>;
  function openTxnModal(row) {
    if (!row) return;
    var amt = parseFloat(row.getAttribute('data-amount')) || 0;
    document.getElementById('accTxnAmount').textContent = amt.toLocaleString('fr-FR') + ' XAF';
    document.getElementById('accTxnMeta').textContent = _txnPrefix + (row.getAttribute('data-method') || '—');
    document.getElementById('accTxnPatient').textContent = row.getAttribute('data-patient') || '—';
    document.getElementById('accTxnMethod').textContent = row.getAttribute('data-method') || '—';
    document.getElementById('accTxnDate').textContent = row.getAttribute('data-date') || '—';
    document.getElementById('accTxnRef').textContent = row.getAttribute('data-ref') || '—';
    var stEl = document.getElementById('accTxnStatus');
    if (stEl) stEl.textContent = row.getAttribute('data-status') || '—';
    document.getElementById('accTxnId').textContent = '#' + (row.getAttribute('data-id') || '—');
    var link = document.getElementById('accTxnBillingLink');
    if (link) link.href = '/billing/transactions';
    if (window.jQuery) jQuery('#accTxnModal').modal('show');
  }
  document.querySelectorAll('.acc-txn-row').forEach(function (row) {
    row.addEventListener('click', function () { openTxnModal(row); });
    row.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openTxnModal(row); }
    });
  });
})();
</script>

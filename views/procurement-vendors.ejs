<%- include('partials/header') %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>
<% var classes = vendorClasses || ['pharmaceutical','consumables','equipment','services','general']; %>

<div class="page-wrapper hms-surface-module">
 <div class="content">
 <% if(locals.flash){ %>
 <div class="hms-flash hms-flash--success"><%= flash %></div>
 <% } %>
 <% if(locals.error){ %>
 <div class="hms-flash hms-flash--error"><%= error %></div>
 <% } %>
 <div class="row align-items-center mb-3">
 <div class="col-sm-8">
 <h4 class="page-title font-weight-bold text-dark"><%= _t('procurement_vendors.title', { ns: 'legacy', defaultValue: 'Vendor Directory' }) %></h4>
 <p class="text-muted small mb-0"><%= _t('procurement_vendors.subtitle', { ns: 'legacy', defaultValue: 'Register, classify, suspend, and manage suppliers.' }) %></p>
 </div>
 <div class="col-sm-4 text-right">
 <% if (canWrite) { %>
 <button class="btn btn-primary hms-btn-premium" data-toggle="modal" data-target="#addVendorModal">
 <i class="fa fa-plus mr-2"></i> <%= _t('procurement_vendors.register_vendor', { ns: 'legacy', defaultValue: 'Register New Vendor' }) %>
 </button>
 <% } %>
 </div>
 </div>

 <div class="hms-stat-grid" style="grid-template-columns: repeat(2, minmax(0, 1fr)); max-width: 480px;">
  <div class="hms-stat-card hms-stat-card--procurement">
   <div class="hms-stat-card__value"><%= vendors.length %></div>
   <div class="hms-stat-card__label"><%= _t('procurement_vendors.stat_listed', { ns: 'legacy', defaultValue: 'Listed vendors' }) %></div>
  </div>
  <div class="hms-stat-card hms-stat-card--success">
   <div class="hms-stat-card__value"><%= vendors.filter(function(v){ return v.is_active; }).length %></div>
   <div class="hms-stat-card__label"><%= _t('procurement_vendors.stat_active', { ns: 'legacy', defaultValue: 'Active' }) %></div>
  </div>
 </div>

 <form method="get" action="/procurement/vendors" class="hms-filter-bar">
  <input type="search" name="q" class="form-control hms-filter-bar__search" value="<%= locals.vendorSearch || '' %>" placeholder="<%= _t('procurement_vendors.search_ph', { ns: 'legacy', defaultValue: 'Search name, code, contact or email' }) %>">
  <button type="submit" class="btn btn-outline-secondary"><%= _t('procurement_vendors.search', { ns: 'legacy', defaultValue: 'Search' }) %></button>
  <% if (locals.vendorSearch) { %><a href="/procurement/vendors" class="btn btn-link"><%= _t('procurement_vendors.reset', { ns: 'legacy', defaultValue: 'Reset' }) %></a><% } %>
 </form>

 <div class="hms-surface-card">
 <div class="table-responsive">
 <table class="table table-hover mb-0 hms-table-v3">
 <thead class="bg-light">
 <tr>
 <th><%= _t('procurement_vendors.col_code', { ns: 'legacy', defaultValue: 'Code' }) %></th>
 <th><%= _t('procurement_vendors.col_name', { ns: 'legacy', defaultValue: 'Vendor Name' }) %></th>
 <th><%= _t('procurement_vendors.col_class', { ns: 'legacy', defaultValue: 'Class' }) %></th>
 <th><%= _t('procurement_vendors.col_contact', { ns: 'legacy', defaultValue: 'Contact Person' }) %></th>
 <th><%= _t('procurement_vendors.col_phone_email', { ns: 'legacy', defaultValue: 'Phone / Email' }) %></th>
 <th><%= _t('procurement_vendors.col_status', { ns: 'legacy', defaultValue: 'Status' }) %></th>
 <th class="text-right"><%= _t('procurement_vendors.col_action', { ns: 'legacy', defaultValue: 'Action' }) %></th>
 </tr>
 </thead>
 <tbody>
 <% vendors.forEach(vendor => { %>
 <tr class="<%= vendor.is_active ? '' : 'opacity-75' %>">
 <td><code><%= vendor.vendor_code %></code></td>
 <td>
 <div class="font-weight-bold text-dark"><%= vendor.name %></div>
 <div class="extra-small text-muted"><%= vendor.address || _t('procurement_vendors.no_address', { ns: 'legacy', defaultValue: 'No Address' }) %></div>
 </td>
 <td><span class="badge badge-light text-uppercase extra-small"><%= vendor.vendor_class || 'general' %></span></td>
 <td><%= vendor.contact_name || '—' %></td>
 <td>
 <div class="small"><i class="fa fa-phone mr-1 opacity-50"></i> <%= vendor.phone || _t('procurement_vendors.na', { ns: 'legacy', defaultValue: 'N/A' }) %></div>
 <div class="small"><i class="fa fa-envelope mr-1 opacity-50"></i> <%= vendor.email || _t('procurement_vendors.na', { ns: 'legacy', defaultValue: 'N/A' }) %></div>
 </td>
 <td>
 <span class="badge badge-<%= vendor.is_active ? 'success' : 'danger' %>-light px-2 py-1 text-uppercase extra-small">
 <%= vendor.is_active ? _t('procurement_vendors.active', { ns: 'legacy', defaultValue: 'Active' }) : _t('procurement_vendors.suspended', { ns: 'legacy', defaultValue: 'Suspended' }) %>
 </span>
 </td>
 <td class="text-right">
 <% if (canWrite) { %>
 <div class="btn-group btn-group-sm">
 <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3" data-toggle="modal" data-target="#editVendor<%= vendor.id %>">
 <i class="fa fa-pencil mr-1"></i> <%= _t('procurement_vendors.edit', { ns: 'legacy', defaultValue: 'Edit' }) %>
 </button>
 <% if (vendor.is_active) { %>
 <form method="post" action="/procurement/vendors/<%= vendor.id %>/suspend" class="d-inline" onsubmit="return confirm('Suspend this vendor?');">
 <button type="submit" class="btn btn-outline-warning btn-sm rounded-pill px-2" title="Suspend"><i class="fa fa-ban"></i></button>
 </form>
 <% } else { %>
 <form method="post" action="/procurement/vendors/<%= vendor.id %>/activate" class="d-inline">
 <button type="submit" class="btn btn-outline-success btn-sm rounded-pill px-2" title="Reactivate"><i class="fa fa-check"></i></button>
 </form>
 <% } %>
 <form method="post" action="/procurement/vendors/<%= vendor.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this vendor permanently?');">
 <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-2" title="Delete"><i class="fa fa-trash"></i></button>
 </form>
 </div>
 <% } %>
 </td>
 </tr>
 <% }) %>
 <% if(vendors.length === 0) { %>
 <tr>
 <td colspan="7" class="text-center py-5 text-muted"><%= _t('procurement_vendors.empty', { ns: 'legacy', defaultValue: 'No vendors registered yet.' }) %></td>
 </tr>
 <% } %>
 </tbody>
 </table>
 </div>
 </div>
 </div>
</div>

<% if (canWrite) { %>
<div class="modal fade" id="addVendorModal" tabindex="-1" role="dialog" aria-labelledby="addVendorModalTitle">
 <div class="modal-dialog modal-lg">
 <div class="modal-content border-0 rounded-xl shadow-lg">
 <form action="/procurement/vendors/add" method="POST">
 <div class="modal-header bg-indigo text-white p-4">
 <h5 class="modal-title font-weight-bold" id="addVendorModalTitle"><%= _t('procurement_vendors.modal_title', { ns: 'legacy' }) %></h5>
 <button type="button" class="close text-white" data-dismiss="modal" aria-label="<%= _t('procurement_vendors.cancel', { ns: 'legacy' }) %>"><span aria-hidden="true">&times;</span></button>
 </div>
 <div class="modal-body p-4">
 <div class="row">
 <div class="col-md-6 form-group">
 <label class="font-weight-bold text-dark"><%= _t('procurement_vendors.vendor_name', { ns: 'legacy' }) %> <span class="text-danger">*</span></label>
 <input type="text" name="name" class="hms-input w-full" required>
 </div>
 <div class="col-md-6 form-group">
 <label class="font-weight-bold text-dark"><%= _t('procurement_vendors.vendor_code', { ns: 'legacy' }) %></label>
 <input type="text" name="vendor_code" class="hms-input w-full">
 </div>
 <div class="col-md-6 form-group">
 <label class="font-weight-bold text-dark"><%= _t('procurement_vendors.col_class', { ns: 'legacy' }) %></label>
 <select name="vendor_class" class="hms-input w-full">
 <% classes.forEach(function(c){ %><option value="<%= c %>"><%= c %></option><% }) %>
 </select>
 </div>
 <div class="col-md-6 form-group">
 <label class="font-weight-bold text-dark"><%= _t('procurement_vendors.contact_person', { ns: 'legacy' }) %></label>
 <input type="text" name="contact_name" class="hms-input w-full">
 </div>
 <div class="col-md-6 form-group">
 <label class="font-weight-bold text-dark"><%= _t('procurement_vendors.phone', { ns: 'legacy' }) %></label>
 <input type="text" name="phone" class="hms-input w-full">
 </div>
 <div class="col-md-6 form-group">
 <label class="font-weight-bold text-dark"><%= _t('procurement_vendors.email', { ns: 'legacy' }) %></label>
 <input type="email" name="email" class="hms-input w-full">
 </div>
 <div class="col-md-6 form-group">
 <label class="font-weight-bold text-dark"><%= _t('procurement_vendors.tax_id', { ns: 'legacy' }) %></label>
 <input type="text" name="tax_id" class="hms-input w-full">
 </div>
 <div class="col-12 form-group">
 <label class="font-weight-bold text-dark"><%= _t('procurement_vendors.address', { ns: 'legacy' }) %></label>
 <textarea name="address" class="hms-input w-full" rows="2"></textarea>
 </div>
 </div>
 </div>
 <div class="modal-footer bg-light p-4">
 <button type="button" class="hms-btn hms-btn-secondary" data-dismiss="modal"><%= _t('procurement_vendors.cancel', { ns: 'legacy' }) %></button>
 <button type="submit" class="hms-btn hms-btn-primary px-4"><%= _t('procurement_vendors.register_btn', { ns: 'legacy' }) %></button>
 </div>
 </form>
 </div>
 </div>
</div>

<% vendors.forEach(function(vendor) { %>
<div class="modal fade" id="editVendor<%= vendor.id %>" tabindex="-1" role="dialog" aria-labelledby="editVendorTitle<%= vendor.id %>">
 <div class="modal-dialog modal-lg">
 <div class="modal-content border-0 rounded-xl shadow-lg">
 <form action="/procurement/vendors/<%= vendor.id %>/update" method="POST">
 <div class="modal-header bg-primary text-white p-4">
 <h5 class="modal-title font-weight-bold" id="editVendorTitle<%= vendor.id %>"><%= _t('procurement_vendors.edit', { ns: 'legacy' }) %>: <%= vendor.name %></h5>
 <button type="button" class="close text-white" data-dismiss="modal" aria-label="<%= _t('procurement_vendors.cancel', { ns: 'legacy' }) %>"><span aria-hidden="true">&times;</span></button>
 </div>
 <div class="modal-body p-4">
 <div class="row">
 <div class="col-md-6 form-group">
 <label class="font-weight-bold"><%= _t('procurement_vendors.vendor_name', { ns: 'legacy' }) %> *</label>
 <input type="text" name="name" class="hms-input w-full" value="<%= vendor.name %>" required>
 </div>
 <div class="col-md-6 form-group">
 <label class="font-weight-bold"><%= _t('procurement_vendors.col_class', { ns: 'legacy' }) %></label>
 <select name="vendor_class" class="hms-input w-full">
 <% classes.forEach(function(c){ %>
 <option value="<%= c %>" <%= String(vendor.vendor_class||'general')===c?'selected':'' %>><%= c %></option>
 <% }) %>
 </select>
 </div>
 <div class="col-md-6 form-group"><label class="font-weight-bold"><%= _t('procurement_vendors.contact_person', { ns: 'legacy' }) %></label><input name="contact_name" class="hms-input w-full" value="<%= vendor.contact_name || '' %>"></div>
 <div class="col-md-6 form-group"><label class="font-weight-bold"><%= _t('procurement_vendors.phone', { ns: 'legacy' }) %></label><input name="phone" class="hms-input w-full" value="<%= vendor.phone || '' %>"></div>
 <div class="col-md-6 form-group"><label class="font-weight-bold"><%= _t('procurement_vendors.email', { ns: 'legacy' }) %></label><input name="email" type="email" class="hms-input w-full" value="<%= vendor.email || '' %>"></div>
 <div class="col-md-6 form-group"><label class="font-weight-bold"><%= _t('procurement_vendors.tax_id', { ns: 'legacy' }) %></label><input name="tax_id" class="hms-input w-full" value="<%= vendor.tax_id || '' %>"></div>
 <div class="col-12 form-group"><label class="font-weight-bold"><%= _t('procurement_vendors.address', { ns: 'legacy' }) %></label><textarea name="address" class="hms-input w-full" rows="2"><%= vendor.address || '' %></textarea></div>
 </div>
 </div>
 <div class="modal-footer bg-light p-4">
 <button type="button" class="hms-btn hms-btn-secondary" data-dismiss="modal"><%= _t('procurement_vendors.cancel', { ns: 'legacy' }) %></button>
 <button type="submit" class="hms-btn hms-btn-primary"><%= _t('procurement_vendors.save_btn', { ns: 'legacy' }) %></button>
 </div>
 </form>
 </div>
 </div>
</div>
<% }) %>
<% } %>

<style>
 .extra-small { font-size: 0.65rem; }
 .badge-success-light { background: #dcfce7; color: #166534; }
 .badge-danger-light { background: #fee2e2; color: #991b1b; }
</style>

<%- include('partials/footer') %>

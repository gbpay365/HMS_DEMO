<%- include('partials/header') %>
<%
if (typeof _t !== 'function') {
  var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
}
if (typeof _tl !== 'function') {
  var _tl = function (key, fallback, opts) {
    var o = { ns: 'legacy', defaultValue: fallback };
    if (opts && typeof opts === 'object') { for (var pk in opts) { if (Object.prototype.hasOwnProperty.call(opts, pk)) o[pk] = opts[pk]; } }
    return _t(key, o);
  };
}
%>
<%- include('partials/pharmacy-odoo-start', { phaOdooMenu: 'config', phaOdooSub: 'medicine-categories', phaOdooTitle: _tl('pharmacy_config_categories.title', 'Medicine categories'), nursingSupplyPending, flash, error }) %>
<div class="o_control_panel">
  <button type="button" class="o_cp_new" data-toggle="modal" data-target="#catModal"><i class="fa fa-plus"></i> <%= _tl('pharmacy_shared.new', 'New') %></button>
  <div class="o_cp_breadcrumb"><span><%= _tl('pharmacy_config_categories.title', 'Medicine categories') %></span></div>
  <a href="/pharmacy/config/medicine-types" class="o_btn_link"><%= _tl('pharmacy_config_categories.types_link', 'Types') %></a>
</div>
<div class="o_content p-3">
  <div class="o_list_renderer">
    <table class="o_list_table">
      <thead><tr><th><%= _tl('pharmacy_shared.name', 'Name') %></th><th><%= _tl('pharmacy_shared.description', 'Description') %></th><th><%= _tl('pharmacy_config_categories.col_rx_required', 'Rx required') %></th><th><%= _tl('pharmacy_shared.status', 'Status') %></th><th></th></tr></thead>
      <tbody>
        <% (categories||[]).forEach(function(c){ if(!c.is_active) return; %>
        <tr>
          <td class="font-weight-bold"><%= c.name %></td>
          <td class="text-muted small"><%= c.description || _tl('pharmacy_shared.em_dash', '—') %></td>
          <td><%= c.requires_prescription ? _tl('pharmacy_shared.yes', 'Yes') : _tl('pharmacy_shared.no', 'No') %></td>
          <td><span class="o_status_pill o_status_sales"><%= _tl('pharmacy_shared.active', 'Active') %></span></td>
          <td class="text-right">
            <button type="button" class="btn btn-sm btn-outline-secondary pha-edit-cat"
              data-id="<%= c.id %>" data-name="<%= c.name %>" data-desc="<%= c.description || '' %>"
              data-rx="<%= c.requires_prescription ? '1' : '0' %>"><%= _tl('pharmacy_shared.edit', 'Edit') %></button>
            <form method="post" action="/pharmacy/config/medicine-categories" class="d-inline" onsubmit="return confirm('<%= _tl('pharmacy_config_categories.confirm_archive', 'Archive this category?').replace(/'/g, "\\'") %>');">
              <input type="hidden" name="action" value="delete"><input type="hidden" name="id" value="<%= c.id %>">
              <button type="submit" class="btn btn-sm btn-outline-danger"><%= _tl('pharmacy_shared.archive', 'Archive') %></button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<div class="modal fade" id="catModal" tabindex="-1" role="dialog" aria-labelledby="catModalTitle">
  <div class="modal-dialog"><div class="modal-content">
    <form method="post" action="/pharmacy/config/medicine-categories" id="catForm">
      <div class="modal-header"><h5 class="modal-title" id="catModalTitle"><%= _tl('pharmacy_config_categories.modal_title', 'Medicine category') %></h5><button type="button" class="close" data-dismiss="modal" aria-label="<%= _tl('pharmacy_shared.cancel', 'Cancel') %>"><span aria-hidden="true">&times;</span></button></div>
      <div class="modal-body">
        <input type="hidden" name="id" id="catId" value="">
        <div class="form-group"><label class="small font-weight-bold"><%= _tl('pharmacy_shared.name', 'Name') %></label><input name="name" id="catName" class="hms-input w-full" required></div>
        <div class="form-group"><label class="small font-weight-bold"><%= _tl('pharmacy_shared.description', 'Description') %></label><textarea name="description" id="catDesc" class="hms-input w-full" rows="2"></textarea></div>
        <div class="custom-control custom-checkbox">
          <input type="checkbox" class="custom-control-input" name="requires_prescription" id="catRx" value="1">
          <label class="custom-control-label small" for="catRx"><%= _tl('pharmacy_config_categories.requires_prescription', 'Requires prescription') %></label>
        </div>
      </div>
      <div class="modal-footer"><button type="button" class="hms-btn hms-btn-secondary" data-dismiss="modal"><%= _tl('pharmacy_shared.cancel', 'Cancel') %></button><button type="submit" class="hms-btn hms-btn-primary"><%= _tl('pharmacy_shared.save', 'Save') %></button></div>
    </form>
  </div></div>
</div>
<%- include('partials/pharmacy-odoo-end') %>
<script>
document.querySelectorAll('.pha-edit-cat').forEach(function(btn){
  btn.addEventListener('click', function(){
    document.getElementById('catId').value = btn.getAttribute('data-id');
    document.getElementById('catName').value = btn.getAttribute('data-name');
    document.getElementById('catDesc').value = btn.getAttribute('data-desc');
    document.getElementById('catRx').checked = btn.getAttribute('data-rx') === '1';
    $('#catModal').modal('show');
  });
});
$('#catModal').on('hidden.bs.modal', function(){ document.getElementById('catForm').reset(); document.getElementById('catId').value=''; });
</script>
<%- include('partials/footer') %>

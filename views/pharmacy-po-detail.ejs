<%- include('partials/header') %>
<%
if (typeof _t !== 'function') {
  var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
}
if (typeof _tl !== 'function') {
  var _tl = function (key, fallback, opts) {
    var o = { ns: 'legacy', defaultValue: fallback };
    if (opts && typeof opts === 'object') { for (var pk in opts) { if (Object.prototype.hasOwnProperty.call(opts, pk)) o[pk] = opts[pk]; } }
    return _t(key, o);
  };
}
var _po = po || {};
var _lines = lines || [];
var st = String(_po.status||'draft').toLowerCase();
var pill = st==='received'?'o_status_sales':(st==='approved'||st==='issued'?'o_status_preparing':'o_status_pending');
var hasExpired = false;
_lines.forEach(function(l){
  if (l.expiry_date) {
    var exp = String(l.expiry_date).slice(0,10);
    var today = new Date().toISOString().split('T')[0];
    if (exp < today) hasExpired = true;
  }
});
%>
<%- include('partials/pharmacy-odoo-start', { phaOdooMenu: 'purchase', phaOdooTitle: _po.po_number, nursingSupplyPending, flash, error }) %>
<div class="o_control_panel">
  <div class="o_cp_breadcrumb"><span><%= _po.po_number %></span> <span class="o_status_pill <%= pill %> ml-2"><%= st %></span></div>
  <a href="/pharmacy/purchase-orders" class="o_btn_link"><%= _tl('pharmacy_shared.all_pos', 'All POs') %></a>
</div>
<div class="o_content p-3">
  <div class="card mb-3" style="max-width:900px;border-radius:8px;">
    <div class="card-body small">
      <div class="row">
        <div class="col-md-4 mb-2"><strong><%= _tl('pharmacy_shared.supplier', 'Supplier:') %></strong> <%= _po.supplier_name %></div>
        <div class="col-md-4 mb-2"><strong><%= _tl('pharmacy_shared.total', 'Total:') %></strong> <%= parseFloat(_po.total_amount||0).toFixed(2) %> FCFA</div>
        <div class="col-md-4 mb-2"><strong><%= _tl('pharmacy_shared.notes', 'Notes:') %></strong> <%= _po.po_notes || _tl('pharmacy_shared.em_dash', '—') %></div>
      </div>
    </div>
    <% if (hasExpired && st === 'draft') { %>
    <div class="alert alert-warning mb-0 rounded-0"><i class="fa fa-warning"></i> <%= _tl('pharmacy_po_detail.expired_warning', 'Some lines reference products with expired stock on hand. Confirm with override if intentional.') %></div>
    <% } %>
  </div>
  <div class="o_list_renderer mb-3" style="max-width:900px;">
    <table class="o_list_table">
      <thead><tr><th><%= _tl('pharmacy_shared.product', 'Product') %></th><th><%= _tl('pharmacy_po_detail.col_sku', 'SKU') %></th><th style="text-align:right;"><%= _tl('pharmacy_po_new.col_unit_price', 'Unit price') %></th><th style="text-align:right;"><%= _tl('pharmacy_shared.qty', 'Qty') %></th><th style="text-align:right;"><%= _tl('pharmacy_po_detail.col_subtotal', 'Subtotal') %></th><th><%= _tl('pharmacy_po_detail.col_stock_expiry', 'Stock expiry') %></th></tr></thead>
      <tbody>
        <% _lines.forEach(function(l){
             var sub = (parseInt(l.quantity,10)||0) * (parseFloat(l.unit_price)||0);
             var exp = l.expiry_date ? String(l.expiry_date).slice(0,10) : null;
             var today = new Date().toISOString().split('T')[0];
             var expBad = exp && exp < today;
        %>
        <tr>
          <td class="font-weight-bold"><%= l.item_name || _tl('pharmacy_shared.em_dash', '—') %></td>
          <td class="text-muted"><%= l.sku || _tl('pharmacy_shared.em_dash', '—') %></td>
          <td style="text-align:right;"><%= parseFloat(l.unit_price||0).toFixed(2) %></td>
          <td style="text-align:right;"><%= typeof fmtPoQty === 'function' ? fmtPoQty(l.quantity, l.uom) : l.quantity %></td>
          <td style="text-align:right;"><%= sub.toFixed(2) %></td>
          <td><% if(exp){ %><span class="<%= expBad?'text-danger font-weight-bold':'' %>"><%= exp %><% if(expBad){ %> <%= _tl('pharmacy_shared.expired_suffix', '(expired)') %><% } %></span><% } else { %><%= _tl('pharmacy_shared.em_dash', '—') %><% } %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <div class="d-flex flex-wrap" style="gap:8px;">
    <% if (st === 'draft') { %>
    <form method="post" action="/pharmacy/purchase-orders/<%= _po.id %>/confirm" style="margin:0;"
          onsubmit="return confirm('<%= _tl('pharmacy_po_detail.confirm_po', 'Confirm this purchase order?').replace(/'/g, "\\'") %>');">
      <button type="submit" class="o_cp_new border-0"><%= _tl('pharmacy_shared.confirm', 'Confirm') %></button>
    </form>
    <% if (hasExpired) { %>
    <form method="post" action="/pharmacy/purchase-orders/<%= _po.id %>/confirm" style="margin:0;"
          onsubmit="return confirm('<%= _tl('pharmacy_po_detail.confirm_override', 'Override expiry warning and confirm anyway?').replace(/'/g, "\\'") %>');">
      <input type="hidden" name="force" value="1">
      <button type="submit" class="btn btn-danger"><%= _tl('pharmacy_po_detail.confirm_with_override', 'Confirm with override') %></button>
    </form>
    <% } %>
    <a href="/procurement/purchase-orders/<%= _po.id %>?edit=1" class="o_btn_link"><i class="fa fa-pencil mr-1"></i><%= _tl('pharmacy_po_detail.edit_po', 'Edit PO') %></a>
    <% } %>
    <% if (st === 'approved' || st === 'issued' || st === 'received') { %>
    <% if (st === 'approved' || st === 'issued') { %>
    <form method="post" action="/pharmacy/purchase-orders/<%= _po.id %>/receive" style="margin:0;"
          onsubmit="return confirm('<%= _tl('pharmacy_po_detail.receive_confirm', 'Receive goods and update stock?').replace(/'/g, "\\'") %>');">
      <button type="submit" class="o_cp_new border-0"><%= _tl('pharmacy_po_detail.receive_goods', 'Receive goods') %></button>
    </form>
    <% } %>
    <a href="/procurement/purchase-orders/<%= _po.id %>?edit=1" class="o_btn_link"><i class="fa fa-pencil mr-1"></i><%= _tl('pharmacy_po_detail.edit_po', 'Edit PO') %></a>
    <% } %>
  </div>
</div>
<%- include('partials/pharmacy-odoo-end') %>
<%- include('partials/footer') %>

<%- include('partials/header') %>
<%
if (typeof _t !== 'function') {
  var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
}
if (typeof _tl !== 'function') {
  var _tl = function (key, fallback, opts) {
    var o = { ns: 'legacy', defaultValue: fallback };
    if (opts && typeof opts === 'object') { for (var pk in opts) { if (Object.prototype.hasOwnProperty.call(opts, pk)) o[pk] = opts[pk]; } }
    return _t(key, o);
  };
}
%>
<link rel="stylesheet" href="/css/laboratory-templates.css?v=1">
<link rel="stylesheet" href="/css/diagnostic-report-print.css?v=1">

<%- include('partials/laboratory-odoo-start', {
  labOdooMenu: 'templates',
  labOdooTitle: _tl('laboratory_templates.hero_title', 'Structured test templates')
}) %>
<div class="o_content px-3 px-md-4 pb-4">

<div id="labTplRoot">
    <div class="d-flex flex-wrap align-items-center justify-content-end mb-3" style="gap:10px;">
      <span class="badge badge-primary badge-pill px-3 py-2 font-weight-bold" id="labTplTestCount">—</span>
    </div>

    <% if (locals.queryCode && locals.queryOi) { %>
    <div class="alert alert-light border shadow-sm mb-3" style="border-radius:12px;border-color:#e0e7ff!important;">
      <i class="fa fa-link text-primary mr-2"></i>
      <span class="small"><%= _tl('laboratory_templates.prefill_banner', 'Prefilling from validation · Code') %> <strong class="text-monospace"><%= queryCode %></strong> · <%= _tl('laboratory_templates.order_item', 'Order item') %> <strong>#<%= queryOi %></strong></span>
    </div>
    <% } %>
    <div id="labTplOrderBanner" class="hms-flash hms-flash--success border-0 shadow-sm mb-3 d-none" style="border-radius:12px;" role="status"></div>

    <div id="labTplSuggestBar" class="alert border-0 shadow-sm mb-3 d-none" style="border-radius:12px;background:linear-gradient(135deg,#ecfdf5,#d1fae5);border:1px solid #6ee7b7!important;" role="status">
      <div class="d-flex flex-wrap align-items-center justify-content-between" style="gap:10px;">
        <div class="small font-weight-bold text-dark" id="labTplSuggestText"><i class="fa fa-magic mr-1 text-success"></i> <%= _tl('laboratory_templates.suggest_default', 'A template was suggested from the prescribed test.') %></div>
        <div class="d-flex flex-wrap" style="gap:8px;">
          <button type="button" class="btn btn-sm btn-success font-weight-bold" id="labTplSuggestContinue"><%= _tl('laboratory_templates.continue', 'Continue') %></button>
          <button type="button" class="btn btn-sm btn-outline-secondary font-weight-bold" id="labTplSuggestPickOther"><%= _tl('laboratory_templates.choose_other', 'Choose another template') %></button>
        </div>
      </div>
    </div>

    <div class="labtpl-hero mb-3">
      <h1><i class="fa fa-flask mr-2"></i><%= _tl('laboratory_templates.hero_title', 'Structured test templates') %></h1>
      <p><%= _tl('laboratory_templates.hero_subtitle', 'Choose a panel from the library, enter results with reference-aware flags, preview, then save to the laboratory registry (or to the linked OPD order when opened from validation).') %></p>
    </div>

    <div class="row labtpl-shell">
      <div class="col-lg-4 mb-3 mb-lg-0">
        <div class="card border-0 shadow-sm h-100 labtpl-sidebar">
          <div class="card-header bg-white border-bottom-0 pt-3 pb-0" style="border-radius:14px 14px 0 0;">
            <h6 class="font-weight-bold text-dark mb-2"><i class="fa fa-book mr-1 text-primary"></i> <%= _tl('laboratory_templates.test_library', 'Test library') %></h6>
            <div class="input-group input-group-sm mb-3">
              <div class="input-group-prepend"><span class="input-group-text bg-light border-right-0"><i class="fa fa-search text-muted"></i></span></div>
              <input type="text" class="hms-input w-full border-left-0" id="searchInput" placeholder="<%= _tl('laboratory_templates.search_ph', 'Search by name, code, or category…') %>" autocomplete="off">
            </div>
          </div>
          <div class="labtpl-cat-scroll border-top" id="catList"></div>
        </div>
      </div>

      <div class="col-lg-8 labtpl-main">
        <div class="card border-0 shadow-sm h-100" style="min-height:420px;">
          <div class="card-body d-flex flex-column p-0">

            <div class="labtpl-empty flex-grow-1 d-flex flex-column justify-content-center" id="emptyState">
              <div class="labtpl-empty-icon"><i class="fa fa-medkit"></i></div>
              <h5 class="font-weight-bold text-secondary"><%= _tl('laboratory_templates.select_test', 'Select a test') %></h5>
              <p class="small text-muted px-4 mb-0" style="max-width:420px;margin:0 auto;">
                <%= _tl('laboratory_templates.select_test_hint', 'Pick any template from the library. Patient fields and conclusion apply to preview and save. Numeric fields show high / low hints against reference ranges when defined.') %>
              </p>
            </div>

            <div class="labtpl-form-panel p-3 p-md-4" id="formPanel">
              <div class="labtpl-form-head">
                <div class="labtpl-form-icon" id="formCatIcon"></div>
                <div class="flex-grow-1" style="min-width:0;">
                  <div class="labtpl-form-title text-truncate" id="formTestName"></div>
                  <div class="labtpl-form-meta" id="formTestMeta"></div>
                </div>
                <div class="labtpl-form-actions">
                  <button type="button" class="btn btn-sm btn-outline-secondary font-weight-bold" id="labTplEditRefsBtn" style="display:none;" onclick="openLabRefsModal()">
                    <i class="fa fa-sliders mr-1"></i> <%= _tl('laboratory_templates.edit_refs', 'Edit references') %>
                  </button>
                  <button type="button" class="btn btn-sm btn-outline-secondary font-weight-bold" onclick="clearLabTplForm()">
                    <i class="fa fa-undo mr-1"></i> <%= _tl('laboratory_templates.clear', 'Clear') %>
                  </button>
                  <button type="button" class="btn btn-sm btn-outline-primary font-weight-bold" onclick="previewReport()">
                    <i class="fa fa-eye mr-1"></i> <%= _tl('laboratory_templates.preview', 'Preview') %>
                  </button>
                  <button type="button" class="btn btn-sm btn-success font-weight-bold" onclick="saveLabTplReport()">
                    <i class="fa fa-save mr-1"></i> <%= _tl('laboratory_templates.save_registry', 'Save to registry') %>
                  </button>
                </div>
              </div>

              <div class="labtpl-patient-grid" id="labtplPatientGrid">
                <div>
                  <label class="small font-weight-bold text-muted text-uppercase" for="pid"><%= _tl('laboratory_templates.patient_id', 'Patient ID') %></label>
                  <input type="text" class="hms-input w-full text-sm" id="pid" placeholder="<%= _tl('laboratory_templates.patient_id_ph', 'e.g. 42 or #P-42') %>">
                </div>
                <div>
                  <label class="small font-weight-bold text-muted text-uppercase" for="pname"><%= _tl('laboratory_templates.full_name', 'Full name') %></label>
                  <input type="text" class="hms-input w-full text-sm" id="pname" placeholder="<%= _tl('laboratory_templates.full_name_ph', 'Patient name') %>">
                </div>
                <div>
                  <label class="small font-weight-bold text-muted text-uppercase" for="page"><%= _tl('laboratory_templates.age_sex', 'Age / sex') %></label>
                  <input type="text" class="hms-input w-full text-sm" id="page" placeholder="<%= _tl('laboratory_templates.age_sex_ph', 'e.g. 34y / M') %>">
                </div>
                <div>
                  <label class="small font-weight-bold text-muted text-uppercase" for="pdoctor"><%= _tl('laboratory_templates.requesting_doctor', 'Requesting doctor') %></label>
                  <input type="text" class="hms-input w-full text-sm" id="pdoctor" placeholder="<%= _tl('laboratory_templates.requesting_doctor_ph', 'Dr. …') %>">
                </div>
              </div>

              <div class="labtpl-field-scroll">
                <div id="fieldsGrid"></div>
              </div>

              <div class="labtpl-attachments" id="diagTplAttachSection">
                <label class="small font-weight-bold text-muted text-uppercase d-block mb-2">
                  <i class="fa fa-paperclip mr-1"></i> <%= _tl('laboratory_templates.result_files', 'Test result files') %>
                </label>
                <p class="small text-muted mb-2" id="diagTplAttachHint">
                  <%= _tl('laboratory_templates.attach_hint', 'Attach scanned reports or result PDFs/images. Consulting doctors can view these on the patient chart and lab report.') %>
                </p>
                <div class="diagtpl-attach-list mb-2" id="diagTplAttachList"></div>
                <label class="btn btn-sm btn-outline-primary font-weight-bold mb-0">
                  <i class="fa fa-upload mr-1"></i> <%= _tl('laboratory_templates.choose_files', 'Choose files') %>
                  <input type="file" id="diagTplAttachInput" class="d-none" accept="image/*,.pdf,.png,.jpg,.jpeg,.webp,.heic" multiple>
                </label>
                <button type="button" class="btn btn-sm btn-warning font-weight-bold mb-0" id="labTplOcrBtn" style="display:none;" onclick="document.getElementById('labTplOcrInput').click()">
                  <i class="fa fa-magic mr-1"></i> <%= _tl('laboratory_templates.upload_autofill', 'Upload & auto-fill') %>
                </button>
                <input type="file" id="labTplOcrInput" class="d-none" accept="image/*,.pdf,.png,.jpg,.jpeg,.webp">
                <span class="small text-muted ml-2"><%= _tl('laboratory_templates.attach_limits', 'Up to 8 files · 12 MB each · images or PDF') %></span>
              </div>

              <div class="labtpl-conclusion">
                <label for="conclusion"><%= _tl('laboratory_templates.conclusion_label', 'Conclusion / interpretation') %></label>
                <textarea class="hms-input w-full" id="conclusion" rows="3" placeholder="<%= _tl('laboratory_templates.conclusion_ph', 'Overall interpretation, recommendations, or clinical comments…') %>"></textarea>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/diagnostic-validate-code-modal', { validateModalDept: 'laboratory' }) %>
<%- include('partials/hms-diag-tpl-modals-mount') %>

<script>
  window.__LAB_CAN_WRITE = <%- JSON.stringify((locals.userPerms || []).includes('*') || (locals.userPerms || []).some(function (p) { return /lab\.write/.test(String(p)); })) %>;
</script>
<script src="/js/hms-diagnostic-code-validate.js"></script>
<script src="/js/hms-diagnostic-attachments.js"></script>
<script src="/js/hms-diagnostic-report-print.js?v=2"></script>
<%- include('partials/diag-tpl-i18n-script', { diagI18nNs: 'laboratory_templates' }) %>
<script src="/js/laboratory-templates.js?v=13"></script>
</div>
<%- include('partials/laboratory-odoo-end') %>
<%- include('partials/footer') %>

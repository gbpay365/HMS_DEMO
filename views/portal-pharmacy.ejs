<%- include('partials/header') %>
<%
var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
var _up = locals.userPerms || [];
function hasP(){ if (_up.includes('*')) return true; for (var i=0;i<arguments.length;i++) if (_up.includes(arguments[i])) return true; return false; }
var _pharmName = userDisplayName || locals.user?.name || _t('portal_pharmacy.default_role', { ns: 'legacy', defaultValue: 'Pharmacist' });
var _pharmKpis = [
  [_t('portal_pharmacy.kpi_total_rx', { ns: 'legacy', defaultValue: 'Total Prescriptions' }), stats.total, 'fa-medkit', '#10b981', '#d1fae5'],
  [_t('portal_pharmacy.kpi_issued_today', { ns: 'legacy', defaultValue: 'Issued Today' }), stats.today, 'fa-plus-circle', '#1a6bd8', '#dbeafe'],
  [_t('portal_pharmacy.kpi_active_pending', { ns: 'legacy', defaultValue: 'Active / Pending' }), stats.active, 'fa-clock-o', '#f59e0b', '#fef3c7'],
  [_t('portal_pharmacy.kpi_dispensed', { ns: 'legacy', defaultValue: 'Dispensed' }), stats.done, 'fa-check-circle', '#8b5cf6', '#ede9fe'],
  [_t('portal_pharmacy.kpi_nursing_requests', { ns: 'legacy', defaultValue: 'Nursing requests' }), stats.nursingSupply || 0, 'fa-hospital-o', '#dc2626', '#fee2e2']
];
var stMap={
  active:['warning', _t('portal_shared.rx_status_active', { ns: 'legacy', defaultValue: 'Active' })],
  dispensed:['success', _t('portal_shared.rx_status_dispensed', { ns: 'legacy', defaultValue: 'Dispensed' })],
  cancelled:['danger', _t('portal_shared.rx_status_cancelled', { ns: 'legacy', defaultValue: 'Cancelled' })]
};
%>
<div class="page-wrapper"><div class="content">
<%- include('partials/clinical-dept-alerts-strip', { clinicalDeptStripDept: 'pharmacy' }) %>
<%- include('partials/portal-flash') %>
<div class="card border-0 shadow-sm mb-4 hms-page-hero">
  <div class="card-body py-4 px-4 d-flex align-items-center justify-content-between flex-wrap">
 <div>
 <h1 class="h4 mb-1 font-weight-bold" style="color:#fff;"><i class="fa fa-medkit mr-2"></i><%= _t('portal_pharmacy.title', { ns: 'legacy', defaultValue: 'Pharmacy Portal' }) %></h1>
 <p class="mb-0 small" style="color:rgba(255,255,255,.85);"><%= _t('portal_shared.welcome_role', { ns: 'legacy', name: _pharmName, defaultValue: 'Welcome, ' + _pharmName }) %></p>
 </div>
 <div class="mt-2 mt-md-0">
 <% if(hasP('prescription.read','prescription.write','pharmacy.read','pharmacy.write')){ %><a href="/prescriptions" class="btn btn-light btn-sm font-weight-bold" style="color:#10b981;"><i class="fa fa-list mr-1"></i><%= _t('portal_pharmacy.prescriptions_queue', { ns: 'legacy', defaultValue: 'Prescriptions Queue' }) %></a><% } %>
 <% if(hasP('pharmacy.write')){ %><a href="/pharmacy/order-alerts" class="btn btn-outline-light btn-sm font-weight-bold ml-2"><i class="fa fa-bell mr-1"></i><%= _t('portal_pharmacy.order_alerts', { ns: 'legacy', defaultValue: 'Order alerts' }) %></a><% } %>
 <% if(hasP('pharmacy.read','pharmacy.write')){ %>
  <a href="/pharmacy/nursing-requests" class="btn btn-sm font-weight-bold ml-2 <%= (stats.nursingSupply||0) > 0 ? 'btn-warning' : 'btn-outline-light' %>" style="<%= (stats.nursingSupply||0) > 0 ? '' : 'color:#fff;border-color:rgba(255,255,255,.6);' %>"><i class="fa fa-bell mr-1"></i><%= _t('portal_pharmacy.nursing_requests', { ns: 'legacy', defaultValue: 'Nursing requests' }) %><% if ((stats.nursingSupply||0) > 0) { %> (<%= stats.nursingSupply %>)<% } %></a>
 <% } %>
 </div>
  </div>
</div>
<div class="row mb-4">
  <% _pharmKpis.forEach(function(s){ %>
  <div class="col-6 col-md-3 mb-3">
 <div class="card border-0 shadow-sm h-100" style="border-left:4px solid <%=s[3]%>;">
 <div class="card-body d-flex align-items-center">
 <span class="rounded-circle mr-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:<%=s[4]%>;flex-shrink:0;">
 <i class="fa <%=s[2]%>" style="color:<%=s[3]%>;font-size:1.1rem;"></i></span>
 <div><div style="font-size:1.8rem;font-weight:800;color:#1e293b;"><%=s[1]%></div><div class="text-muted small"><%=s[0]%></div></div>
 </div>
 </div>
  </div>
  <% }); %>
</div>
<%- include('partials/portal-tiles', { portal: 'pharmacy', title: _t('portal_pharmacy.pharmacy_tools', { ns: 'legacy', defaultValue: 'Pharmacy Tools' }) }) %>
<div class="card border-0 shadow-sm" style="border-radius:12px;">
  <div class="card-header bg-white d-flex justify-content-between align-items-center" style="border-bottom:2px solid #e2e8f0;">
 <span class="font-weight-bold"><i class="fa fa-medkit mr-1 text-success"></i><%= _t('portal_pharmacy.queue_heading', { ns: 'legacy', defaultValue: 'Prescriptions Queue' }) %></span>
 <a href="/prescriptions" class="btn btn-sm btn-primary"><%= _t('portal_shared.view_all', { ns: 'legacy', defaultValue: 'View All' }) %></a>
  </div>
  <div class="card-body p-0" data-hms-table-paginate data-hms-page-size="5"><div class="table-responsive">
 <table class="table table-hover mb-0">
 <thead class="thead-light"><tr><th><%= _t('portal_shared.patient', { ns: 'legacy', defaultValue: 'Patient' }) %></th><th><%= _t('portal_shared.prescription', { ns: 'legacy', defaultValue: 'Prescription' }) %></th><th><%= _t('portal_shared.status', { ns: 'legacy', defaultValue: 'Status' }) %></th><th><%= _t('portal_shared.date', { ns: 'legacy', defaultValue: 'Date' }) %></th><th><%= _t('portal_shared.action', { ns: 'legacy', defaultValue: 'Action' }) %></th></tr></thead>
 <tbody>
 <% if(!recentRx||recentRx.length===0){ %><tr><td colspan="5" class="text-center text-muted py-4"><%= _t('portal_pharmacy.no_prescriptions', { ns: 'legacy', defaultValue: 'No prescriptions found.' }) %></td></tr>
 <% } else { recentRx.forEach(function(r){ var st=stMap[r.status]||['secondary',r.status]; var d=r.created_at?fmtDate(r.created_at):'—'; %>
 <tr><td class="font-weight-bold"><%=r.first_name||''%> <%=r.last_name||''%></td>
 <td><%=r.title||'—'%></td>
 <td><span class="badge badge-<%=st[0]%>"><%=st[1]%></span></td>
 <td class="small text-muted"><%=d%></td>
 <td><a href="/prescriptions" class="btn btn-sm btn-outline-primary"><%= _t('portal_shared.open', { ns: 'legacy', defaultValue: 'Open' }) %></a></td></tr>
 <% }); } %>
 </tbody>
 </table>
  </div></div>
</div>
</div></div><%- include('partials/footer') %>

<%- include('partials/header') %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>
<div class="page-wrapper"><div class="content">

<% if(locals.flash){%><div class="hms-flash hms-flash--success border-0 shadow-sm mb-3 py-2 d-flex align-items-center"><i class="fa fa-check-circle mr-2"></i><%=locals.flash%></div><%}%>
<% if(locals.error){%><div class="hms-flash hms-flash--error border-0 shadow-sm mb-3 py-2"><i class="fa fa-exclamation-circle mr-2"></i><%=locals.error%></div><%}%>

<!-- Header -->
<div class="d-flex align-items-center mb-4">
  <div>
 <h1 class="h4 font-weight-bold mb-1" style="color:#1b2559;"><i class="fa fa-user-circle mr-2" style="color:#1a6bd8;"></i><%= _t('my_profile.title', { ns: 'legacy', defaultValue: 'My Profile' }) %></h1>
 <p class="text-muted small mb-0"><%= _t('my_profile.subtitle', { ns: 'legacy', defaultValue: 'Update your personal information and change your password.' }) %></p>
  </div>
</div>

<div class="row justify-content-center">
  <div class="col-xl-9 col-lg-11">

 <!-- Profile Card Header -->
 <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;overflow:hidden;background:linear-gradient(135deg,#1a6bd8,#0c8b8b);">
 <div class="card-body p-4 d-flex align-items-center" style="gap:1.5rem;">
 <div style="width:72px;height:72px;border-radius:20px;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:1.8rem;flex-shrink:0;border:2px solid rgba(255,255,255,.35);">
 <%=((emp.first_name||'?')[0]+(emp.last_name||'?')[0]).toUpperCase()%>
 </div>
 <div class="text-white">
 <div style="font-size:1.25rem;font-weight:700;margin-bottom:.2rem;"><%=emp.first_name%> <%=emp.last_name%></div>
 <div style="opacity:.8;font-size:.85rem;">@<%=emp.username||'—'%></div>
 <% var rk=String(emp.role||''); var rTitle=roles.find(r=>String(r.role)===rk)?.title||_t('my_profile.role_fallback', { ns: 'legacy', role: rk, defaultValue: 'Role ' + rk }); %>
 <div style="margin-top:.4rem;"><span style="background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.3);border-radius:20px;padding:.2rem .75rem;font-size:.72rem;font-weight:600;"><%=rTitle%></span></div>
 </div>
 </div>
 </div>

 <!-- Edit Form -->
 <form method="post" action="/profile" class="card border-0 shadow-sm" style="border-radius:14px;overflow:hidden;">

 <!-- Personal Info Section -->
 <div class="card-body pb-0">
 <h6 class="font-weight-bold text-uppercase small mb-3 pb-2" style="color:#64748b;border-bottom:2px solid #f1f5f9;letter-spacing:.06em;">
 <i class="fa fa-user mr-2 text-primary"></i><%= _t('my_profile.personal_info', { ns: 'legacy', defaultValue: 'Personal Information' }) %>
 </h6>
 <div class="row">
 <div class="col-md-6"><div class="form-group">
 <label class="font-weight-bold small" for="fn"><%= _t('employee_edit.first_name', { ns: 'legacy', defaultValue: 'First Name' }) %></label>
 <input id="fn" class="hms-input w-full" type="text" name="first_name" value="<%=emp.first_name||''%>" required>
 </div></div>
 <div class="col-md-6"><div class="form-group">
 <label class="font-weight-bold small" for="ln"><%= _t('employee_edit.last_name', { ns: 'legacy', defaultValue: 'Last Name' }) %></label>
 <input id="ln" class="hms-input w-full" type="text" name="last_name" value="<%=emp.last_name||''%>" required>
 </div></div>
 <div class="col-md-6"><div class="form-group">
 <label class="font-weight-bold small" for="em"><%= _t('employee_edit.email', { ns: 'legacy', defaultValue: 'Email' }) %></label>
 <input id="em" class="hms-input w-full" type="email" name="emailid" value="<%=emp.emailid||''%>">
 </div></div>
 <div class="col-md-6"><div class="form-group">
 <label class="font-weight-bold small" for="ph"><%= _t('employee_edit.phone', { ns: 'legacy', defaultValue: 'Phone' }) %></label>
 <input id="ph" class="hms-input w-full" type="text" name="phone" value="<%=emp.phone||''%>">
 </div></div>
 <div class="col-12"><div class="form-group">
 <label class="font-weight-bold small" for="bio"><%= _t('employee_edit.bio', { ns: 'legacy', defaultValue: 'Short Biography' }) %></label>
 <textarea id="bio" class="hms-input w-full" rows="3" name="bio"><%=emp.bio||''%></textarea>
 </div></div>
 </div>
 </div>

 <!-- Read-only Info -->
 <div class="card-body pb-0 pt-1">
 <h6 class="font-weight-bold text-uppercase small mb-3 pb-2" style="color:#64748b;border-bottom:2px solid #f1f5f9;letter-spacing:.06em;">
 <i class="fa fa-briefcase mr-2" style="color:#10b981;"></i><%= _t('my_profile.employment_details', { ns: 'legacy', defaultValue: 'Employment Details' }) %> <span class="text-muted font-weight-normal" style="text-transform:none;font-size:.75rem;"><%= _t('my_profile.employment_readonly', { ns: 'legacy', defaultValue: '(read-only — contact Admin to change)' }) %></span>
 </h6>
 <div class="row">
 <div class="col-md-4 mb-3">
 <div class="small font-weight-bold text-muted mb-1"><%= _t('employee_edit.username', { ns: 'legacy', defaultValue: 'Username' }) %></div>
 <div class="font-weight-600" style="color:#1e293b;"><%=emp.username||'—'%></div>
 </div>
 <div class="col-md-4 mb-3">
 <div class="small font-weight-bold text-muted mb-1"><%= _t('my_profile.employee_id', { ns: 'legacy', defaultValue: 'Employee ID' }) %></div>
 <div class="font-weight-600" style="color:#1e293b;"><%=emp.employee_id||'—'%></div>
 </div>
 <div class="col-md-4 mb-3">
 <div class="small font-weight-bold text-muted mb-1"><%= _t('employee_edit.role', { ns: 'legacy', defaultValue: 'Role' }) %></div>
 <div class="font-weight-600" style="color:#1e293b;"><%=rTitle%></div>
 </div>
 <div class="col-md-4 mb-3">
 <div class="small font-weight-bold text-muted mb-1"><%= _t('employee_edit.department', { ns: 'legacy', defaultValue: 'Department' }) %></div>
 <div class="font-weight-600" style="color:#1e293b;"><%=emp.primary_department||'—'%></div>
 </div>
 <div class="col-md-4 mb-3">
 <div class="small font-weight-bold text-muted mb-1"><%= _t('my_profile.joining_date', { ns: 'legacy', defaultValue: 'Joining Date' }) %></div>
 <div class="font-weight-600" style="color:#1e293b;"><%= emp.joining_date ? fmtDate(emp.joining_date) : '—' %></div>
 </div>
 <div class="col-md-4 mb-3">
 <div class="small font-weight-bold text-muted mb-1"><%= _t('my_profile.status', { ns: 'legacy', defaultValue: 'Status' }) %></div>
 <% if(emp.status==1){ %>
 <span class="badge" style="background:#ecfdf5;color:#059669;border:1px solid #a7f3d0;border-radius:20px;padding:.25rem .6rem;font-size:.72rem;"><%= _t('employee_edit.active', { ns: 'legacy', defaultValue: 'Active' }) %></span>
 <% } else { %>
 <span class="badge" style="background:#f8fafc;color:#64748b;border-radius:20px;padding:.25rem .6rem;font-size:.72rem;"><%= _t('employee_edit.inactive', { ns: 'legacy', defaultValue: 'Inactive' }) %></span>
 <% } %>
 </div>
 </div>
 </div>

 <!-- Change Password -->
 <div class="card-body pt-1">
 <h6 class="font-weight-bold text-uppercase small mb-3 pb-2" style="color:#64748b;border-bottom:2px solid #f1f5f9;letter-spacing:.06em;">
 <i class="fa fa-lock mr-2" style="color:#dc2626;"></i><%= _t('my_profile.change_password', { ns: 'legacy', defaultValue: 'Change Password' }) %> <span class="text-muted font-weight-normal" style="text-transform:none;font-size:.75rem;"><%= _t('my_profile.password_hint', { ns: 'legacy', defaultValue: '(leave blank to keep current)' }) %></span>
 </h6>
 <div class="row">
 <div class="col-md-6"><div class="form-group mb-0">
 <label class="font-weight-bold small" for="pw"><%= _t('my_profile.new_password', { ns: 'legacy', defaultValue: 'New Password' }) %></label>
 <input id="pw" class="hms-input w-full" type="password" name="pwd" placeholder="<%= _t('my_profile.password_ph', { ns: 'legacy', defaultValue: 'Enter new password to change…' }) %>" autocomplete="new-password">
 </div></div>
 </div>
 </div>

 <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3" style="border-top:2px solid #f1f5f9;gap:8px;">
 <a href="/dashboard" class="hms-btn hms-btn-secondary"><i class="fa fa-arrow-left mr-1"></i><%= _t('my_profile.back', { ns: 'legacy', defaultValue: 'Back' }) %></a>
 <button type="submit" class="hms-btn hms-btn-primary font-weight-bold shadow-sm">
 <i class="fa fa-save mr-1"></i> <%= _t('my_profile.save_changes', { ns: 'legacy', defaultValue: 'Save Changes' }) %>
 </button>
 </div>
 </form>

  </div>
</div>

</div></div>
<%- include('partials/footer') %>

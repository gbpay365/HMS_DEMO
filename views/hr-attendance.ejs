<%- include('partials/header') %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>

<div class="page-wrapper">
 <div class="content">
 <% if(locals.flash){ %>
 <div class="hms-flash hms-flash--success border-0 shadow-sm mb-3 alert-dismissible"><%= flash %><button type="button" class="close" data-dismiss="alert"><span>&times;</span></button></div>
 <% } %>
 <% if(locals.error){ %>
 <div class="hms-flash hms-flash--error border-0 shadow-sm mb-3 alert-dismissible"><%= error %><button type="button" class="close" data-dismiss="alert"><span>&times;</span></button></div>
 <% } %>
 <!-- Header -->
 <div class="row align-items-center mb-4">
 <div class="col-sm-8">
 <h4 class="page-title font-weight-bold text-dark"><%= _t('hr_attendance.title', { ns: 'legacy', defaultValue: 'Staff Attendance' }) %></h4>
 <p class="text-muted small"><%= _t('hr_attendance.subtitle', { ns: 'legacy', defaultValue: 'Record daily clock-in/out and operational availability (per facility).' }) %></p>
 </div>
 <div class="col-sm-4 text-right">
 <form action="/hr/attendance" method="GET" class="form-inline justify-content-end">
 <input type="date" name="date" class="hms-input w-full mr-2" value="<%= date %>">
 <button type="submit" class="hms-btn-premium"><%= _t('hr_attendance.fetch_date', { ns: 'legacy', defaultValue: 'Fetch Date' }) %></button>
 </form>
 </div>
 </div>

 <div class="row mb-3">
 <div class="col-md-5">
 <div class="input-group">
 <div class="input-group-prepend"><span class="input-group-text bg-white border-right-0"><i class="fa fa-search text-muted"></i></span></div>
 <input type="text" id="hmsAttendanceSearch" class="hms-input w-full border-left-0" placeholder="<%= _t('hr_attendance.filter_ph', { ns: 'legacy', defaultValue: 'Filter staff by name...' }) %>" autocomplete="off">
 </div>
 </div>
 </div>

 <div class="card border-0 shadow-sm rounded-xl overflow-hidden bg-white">
 <form action="/hr/attendance/save" method="POST">
 <input type="hidden" name="date" value="<%= date %>">
 <div class="table-responsive">
 <table class="table table-hover mb-0 hms-table-v3">
 <thead class="bg-light">
 <tr>
 <th><%= _t('hr_attendance.col_staff', { ns: 'legacy', defaultValue: 'Staff Member' }) %></th>
 <th><%= _t('hr_attendance.col_status', { ns: 'legacy', defaultValue: 'Status' }) %></th>
 <th><%= _t('hr_attendance.col_check_in', { ns: 'legacy', defaultValue: 'Check In' }) %></th>
 <th><%= _t('hr_attendance.col_check_out', { ns: 'legacy', defaultValue: 'Check Out' }) %></th>
 <th class="text-right"><%= _t('hr_attendance.col_shift', { ns: 'legacy', defaultValue: 'Shift Details' }) %></th>
 </tr>
 </thead>
 <tbody>
 <% staff.forEach(emp => { 
 const ex = existing[emp.id] || {};
 const st = ex.status || 'present';
 const cin = ex.check_in_time ? ex.check_in_time.substring(0,5) : '08:00';
 const cout = ex.check_out_time ? ex.check_out_time.substring(0,5) : '17:00';
 const searchBlob = (emp.first_name + ' ' + emp.last_name).toLowerCase();
 %>
 <tr class="hms-att-row" data-hms-search="<%= searchBlob %>">
 <td>
 <div class="font-weight-bold text-dark"><%= emp.first_name %> <%= emp.last_name %></div>
 <div class="extra-small text-muted text-uppercase"><%= _t('hr_attendance.employee_num', { ns: 'legacy', defaultValue: 'Employee #{{id}}', id: emp.id }) %></div>
 </td>
 <td>
 <select name="attendance[<%= emp.id %>][status]" class="hms-input w-full text-sm hms-select-pill">
 <option value="present" <%= st === 'present' ? 'selected' : '' %>><%= _t('hr_attendance.status_present', { ns: 'legacy', defaultValue: 'Present' }) %></option>
 <option value="absent" <%= st === 'absent' ? 'selected' : '' %>><%= _t('hr_attendance.status_absent', { ns: 'legacy', defaultValue: 'Absent' }) %></option>
 <option value="late" <%= st === 'late' ? 'selected' : '' %>><%= _t('hr_attendance.status_late', { ns: 'legacy', defaultValue: 'Late' }) %></option>
 <option value="half-day" <%= st === 'half-day' ? 'selected' : '' %>><%= _t('hr_attendance.status_half_day', { ns: 'legacy', defaultValue: 'Half Day' }) %></option>
 <option value="on-leave" <%= st === 'on-leave' ? 'selected' : '' %>><%= _t('hr_attendance.status_on_leave', { ns: 'legacy', defaultValue: 'On Leave' }) %></option>
 </select>
 </td>
 <td>
 <input type="time" name="attendance[<%= emp.id %>][in]" class="hms-input w-full text-sm hms-input-pill" value="<%= cin %>">
 </td>
 <td>
 <input type="time" name="attendance[<%= emp.id %>][out]" class="hms-input w-full text-sm hms-input-pill" value="<%= cout %>">
 </td>
 <td class="text-right">
 <span class="badge badge-light px-2 py-1 text-muted extra-small"><%= _t('hr_attendance.standard_day', { ns: 'legacy', defaultValue: 'Standard Day (9h)' }) %></span>
 </td>
 </tr>
 <% }) %>
 </tbody>
 </table>
 </div>
 <div class="card-footer bg-white p-4 border-top text-right">
 <button type="submit" class="btn btn-indigo px-5"><%= _t('hr_attendance.save', { ns: 'legacy', defaultValue: 'Save Attendance Records' }) %></button>
 </div>
 </form>
 </div>
 </div>
</div>

<style>
 .hms-select-pill, .hms-input-pill { border-radius: 8px; border: 1px solid #e2e8f0; }
 .extra-small { font-size: 0.65rem; }
</style>
<script>
(function() {
 var input = document.getElementById('hmsAttendanceSearch');
 if (!input) return;
 input.addEventListener('input', function() {
  var q = this.value.toLowerCase().trim();
  document.querySelectorAll('.hms-att-row').forEach(function(row) {
   var blob = row.getAttribute('data-hms-search') || '';
   row.style.display = (q === '' || blob.indexOf(q) !== -1) ? '' : 'none';
  });
 });
})();
</script>

<%- include('partials/footer') %>

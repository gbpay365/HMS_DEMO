<%- include('partials/header') %>
<%
var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
var _up = locals.userPerms || [];
function hasP() {
  if (_up.includes('*')) return true;
  for (var i = 0; i < arguments.length; i++) if (_up.includes(arguments[i])) return true;
  return false;
}
var _cashName = userDisplayName || locals.user?.name || _t('portal_cashier.default_role', { ns: 'legacy', defaultValue: 'Cashier' });
var _cashDate = fmtDate(new Date());
var _cashKpis = [
  [_t('portal_cashier.kpi_pending', { ns: 'legacy', defaultValue: 'Pending Payments' }), stats.pending, 'fa-clock-o', '#f59e0b', '#fef3c7'],
  [_t('portal_cashier.kpi_paid_today', { ns: 'legacy', defaultValue: 'Paid Today' }), stats.paidToday, 'fa-check-circle', '#10b981', '#d1fae5'],
  [_t('portal_cashier.kpi_fcfa_collected', { ns: 'legacy', defaultValue: 'FCFA Collected' }), '—', 'fa-money', '#1a6bd8', '#dbeafe'],
  [_t('portal_cashier.kpi_open_tickets', { ns: 'legacy', defaultValue: 'Open Tickets' }), stats.pending, 'fa-ticket', '#8b5cf6', '#ede9fe']
];
%>
<div class="page-wrapper"><div class="content">
<%- include('partials/portal-flash') %>
<!-- Banner -->
<div class="card border-0 shadow mb-4 hms-page-hero">
  <div class="card-body py-4 px-4 d-flex align-items-center justify-content-between flex-wrap" style="gap:12px;">
 <div>
 <h1 class="h4 mb-1 font-weight-bold" style="color:#fff;"><i class="fa fa-money mr-2"></i><%= _t('portal_cashier.title', { ns: 'legacy', defaultValue: 'Cashier Station' }) %></h1>
 <p class="mb-0 small" style="color:rgba(255,255,255,.85);"><%= _t('portal_shared.welcome_named_date', { ns: 'legacy', name: _cashName, date: _cashDate, defaultValue: 'Welcome, ' + _cashName + ' — ' + _cashDate }) %></p>
 </div>
 <div class="d-flex flex-wrap" style="gap:8px;">
 <% if (uiVisible('cashier.hero.guides')) { %><a href="/workflow-guides" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-sitemap mr-1"></i><%= _t('portal_shared.workflow_guide', { ns: 'legacy', defaultValue: 'Workflow Guide' }) %></a><% } %>
 <% if(hasP('cashier.read','cashier.write')){ %><a href="/cashier" class="btn btn-light btn-sm font-weight-bold" style="color:#10b981;"><i class="fa fa-money mr-1"></i><%= _t('portal_cashier.issue_payment', { ns: 'legacy', defaultValue: 'Payment' }) %></a><% } %>
 <% if(hasP('cashier.read','billing.read','patient.read')){ %><a href="/hms" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-hospital-o mr-1"></i><%= _t('portal_cashier.hms_hub', { ns: 'legacy', defaultValue: 'HMS Hub' }) %></a><% } %>
 <% if(hasP('patient.read')){ %><a href="/patients" class="btn btn-outline-light btn-sm font-weight-bold"><i class="fa fa-users mr-1"></i><%= _t('portal_cashier.patients', { ns: 'legacy', defaultValue: 'Patients' }) %></a><% } %>
 </div>
  </div>
</div>
<!-- Stats -->
<div class="row mb-4">
  <% _cashKpis.forEach(function(s){ %>
  <div class="col-6 col-md-3 mb-3">
 <div class="card border-0 shadow-sm h-100" style="border-left:4px solid <%=s[3]%>;border-radius:12px;">
 <div class="card-body d-flex align-items-center">
 <span class="rounded-circle mr-3 d-flex align-items-center justify-content-center" style="width:50px;height:50px;background:<%=s[4]%>;flex-shrink:0;">
 <i class="fa <%=s[2]%>" style="color:<%=s[3]%>;font-size:1.1rem;"></i>
 </span>
 <div><div style="font-size:1.9rem;font-weight:800;color:#1e293b;"><%=s[1]%></div><div class="text-muted small"><%=s[0]%></div></div>
 </div>
 </div>
  </div>
  <% }); %>
</div>

<%- include('partials/portal-tiles', { portal: 'cashier', title: _t('portal_cashier.cashier_tools', { ns: 'legacy', defaultValue: 'Cashier Tools' }) }) %>

<!-- Recent Tickets -->
<div class="card border-0 shadow-sm" style="border-radius:14px;">
  <div class="card-header bg-white d-flex justify-content-between align-items-center py-3" style="border-bottom:2px solid #e2e8f0;">
 <span class="font-weight-bold"><i class="fa fa-money mr-1 text-success"></i><%= _t('portal_cashier.recent_tickets', { ns: 'legacy', defaultValue: 'Recent Payment Tickets' }) %></span>
 <a href="/cashier" class="btn btn-sm btn-outline-success" style="border-radius:8px;"><%= _t('portal_shared.view_all', { ns: 'legacy', defaultValue: 'View All' }) %></a>
  </div>
  <div class="card-body p-0" data-hms-table-paginate data-hms-page-size="5"><div class="table-responsive">
 <table class="table table-hover mb-0">
 <thead class="thead-light"><tr><th><%= _t('portal_shared.code', { ns: 'legacy', defaultValue: 'Code' }) %></th><th><%= _t('portal_shared.patient', { ns: 'legacy', defaultValue: 'Patient' }) %></th><th><%= _t('portal_cashier.col_amount_fcfa', { ns: 'legacy', defaultValue: 'Amount (FCFA)' }) %></th><th><%= _t('portal_shared.status', { ns: 'legacy', defaultValue: 'Status' }) %></th><th><%= _t('portal_shared.date', { ns: 'legacy', defaultValue: 'Date' }) %></th></tr></thead>
 <tbody>
 <% if(!recentTickets||recentTickets.length===0){ %><tr><td colspan="5" class="text-center text-muted py-4"><%= _t('portal_cashier.no_tickets', { ns: 'legacy', defaultValue: 'No recent tickets.' }) %></td></tr>
 <% } else { recentTickets.forEach(function(r){ var sb=r.status==='paid'?'success':'warning'; var d=r.created_at?fmtDate(r.created_at):'—'; %>
 <tr><td class="font-weight-bold small text-primary"><%=r.ticket_code||'—'%></td>
 <td class="small"><%=r.first_name||''%> <%=r.last_name||''%></td>
 <td class="small font-weight-bold"><%=(parseFloat(r.total_amount)||0).toLocaleString('fr-FR')%></td>
 <td><span class="badge badge-<%=sb%>"><%=r.status%></span></td>
 <td class="small text-muted"><%=d%></td></tr>
 <% }); } %>
 </tbody>
 </table>
  </div></div>
</div>
</div></div><%- include('partials/footer') %>

<%- include('partials/header') %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>
<%- include('partials/vaccination-odoo-start', {
  vacOdooMenu: 'administer',
  vacOdooTitle: _t('vaccination_administer.title', { ns: 'legacy', defaultValue: 'Administer vaccine dose' })
}) %>
<div class="o_content">

<div class="row">
 <div class="col-lg-5 mb-3">
  <div class="vac-card p-3">
   <p class="small text-muted"><%= _t('vaccination_administer.link_hint', { ns: 'legacy', defaultValue: 'Find the patient in' }) %> <a href="/patients?from=vaccination"><%= _t('vaccination_administer.patient_directory', { ns: 'legacy', defaultValue: 'Patient directory' }) %></a> <%= _t('vaccination_administer.link_hint_suffix', { ns: 'legacy', defaultValue: 'or enter patient ID below.' }) %></p>
   <form method="get" action="/vaccination/administer" class="form-inline mb-0">
    <input type="number" name="patient_id" class="hms-input w-full mr-2" placeholder="<%= _t('vaccination_administer.patient_id_ph', { ns: 'legacy', defaultValue: 'Patient ID' }) %>" value="<%= patient ? patient.id : '' %>" required>
    <button class="hms-btn hms-btn-secondary"><%= _t('vaccination_administer.load', { ns: 'legacy', defaultValue: 'Load' }) %></button>
   </form>
   <% if (patient) { %>
   <div class="hms-flash hms-flash--success mt-3 mb-0">
    <strong><%= patient.first_name %> <%= patient.last_name %></strong> (#<%= patient.id %>)<br>
    <span class="small"><%= patient.patient_code || '' %> · <%= patient.gender || '' %> · <%= patient.phone || '' %></span>
    <% if (patient.dob) { %><br><span class="small"><%= _t('vaccination_administer.dob', { ns: 'legacy', defaultValue: 'DOB' }) %>: <%= patient.dob %></span><% } %>
   </div>
   <a href="/vaccination/chart/<%= patient.id %>" class="btn btn-sm btn-link mt-2 p-0"><%= _t('vaccination_administer.view_chart', { ns: 'legacy', defaultValue: 'View immunization chart →' }) %></a>
   <% } %>
  </div>
 </div>
 <div class="col-lg-7">
  <form method="post" action="/vaccination/administer" class="vac-card p-4">
   <% if (!patient) { %>
   <p class="text-muted"><%= _t('vaccination_administer.load_patient_first', { ns: 'legacy', defaultValue: 'Load a patient before recording a dose.' }) %></p>
   <% } else { %>
   <input type="hidden" name="patient_id" value="<%= patient.id %>">
   <div class="form-group">
    <label class="small font-weight-bold"><%= _t('vaccination_administer.vaccine', { ns: 'legacy', defaultValue: 'Vaccine' }) %></label>
    <select name="vaccine_id" class="hms-input w-full" required id="vac_select">
     <option value=""><%= _t('vaccination_administer.select_vaccine', { ns: 'legacy', defaultValue: '— Select vaccine —' }) %></option>
     <% (vaccines || []).forEach(function(v){ %>
     <option value="<%= v.id %>" data-route="<%= v.route || '' %>" data-site="<%= v.site || '' %>" data-doses="<%= v.doses_required %>"><%= v.name %> (<%= v.code %>)</option>
     <% }) %>
    </select>
   </div>
   <div class="form-row">
    <div class="form-group col-md-4">
     <label class="small font-weight-bold"><%= _t('vaccination_administer.dose_number', { ns: 'legacy', defaultValue: 'Dose number' }) %></label>
     <input type="number" name="dose_number" class="hms-input w-full" value="1" min="1" max="10" required>
    </div>
    <div class="form-group col-md-4">
     <label class="small font-weight-bold"><%= _t('vaccination_administer.date', { ns: 'legacy', defaultValue: 'Date administered' }) %></label>
     <input type="date" name="administered_date" class="hms-input w-full" value="<%= new Date().toISOString().slice(0,10) %>" required>
    </div>
    <div class="form-group col-md-4">
     <label class="small font-weight-bold"><%= _t('vaccination_administer.batch', { ns: 'legacy', defaultValue: 'Batch / lot no.' }) %></label>
     <input type="text" name="batch_number" class="hms-input w-full" placeholder="LOT-XXXX">
    </div>
   </div>
   <div class="form-row">
    <div class="form-group col-md-4">
     <label class="small font-weight-bold"><%= _t('vaccination_administer.lot_expiry', { ns: 'legacy', defaultValue: 'Lot expiry' }) %></label>
     <input type="date" name="lot_expiry" class="hms-input w-full">
    </div>
    <div class="form-group col-md-4">
     <label class="small font-weight-bold"><%= _t('vaccination_administer.route', { ns: 'legacy', defaultValue: 'Route' }) %></label>
     <input type="text" name="route" class="hms-input w-full" id="vac_route" placeholder="IM / Oral / SC">
    </div>
    <div class="form-group col-md-4">
     <label class="small font-weight-bold"><%= _t('vaccination_administer.site', { ns: 'legacy', defaultValue: 'Site' }) %></label>
     <input type="text" name="site" class="hms-input w-full" id="vac_site" placeholder="Upper arm / Thigh">
    </div>
   </div>
   <div class="form-group">
    <label class="small font-weight-bold"><%= _t('vaccination_administer.adverse', { ns: 'legacy', defaultValue: 'Adverse reaction (if any)' }) %></label>
    <textarea name="adverse_reaction" class="hms-input w-full" rows="2"></textarea>
   </div>
   <div class="form-group">
    <label class="small font-weight-bold"><%= _t('vaccination_administer.notes', { ns: 'legacy', defaultValue: 'Notes' }) %></label>
    <textarea name="notes" class="hms-input w-full" rows="2"></textarea>
   </div>
   <button type="submit" class="hms-btn hms-btn-success font-weight-bold" style="background:var(--vac-primary);border:none">
    <i class="fa fa-check"></i> <%= _t('vaccination_administer.save', { ns: 'legacy', defaultValue: 'Record dose' }) %>
   </button>
   <% } %>
  </form>
 </div>
</div>

</div>
<script>
(function(){
 var sel = document.getElementById('vac_select');
 if (!sel) return;
 sel.addEventListener('change', function(){
  var opt = sel.options[sel.selectedIndex];
  if (!opt || !opt.value) return;
  var route = document.getElementById('vac_route');
  var site = document.getElementById('vac_site');
  if (route && opt.dataset.route) route.value = opt.dataset.route;
  if (site && opt.dataset.site) site.value = opt.dataset.site;
 });
})();
</script>
<%- include('partials/vaccination-odoo-end') %>
<%- include('partials/footer') %>

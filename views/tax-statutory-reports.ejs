<%- include('partials/header') %>

<div class="page-wrapper">
 <div class="content">
 <% if(locals.flash){ %>
 <div class="alert alert-success border-0 shadow-sm mb-3 alert-dismissible"><%= flash %><button type="button" class="close" data-dismiss="alert"><span>&times;</span></button></div>
 <% } %>
 <% if(locals.error){ %>
 <div class="alert alert-danger border-0 shadow-sm mb-3 alert-dismissible"><%= error %><button type="button" class="close" data-dismiss="alert"><span>&times;</span></button></div>
 <% } %>

 <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
 <div>
 <h4 class="page-title font-weight-bold text-dark mb-1"><%= _tl('tax_statutory.title', 'Statutory payroll declarations') %></h4>
 <p class="text-muted small mb-0"><%= _tl('tax_statutory.subtitle', 'Printable summaries for CNPS and DGI filings. Validate layouts with CNPS / DGI and your accountant before official submission.') %></p>
 </div>
 <a href="/tax" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="fa fa-arrow-left mr-1"></i><%= _tl('tax_statutory.tax_hub', 'Tax hub') %></a>
 </div>

 <div class="alert alert-light border small mb-4" style="border-radius:12px;">
 <i class="fa fa-info-circle mr-1 text-muted"></i>
 <%= _tl('tax_statutory.hint', 'Use Print / Save as PDF on each report, then sign and stamp for filing. Data comes from processed payroll records.') %>
 </div>

 <div class="row">
 <% var cards = [
   { key: 'cnps-monthly', icon: 'fa-file-text-o', color: '#1d4ed8', exportHref: '/tax/cnps', exportLabel: _tl('tax_statutory.open_cnps_export', 'CNPS / DIPE export') },
   { key: 'dgi-monthly', icon: 'fa-file-excel-o', color: '#b91c1c', exportHref: '/tax/dgi', exportLabel: _tl('tax_statutory.open_dgi_export', 'DGI CSV exports') },
   { key: 'cnps-annual', icon: 'fa-calendar', color: '#1e40af', exportHref: '/tax/compliance', exportLabel: _tl('tax_statutory.open_compliance', 'Compliance calendar') },
   { key: 'dgi-annual', icon: 'fa-bar-chart', color: '#991b1b', exportHref: '/tax/dgi', exportLabel: _tl('tax_statutory.open_dgi_annual', 'DGI annual CSV') }
 ]; %>
 <% cards.forEach(function(card){
   var k = kinds[card.key] || {};
 %>
 <div class="col-md-6 mb-4">
 <div class="card border-0 shadow-sm h-100" style="border-radius:14px;">
 <div class="card-body p-4">
 <div class="d-flex align-items-start mb-3">
 <div class="rounded-lg d-flex align-items-center justify-content-center mr-3" style="width:48px;height:48px;background:#f8fafc;color:<%= card.color %>;">
 <i class="fa <%= card.icon %> fa-lg"></i>
 </div>
 <div>
 <h5 class="font-weight-bold mb-1"><%= k.title || card.key %></h5>
 <p class="small text-muted mb-0"><%= k.subtitle || '' %></p>
 </div>
 </div>
 <form method="GET" action="/tax/statutory-reports/<%= card.key %>/print" class="form-row align-items-end mb-3" target="_blank">
 <% if (k.period === 'monthly') { %>
 <div class="form-group col-6 col-md-4 mb-2">
 <label class="small font-weight-bold"><%= _tl('tax_hub_page.month', 'Month') %></label>
 <select name="month" class="form-control form-control-sm">
 <% for(var n=1;n<=12;n++){ %>
 <option value="<%=n%>" <%= n===cm ? 'selected' : '' %>><%= months[n] %></option>
 <% } %>
 </select>
 </div>
 <% } %>
 <div class="form-group col-6 col-md-4 mb-2">
 <label class="small font-weight-bold"><%= _tl('tax_hub_page.year', 'Year') %></label>
 <select name="year" class="form-control form-control-sm">
 <% for(var y = cy - 2; y <= cy + 1; y++){ %>
 <option value="<%=y%>" <%= y===cy ? 'selected' : '' %>><%=y%></option>
 <% } %>
 </select>
 </div>
 <div class="form-group col-12 mb-0">
 <button type="submit" class="btn btn-primary btn-sm font-weight-bold rounded-pill"><i class="fa fa-print mr-1"></i><%= _tl('tax_statutory.print_report', 'Print report') %></button>
 </div>
 </form>
 <a href="<%= card.exportHref %>" class="small font-weight-bold"><%= card.exportLabel %> <i class="fa fa-external-link"></i></a>
 </div>
 </div>
 </div>
 <% }); %>
 </div>
 </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>
<% var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; }); %>

<div class="page-wrapper">
 <div class="content">
 <% if(locals.flash){ %>
 <div class="hms-flash hms-flash--success border-0 shadow-sm mb-3 alert-dismissible"><%= flash %><button type="button" class="close" data-dismiss="alert"><span>&times;</span></button></div>
 <% } %>
 <% if(locals.error){ %>
 <div class="hms-flash hms-flash--error border-0 shadow-sm mb-3 alert-dismissible"><%= error %><button type="button" class="close" data-dismiss="alert"><span>&times;</span></button></div>
 <% } %>

 <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
 <div>
 <h4 class="page-title font-weight-bold text-dark mb-1"><%= _t('hr_leave_balances.title', { ns: 'legacy', defaultValue: 'Leave balances' }) %></h4>
 <p class="text-muted small mb-0"><%= _t('hr_leave_balances.subtitle', { ns: 'legacy', defaultValue: 'Annual leave balance per employee (leave type: annual).' }) %></p>
 </div>
 <div class="d-flex flex-wrap gap-2 align-items-center">
 <form method="GET" action="/hr/leave-balances" class="form-inline">
 <label class="small font-weight-bold mr-2 mb-0"><%= _t('hr_leave_balances.year', { ns: 'legacy', defaultValue: 'Year' }) %></label>
 <select name="year" class="hms-input w-full text-sm" onchange="this.form.submit()">
 <% var cy = new Date().getFullYear(); for(var y = cy - 2; y <= cy + 2; y++){ %>
 <option value="<%= y %>" <%= (Number(year)===y)?'selected':'' %>><%= y %></option>
 <% } %>
 </select>
 </form>
 <a href="/payroll" class="hms-btn hms-btn-secondary btn-sm rounded-pill"><i class="fa fa-arrow-left mr-1"></i><%= _t('hr_leave_balances.hr_hub', { ns: 'legacy', defaultValue: 'HR hub' }) %></a>
 </div>
 </div>

 <div class="card border-0 shadow-sm" style="border-radius:14px;">
 <div class="card-header bg-white font-weight-bold py-3"><%= _t('hr_leave_balances.balances_for', { ns: 'legacy', year: year, defaultValue: 'Balances for ' + year }) %></div>
 <div class="card-body">
 <form method="POST" action="/hr/leave-balances/save">
 <input type="hidden" name="year" value="<%= year %>">
 <div class="table-responsive">
 <table class="table table-sm table-striped mb-0" data-hms-table-paginate="10">
 <thead><tr><th><%= _t('hr_leave_balances.col_employee', { ns: 'legacy', defaultValue: 'Employee' }) %></th><th><%= _t('hr_leave_balances.col_ref', { ns: 'legacy', defaultValue: 'Ref' }) %></th><th class="text-right"><%= _t('hr_leave_balances.col_annual_days', { ns: 'legacy', defaultValue: 'Annual days' }) %></th></tr></thead>
 <tbody>
 <% (rows||[]).forEach(function(r){
 var eid = parseInt(r.id,10)||0;
 %>
 <tr>
 <td><%= r.first_name %> <%= r.last_name %></td>
 <td class="text-muted small"><%= r.employee_ref || r.employee_id || '' %></td>
 <td class="text-right" style="max-width:140px;">
 <input type="number" step="0.5" min="0" name="bal_<%= eid %>" class="hms-input w-full text-sm text-right d-inline-block" style="max-width:120px;" value="<%= Number(r.balance||0) %>">
 </td>
 </tr>
 <% }); %>
 </tbody>
 </table>
 </div>
 <div class="mt-3">
 <button type="submit" class="hms-btn hms-btn-primary font-weight-bold"><%= _t('hr_leave_balances.save_balances', { ns: 'legacy', defaultValue: 'Save balances' }) %></button>
 </div>
 </form>
 </div>
 </div>
 </div>
</div>

<%- include('partials/footer') %>

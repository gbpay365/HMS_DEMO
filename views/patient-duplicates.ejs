<%- include('partials/header') %>
<div class="page-wrapper"><div class="content">
 <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap" style="gap:10px;">
  <div>
   <h4 class="font-weight-bold mb-1" style="color:#1b2559;"><%= _tl('patient_duplicates.title', 'Merge patients') %></h4>
   <p class="text-muted small mb-0">
    <%= _tl('patient_duplicates.intro', 'Candidates match on first name + last name + phone + DOB/age (same rule as registration). Review before deleting — run node scripts/dedupe-patients-by-name.js for CSV export, then --apply after sign-off.') %>
   </p>
  </div>
  <a href="/patients" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="fa fa-arrow-left mr-1"></i><%= _tl('patient_duplicates.back_patients', 'Patients') %></a>
 </div>

 <% if (locals.flash) { %><div class="alert alert-success"><%= flash %></div><% } %>
 <% if (locals.error) { %><div class="alert alert-danger"><%= error %></div><% } %>

 <% if (!duplicateGroups || !duplicateGroups.length) { %>
 <div class="alert alert-success border-0 shadow-sm">
  <i class="fa fa-check-circle mr-2"></i><%= _tl('patient_duplicates.no_groups', 'No duplicate identity groups found among active patients.') %>
 </div>
 <% } else { %>
 <div class="alert alert-warning border-0 shadow-sm small">
  <i class="fa fa-info-circle mr-1"></i>
  <%= _tl('patient_duplicates.groups_count', '{{count}} duplicate group(s). Keep the lowest ID (oldest registration) unless clinical records indicate otherwise.', { count: duplicateGroups.length }) %>
 </div>
 <% duplicateGroups.forEach(function(g, gi){ %>
 <div class="card shadow-sm mb-3 border-0" style="border-radius:12px;">
  <div class="card-header bg-white font-weight-bold py-2">
   <%= _tl('patient_duplicates.group_header', 'Group {{num}} — keep #{{id}} {{name}}', { num: gi + 1, id: g.keep.id, name: g.keep.first_name + ' ' + g.keep.last_name }) %>
  </div>
  <div class="card-body p-0">
   <table class="table table-sm mb-0">
    <thead class="thead-light"><tr>
     <th><%= _tl('patient_duplicates.th_id', 'ID') %></th><th><%= _tl('patient_duplicates.th_name', 'Name') %></th><th><%= _tl('patient_duplicates.th_phone', 'Phone') %></th><th><%= _tl('patient_duplicates.th_dob', 'DOB / age') %></th><th><%= _tl('patient_duplicates.th_code', 'Code') %></th><th><%= _tl('patient_duplicates.th_created', 'Created') %></th><th></th>
    </tr></thead>
    <tbody>
     <tr class="table-success">
      <td><%= g.keep.id %></td>
      <td><%= g.keep.first_name %> <%= g.keep.last_name %></td>
      <td><%= g.keep.phone || _tl('patient_duplicates.dash', '—') %></td>
      <td><%= g.keep.age_only_registration == 1 ? (_tl('patient_duplicates.age_prefix', 'age') + ' ' + g.keep.age_years) : (g.keep.dob || _tl('patient_duplicates.dash', '—')) %></td>
      <td class="text-monospace small"><%= g.keep.patient_code || _tl('patient_duplicates.dash', '—') %></td>
      <td class="small"><%= g.keep.created_at ? new Date(g.keep.created_at).toLocaleDateString() : _tl('patient_duplicates.dash', '—') %></td>
      <td><span class="badge badge-success"><%= _tl('patient_duplicates.keep', 'KEEP') %></span></td>
     </tr>
     <% g.duplicates.forEach(function(d){ %>
     <tr>
      <td><%= d.id %></td>
      <td><%= d.first_name %> <%= d.last_name %></td>
      <td><%= d.phone || _tl('patient_duplicates.dash', '—') %></td>
      <td><%= d.age_only_registration == 1 ? (_tl('patient_duplicates.age_prefix', 'age') + ' ' + d.age_years) : (d.dob || _tl('patient_duplicates.dash', '—')) %></td>
      <td class="text-monospace small"><%= d.patient_code || _tl('patient_duplicates.dash', '—') %></td>
      <td class="small"><%= d.created_at ? new Date(d.created_at).toLocaleDateString() : _tl('patient_duplicates.dash', '—') %></td>
      <td><a href="/patient-chart/<%= d.id %>" class="btn btn-link btn-sm p-0"><%= _tl('patient_duplicates.chart', 'Chart') %></a></td>
     </tr>
     <% }); %>
    </tbody>
   </table>
  </div>
 </div>
 <% }); %>
 <% } %>
</div></div>
<%- include('partials/footer') %>

<%- include('partials/hms-date-helpers') %>
<%- include('partials/header') %>
<%- include('partials/maternity-odoo-start', {
  matOdooMenu: 'patients',
  matOdooTitle: _tl('maternity_patients.title', 'ANC registry'),
  matOdooActions: '<a href="/maternity/register" class="o_btn_primary"><i class="fa fa-plus"></i> ' + _tl('maternity_patients.book_anc', 'Book ANC') + '</a>'
}) %>
<div class="o_content">

<form method="get" class="hms-filter-bar">
 <input type="search" name="q" class="hms-input w-full hms-filter-bar__search" placeholder="<%= _tl('maternity_patients.search_placeholder', 'Search ANC # or name') %>" value="<%= search || '' %>">
 <select name="status" class="hms-input w-full" style="max-width:160px">
  <option value=""><%= _tl('maternity_patients.all_status', 'All status') %></option>
  <option value="active"<%= status==='active'?' selected':'' %>><%= _tl('maternity_patients.status_active', 'Active') %></option>
  <option value="delivered"<%= status==='delivered'?' selected':'' %>><%= _tl('maternity_patients.status_delivered', 'Delivered') %></option>
 </select>
 <select name="risk" class="hms-input w-full" style="max-width:140px">
  <option value=""><%= _tl('maternity_patients.all_risk', 'All risk') %></option>
  <option value="low"<%= risk==='low'?' selected':'' %>><%= _tl('maternity_patients.risk_low', 'Low') %></option>
  <option value="medium"<%= risk==='medium'?' selected':'' %>><%= _tl('maternity_patients.risk_medium', 'Medium') %></option>
  <option value="high"<%= risk==='high'?' selected':'' %>><%= _tl('maternity_patients.risk_high', 'High') %></option>
 </select>
 <button class="hms-btn hms-btn-secondary"><%= _tl('maternity_patients.filter', 'Filter') %></button>
</form>

<div class="mat-card">
 <div class="table-responsive">
  <table class="table table-hover mb-0">
   <thead class="thead-light"><tr>
    <th><%= _tl('maternity_patients.th_anc', 'ANC #') %></th><th><%= _tl('maternity_patients.th_patient', 'Patient') %></th><th><%= _tl('maternity_patients.th_gpa', 'G/P/A') %></th><th><%= _tl('maternity_patients.th_edd', 'EDD') %></th><th><%= _tl('maternity_patients.th_risk', 'Risk') %></th><th><%= _tl('maternity_patients.th_visits', 'Visits') %></th><th><%= _tl('maternity_patients.th_status', 'Status') %></th><th></th>
   </tr></thead>
   <tbody>
   <% if (!rows || !rows.length) { %><tr><td colspan="8" class="text-muted text-center py-4"><%= _tl('maternity_patients.empty', 'No maternity patients.') %> <a href="/maternity/register"><%= _tl('maternity_patients.register_first', 'Register first ANC') %></a>.</td></tr><% } %>
   <% (rows||[]).forEach(function(r){ %>
   <tr>
    <td class="font-weight-bold"><%= r.antenatal_number %></td>
    <td><%= r.first_name %> <%= r.last_name %><br><span class="small text-muted"><%= r.phone || '' %></span></td>
    <td><%= r.gravida %>/<%= r.para %>/<%= r.abortion %></td>
    <td class="text-nowrap"><%= fmtDate(r.edd) %></td>
    <td><span class="risk-pill <%= r.risk_level %>"><%= r.risk_level %></span></td>
    <td><%= r.anc_visits_count || 0 %></td>
    <td><%= r.status %></td>
    <td><a href="/maternity/chart/<%= r.id %>" class="btn btn-sm btn-outline-primary"><%= _tl('maternity_patients.chart', 'Chart') %></a></td>
   </tr>
   <% }) %>
   </tbody>
  </table>
 </div>
</div>

</div>
<%- include('partials/maternity-odoo-end') %>
<%- include('partials/footer') %>

# Copy to .env and adjust for your environment.

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=hms

# HMS ↔ Account_Core integration (env fallbacks — per-facility settings in Super Admin → Integrations)
# PUBLIC_BASE_URL=https://hms.example.com
INTEGRATION_MODE=account_core
CORE_ACCOUNT_SYNC_ENABLED=0
CORE_ACCOUNT_URL=http://127.0.0.1:5072
CORE_ACCOUNT_WEBHOOK_KEY=dev-integration-key-change-in-production
CORE_ACCOUNT_FACILITY_ID=1
HMS_INTEGRATION_API_KEY=dev-hms-inbound-key-change-in-production

# HMS → Zaizens PayRoll employee replication (one-way)
ZAIZENS_PAYROLL_SYNC_ENABLED=0
ZAIZENS_PAYROLL_URL=http://127.0.0.1:3010
ZAIZENS_PAYROLL_API_KEY=dev-hms-inbound-key-change-in-production

# Block staff payslip self-service (default off when integrated)
PAYROLL_SELF_SERVICE_ENABLED=0

# Strict OHADA journal validation (default on; set 0 to disable)
# HMS_STRICT_JOURNAL=1

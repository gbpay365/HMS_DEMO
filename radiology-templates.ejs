<%- include('partials/header') %>
<%
if (typeof _t !== 'function') {
  var _t = (typeof t === 'function' ? t : function (k, o) { return (o && o.defaultValue != null) ? o.defaultValue : k; });
}
if (typeof _tl !== 'function') {
  var _tl = function (key, fallback, opts) {
    var o = { ns: 'legacy', defaultValue: fallback };
    if (opts && typeof opts === 'object') { for (var pk in opts) { if (Object.prototype.hasOwnProperty.call(opts, pk)) o[pk] = opts[pk]; } }
    return _t(key, o);
  };
}
%>
<link rel="stylesheet" href="/css/radiology-templates.css?v=3">
<link rel="stylesheet" href="/css/diagnostic-report-print.css?v=1">

<div class="page-wrapper">
  <div class="content" id="radTplRoot">

    <div class="d-flex flex-wrap align-items-center justify-content-between mb-3" style="gap:10px;">
      <div>
        <a href="/radiology" class="btn btn-sm btn-outline-secondary rounded-pill font-weight-bold">
          <i class="fa fa-arrow-left mr-1"></i> <%= _tl('radiology_templates.registry_link', 'Radiology registry') %>
        </a>
        <a href="/radiology/validate" class="btn btn-sm btn-link font-weight-bold text-muted"><%= _tl('radiology_templates.validate_code', 'Validate code') %></a>
      </div>
      <span class="badge badge-primary badge-pill px-3 py-2 font-weight-bold" id="radTplTestCount">—</span>
    </div>

    <% if (locals.queryCode && locals.queryOi) { %>
    <div class="alert alert-light border shadow-sm mb-3" style="border-radius:12px;border-color:#e0e7ff!important;">
      <i class="fa fa-link text-primary mr-2"></i>
      <span class="small"><%= _tl('radiology_templates.prefill_validation', 'Prefilling from validation · Code {{code}} · Order item #{{oi}}', { code: queryCode, oi: queryOi }) %></span>
    </div>
    <% } %>
    <div id="radTplOrderBanner" class="alert alert-info border-0 shadow-sm mb-3 d-none" style="border-radius:12px;" role="status"></div>

    <div id="radTplSuggestBar" class="alert border-0 shadow-sm mb-3 d-none" style="border-radius:12px;background:linear-gradient(135deg,#ecfdf5,#d1fae5);border:1px solid #6ee7b7!important;" role="status">
      <div class="d-flex flex-wrap align-items-center justify-content-between" style="gap:10px;">
        <div class="small font-weight-bold text-dark" id="radTplSuggestText"><i class="fa fa-magic mr-1 text-success"></i> <%= _tl('radiology_templates.suggest_text', 'A template was suggested from the prescribed test.') %></div>
        <div class="d-flex flex-wrap" style="gap:8px;">
          <button type="button" class="btn btn-sm btn-success font-weight-bold" id="radTplSuggestContinue"><%= _tl('radiology_templates.suggest_continue', 'Continue') %></button>
          <button type="button" class="btn btn-sm btn-outline-secondary font-weight-bold" id="radTplSuggestPickOther"><%= _tl('radiology_templates.suggest_pick_other', 'Choose another template') %></button>
          <button type="button" class="btn btn-sm btn-outline-dark font-weight-bold d-none" id="radTplSuggestCustom"><%= _tl('radiology_templates.suggest_custom', 'Use custom report') %></button>
        </div>
      </div>
    </div>

    <div class="labtpl-hero mb-3">
      <h1><i class="fa fa-film mr-2"></i><%= _tl('radiology_templates.hero_title', 'Structured exam templates') %></h1>
      <p><%= _tl('radiology_templates.hero_desc', 'Choose a panel from the library, enter results with reference-aware flags, preview, then save to the radiology registry (or to the linked OPD order when opened from validation).') %></p>
    </div>

    <div class="row labtpl-shell">
      <div class="col-lg-4 mb-3 mb-lg-0">
        <div class="card border-0 shadow-sm h-100 labtpl-sidebar">
          <div class="card-header bg-white border-bottom-0 pt-3 pb-0" style="border-radius:14px 14px 0 0;">
            <h6 class="font-weight-bold text-dark mb-2"><i class="fa fa-book mr-1 text-primary"></i> <%= _tl('radiology_templates.test_library', 'Test library') %></h6>
            <div class="input-group input-group-sm mb-3">
              <div class="input-group-prepend"><span class="input-group-text bg-light border-right-0"><i class="fa fa-search text-muted"></i></span></div>
              <input type="text" class="form-control border-left-0" id="searchInput" placeholder="<%= _tl('radiology_templates.search_ph', 'Search by name, code, or category…') %>" autocomplete="off">
            </div>
          </div>
          <div class="labtpl-cat-scroll border-top" id="catList"></div>
        </div>
      </div>

      <div class="col-lg-8 labtpl-main">
        <div class="card border-0 shadow-sm h-100" style="min-height:420px;">
          <div class="card-body d-flex flex-column p-0">

            <div class="labtpl-empty flex-grow-1 d-flex flex-column justify-content-center" id="emptyState">
              <div class="labtpl-empty-icon"><i class="fa fa-picture-o"></i></div>
              <h5 class="font-weight-bold text-secondary"><%= _tl('radiology_templates.select_test', 'Select a test') %></h5>
              <p class="small text-muted px-4 mb-0" style="max-width:420px;margin:0 auto;">
                <%= _tl('radiology_templates.select_test_hint', 'Pick any template from the library. Patient fields and conclusion apply to preview and save. Numeric fields show high / low hints against reference ranges when defined.') %>
              </p>
            </div>

            <div class="labtpl-form-panel p-3 p-md-4" id="formPanel">
              <div class="labtpl-form-head">
                <div class="labtpl-form-icon" id="formCatIcon"></div>
                <div class="flex-grow-1" style="min-width:0;">
                  <div class="labtpl-form-title text-truncate" id="formTestName"></div>
                  <div class="labtpl-form-meta" id="formTestMeta"></div>
                </div>
                <div class="labtpl-form-actions">
                  <button type="button" class="btn btn-sm btn-outline-secondary font-weight-bold" id="radTplEditRefsBtn" style="display:none;" onclick="openRadRefsModal()">
                    <i class="fa fa-sliders mr-1"></i> <%= _tl('radiology_templates.edit_refs', 'Edit references') %>
                  </button>
                  <button type="button" class="btn btn-sm btn-outline-secondary font-weight-bold" onclick="clearRadTplForm()">
                    <i class="fa fa-undo mr-1"></i> <%= _tl('radiology_templates.clear', 'Clear') %>
                  </button>
                  <button type="button" class="btn btn-sm btn-outline-primary font-weight-bold" onclick="previewReport()">
                    <i class="fa fa-eye mr-1"></i> <%= _tl('radiology_templates.preview', 'Preview') %>
                  </button>
                  <button type="button" class="btn btn-sm btn-success font-weight-bold" onclick="saveRadTplReport()">
                    <i class="fa fa-save mr-1"></i> <%= _tl('radiology_templates.save_registry', 'Save to registry') %>
                  </button>
                </div>
              </div>

              <div class="labtpl-patient-grid" id="labtplPatientGrid">
                <div>
                  <label class="small font-weight-bold text-muted text-uppercase" for="pid"><%= _tl('radiology_templates.patient_id', 'Patient ID') %></label>
                  <input type="text" class="form-control form-control-sm" id="pid" placeholder="<%= _tl('radiology_templates.patient_id_ph', 'e.g. 42 or #P-42') %>">
                </div>
                <div>
                  <label class="small font-weight-bold text-muted text-uppercase" for="pname"><%= _tl('radiology_templates.full_name', 'Full name') %></label>
                  <input type="text" class="form-control form-control-sm" id="pname" placeholder="<%= _tl('radiology_templates.full_name_ph', 'Patient name') %>">
                </div>
                <div>
                  <label class="small font-weight-bold text-muted text-uppercase" for="page"><%= _tl('radiology_templates.age_sex', 'Age / sex') %></label>
                  <input type="text" class="form-control form-control-sm" id="page" placeholder="<%= _tl('radiology_templates.age_sex_ph', 'e.g. 34y / M') %>">
                </div>
                <div>
                  <label class="small font-weight-bold text-muted text-uppercase" for="pdoctor"><%= _tl('radiology_templates.requesting_doctor', 'Requesting doctor') %></label>
                  <input type="text" class="form-control form-control-sm" id="pdoctor" placeholder="<%= _tl('radiology_templates.requesting_doctor_ph', 'Dr. …') %>">
                </div>
              </div>

              <div class="labtpl-field-scroll">
                <div id="fieldsGrid"></div>
              </div>

              <div class="labtpl-attachments" id="diagTplAttachSection">
                <label class="small font-weight-bold text-muted text-uppercase d-block mb-2">
                  <i class="fa fa-image mr-1"></i> <%= _tl('radiology_templates.scan_files', 'Scan / imaging files') %>
                </label>
                <p class="small text-muted mb-2" id="diagTplAttachHint">
                  <%= _tl('radiology_templates.attach_hint', 'Attach X-rays, scans, or imaging PDFs. The consulting doctor can view these on the patient chart and radiology report.') %>
                </p>
                <div class="diagtpl-attach-list mb-2" id="diagTplAttachList"></div>
                <label class="btn btn-sm btn-outline-primary font-weight-bold mb-0">
                  <i class="fa fa-upload mr-1"></i> <%= _tl('radiology_templates.choose_images', 'Choose images') %>
                  <input type="file" id="diagTplAttachInput" class="d-none" accept="image/*,.pdf,.png,.jpg,.jpeg,.webp,.heic,.dcm,.dicom" multiple>
                </label>
                <button type="button" class="btn btn-sm btn-warning font-weight-bold mb-0" id="radTplOcrBtn" style="display:none;" onclick="document.getElementById('radTplOcrInput').click()">
                  <i class="fa fa-magic mr-1"></i> <%= _tl('radiology_templates.upload_autofill', 'Upload & auto-fill') %>
                </button>
                <input type="file" id="radTplOcrInput" class="d-none" accept="image/*,.pdf,.png,.jpg,.jpeg,.webp">
                <span class="small text-muted ml-2"><%= _tl('radiology_templates.attach_limits', 'Up to 8 files · 12 MB each · images or PDF') %></span>
              </div>

              <div class="labtpl-conclusion">
                <label for="conclusion"><%= _tl('radiology_templates.conclusion_label', 'Conclusion / interpretation') %></label>
                <textarea class="form-control" id="conclusion" rows="3" placeholder="<%= _tl('radiology_templates.conclusion_ph', 'Overall interpretation, recommendations, or clinical comments…') %>"></textarea>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/diagnostic-validate-code-modal', { validateModalDept: 'radiology' }) %>

<div class="modal fade" id="radTplRefsModal" tabindex="-1" role="dialog" aria-labelledby="radTplRefsModalTitle">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered" role="document">
    <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
      <div class="modal-header border-0" style="background:linear-gradient(135deg,#0891b2,#0e7490);color:#fff;">
        <h5 class="modal-title font-weight-bold" id="radTplRefsModalTitle"><%= _tl('radiology_templates.edit_refs_title', 'Edit reference ranges') %></h5>
        <button type="button" class="close text-white" data-dismiss="modal" aria-label="<%= _tl('radiology_templates.close_aria', 'Close') %>"><span aria-hidden="true">&times;</span></button>
      </div>
      <div class="modal-body p-0">
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead class="bg-light text-uppercase small">
              <tr><th><%= _tl('radiology_templates.ref_field', 'Field') %></th><th><%= _tl('radiology_templates.ref_unit', 'Unit') %></th><th><%= _tl('radiology_templates.ref_display', 'Ref display') %></th><th><%= _tl('radiology_templates.ref_min', 'Min') %></th><th><%= _tl('radiology_templates.ref_max', 'Max') %></th></tr>
            </thead>
            <tbody id="radTplRefsBody"></tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer border-0 bg-light">
        <button type="button" class="hms-btn hms-btn-secondary font-weight-bold" data-dismiss="modal"><%= _tl('radiology_templates.close', 'Close') %></button>
        <button type="button" class="hms-btn hms-btn-primary font-weight-bold" onclick="saveRadRefsModal()"><i class="fa fa-save mr-1" aria-hidden="true"></i> <%= _tl('radiology_templates.save_refs', 'Save references') %></button>
      </div>
    </div>
  </div>
</div>

<script>
  window.__RAD_CAN_WRITE = <%- JSON.stringify((locals.userPerms || []).includes('*') || (locals.userPerms || []).some(function (p) { return /radiology\.write/.test(String(p)); })) %>;
</script>

<div class="modal fade" id="radTplPreviewModal" tabindex="-1" role="dialog" aria-labelledby="radTplPreviewModalTitle">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered" role="document">
    <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">
      <div class="modal-header text-white border-0" style="background:linear-gradient(135deg,#0891b2,#0e7490);">
        <h5 class="modal-title font-weight-bold" id="radTplPreviewModalTitle"><%= _tl('radiology_templates.preview_title', 'Report preview') %></h5>
        <button type="button" class="close text-white" data-dismiss="modal" aria-label="<%= _tl('radiology_templates.close_aria', 'Close') %>"><span aria-hidden="true">&times;</span></button>
      </div>
      <div class="modal-body bg-white" id="modalBody" style="min-height:200px;"></div>
      <div class="modal-footer border-0 bg-light flex-wrap" style="gap:8px;">
        <button type="button" class="hms-btn hms-btn-secondary font-weight-bold" data-dismiss="modal"><%= _tl('radiology_templates.close', 'Close') %></button>
        <button type="button" class="hms-btn hms-btn-secondary font-weight-bold" onclick="printRadTplReport()"><i class="fa fa-print mr-1" aria-hidden="true"></i> <%= _tl('radiology_templates.print', 'Print') %></button>
        <button type="button" class="hms-btn hms-btn-primary font-weight-bold" onclick="saveRadTplReport()"><i class="fa fa-save mr-1" aria-hidden="true"></i> <%= _tl('radiology_templates.save_registry', 'Save to registry') %></button>
      </div>
    </div>
  </div>
</div>

<script src="/js/hms-diagnostic-code-validate.js"></script>
<script src="/js/hms-diagnostic-attachments.js"></script>
<script src="/js/hms-diagnostic-report-print.js?v=2"></script>
<%- include('partials/diag-tpl-i18n-script', { diagI18nNs: 'radiology_templates' }) %>
<script src="/js/radiology-templates.js?v=14"></script>
<%- include('partials/footer') %>

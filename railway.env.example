# Railway — set these on the WEB service (not Postgres service)

HMS_DB_DRIVER=postgres
DATABASE_URL=${{Postgres.DATABASE_URL}}
HMS_SKIP_SCHEMA_MIGRATIONS=1
SESSION_SECRET=generate-a-long-random-string
NODE_ENV=production

